# === MaskFactory .gitignore (MF-P0-08.01) ===
# Spec-required list (item MF-P0-08.01): large binary data + secrets never in git.
/models/*
!/models/model_sources.yaml
!/models/model_registry.json
/data/*
!/data/.gitignore
!/data/packages.dvc
/runs/
/logs/
/datasets/*
!/datasets/.gitignore
!/datasets/*.dvc
/work/
qa/reports/maskedwarehouse_alignment/
.env
mfwork/

# External CVAT clone lives here (MF-P0-03.04); it is its own upstream git repo,
# not part of this source tree, so it is not committed here.
/cvat/

# Tracker: tracker.json (state) and phases/*.md / DASHBOARD.md ARE committed, but
# the auto-generated backup snapshots and transient swap files are not.
Plan/Tracker/backups/
Plan/Tracker/*.tmp
Plan/Tracker/*.orphan*
Plan/Tracker/*.probe
Plan/Tracker/*.mfbak

# Model-weight binaries are NEVER committed to git (they belong in models/
# [ignored], DVC, or an external cache). Plan/Civitai/ ships ~9 GB of these;
# its JSON manifests / workflow references stay tracked, its weights do not.
*.safetensors
*.pt
*.pt2
*.pth
*.onnx
*.ckpt
*.bin
*.pkl
*.zip

# Plan/Civitai/ is ~9 GB of external bootstrap reference assets (model weights,
# archives, and adult/NSFW pose-pack PREVIEW imagery) — reference material the
# P0-10/P0-14 tasks read locally, NOT this repo's source, and unsuitable for a
# code repo. Kept local + un-versioned pending Kevin's call on how to store it
# (DVC / external cache). See DECISIONS_LOG 2026-07-10. Classification OUTPUTS
# are written outside this tree (configs/, Plan/) so they stay tracked.
Plan/Civitai/

# Python / tooling artifacts
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.pytest*/
.pytest_*/
.ruff_cache/
.black_cache/
.runtime_tmp/
.tools/
.publish_tmp/
.pt_*/
.mypy_cache/
.venv/
venv/
*.log
*.sqlite-shm
*.sqlite-wal

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz/asset-manifest-1.0.0.json",
  "title": "MaskFactory DAZ Asset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "manifest_revision", "record_state", "created_at", "updated_at", "product", "packages", "files", "assets", "classifications", "dependencies", "inspections", "validation"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "manifest_id": {"$ref": "#/$defs/id"},
    "manifest_revision": {"type": "integer", "minimum": 1},
    "record_state": {"enum": ["discovered", "hashed", "classified", "installed", "static_inspected", "runtime_inspected", "qualified", "incomplete", "quarantined", "superseded", "retired"]},
    "created_at": {"$ref": "#/$defs/time"},
    "updated_at": {"$ref": "#/$defs/time"},
    "created_by": {"type": "string", "minLength": 1},
    "updated_by": {"type": "string", "minLength": 1},
    "canonical_asset_id": {"$ref": "#/$defs/id"},
    "supersedes": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
    "superseded_by": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
    "product": {"$ref": "#/$defs/product"},
    "packages": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/package"}},
    "files": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file"}},
    "assets": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/asset"}},
    "components": {"type": "array", "items": {"$ref": "#/$defs/component"}},
    "properties": {"type": "array", "items": {"$ref": "#/$defs/property"}},
    "classifications": {"$ref": "#/$defs/classifications"},
    "body_associations": {"type": "array", "items": {"$ref": "#/$defs/bodyAssociation"}},
    "maskfactory_mappings": {"type": "array", "items": {"$ref": "#/$defs/ontologyMapping"}},
    "capability_profiles": {"type": "object", "additionalProperties": {"type": ["object", "array", "string", "number", "boolean", "null"]}},
    "dependencies": {"type": "array", "items": {"$ref": "#/$defs/dependency"}},
    "compatibility_results": {"type": "array", "items": {"$ref": "#/$defs/testResult"}},
    "inspections": {"type": "array", "items": {"$ref": "#/$defs/inspection"}},
    "search": {"$ref": "#/$defs/search"},
    "technical_lineage": {"type": "array", "items": {"$ref": "#/$defs/lineage"}},
    "conflicts": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "unknowns": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "validation": {"$ref": "#/$defs/validation"},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_:.\\-]{2,127}$"},
    "time": {"type": "string", "format": "date-time"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "evidence": {"type": "object", "required": ["method", "confidence"], "properties": {"method": {"type": "string"}, "reference": {"type": "string"}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}, "observed_at": {"$ref": "#/$defs/time"}, "tool": {"type": "string"}}, "additionalProperties": false},
    "product": {"type": "object", "additionalProperties": false, "required": ["product_id", "source_name", "title"], "properties": {"product_id": {"$ref": "#/$defs/id"}, "source_name": {"type": "string"}, "source_product_id": {"type": "string"}, "source_guid": {"type": "string"}, "title": {"type": "string"}, "edition": {"type": "string"}, "version": {"type": "string"}, "creators": {"type": "array", "items": {"type": "string"}}, "source_url": {"type": "string", "format": "uri"}, "acquired_at": {"$ref": "#/$defs/time"}, "description": {"type": "string"}, "declared_content_types": {"type": "array", "items": {"type": "string"}}, "tags": {"type": "array", "items": {"type": "string"}}, "local_record_refs": {"type": "array", "items": {"type": "string"}}}},
    "package": {"type": "object", "additionalProperties": false, "required": ["package_id", "product_id", "archive", "dropzone_relative_path"], "properties": {"package_id": {"$ref": "#/$defs/id"}, "product_id": {"$ref": "#/$defs/id"}, "global_id": {"type": "string"}, "name": {"type": "string"}, "version": {"type": "string"}, "platform": {"type": "string"}, "archive": {"$ref": "#/$defs/archive"}, "dropzone_relative_path": {"type": "string"}, "manifest_dsx_path": {"type": "string"}, "extraction_state": {"enum": ["not_extracted", "inspected", "installed", "failed", "unknown"]}, "member_file_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}}}},
    "archive": {"type": "object", "additionalProperties": false, "required": ["filename", "sha256", "size_bytes"], "properties": {"filename": {"type": "string"}, "absolute_path": {"type": "string"}, "sha256": {"$ref": "#/$defs/sha256"}, "size_bytes": {"type": "integer", "minimum": 0}, "compression": {"type": "string"}, "modified_at": {"$ref": "#/$defs/time"}}},
    "file": {"type": "object", "additionalProperties": false, "required": ["file_id", "package_id", "role", "sha256", "size_bytes", "existence"], "properties": {"file_id": {"$ref": "#/$defs/id"}, "package_id": {"$ref": "#/$defs/id"}, "archive_member_path": {"type": "string"}, "content_root_id": {"type": "string"}, "installed_relative_path": {"type": "string"}, "installed_absolute_path": {"type": "string"}, "canonical_comparison_path": {"type": "string"}, "logical_uri": {"type": "string"}, "dson_url": {"type": "string"}, "role": {"type": "string"}, "extension": {"type": "string"}, "detected_format": {"type": "string"}, "mime_type": {"type": "string"}, "sha256": {"$ref": "#/$defs/sha256"}, "size_bytes": {"type": "integer", "minimum": 0}, "modified_at": {"$ref": "#/$defs/time"}, "existence": {"enum": ["present", "missing", "unresolved", "archive_only"]}, "is_primary": {"type": "boolean"}, "owner_asset_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}}, "references": {"type": "array", "items": {"type": "string"}}, "referenced_by": {"type": "array", "items": {"type": "string"}}, "duplicate_cluster_id": {"type": "string"}, "errors": {"type": "array", "items": {"type": "string"}}}},
    "asset": {"type": "object", "additionalProperties": false, "required": ["asset_id", "source_file_id", "name", "primary_class"], "properties": {"asset_id": {"$ref": "#/$defs/id"}, "source_file_id": {"$ref": "#/$defs/id"}, "dson_asset_id": {"type": "string"}, "asset_uri": {"type": "string"}, "asset_type_raw": {"type": "string"}, "name": {"type": "string"}, "label": {"type": "string"}, "description": {"type": "string"}, "author": {"type": "string"}, "revision": {"type": "string"}, "modified_at": {"$ref": "#/$defs/time"}, "primary_class": {"type": "string"}, "secondary_classes": {"type": "array", "items": {"type": "string"}}, "content_type_raw": {"type": "string"}, "categories_raw": {"type": "array", "items": {"type": "string"}}, "tags": {"type": "array", "items": {"type": "string"}}, "figure_generations": {"type": "array", "items": {"type": "string"}}, "compatibility_bases": {"type": "array", "items": {"type": "string"}}, "compatibility_filters": {"type": "array", "items": {"type": "string"}}, "load_mode": {"type": "string"}, "static_findings": {"type": "object", "additionalProperties": true}}},
    "component": {"type": "object", "additionalProperties": true, "required": ["component_id", "asset_id", "component_type", "action", "scene_locator"], "properties": {"component_id": {"$ref": "#/$defs/id"}, "asset_id": {"$ref": "#/$defs/id"}, "component_type": {"type": "string"}, "action": {"enum": ["created", "modified", "removed", "referenced"]}, "scene_locator": {"type": "string"}, "asset_uri": {"type": "string"}, "name": {"type": "string"}, "label": {"type": "string"}, "parent_component_id": {"$ref": "#/$defs/id"}, "follow_target": {"type": "string"}, "skeleton": {"type": "string"}, "geometry_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}}, "material_slots": {"type": "array", "items": {"type": "string"}}, "face_groups": {"type": "array", "items": {"type": "string"}}, "uv_sets": {"type": "array", "items": {"type": "string"}}, "topology_signature": {"type": "string"}}},
    "property": {"type": "object", "additionalProperties": true, "required": ["property_id", "owner_component_id", "name", "value_type"], "properties": {"property_id": {"$ref": "#/$defs/id"}, "owner_component_id": {"$ref": "#/$defs/id"}, "asset_uri": {"type": "string"}, "name": {"type": "string"}, "label": {"type": "string"}, "group_path": {"type": "string"}, "presentation_type": {"type": "string"}, "region": {"type": "string"}, "value_type": {"enum": ["float", "integer", "boolean", "string", "color", "image", "enum", "unknown"]}, "units": {"type": "string"}, "minimum": {"type": "number"}, "maximum": {"type": "number"}, "default": {}, "current": {}, "sensitivity": {"type": "number"}, "flags": {"type": "object", "additionalProperties": {"type": "boolean"}}, "morph_subtype": {"type": "string"}, "controllers_in": {"type": "array", "items": {"type": "string"}}, "controllers_out": {"type": "array", "items": {"type": "string"}}, "affected_entities": {"type": "array", "items": {"type": "string"}}, "safe_sampling_range": {"type": "array", "prefixItems": [{"type": "number"}, {"type": "number"}], "minItems": 2, "maxItems": 2}, "evidence": {"$ref": "#/$defs/evidence"}}},
    "classifications": {"type": "object", "additionalProperties": false, "required": ["primary_asset_class", "dropzone_generation", "dropzone_category"], "properties": {"primary_asset_class": {"type": "string"}, "secondary_asset_classes": {"type": "array", "items": {"type": "string"}}, "dropzone_generation": {"type": "string"}, "dropzone_category": {"type": "string"}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}, "evidence_refs": {"type": "array", "items": {"type": "string"}}}},
    "bodyAssociation": {"type": "object", "additionalProperties": false, "required": ["entity_id", "taxon_id", "level", "relationship", "side", "evidence"], "properties": {"entity_id": {"$ref": "#/$defs/id"}, "taxon_id": {"type": "string", "pattern": "^body\\."}, "level": {"enum": ["major", "sub", "micro", "nano"]}, "relationship": {"enum": ["targets", "changes_shape", "covers", "attaches_to", "poses", "occludes", "textures", "creates", "supports"]}, "side": {"enum": ["left", "right", "bilateral", "midline", "not_applicable", "unknown"]}, "coverage_fraction": {"type": "number", "minimum": 0, "maximum": 1}, "evidence": {"$ref": "#/$defs/evidence"}, "review_state": {"enum": ["machine_observed", "machine_inferred", "confirmed", "disputed", "unknown"]}}},
    "ontologyMapping": {"type": "object", "additionalProperties": false, "required": ["taxon_id", "ontology_version", "relationship", "status"], "properties": {"taxon_id": {"type": "string"}, "ontology_version": {"type": "string"}, "label_id": {"type": "integer", "minimum": 0}, "label_name": {"type": "string"}, "relationship": {"enum": ["exact", "contains", "contained_by", "overlaps", "derived", "none"]}, "status": {"enum": ["active", "inactive_future", "descriptive_only", "requires_mapping", "not_applicable"]}, "evidence": {"$ref": "#/$defs/evidence"}}},
    "dependency": {"type": "object", "additionalProperties": false, "required": ["dependency_id", "source_entity_id", "target_kind", "target_locator", "relation", "required", "resolution_state"], "properties": {"dependency_id": {"$ref": "#/$defs/id"}, "source_entity_id": {"$ref": "#/$defs/id"}, "target_kind": {"enum": ["product", "package", "file", "asset", "figure", "plugin", "application", "renderer", "script", "unknown"]}, "target_locator": {"type": "string"}, "relation": {"type": "string"}, "version_constraint": {"type": "string"}, "required": {"type": "boolean"}, "resolution_state": {"enum": ["resolved", "missing", "ambiguous", "not_tested", "not_applicable"]}, "resolved_entity_id": {"$ref": "#/$defs/id"}, "evidence": {"$ref": "#/$defs/evidence"}}},
    "testResult": {"type": "object", "additionalProperties": true, "required": ["test_id", "operation", "outcome", "observed_at"], "properties": {"test_id": {"$ref": "#/$defs/id"}, "operation": {"type": "string"}, "fixture": {"type": "string"}, "outcome": {"enum": ["pass", "warn", "fail", "not_run"]}, "observed_at": {"$ref": "#/$defs/time"}, "application_version": {"type": "string"}, "renderer": {"type": "string"}, "duration_ms": {"type": "integer", "minimum": 0}, "warnings": {"type": "array", "items": {"type": "string"}}, "errors": {"type": "array", "items": {"type": "string"}}, "evidence_refs": {"type": "array", "items": {"type": "string"}}}},
    "inspection": {"type": "object", "additionalProperties": false, "required": ["inspection_id", "stage", "tool", "tool_version", "observed_at", "outcome", "evidence_refs"], "properties": {"inspection_id": {"$ref": "#/$defs/id"}, "stage": {"enum": ["archive", "install", "static_dson", "cms", "runtime_load", "runtime_diff", "render", "simulation", "rescan"]}, "tool": {"type": "string"}, "tool_version": {"type": "string"}, "observed_at": {"$ref": "#/$defs/time"}, "outcome": {"enum": ["pass", "warn", "fail"]}, "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "summary": {"type": "string"}}},
    "search": {"type": "object", "additionalProperties": false, "properties": {"summary": {"type": "string"}, "tokens": {"type": "array", "items": {"type": "string"}}, "aliases": {"type": "array", "items": {"type": "string"}}, "body_taxa": {"type": "array", "items": {"type": "string"}}, "generations": {"type": "array", "items": {"type": "string"}}, "file_extensions": {"type": "array", "items": {"type": "string"}}}},
    "lineage": {"type": "object", "additionalProperties": false, "required": ["operation", "tool", "at"], "properties": {"operation": {"type": "string"}, "tool": {"type": "string"}, "tool_version": {"type": "string"}, "at": {"$ref": "#/$defs/time"}, "input_refs": {"type": "array", "items": {"type": "string"}}, "output_hash": {"$ref": "#/$defs/sha256"}}},
    "finding": {"type": "object", "additionalProperties": false, "required": ["field", "description", "state"], "properties": {"field": {"type": "string"}, "description": {"type": "string"}, "state": {"enum": ["open", "resolved", "accepted_unknown"]}, "evidence_refs": {"type": "array", "items": {"type": "string"}}}},
    "validation": {"type": "object", "additionalProperties": false, "required": ["schema_valid", "vocabulary_valid", "reference_valid", "path_valid", "hash_valid", "validated_at", "validator_version"], "properties": {"schema_valid": {"type": "boolean"}, "vocabulary_valid": {"type": "boolean"}, "reference_valid": {"type": "boolean"}, "path_valid": {"type": "boolean"}, "hash_valid": {"type": "boolean"}, "validated_at": {"$ref": "#/$defs/time"}, "validator_version": {"type": "string"}, "errors": {"type": "array", "items": {"type": "string"}}, "warnings": {"type": "array", "items": {"type": "string"}}}}
  }
}

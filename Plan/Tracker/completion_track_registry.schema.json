{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/plan/completion_track_registry.schema.json",
  "title": "MaskFactory completion-track registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "policy_version",
    "authoritative_spec",
    "authoritative_spec_sha256",
    "profiles",
    "sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "registry_id": { "const": "maskfactory_completion_tracks" },
    "policy_version": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "authoritative_spec": {
      "const": "Plan/24_AUTONOMOUS_CORE_COMPLETION_AND_COMFYUI_BRIDGE.md"
    },
    "authoritative_spec_sha256": { "$ref": "#/$defs/sha256" },
    "profiles": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/profile" },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": ["profile_id"],
            "properties": { "profile_id": { "const": "core_autonomous_runtime" } }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "required": ["profile_id"],
            "properties": { "profile_id": { "const": "independent_real_accuracy" } }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "required": ["profile_id"],
            "properties": { "profile_id": { "const": "scale_daz_maturity" } }
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    },
    "sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "nonemptyUniqueStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "classification",
        "blocking_for_core_completion",
        "purpose",
        "completion_claim",
        "required_item_ids",
        "prerequisite_profile_ids",
        "allowed_evidence",
        "forbidden_claims",
        "excluded_core_dependencies"
      ],
      "properties": {
        "profile_id": {
          "enum": [
            "core_autonomous_runtime",
            "independent_real_accuracy",
            "scale_daz_maturity"
          ]
        },
        "classification": { "enum": ["required", "optional", "post_core"] },
        "blocking_for_core_completion": { "type": "boolean" },
        "purpose": { "type": "string", "minLength": 1 },
        "completion_claim": { "type": "string", "minLength": 1 },
        "required_item_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^MF-P[0-9]+-[A-Z0-9]+(?:\\.[0-9]+)?$" }
        },
        "prerequisite_profile_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "core_autonomous_runtime",
              "independent_real_accuracy",
              "scale_daz_maturity"
            ]
          }
        },
        "allowed_evidence": { "$ref": "#/$defs/nonemptyUniqueStrings" },
        "forbidden_claims": { "$ref": "#/$defs/nonemptyUniqueStrings" },
        "excluded_core_dependencies": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "human_anchor_masks",
              "manual_cvat_correction",
              "blinded_human_review",
              "minimum_package_corpus",
              "full_model_library_download",
              "daz_asset_or_render_work",
              "long_duration_daz_soak",
              "independent_real_accuracy_measurement"
            ]
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "profile_id": { "const": "core_autonomous_runtime" } } },
          "then": {
            "properties": {
              "classification": { "const": "required" },
              "blocking_for_core_completion": { "const": true },
              "prerequisite_profile_ids": { "maxItems": 0 },
              "excluded_core_dependencies": {
                "minItems": 8,
                "maxItems": 8
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "profile_id": {
                "enum": ["independent_real_accuracy", "scale_daz_maturity"]
              }
            }
          },
          "then": {
            "properties": {
              "blocking_for_core_completion": { "const": false },
              "excluded_core_dependencies": { "maxItems": 0 }
            }
          }
        }
      ]
    }
  }
}

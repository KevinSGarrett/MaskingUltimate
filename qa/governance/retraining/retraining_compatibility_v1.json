{
  "authority": "pre_result_contract_only_no_training_promotion_serving_or_gold_authority",
  "compatibility_rules": {
    "autonomy_certificates": {
      "decision": "invalidate",
      "exact_scope_dimensions": ["pipeline_fingerprint", "risk_bucket", "instance_context"],
      "rationale": "Autonomy certificates are fingerprint scoped and must be rebuilt or replaced by residual abstention.",
      "rule_id": "retraining_compatibility_v1.autonomy_certificates"
    },
    "benchmark_observations": {
      "decision": "reuse",
      "exact_scope_dimensions": ["provider", "model", "prompt", "code", "hardware", "eval_set"],
      "rationale": "Benchmark observations may be reused only when every execution and evaluation identity is byte-identical.",
      "rule_id": "retraining_compatibility_v1.benchmark_observations"
    },
    "human_anchor_holdout": {
      "decision": "reuse",
      "exact_scope_dimensions": ["dataset", "partition", "image_ids", "truth_authority"],
      "rationale": "Frozen human-anchor holdouts remain valid only with exact dataset, partition, image, and authority identity.",
      "rule_id": "retraining_compatibility_v1.human_anchor_holdout"
    },
    "human_gold_training": {
      "decision": "reuse",
      "exact_scope_dimensions": ["dataset", "partition", "image_ids", "truth_authority"],
      "rationale": "Approved human gold may be reused only with exact immutable package and partition identity.",
      "rule_id": "retraining_compatibility_v1.human_gold_training"
    },
    "immutable_audit_history": {
      "decision": "reuse",
      "exact_scope_dimensions": ["queue", "outcomes", "auditor_authority"],
      "rationale": "Historical audit outcomes are immutable observations and retain provenance without becoming a new certificate.",
      "rule_id": "retraining_compatibility_v1.immutable_audit_history"
    },
    "pseudo_labels": {
      "decision": "invalidate",
      "exact_scope_dimensions": ["pipeline_fingerprint", "certificate_bundle", "dataset_manifest"],
      "rationale": "Pseudo-label eligibility is certificate and fingerprint bound and must be regenerated after retraining.",
      "rule_id": "retraining_compatibility_v1.pseudo_labels"
    },
    "serving_promotion_evidence": {
      "decision": "invalidate",
      "exact_scope_dimensions": ["candidate", "checkpoint", "registry", "serving_smoke"],
      "rationale": "A new checkpoint requires a new promotion transaction and serving smoke; prior role authority cannot carry over.",
      "rule_id": "retraining_compatibility_v1.serving_promotion_evidence"
    }
  },
  "fingerprint_components": ["code_tree", "dataset_manifest", "model_checkpoint", "training_config"],
  "governing_source_hashes": {
    "configs/autonomous_masks.yaml": "e71241b6c640c30550ce29b58872fb42da4b220678f40b66cb7434292751b482",
    "src/maskfactory/autonomy/calibration.py": "946ffca6e323c1ef95eec5aa323f08ba6dea7bd8b8e8b577ada85f73d8beec5e",
    "src/maskfactory/autonomy/operations.py": "a30f1cda7c0ded91b72e6b7acb266c308e5840527e9a8a9e1e664db71c3e9214",
    "src/maskfactory/models/registry.py": "df43b9f255afc6b67d7b7903039ab50404ff462c62fe470aed81c67900622d55"
  },
  "policy_id": "retraining_compatibility_v1",
  "role_decision": {
    "allow_residual_abstention": true,
    "require_benchmark_pass": true,
    "require_frozen_holdout_pass": true
  },
  "rollback": {
    "require_exact_registry_restore": true,
    "require_serving_smoke": true,
    "required_for_promotion": true
  },
  "schema_version": "1.0.0",
  "sha256": "f02a057c45d76a5e586f1758c94e9df895e20afdaf22edf33d9cc10c13d19107",
  "trigger_thresholds": {
    "minimum_audit_failures": 1,
    "minimum_new_human_corrections": 1
  }
}

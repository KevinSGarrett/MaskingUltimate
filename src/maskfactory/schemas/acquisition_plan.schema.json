{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/acquisition_plan.schema.json",
  "title": "MaskFactory acquisition plan",
  "description": "Machine-readable weekly failure-mining acquisition plan (doc 12 §7). Markdown companion remains human-readable; this document is the schema authority. Never asserts D4 or VLM calibration completion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "report_date",
    "unresolved_failure_count",
    "top_action_cap",
    "top_actions",
    "action_kinds_used",
    "d4_complete",
    "vlm_calibration_complete",
    "human_anchor_authority",
    "weekly_plan_authority",
    "sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "artifact_type": { "const": "acquisition_plan" },
    "report_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "unresolved_failure_count": { "type": "integer", "minimum": 0 },
    "top_action_cap": { "const": 20 },
    "top_actions": {
      "type": "array",
      "maxItems": 20,
      "items": { "$ref": "#/$defs/top_action" }
    },
    "action_kinds_used": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/action_kind" }
    },
    "markdown_relative_path": { "type": "string", "minLength": 1 },
    "clustering_complete": { "type": "boolean" },
    "d4_complete": { "const": false },
    "vlm_calibration_complete": { "const": false },
    "human_anchor_authority": { "const": false },
    "weekly_plan_authority": { "type": "boolean" },
    "sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "action_kind": {
      "enum": [
        "collect_cell_reannotate_holdout",
        "reannotate_skeleton_audit",
        "reannotate_label_proposal",
        "v2_governed_acquisition"
      ]
    },
    "top_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "image_id",
        "failed_body_part",
        "failure_reason",
        "pose_angle",
        "priority",
        "cluster",
        "action_kind",
        "action_text"
      ],
      "properties": {
        "rank": { "type": "integer", "minimum": 1, "maximum": 20 },
        "image_id": { "type": "string", "pattern": "^img_[a-f0-9]{12}$" },
        "failed_body_part": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
        },
        "failure_reason": { "type": "string", "minLength": 1 },
        "pose_angle": { "type": "string", "minLength": 1 },
        "priority": { "type": "number", "minimum": 0, "maximum": 1 },
        "cluster": { "type": "string", "minLength": 1 },
        "action_kind": { "$ref": "#/$defs/action_kind" },
        "action_text": { "type": "string", "minLength": 1 }
      }
    }
  }
}

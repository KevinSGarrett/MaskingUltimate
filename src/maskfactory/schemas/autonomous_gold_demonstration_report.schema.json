{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/autonomous_gold_demonstration_report.schema.json",
  "title": "MaskFactory governed autonomous demonstration report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_id", "fixture_truth_tier", "manual_approval_used", "branches", "hard_veto_cases", "zero_hard_veto_bypass", "report_sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "report_id": {"const": "mf-p6-08-08-autonomous-demonstration-v1"},
    "fixture_truth_tier": {"const": "synthetic_contract_fixture"},
    "manual_approval_used": {"const": false},
    "branches": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "context", "outcome", "certificate_payload_sha256", "at_use_status"],
        "properties": {
          "case_id": {"enum": ["accepted_single", "repaired_multi", "abstained_single", "revoked_multi"]},
          "context": {"enum": ["solo", "duo"]},
          "outcome": {"type": "string", "minLength": 1},
          "certificate_payload_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
          "at_use_status": {"enum": ["allow", "reject", "not_exercised", "not_applicable"]},
          "repair": {"type": "object"},
          "policy_status": {"enum": ["pass", "autonomous_abstention"]},
          "at_use_reasons": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "hard_veto_cases": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["context", "failed_qc_id", "issuer_rejected"],
        "properties": {
          "context": {"enum": ["solo", "duo"]},
          "failed_qc_id": {"enum": ["QC-001", "QC-035"]},
          "issuer_rejected": {"const": true}
        }
      }
    },
    "zero_hard_veto_bypass": {"const": true},
    "report_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}

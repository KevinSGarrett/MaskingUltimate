{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/autonomy_multi_person_risk_buckets.schema.json",
  "title": "MaskFactory multi-person autonomous calibration buckets",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_id", "allowed_instance_contexts", "solo_evidence_allowed", "assignment_priority", "buckets", "exchangeability"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "policy_id": { "const": "multi_person_risk_v1" },
    "allowed_instance_contexts": { "const": ["duo", "small_group"] },
    "solo_evidence_allowed": { "const": false },
    "assignment_priority": {
      "type": "array", "minItems": 10, "maxItems": 10, "uniqueItems": true,
      "items": { "$ref": "#/$defs/bucketName" }
    },
    "buckets": {
      "type": "object", "additionalProperties": false,
      "required": ["duo_baseline", "small_group_baseline", "duo_overlap", "small_group_overlap", "contact", "occlusion", "scale_disparity", "truncation", "crowding", "identity_ambiguity"],
      "properties": {
        "duo_baseline": { "$ref": "#/$defs/bucket" },
        "small_group_baseline": { "$ref": "#/$defs/bucket" },
        "duo_overlap": { "$ref": "#/$defs/bucket" },
        "small_group_overlap": { "$ref": "#/$defs/bucket" },
        "contact": { "$ref": "#/$defs/bucket" },
        "occlusion": { "$ref": "#/$defs/bucket" },
        "scale_disparity": { "$ref": "#/$defs/bucket" },
        "truncation": { "$ref": "#/$defs/bucket" },
        "crowding": { "$ref": "#/$defs/bucket" },
        "identity_ambiguity": { "$ref": "#/$defs/bucket" }
      }
    },
    "exchangeability": {
      "type": "object", "additionalProperties": false,
      "required": ["confidence_level", "minimum_records_per_stratum", "maximum_false_accept_rate_delta", "maximum_serious_failure_rate_delta", "require_wilson_interval_overlap", "sparse_action", "nonexchangeable_action"],
      "properties": {
        "confidence_level": { "type": "number", "minimum": 0.95, "exclusiveMaximum": 1 },
        "minimum_records_per_stratum": { "type": "integer", "minimum": 1 },
        "maximum_false_accept_rate_delta": { "type": "number", "minimum": 0, "maximum": 1 },
        "maximum_serious_failure_rate_delta": { "type": "number", "minimum": 0, "maximum": 1 },
        "require_wilson_interval_overlap": { "const": true },
        "sparse_action": { "const": "abstain" },
        "nonexchangeable_action": { "const": "split" }
      }
    }
  },
  "$defs": {
    "bucketName": { "enum": ["duo_baseline", "small_group_baseline", "duo_overlap", "small_group_overlap", "contact", "occlusion", "scale_disparity", "truncation", "crowding", "identity_ambiguity"] },
    "bucket": {
      "type": "object", "additionalProperties": false, "required": ["description"],
      "properties": { "description": { "type": "string", "minLength": 1 } }
    }
  }
}

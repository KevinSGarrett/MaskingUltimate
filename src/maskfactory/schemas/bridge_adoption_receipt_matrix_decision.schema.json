{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/bridge_adoption_receipt_matrix_decision.schema.json",
  "title": "Additive Main adoption receipt matrix decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "policy_id",
    "policy_sha256",
    "receipt_adoption_id",
    "receipt_payload_sha256",
    "receipt_decision",
    "expected_decision",
    "decision_time_valid",
    "compatibility_failures",
    "required_executed_test_hashes",
    "external_main_adoption_prerequisites",
    "status",
    "rejection_reasons",
    "decision_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "bridge_adoption_receipt_matrix_decision"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "policy_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "receipt_adoption_id": {
      "type": "string",
      "minLength": 1
    },
    "receipt_payload_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "receipt_decision": {
      "enum": [
        "adopted",
        "partially_adopted",
        "rejected"
      ]
    },
    "expected_decision": {
      "enum": [
        "adopted",
        "partially_adopted",
        "rejected"
      ]
    },
    "decision_time_valid": {
      "type": "boolean"
    },
    "compatibility_failures": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_executed_test_hashes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check",
          "executed_test_hash_sha256"
        ],
        "properties": {
          "check": {
            "type": "string",
            "minLength": 1
          },
          "executed_test_hash_sha256": {
            "$ref": "#/$defs/sha256"
          }
        }
      }
    },
    "external_main_adoption_prerequisites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "prerequisite",
          "status",
          "detail"
        ],
        "properties": {
          "prerequisite": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "met",
              "failed",
              "missing_external_main_evidence"
            ]
          },
          "detail": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "status": {
      "enum": [
        "accepted",
        "rejected"
      ]
    },
    "rejection_reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decision_sha256": {
      "$ref": "#/$defs/sha256"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}

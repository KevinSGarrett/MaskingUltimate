{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/bridge_consumer_invalidation_decision.schema.json",
  "title": "Additive bridge consumer invalidation decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "policy_id",
    "policy_sha256",
    "status",
    "rejection_reasons",
    "external_main_runtime_blockers",
    "consumed_context",
    "decision_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "bridge_consumer_invalidation_decision"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "policy_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "status": {
      "enum": [
        "accepted",
        "rejected"
      ]
    },
    "rejection_reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "external_main_runtime_blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action_id",
          "action",
          "blocker"
        ],
        "properties": {
          "action_id": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "blocker": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "consumed_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_payload_sha256",
        "reason",
        "required_actions",
        "cache_snapshot_sha256",
        "revocation_head_sha256",
        "journal_event_count",
        "rollback_target_release_id",
        "rollback_target_release_sha256"
      ],
      "properties": {
        "event_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "event_payload_sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "required_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "action_id",
              "action",
              "deadline_at"
            ],
            "properties": {
              "action_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "action": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "deadline_at": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "cache_snapshot_sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "revocation_head_sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "journal_event_count": {
          "type": "integer",
          "minimum": 0
        },
        "rollback_target_release_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "rollback_target_release_sha256": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "decision_sha256": {
      "$ref": "#/$defs/sha256"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}

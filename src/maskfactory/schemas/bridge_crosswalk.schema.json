{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/bridge_crosswalk.schema.json",
  "title": "Executable MaskFactory/Main crosswalk",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "crosswalk_id",
    "crosswalk_version",
    "policy_id",
    "policy_sha256",
    "versions",
    "compatibility_matrix",
    "crosswalk_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "maskfactory_main_contract_crosswalk"
    },
    "crosswalk_id": {
      "type": "string",
      "minLength": 1
    },
    "crosswalk_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "policy_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "versions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_contract",
        "target_contract",
        "producer_major",
        "producer_minor",
        "target_major",
        "target_minor"
      ],
      "properties": {
        "producer_contract": {
          "type": "string",
          "minLength": 1
        },
        "target_contract": {
          "type": "string",
          "minLength": 1
        },
        "producer_major": {
          "type": "integer",
          "minimum": 1
        },
        "producer_minor": {
          "type": "integer",
          "minimum": 0
        },
        "target_major": {
          "type": "integer",
          "minimum": 1
        },
        "target_minor": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "compatibility_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_source_paths",
        "required_target_paths",
        "compatible_minor_additions",
        "removed_source_paths",
        "order_sensitive_sequences",
        "rows"
      ],
      "properties": {
        "required_source_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/pointer"
          }
        },
        "required_target_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/pointer"
          }
        },
        "compatible_minor_additions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "producer_minor",
              "source_path",
              "target_path",
              "rule"
            ],
            "properties": {
              "producer_minor": {
                "type": "integer",
                "minimum": 1
              },
              "source_path": {
                "$ref": "#/$defs/pointer"
              },
              "target_path": {
                "$ref": "#/$defs/pointer"
              },
              "rule": {
                "enum": [
                  "map",
                  "drop"
                ]
              }
            }
          }
        },
        "removed_source_paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pointer"
          }
        },
        "order_sensitive_sequences": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_path",
              "target_path",
              "canonical_order"
            ],
            "properties": {
              "source_path": {
                "$ref": "#/$defs/pointer"
              },
              "target_path": {
                "$ref": "#/$defs/pointer"
              },
              "canonical_order": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": [
                    "string",
                    "number",
                    "boolean"
                  ]
                }
              }
            }
          }
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/row"
          }
        }
      }
    },
    "crosswalk_sha256": {
      "$ref": "#/$defs/sha256"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "pointer": {
      "type": "string",
      "pattern": "^/(?:[^/~]|~0|~1)+(?:/(?:[^/~]|~0|~1)+)*$"
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_path",
        "target_path",
        "rule",
        "conversion"
      ],
      "properties": {
        "source_path": {
          "$ref": "#/$defs/pointer"
        },
        "target_path": {
          "$ref": "#/$defs/pointer"
        },
        "rule": {
          "enum": [
            "map",
            "drop",
            "default",
            "reject"
          ]
        },
        "conversion": {
          "enum": [
            "identity",
            "enum_map",
            "literal"
          ]
        },
        "enum_map": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          }
        },
        "default_value": {
          "type": [
            "string",
            "number",
            "boolean",
            "null"
          ]
        },
        "producer_observation_mode": {
          "enum": [
            "none",
            "preserve_only"
          ]
        }
      }
    }
  }
}

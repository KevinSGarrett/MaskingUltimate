{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/bridge_identity_decision.schema.json",
  "title": "Canonical cross-record MaskFactory bridge identity decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "record_type", "policy_id", "policy_sha256", "canonicalization",
    "decision_scope_sha256", "records", "replay_count", "status", "collisions", "rejection_reasons",
    "decision_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "bridge_identity_decision"},
    "policy_id": {"const": "maskfactory-bridge-canonical-identity-v1"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "canonicalization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "excluded_top_level_fields"],
      "properties": {
        "algorithm": {"const": "maskfactory-canonical-json-v1"},
        "excluded_top_level_fields": {
          "type": "array",
          "prefixItems": [{"const": "decision_sha256"}],
          "minItems": 1,
          "maxItems": 1
        }
      }
    },
    "decision_scope_sha256": {"$ref": "#/$defs/sha256"},
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/record"}
    },
    "replay_count": {"type": "integer", "minimum": 0},
    "status": {"enum": ["accepted", "rejected"]},
    "collisions": {
      "type": "array",
      "items": {"$ref": "#/$defs/collision"}
    },
    "rejection_reasons": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "decision_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_sha256", "request_payload_sha256", "receipt_payload_sha256",
        "idempotency_key", "execution", "source", "media_scope", "subject",
        "assignment_evidence_sha256", "package", "owner_roster", "intents", "artifacts"
      ],
      "properties": {
        "record_sha256": {"$ref": "#/$defs/sha256"},
        "request_payload_sha256": {"$ref": "#/$defs/sha256"},
        "receipt_payload_sha256": {"$ref": "#/$defs/sha256"},
        "idempotency_key": {"type": "string", "minLength": 16},
        "execution": {"$ref": "#/$defs/execution"},
        "source": {"$ref": "#/$defs/source"},
        "media_scope": {"type": "object"},
        "subject": {"$ref": "#/$defs/subject"},
        "assignment_evidence_sha256": {"$ref": "#/$defs/sha256"},
        "package": {"$ref": "#/$defs/package"},
        "owner_roster": {"type": "array", "minItems": 1, "items": {"type": "object"}},
        "intents": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/intent"}},
        "artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/artifact"}}
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "run_id", "job_id", "pass_id", "attempt_id", "attempt_number", "hypothesis_id"],
      "properties": {
        "project_id": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "job_id": {"type": "string", "minLength": 1},
        "pass_id": {"type": "string", "minLength": 1},
        "attempt_id": {"type": "string", "minLength": 1},
        "attempt_number": {"type": "integer", "minimum": 1},
        "hypothesis_id": {"type": "string", "minLength": 1}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["encoded_sha256", "decoded_pixel_sha256", "decoder_id", "decoder_version", "decoder_binary_sha256"],
      "properties": {
        "encoded_sha256": {"$ref": "#/$defs/sha256"},
        "decoded_pixel_sha256": {"$ref": "#/$defs/sha256"},
        "decoder_id": {"type": "string", "minLength": 1},
        "decoder_version": {"type": "string", "minLength": 1},
        "decoder_binary_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scene_id", "shot_id", "take_id", "character_id", "character_revision", "scene_instance_id", "canonical_person_id", "person_index", "provider_person_index"],
      "properties": {
        "scene_id": {"type": "string", "minLength": 1},
        "shot_id": {"type": "string", "minLength": 1},
        "take_id": {"type": "string", "minLength": 1},
        "character_id": {"type": "string", "minLength": 1},
        "character_revision": {"type": "string", "minLength": 1},
        "scene_instance_id": {"type": "string", "minLength": 1},
        "canonical_person_id": {"type": "string", "minLength": 1},
        "person_index": {"type": "integer", "minimum": 0},
        "provider_person_index": {"type": "integer", "minimum": 0}
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_id", "package_revision", "package_manifest_sha256"],
      "properties": {
        "package_id": {"type": ["string", "null"]},
        "package_revision": {"type": ["string", "null"]},
        "package_manifest_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent_id", "label", "artifact_kind", "purpose", "target_coordinate_space"],
      "properties": {
        "intent_id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "artifact_kind": {"type": "string", "minLength": 1},
        "purpose": {"type": "string", "minLength": 1},
        "target_coordinate_space": {"type": "string", "minLength": 1}
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "intent_id", "artifact_identity_sha256", "encoded_sha256", "decoded_mask_sha256", "owner"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "intent_id": {"type": "string", "minLength": 1},
        "artifact_identity_sha256": {"$ref": "#/$defs/sha256"},
        "encoded_sha256": {"$ref": "#/$defs/sha256"},
        "decoded_mask_sha256": {"$ref": "#/$defs/sha256"},
        "owner": {"type": "object"}
      }
    },
    "collision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "key_sha256", "record_sha256s"],
      "properties": {
        "code": {"enum": ["assignment_evidence_drift", "character_revision_collision", "duplicate_intent_collision", "provider_person_index_collision", "artifact_identity_collision", "idempotency_replay_collision"]},
        "key_sha256": {"$ref": "#/$defs/sha256"},
        "record_sha256s": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}}
      }
    }
  }
}

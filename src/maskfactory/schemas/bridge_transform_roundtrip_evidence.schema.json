{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/bridge_transform_roundtrip_evidence.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "policy_id", "policy_sha256", "transform_chain_id", "transform_chain_sha256", "inverse_chain_sha256", "roundtrip_passed", "maximum_error_px", "probe_results", "protected_region_count", "evidence_sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "bridge_transform_roundtrip_evidence"},
    "policy_id": {"const": "maskfactory-bridge-transform-execution-v1"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "transform_chain_id": {"type": "string", "minLength": 1},
    "transform_chain_sha256": {"$ref": "#/$defs/sha256"},
    "inverse_chain_sha256": {"$ref": "#/$defs/sha256"},
    "roundtrip_passed": {"const": true},
    "maximum_error_px": {"type": "number", "minimum": 0},
    "probe_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["input", "output", "replayed", "error_px"],
        "properties": {
          "input": {"$ref": "#/$defs/point"},
          "output": {"$ref": "#/$defs/point"},
          "replayed": {"$ref": "#/$defs/point"},
          "error_px": {"type": "number", "minimum": 0}
        }
      }
    },
    "protected_region_count": {"type": "integer", "minimum": 0},
    "evidence_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "coordinate_space"],
      "properties": {
        "x": {"type": "number"},
        "y": {"type": "number"},
        "coordinate_space": {"enum": ["source_pixel", "crop_pixel", "output_pixel"]}
      }
    }
  }
}

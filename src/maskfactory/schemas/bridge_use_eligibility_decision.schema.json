{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/bridge_use_eligibility_decision.schema.json",
  "title": "Independent bridge use-eligibility decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "record_type", "policy_id", "policy_sha256",
    "required_authority_state", "exact_use_scope", "eligible", "reasons",
    "normalized_facts", "producer_observation", "decision_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "bridge_use_eligibility_decision"},
    "policy_id": {"const": "maskfactory-bridge-use-eligibility-v1"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "required_authority_state": {
      "enum": ["invalid", "hypothesis", "draft", "qa_passed_noncertified", "certified"]
    },
    "exact_use_scope": {
      "enum": ["production_conditioning", "downstream_promotion_support", "repair_seed", "qa", "diagnostic"]
    },
    "eligible": {"type": "boolean"},
    "reasons": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "normalized_facts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_payload_sha256", "receipt_payload_sha256", "result", "authority_state",
        "certificate_status", "certificate_sha256", "qa_status", "transform_roundtrip_passed",
        "revocation_index_sha256", "certificate_evidence_sha256"
      ],
      "properties": {
        "request_payload_sha256": {"type": ["string", "null"]},
        "receipt_payload_sha256": {"type": ["string", "null"]},
        "result": {"type": ["string", "null"]},
        "authority_state": {"type": ["string", "null"]},
        "certificate_status": {"type": ["string", "null"]},
        "certificate_sha256": {"type": ["string", "null"]},
        "qa_status": {"type": ["string", "null"]},
        "transform_roundtrip_passed": {"type": ["boolean", "null"]},
        "revocation_index_sha256": {"type": ["string", "null"]},
        "certificate_evidence_sha256": {"type": ["string", "null"]}
      }
    },
    "producer_observation": {"type": "object"},
    "decision_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}

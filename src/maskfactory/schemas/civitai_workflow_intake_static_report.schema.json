{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/civitai_workflow_intake_static_report.schema.json",
  "title": "MaskFactory Civitai workflow intake STATIC report (MF-P0-10 / MF-P0-14.01)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "proof_tier",
    "authority",
    "checked_at",
    "items",
    "memo_binding",
    "classifications_binding",
    "classification_admission",
    "metadata_disposition",
    "workflow_admissions",
    "license_provenance_gate",
    "checks",
    "direct_gold_negative_fixture_blocked",
    "training_without_review_negative_fixture_blocked",
    "paid_download_negative_fixture_blocked",
    "kevin_credentials_negative_fixture_blocked",
    "direct_gold_promotion_claimed",
    "paid_download_claimed",
    "kevin_credentials_claimed",
    "plan_civitai_extracted_runtime_claimed",
    "doctor_green_claimed",
    "gold_claimed",
    "visual_qa_pass_claimed",
    "main_complete_claimed",
    "production_evidence_pass_claimed",
    "honest_non_claims",
    "report_id",
    "seal_sha256",
    "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "civitai_workflow_intake_static_report"},
    "proof_tier": {"const": "STATIC_PASS"},
    "authority": {
      "const": "civitai_workflow_intake_static_only_no_gold_paid_download_or_kevin_credential_authority"
    },
    "checked_at": {"type": "string", "minLength": 1},
    "items": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "MF-P0-10.01",
          "MF-P0-10.02",
          "MF-P0-10.03",
          "MF-P0-10.04",
          "MF-P0-14.01"
        ]
      }
    },
    "memo_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes", "required_markers_present"],
      "properties": {
        "path": {"const": "Plan/CIVITAI_WORKFLOW_INTAKE.md"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "bytes": {"type": "integer", "minimum": 64},
        "required_markers_present": {"const": true}
      }
    },
    "classifications_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "record_count"],
      "properties": {
        "path": {"const": "configs/civitai_classifications.json"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "record_count": {"const": 79}
      }
    },
    "classification_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_count",
        "classification_counts",
        "mask_authority",
        "authority_uniform",
        "license_provenance_gate",
        "rejected_files"
      ],
      "properties": {
        "record_count": {"const": 79},
        "classification_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "provider_inference",
            "comfyui_graph_reference",
            "annotation_aid",
            "qa_visualization",
            "reject"
          ],
          "properties": {
            "provider_inference": {"const": 31},
            "comfyui_graph_reference": {"const": 17},
            "annotation_aid": {"const": 6},
            "qa_visualization": {"const": 23},
            "reject": {"const": 2}
          }
        },
        "mask_authority": {"const": "none"},
        "authority_uniform": {"const": "proposal_or_reference_only"},
        "license_provenance_gate": {"const": true},
        "rejected_files": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["breastExpansion_v10.zip", "rotomakerWith_v3.zip"]
          }
        }
      }
    },
    "metadata_disposition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadata_only_count",
        "download_action",
        "disposition",
        "paid_download_required",
        "kevin_credentials_required",
        "manual_browser_download_required",
        "replacements"
      ],
      "properties": {
        "metadata_only_count": {"const": 6},
        "download_action": {"const": "unnecessary"},
        "disposition": {"const": "superseded_by_downloaded_variant"},
        "paid_download_required": {"const": false},
        "kevin_credentials_required": {"const": false},
        "manual_browser_download_required": {"const": false},
        "replacements": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "yoloDatasetAuto_v10.zip",
            "handDetailer_v1b.zip",
            "handDetailer_v1.zip",
            "eyeDetailerSegmentation_v1b.zip",
            "eyeDetailerSegmentation_v1.zip",
            "adetailer2dArmpitYolov8_v10Bbox.zip"
          ],
          "properties": {
            "yoloDatasetAuto_v10.zip": {"const": "yoloDatasetAuto_v20.zip"},
            "handDetailer_v1b.zip": {"const": "handDetailer_v2V9c.zip"},
            "handDetailer_v1.zip": {"const": "handDetailer_v2V9c.zip"},
            "eyeDetailerSegmentation_v1b.zip": {
              "const": "eyeDetailerSegmentation_v2.zip"
            },
            "eyeDetailerSegmentation_v1.zip": {
              "const": "eyeDetailerSegmentation_v2.zip"
            },
            "adetailer2dArmpitYolov8_v10Bbox.zip": {
              "const": "adetailer2dArmpitYolov8_v10Segmentation.zip"
            }
          }
        }
      }
    },
    "workflow_admissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "simpleImageToDWPoseDense_v10.zip",
        "SegmentMaskMaskAddRemove_v10.zip"
      ],
      "properties": {
        "simpleImageToDWPoseDense_v10.zip": {
          "$ref": "#/$defs/workflow_admission"
        },
        "SegmentMaskMaskAddRemove_v10.zip": {
          "$ref": "#/$defs/workflow_admission"
        }
      }
    },
    "license_provenance_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gates",
        "direct_gold_allowed",
        "training_without_review_allowed",
        "paid_download_required",
        "kevin_credentials_required"
      ],
      "properties": {
        "gates": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "direct_gold_allowed": {"const": false},
        "training_without_review_allowed": {"const": false},
        "paid_download_required": {"const": false},
        "kevin_credentials_required": {"const": false}
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intake_memo_bound",
        "classification_admission",
        "metadata_disposition_unnecessary",
        "workflow_admissions",
        "license_provenance_gate",
        "direct_gold_refused",
        "training_without_review_refused",
        "paid_download_not_required",
        "kevin_credentials_not_required"
      ],
      "properties": {
        "intake_memo_bound": {"const": "pass"},
        "classification_admission": {"const": "pass"},
        "metadata_disposition_unnecessary": {"const": "pass"},
        "workflow_admissions": {"const": "pass"},
        "license_provenance_gate": {"const": "pass"},
        "direct_gold_refused": {"const": "pass"},
        "training_without_review_refused": {"const": "pass"},
        "paid_download_not_required": {"const": "pass"},
        "kevin_credentials_not_required": {"const": "pass"}
      }
    },
    "direct_gold_negative_fixture_blocked": {"const": true},
    "training_without_review_negative_fixture_blocked": {"const": true},
    "paid_download_negative_fixture_blocked": {"const": true},
    "kevin_credentials_negative_fixture_blocked": {"const": true},
    "direct_gold_promotion_claimed": {"const": false},
    "paid_download_claimed": {"const": false},
    "kevin_credentials_claimed": {"const": false},
    "plan_civitai_extracted_runtime_claimed": {"const": false},
    "doctor_green_claimed": {"const": false},
    "gold_claimed": {"const": false},
    "visual_qa_pass_claimed": {"const": false},
    "main_complete_claimed": {"const": false},
    "production_evidence_pass_claimed": {"const": false},
    "honest_non_claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "report_id": {"type": "string", "pattern": "^cwi_[a-f0-9]{24}$"},
    "seal_sha256": {"$ref": "#/$defs/sha256"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "workflow_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_json",
        "classification",
        "authority",
        "mask_authority",
        "direct_gold_promotion",
        "admitted_for_static_reference",
        "requires_paid_download",
        "requires_kevin_credentials"
      ],
      "properties": {
        "workflow_json": {
          "type": "string",
          "enum": ["imageToOpenPose.json", "mask_add_remove_self.json"]
        },
        "classification": {
          "type": "string",
          "enum": ["comfyui_graph_reference", "annotation_aid"]
        },
        "authority": {"const": "proposal_or_reference_only"},
        "mask_authority": {"const": "none"},
        "direct_gold_promotion": {"const": false},
        "admitted_for_static_reference": {"const": true},
        "requires_paid_download": {"const": false},
        "requires_kevin_credentials": {"const": false}
      }
    }
  }
}

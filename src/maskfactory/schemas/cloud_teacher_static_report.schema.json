{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/cloud_teacher_static_report.schema.json",
  "title": "MaskFactory cloud-teacher STATIC binder report",
  "description": "STATIC_PASS binder for budget circuit-breaker, shadow-teacher schema, and incremental-value corpus audit machinery. Never claims MF-P4-10.08/09, paid cloud calls, or human-anchor ≥200 corpus authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "proof_tier",
    "authority",
    "coverage_themes_required",
    "minimum_incremental_cases",
    "checks",
    "seeded_fixture_blocks",
    "budget_proof",
    "config_proof",
    "shadow_consensus",
    "incremental_audit_fixture_failures",
    "mf_p4_10_08_complete",
    "mf_p4_10_09_complete",
    "human_anchor_ge_200_corpus",
    "paid_cloud_calls_executed",
    "doctor_green_claimed",
    "gold_claimed",
    "production_evidence_pass_claimed",
    "honest_non_claims",
    "items",
    "report_id",
    "seal_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "artifact_type": { "const": "cloud_teacher_static_report" },
    "proof_tier": { "const": "STATIC_PASS" },
    "authority": {
      "const": "cloud_teacher_static_only_no_paid_calls_no_mf_p4_10_08_09_human_anchor_authority"
    },
    "coverage_themes_required": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "enum": [
          "serious_anatomy_swap",
          "missing_part",
          "neighbor_person_contamination",
          "clothing_skin_boundary",
          "hair",
          "hands_fingers",
          "feet_toes",
          "occlusion",
          "multi_person_contact",
          "good_mask"
        ]
      }
    },
    "minimum_incremental_cases": { "const": 200 },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budget_circuit_breaker",
        "shadow_teacher_schema",
        "shadow_consensus_residual",
        "incremental_value_corpus_audit",
        "config_shadow_budget_defaults"
      ],
      "properties": {
        "budget_circuit_breaker": { "const": "pass" },
        "shadow_teacher_schema": { "const": "pass" },
        "shadow_consensus_residual": { "const": "pass" },
        "incremental_value_corpus_audit": { "const": "pass" },
        "config_shadow_budget_defaults": { "const": "pass" }
      }
    },
    "seeded_fixture_blocks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budget_circuit_breaker",
        "config_shadow_budget_defaults",
        "coverage_gap_rejected",
        "leakage_and_duplicate_rejected",
        "mf_p4_10_08_09_overclaim_refused",
        "shadow_judgment_schema",
        "undersized_corpus_rejected",
        "unanimous_cloud_deterministic_veto_residual"
      ],
      "properties": {
        "budget_circuit_breaker": { "const": true },
        "config_shadow_budget_defaults": { "const": true },
        "coverage_gap_rejected": { "const": true },
        "leakage_and_duplicate_rejected": { "const": true },
        "mf_p4_10_08_09_overclaim_refused": { "const": true },
        "shadow_judgment_schema": { "const": true },
        "undersized_corpus_rejected": { "const": true },
        "unanimous_cloud_deterministic_veto_residual": { "const": true }
      }
    },
    "budget_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hard_limit_usd",
        "reservation_usd",
        "circuit_breaker_tripped",
        "duplicate_request_refused",
        "paid_cloud_calls_executed"
      ],
      "properties": {
        "hard_limit_usd": { "type": "string", "minLength": 1 },
        "reservation_usd": { "type": "string", "minLength": 1 },
        "circuit_breaker_tripped": { "const": true },
        "duplicate_request_refused": { "const": true },
        "paid_cloud_calls_executed": { "const": false }
      }
    },
    "config_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "operational_limit_usd",
        "hard_limit_usd",
        "reservation_usd",
        "maximum_calls_per_image",
        "minimum_incremental_cases"
      ],
      "properties": {
        "mode": { "const": "shadow_only" },
        "operational_limit_usd": { "const": 14.5 },
        "hard_limit_usd": { "const": 15.0 },
        "reservation_usd": { "const": 1.0 },
        "maximum_calls_per_image": { "const": 3 },
        "minimum_incremental_cases": { "const": 200 }
      }
    },
    "shadow_consensus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "destination",
        "reason",
        "may_approve_gold",
        "may_clear_blocks",
        "may_create_quick_pass"
      ],
      "properties": {
        "destination": { "const": "residual_human_queue" },
        "reason": { "type": "string", "minLength": 1 },
        "may_approve_gold": { "const": false },
        "may_clear_blocks": { "const": false },
        "may_create_quick_pass": { "const": false }
      }
    },
    "incremental_audit_fixture_failures": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "mf_p4_10_08_complete": { "const": false },
    "mf_p4_10_09_complete": { "const": false },
    "human_anchor_ge_200_corpus": { "const": false },
    "paid_cloud_calls_executed": { "const": false },
    "doctor_green_claimed": { "const": false },
    "gold_claimed": { "const": false },
    "production_evidence_pass_claimed": { "const": false },
    "honest_non_claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "items": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "enum": [
          "MF-P4-10.04",
          "MF-P4-10.05",
          "MF-P4-10.07",
          "MF-P4-10.08",
          "MF-P4-10.09"
        ]
      }
    },
    "report_id": {
      "type": "string",
      "pattern": "^cts_[a-f0-9]{24}$"
    },
    "seal_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}

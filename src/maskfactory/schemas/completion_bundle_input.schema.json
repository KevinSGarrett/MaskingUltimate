{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/completion_bundle_input.schema.json",
  "title": "MaskFactory modernization completion input",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "bundle_id", "created_at", "policy_sha256", "tracker", "evidence_receipts", "sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "bundle_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "tracker": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}}
    },
    "evidence_receipts": {"type": "array", "minItems": 15, "items": {"$ref": "#/$defs/receipt"}},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}}
    },
    "receipt": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "domain", "evidence_id", "observed_at", "evidence_class", "result", "verifier_id", "verifier_version", "source_artifacts", "measurements", "authority", "sha256"],
      "properties": {
        "schema_version": {"const": "1.0.0"},
        "domain": {"type": "string", "minLength": 1},
        "evidence_id": {"type": "string", "minLength": 1},
        "observed_at": {"type": "string", "format": "date-time"},
        "evidence_class": {"const": "real_operation"},
        "result": {"const": "pass"},
        "verifier_id": {"type": "string", "minLength": 1},
        "verifier_version": {"type": "string", "minLength": 1},
        "source_artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/artifact"}},
        "measurements": {"type": "object"},
        "authority": {"const": "primary_domain_evidence"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/coverage_matrix.schema.json",
  "title": "MaskFactory approved-gold coverage matrix",
  "description": "Closed view/pose/attribute coverage with doc 17 instance context.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "cells", "attribute_totals"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "cells": {
      "type": "array",
      "items": { "$ref": "#/$defs/cell" }
    },
    "attribute_totals": { "$ref": "#/$defs/attributeCounts" }
  },
  "$defs": {
    "view": {
      "enum": [
        "front",
        "back",
        "left_profile",
        "right_profile",
        "left_3_4",
        "right_3_4"
      ]
    },
    "pose": {
      "enum": [
        "arms_raised",
        "arms_down",
        "arms_crossed",
        "seated_or_crouched",
        "lying",
        "walking",
        "leg_overlap"
      ]
    },
    "instanceContext": { "enum": ["solo", "duo", "small_group"] },
    "cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view", "pose", "instance_context", "approved_gold_count"],
      "properties": {
        "view": { "$ref": "#/$defs/view" },
        "pose": { "$ref": "#/$defs/pose" },
        "instance_context": { "$ref": "#/$defs/instanceContext" },
        "approved_gold_count": { "type": "integer", "minimum": 0 }
      }
    },
    "attributeCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hands_visible",
        "feet_visible",
        "hand_body_contact",
        "hair_occlusion",
        "clothing_boundary",
        "bare_skin_dominant",
        "tight_clothing",
        "loose_clothing",
        "back_visible",
        "fingers_spread",
        "fingers_merged",
        "props_present"
      ],
      "properties": {
        "hands_visible": { "$ref": "#/$defs/count" },
        "feet_visible": { "$ref": "#/$defs/count" },
        "hand_body_contact": { "$ref": "#/$defs/count" },
        "hair_occlusion": { "$ref": "#/$defs/count" },
        "clothing_boundary": { "$ref": "#/$defs/count" },
        "bare_skin_dominant": { "$ref": "#/$defs/count" },
        "tight_clothing": { "$ref": "#/$defs/count" },
        "loose_clothing": { "$ref": "#/$defs/count" },
        "back_visible": { "$ref": "#/$defs/count" },
        "fingers_spread": { "$ref": "#/$defs/count" },
        "fingers_merged": { "$ref": "#/$defs/count" },
        "props_present": { "$ref": "#/$defs/count" }
      }
    },
    "count": { "type": "integer", "minimum": 0 }
  }
}

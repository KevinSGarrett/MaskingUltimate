{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/crop_transform.schema.json",
  "title": "MaskFactory crop-to-full transform",
  "description": "Exact square-crop placement contract (doc 03 §5).",
  "type": "object",
  "additionalProperties": false,
  "required": ["part", "x0", "y0", "scale", "crop_size", "source_sha256"],
  "properties": {
    "part": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "x0": { "type": "integer", "minimum": 0 },
    "y0": { "type": "integer", "minimum": 0 },
    "scale": { "type": "number", "exclusiveMinimum": 0 },
    "crop_size": { "type": "integer", "minimum": 1 },
    "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}

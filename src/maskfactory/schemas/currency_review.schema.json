{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/currency_review.schema.json",
  "title": "MaskFactory technology-currency review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "event",
    "reviewed_at",
    "expires_at",
    "reviewer",
    "signer_public_key_sha256",
    "input_hashes",
    "active_role_digest",
    "active_roles",
    "global_findings",
    "status",
    "previous_review_sha256",
    "signature_algorithm",
    "payload_sha256",
    "signature",
    "review_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "review_id": { "type": "string", "pattern": "^[a-f0-9]{24}$" },
    "event": {
      "enum": ["scheduled_90_day", "dataset_freeze", "training", "promotion", "major_release"]
    },
    "reviewed_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "reviewer": { "type": "string", "minLength": 1 },
    "signer_public_key_sha256": { "$ref": "#/$defs/sha256" },
    "input_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pipeline", "external_registry", "model_registry", "rollback_evidence", "dependencies"],
      "properties": {
        "pipeline": { "$ref": "#/$defs/sha256" },
        "external_registry": { "$ref": "#/$defs/sha256" },
        "model_registry": { "$ref": "#/$defs/sha256" },
        "rollback_evidence": { "$ref": "#/$defs/sha256" },
        "dependencies": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/sha256" }
        }
      }
    },
    "active_role_digest": { "$ref": "#/$defs/sha256" },
    "active_roles": {
      "type": "array",
      "items": { "$ref": "#/$defs/roleReview" }
    },
    "global_findings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "status": { "enum": ["pass", "fail"] },
    "previous_review_sha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
    "signature_algorithm": { "const": "ed25519" },
    "payload_sha256": { "$ref": "#/$defs/sha256" },
    "signature": { "type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$" },
    "review_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "roleReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role", "provider_alias", "registry", "authority_key", "lifecycle_state",
        "artifact_sha256", "runtime_identity", "license_status",
        "benchmark_certificate_sha256", "benchmark_issued_at", "rollback_provider",
        "rollback_evidence_sha256", "rollback_tested_at", "findings", "status"
      ],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "provider_alias": { "type": "string", "minLength": 1 },
        "registry": { "enum": ["external_sources", "model_registry"] },
        "authority_key": { "type": "string", "minLength": 1 },
        "lifecycle_state": { "type": ["string", "null"] },
        "artifact_sha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
        "runtime_identity": { "type": ["string", "null"] },
        "license_status": { "type": "string", "minLength": 1 },
        "benchmark_certificate_sha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
        "benchmark_issued_at": { "type": ["string", "null"], "format": "date-time" },
        "rollback_provider": { "type": ["string", "null"] },
        "rollback_evidence_sha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
        "rollback_tested_at": { "type": ["string", "null"], "format": "date-time" },
        "findings": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "status": { "enum": ["pass", "fail"] }
      }
    }
  }
}

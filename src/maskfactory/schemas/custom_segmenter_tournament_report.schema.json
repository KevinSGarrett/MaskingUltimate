{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/custom_segmenter_tournament_report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "tournament_id", "evaluated_at", "policy_sha256", "source_runs_sha256", "shared_identity_sha256", "providers", "comparability", "result", "authority", "sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "tournament_id": {"type": "string", "minLength": 1},
    "evaluated_at": {"type": "string", "format": "date-time"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "source_runs_sha256": {"$ref": "#/$defs/sha256"},
    "shared_identity_sha256": {"$ref": "#/$defs/sha256"},
    "providers": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "object"}},
    "comparability": {"type": "object"},
    "result": {"const": "comparable_complete_runs"},
    "authority": {"const": "measurement_evidence_only_no_winner_promotion_serving_mask_or_gold_authority"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}

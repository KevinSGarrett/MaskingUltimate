{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_acceptance_certificate.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "certificate_id", "certificate_sha256", "policy_version", "policy_sha256", "issued_at", "worker_identity", "use_profile", "scene_id", "bindings", "authority", "validation", "semantic_replay", "package", "repair", "source_lineage_declaration", "train_eligible", "accepted"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "certificate_id": {"type": "string", "pattern": "^dacc_[0-9a-f]{24}$"},
    "certificate_sha256": {"$ref": "#/$defs/sha"},
    "policy_version": {"const": "1.0.0"}, "policy_sha256": {"$ref": "#/$defs/sha"},
    "issued_at": {"type": "string", "format": "date-time"}, "worker_identity": {"type": "string", "minLength": 1},
    "use_profile": {"const": "private_personal_noncommercial"}, "scene_id": {"type": "string"},
    "bindings": {"type": "object", "additionalProperties": false, "required": ["scene_sha256", "package_sha256", "recipe_sha256", "registry_sha256", "runtime_sha256", "mapping_set_sha256", "label_table_sha256", "training_weight_sha256", "source_lineage_sha256"], "additionalProperties": false, "properties": {"scene_sha256": {"$ref": "#/$defs/sha"}, "package_sha256": {"$ref": "#/$defs/sha"}, "recipe_sha256": {"$ref": "#/$defs/sha"}, "registry_sha256": {"$ref": "#/$defs/sha"}, "runtime_sha256": {"$ref": "#/$defs/sha"}, "mapping_set_sha256": {"$ref": "#/$defs/sha"}, "label_table_sha256": {"$ref": "#/$defs/sha"}, "training_weight_sha256": {"$ref": "#/$defs/sha"}, "source_lineage_sha256": {"$ref": "#/$defs/sha"}}},
    "authority": {"type": "object", "additionalProperties": false, "required": ["provider_id", "authority_tier", "ontology_version", "ontology_sha256", "owner", "package_revision", "certificate_scope", "transform_chain_sha256"], "properties": {"provider_id": {"const": "daz_exact_geometry"}, "authority_tier": {"const": "synthetic_exact"}, "ontology_version": {"type": "string"}, "ontology_sha256": {"$ref": "#/$defs/sha"}, "owner": {"const": "maskfactory"}, "package_revision": {"type": "string"}, "certificate_scope": {"type": "string"}, "transform_chain_sha256": {"$ref": "#/$defs/sha"}}},
    "validation": {"type": "object", "additionalProperties": false, "required": ["report_id", "report_sha256", "registry_version", "required_validator_ids", "pass_count", "not_applicable_count", "warning_count", "failure_count", "measurements"], "properties": {"report_id": {"type": "string", "pattern": "^dvsr_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"}, "registry_version": {"const": "1.0.0"}, "required_validator_ids": {"type": "array", "minItems": 9, "maxItems": 9, "uniqueItems": true, "items": {"type": "string"}}, "pass_count": {"type": "integer", "minimum": 0}, "not_applicable_count": {"type": "integer", "minimum": 0}, "warning_count": {"const": 0}, "failure_count": {"const": 0}, "measurements": {"type": "array", "minItems": 9, "maxItems": 9, "items": {"type": "object", "additionalProperties": false, "required": ["validator_id", "status", "reason_code", "metric", "observed", "expected"], "properties": {"validator_id": {"type": "string", "pattern": "^DAZ-V[0-8]-001$"}, "status": {"enum": ["pass", "not_applicable"]}, "reason_code": {"type": "string", "minLength": 1}, "metric": {"type": "string", "minLength": 1}, "observed": {}, "expected": {}}}}}},
    "semantic_replay": {"type": "object", "additionalProperties": false, "required": ["report_id", "report_sha256", "semantic_set_sha256", "semantic_hashes_byte_identical", "scene_state_unchanged", "runs_independent", "authorities_identical"], "properties": {"report_id": {"type": "string", "pattern": "^dssr_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"}, "semantic_set_sha256": {"$ref": "#/$defs/sha"}, "semantic_hashes_byte_identical": {"const": true}, "scene_state_unchanged": {"const": true}, "runs_independent": {"const": true}, "authorities_identical": {"const": true}}},
    "package": {"type": "object", "additionalProperties": false, "required": ["contract_id", "contract_sha256", "input_truth_contract_sha256", "input_truth_tier", "certified_truth_tier", "report_id", "report_sha256", "file_map_sha256", "package_tree_sha256s", "package_count"], "properties": {"contract_id": {"type": "string", "pattern": "^dpdc_[0-9a-f]{24}$"}, "contract_sha256": {"$ref": "#/$defs/sha"}, "input_truth_contract_sha256": {"$ref": "#/$defs/sha"}, "input_truth_tier": {"const": "weighted_pseudo_label"}, "certified_truth_tier": {"const": "synthetic_exact"}, "report_id": {"type": "string", "pattern": "^dpdr_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"}, "file_map_sha256": {"$ref": "#/$defs/sha"}, "package_tree_sha256s": {"type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": {"$ref": "#/$defs/sha"}}, "package_count": {"type": "integer", "minimum": 1, "maximum": 4}}},
    "repair": {"type": "object", "additionalProperties": false, "required": ["history_id", "history_sha256", "entry_count", "scheduled_count", "post_repair_validations"], "properties": {"history_id": {"oneOf": [{"type": "null"}, {"type": "string", "pattern": "^drrh_[0-9a-f]{24}$"}]}, "history_sha256": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/sha"}]}, "entry_count": {"type": "integer", "minimum": 0}, "scheduled_count": {"type": "integer", "minimum": 0}, "post_repair_validations": {"type": "array", "uniqueItems": true, "items": {"type": "object", "additionalProperties": false, "required": ["recipe_revision_id", "report_id", "report_sha256"], "properties": {"recipe_revision_id": {"type": "string", "pattern": "^daz_recipe_revision_[0-9a-f]{24}$"}, "report_id": {"type": "string", "pattern": "^dvsr_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"}}}}}},
    "source_lineage_declaration": {"type": "object", "additionalProperties": false, "required": ["source_origin", "annotation_authority", "visible_only", "amodal_included", "human_annotation_used", "live_mode_b_result", "license_profile"], "properties": {"source_origin": {"const": "synthetic"}, "annotation_authority": {"const": "exact_geometry_render"}, "visible_only": {"const": true}, "amodal_included": {"const": false}, "human_annotation_used": {"const": false}, "live_mode_b_result": {"const": false}, "license_profile": {"const": "private_personal_noncommercial"}}}, "train_eligible": {"const": true}, "accepted": {"const": true}
  }, "$defs": {"sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_acquisition_capacity.schema.json",
  "title": "DAZ acquisition capacity policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "root",
    "soft_floor_gib",
    "hard_floor_gib",
    "emergency_floor_gib",
    "new_work_allowed_states",
    "active_job_allowed_states",
    "refused_exit_code",
    "live_guard_path",
    "source_guard_path"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "root": { "type": "string", "minLength": 3 },
    "soft_floor_gib": { "const": 150 },
    "hard_floor_gib": { "const": 100 },
    "emergency_floor_gib": { "const": 60 },
    "new_work_allowed_states": {
      "type": "array",
      "prefixItems": [{ "const": "healthy" }],
      "minItems": 1,
      "maxItems": 1
    },
    "active_job_allowed_states": {
      "type": "array",
      "prefixItems": [{ "const": "healthy" }, { "const": "soft" }],
      "minItems": 2,
      "maxItems": 2
    },
    "refused_exit_code": { "const": 76 },
    "live_guard_path": { "const": "F:\\DAZ\\00_control\\render_state_ingest\\capacity_guard.py" },
    "source_guard_path": { "const": "integrations/daz/acquisition/capacity_guard.py" }
  }
}

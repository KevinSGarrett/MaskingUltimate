{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_adapted_package_qc_report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "policy_version", "policy_sha256", "adapter_report_id", "adapter_report_sha256", "contract_id", "contract_sha256", "scene_id", "image_id", "scene_family_id", "ontology_version", "ontology_sha256", "package_count", "results", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "report_id": {"type": "string", "pattern": "^daqc_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"}, "policy_version": {"const": "1.0.0"}, "policy_sha256": {"$ref": "#/$defs/sha"},
    "adapter_report_id": {"type": "string", "pattern": "^dsar_[0-9a-f]{24}$"}, "adapter_report_sha256": {"$ref": "#/$defs/sha"}, "contract_id": {"type": "string", "pattern": "^dpdc_[0-9a-f]{24}$"}, "contract_sha256": {"$ref": "#/$defs/sha"},
    "scene_id": {"type": "string"}, "image_id": {"type": "string"}, "scene_family_id": {"type": "string"}, "ontology_version": {"const": "body_parts_v1"}, "ontology_sha256": {"$ref": "#/$defs/sha"}, "package_count": {"type": "integer", "minimum": 1, "maximum": 4},
    "results": {"type": "array", "minItems": 19, "items": {"$ref": "#/$defs/result"}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["passed", "required_count", "required_pass_count", "not_applicable_count", "failed_count", "existing_qc_count", "daz_qc_count", "freeze_eligible"], "properties": {"passed": {"type": "boolean"}, "required_count": {"type": "integer", "minimum": 1}, "required_pass_count": {"type": "integer", "minimum": 0}, "not_applicable_count": {"type": "integer", "minimum": 0}, "failed_count": {"type": "integer", "minimum": 0}, "existing_qc_count": {"type": "integer", "minimum": 1}, "daz_qc_count": {"type": "integer", "minimum": 1}, "freeze_eligible": {"type": "boolean"}}}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "result": {"type": "object", "additionalProperties": false, "required": ["check_id", "check_family", "scope", "p_index", "status", "severity", "reason_code", "detail", "evidence_sha256"], "properties": {"check_id": {"type": "string", "pattern": "^(QC-[0-9]{3}|DAZ-QC-[0-9]{3})$"}, "check_family": {"enum": ["existing_maskfactory", "daz_specific"]}, "scope": {"enum": ["scene", "package"]}, "p_index": {"oneOf": [{"enum": ["p0", "p1", "p2", "p3"]}, {"type": "null"}]}, "status": {"enum": ["pass", "fail", "not_applicable"]}, "severity": {"enum": ["BLOCK", "ROUTE", "WARN", "INFO"]}, "reason_code": {"type": "string", "pattern": "^[A-Z0-9_]+$"}, "detail": {"type": "string"}, "evidence_sha256": {"$ref": "#/$defs/sha"}}}
  }
}

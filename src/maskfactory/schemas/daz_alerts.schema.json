{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_alerts.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "local_only", "severity_order", "rules"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "local_only": {"const": true},
    "severity_order": {
      "const": ["info", "warning", "high", "critical"]
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_id", "metric_path", "operator", "threshold", "severity", "action"],
        "properties": {
          "rule_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]+$"},
          "metric_path": {"type": "string", "pattern": "^(machine|pipeline|corpus)\\.[a-z][a-z0-9_]+$"},
          "operator": {"enum": ["eq", "ne", "gt", "gte", "lt", "lte"]},
          "threshold": {"type": ["string", "number", "integer", "boolean"]},
          "severity": {"enum": ["info", "warning", "high", "critical"]},
          "action": {
            "enum": ["report", "pause_planning_investigate", "drain_affected_work", "stop_ingestion_preserve_evidence"]
          },
          "suppression_group": {"type": "string", "pattern": "^[a-z][a-z0-9_]+$"}
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_asset_identity_snapshot.schema.json",
  "title": "DAZ asset identity and duplicate/shadow snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "snapshot_id",
    "identity_sha256",
    "inventory_snapshot_id",
    "inventory_sha256",
    "summary",
    "files",
    "logical_conflicts",
    "content_duplicate_groups"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "snapshot_id": { "type": "string", "pattern": "^aid_[0-9a-f]{24}$" },
    "identity_sha256": { "$ref": "#/$defs/sha256" },
    "inventory_snapshot_id": { "type": "string", "pattern": "^fs_[0-9a-f]{24}$" },
    "inventory_sha256": { "$ref": "#/$defs/sha256" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file_count",
        "byte_count",
        "unique_logical_assets",
        "duplicate_copies",
        "shadow_conflict_files",
        "logical_conflict_count",
        "content_duplicate_group_count",
        "complete"
      ],
      "properties": {
        "file_count": { "type": "integer", "minimum": 0 },
        "byte_count": { "type": "integer", "minimum": 0 },
        "unique_logical_assets": { "type": "integer", "minimum": 0 },
        "duplicate_copies": { "type": "integer", "minimum": 0 },
        "shadow_conflict_files": { "type": "integer", "minimum": 0 },
        "logical_conflict_count": { "type": "integer", "minimum": 0 },
        "content_duplicate_group_count": { "type": "integer", "minimum": 0 },
        "complete": { "const": true }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "asset_id",
          "root_id",
          "relative_path",
          "canonical_path",
          "logical_uri",
          "sha256",
          "size_bytes",
          "mtime_ns",
          "file_id",
          "root_priority",
          "source_kind",
          "logical_status",
          "precedence_rank",
          "eligible"
        ],
        "properties": {
          "asset_id": { "type": "string", "pattern": "^ast_[0-9a-f]{24}$" },
          "root_id": { "type": "string", "minLength": 1 },
          "relative_path": { "type": "string", "minLength": 1 },
          "canonical_path": { "type": "string", "minLength": 1 },
          "logical_uri": { "type": "string", "pattern": "^/" },
          "sha256": { "$ref": "#/$defs/sha256" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "mtime_ns": { "type": "integer", "minimum": 0 },
          "file_id": { "type": ["string", "null"] },
          "root_priority": { "type": "integer" },
          "source_kind": { "type": "string", "minLength": 1 },
          "logical_status": {
            "enum": ["unique", "duplicate_winner", "duplicate_copy", "shadow_conflict"]
          },
          "precedence_rank": { "type": "integer", "minimum": 1 },
          "eligible": { "type": "boolean" }
        }
      }
    },
    "logical_conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["logical_key", "logical_uri", "resolution", "candidates"],
        "properties": {
          "logical_key": { "type": "string", "minLength": 1 },
          "logical_uri": { "type": "string", "pattern": "^/" },
          "resolution": { "const": "explicit_technical_resolution_required" },
          "candidates": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["root_id", "sha256", "size_bytes"],
              "properties": {
                "root_id": { "type": "string", "minLength": 1 },
                "sha256": { "$ref": "#/$defs/sha256" },
                "size_bytes": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    },
    "content_duplicate_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["group_id", "sha256", "asset_ids"],
        "properties": {
          "group_id": { "type": "string", "pattern": "^dup_[0-9a-f]{24}$" },
          "sha256": { "$ref": "#/$defs/sha256" },
          "asset_ids": {
            "type": "array",
            "minItems": 2,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^ast_[0-9a-f]{24}$" }
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}

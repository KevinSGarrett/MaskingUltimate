{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_asset_quarantine.schema.json",
  "title": "DAZ asset smoke quarantine record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "quarantine_id", "quarantine_sha256", "asset_id", "asset_sha256", "dependency_snapshot_sha256", "runtime_snapshot_sha256", "script_bundle_sha256", "mapping_bundle_id", "mapping_bundle_sha256", "plan_id", "result_id", "fixture_ids", "quarantine_codes", "log_excerpt_sha256", "output_evidence_sha256", "first_occurrence", "last_occurrence", "retry_count", "recommended_actions", "state"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "quarantine_id": {"type": "string", "pattern": "^daz_quarantine_[0-9a-f]{24}$"},
    "quarantine_sha256": {"$ref": "#/$defs/sha256"},
    "asset_id": {"$ref": "#/$defs/asset_id"},
    "asset_sha256": {"$ref": "#/$defs/sha256"},
    "dependency_snapshot_sha256": {"$ref": "#/$defs/sha256"},
    "runtime_snapshot_sha256": {"$ref": "#/$defs/sha256"},
    "script_bundle_sha256": {"$ref": "#/$defs/sha256"},
    "mapping_bundle_id": {"type": ["string", "null"]},
    "mapping_bundle_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "plan_id": {"type": "string", "pattern": "^dsmk_[0-9a-f]{24}$"},
    "result_id": {"type": "string", "pattern": "^dsmr_[0-9a-f]{24}$"},
    "fixture_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "quarantine_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^Q-ASSET-0(0[1-9]|1[0-9]|2[0-2])$"}},
    "log_excerpt_sha256": {"$ref": "#/$defs/sha256"},
    "output_evidence_sha256": {"$ref": "#/$defs/sha256"},
    "first_occurrence": {"type": "string", "format": "date-time"},
    "last_occurrence": {"type": "string", "format": "date-time"},
    "retry_count": {"type": "integer", "minimum": 0},
    "recommended_actions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "state": {"const": "quarantined"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "asset_id": {"type": "string", "pattern": "^ast_[0-9a-f]{24}$"}
  }
}

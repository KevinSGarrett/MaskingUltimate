{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_asset_smoke_certificate.schema.json",
  "title": "DAZ asset smoke qualification certificate",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "certificate_id", "certificate_sha256", "asset_id", "asset_sha256", "dependency_snapshot_sha256", "runtime_snapshot_sha256", "script_bundle_sha256", "mapping_bundle_id", "mapping_bundle_sha256", "plan_id", "plan_sha256", "result_id", "evaluation_sha256", "fixture_ids", "checks", "eligible_generations", "eligible_scene_categories", "limitations", "created_at", "expires_on_change"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "certificate_id": {"type": "string", "pattern": "^daz_smoke_[0-9a-f]{24}$"},
    "certificate_sha256": {"$ref": "#/$defs/sha256"},
    "asset_id": {"$ref": "#/$defs/asset_id"},
    "asset_sha256": {"$ref": "#/$defs/sha256"},
    "dependency_snapshot_sha256": {"$ref": "#/$defs/sha256"},
    "runtime_snapshot_sha256": {"$ref": "#/$defs/sha256"},
    "script_bundle_sha256": {"$ref": "#/$defs/sha256"},
    "mapping_bundle_id": {"type": ["string", "null"]},
    "mapping_bundle_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "plan_id": {"type": "string", "pattern": "^dsmk_[0-9a-f]{24}$"},
    "plan_sha256": {"$ref": "#/$defs/sha256"},
    "result_id": {"type": "string", "pattern": "^dsmr_[0-9a-f]{24}$"},
    "evaluation_sha256": {"$ref": "#/$defs/sha256"},
    "fixture_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "checks": {"type": "object", "minProperties": 1, "additionalProperties": {"const": "pass"}},
    "eligible_generations": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "eligible_scene_categories": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "limitations": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "created_at": {"type": "string", "format": "date-time"},
    "expires_on_change": {"const": true}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "asset_id": {"type": "string", "pattern": "^ast_[0-9a-f]{24}$"}
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_asset_smoke_plan.schema.json",
  "title": "DAZ type-specific asset smoke plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "plan_id", "plan_sha256", "created_at", "bundle_version", "content_directories", "graph_id", "dependency_snapshot_sha256", "asset_id", "asset_sha256", "profile_id", "fixture_ids", "required_checks", "required_artifact_roles", "runtime_snapshot_sha256", "script_bundle_sha256", "mapping_bundle_id", "mapping_bundle_sha256", "repetitions", "recipes"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "plan_id": {"type": "string", "pattern": "^dsmk_[0-9a-f]{24}$"},
    "plan_sha256": {"$ref": "#/$defs/sha256"},
    "created_at": {"type": "string", "format": "date-time"},
    "bundle_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "content_directories": {"type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true, "items": {"type": "string", "minLength": 3}},
    "graph_id": {"type": "string", "pattern": "^acg_[0-9a-f]{24}$"},
    "dependency_snapshot_sha256": {"$ref": "#/$defs/sha256"},
    "asset_id": {"$ref": "#/$defs/asset_id"},
    "asset_sha256": {"$ref": "#/$defs/sha256"},
    "profile_id": {"type": "string", "minLength": 1},
    "fixture_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "required_checks": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "required_artifact_roles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["beauty_preview", "silhouette", "instance_id", "mapping_pass"]}},
    "runtime_snapshot_sha256": {"$ref": "#/$defs/sha256"},
    "script_bundle_sha256": {"$ref": "#/$defs/sha256"},
    "mapping_bundle_id": {"type": ["string", "null"]},
    "mapping_bundle_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "repetitions": {"const": 2},
    "recipes": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"type": "object"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "asset_id": {"type": "string", "pattern": "^ast_[0-9a-f]{24}$"}
  }
}

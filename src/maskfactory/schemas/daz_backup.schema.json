{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_backup.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tier", "include_roots", "required_restore_categories", "conditional_restore_categories", "reject_symlinks", "verify_hashes", "require_empty_restore_root"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "tier": {"const": "A"},
    "include_roots": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[0-9]{2}_[A-Za-z0-9_./-]+$"}
    },
    "required_restore_categories": {
      "type": "object",
      "additionalProperties": false,
      "required": ["control", "registry", "mapping", "queue"],
      "properties": {
        "control": {"$ref": "#/$defs/prefixes"},
        "registry": {"$ref": "#/$defs/prefixes"},
        "mapping": {"$ref": "#/$defs/prefixes"},
        "queue": {"$ref": "#/$defs/prefixes"}
      }
    },
    "conditional_restore_categories": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recipe", "package_metadata", "dataset_model_lineage"],
      "properties": {
        "recipe": {"$ref": "#/$defs/prefixes"},
        "package_metadata": {"$ref": "#/$defs/prefixes"},
        "dataset_model_lineage": {"$ref": "#/$defs/prefixes"}
      }
    },
    "reject_symlinks": {"const": true},
    "verify_hashes": {"const": true},
    "require_empty_restore_root": {"const": true}
  },
  "$defs": {
    "prefixes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[0-9]{2}_[A-Za-z0-9_./-]+$"}
    }
  }
}

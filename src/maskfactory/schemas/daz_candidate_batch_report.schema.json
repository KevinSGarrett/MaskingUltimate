{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_candidate_batch_report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "batch_id", "batch_sha256", "generator_version", "policy_sha256", "vocabulary", "demand", "registry_snapshot", "master_seed", "requested_candidate_count", "candidates", "distribution", "summary", "authority", "publication"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "batch_id": {"type": "string", "pattern": "^dcb_[0-9a-f]{24}$"},
    "batch_sha256": {"$ref": "#/$defs/sha"},
    "generator_version": {"const": "1.0.0"},
    "policy_sha256": {"const": "8cef5db1e8f43d8ba1ceea47b0898c80494c030e8409d703a3dcaea7c42f308d"},
    "vocabulary": {
      "type": "object", "additionalProperties": false,
      "required": ["report_id", "report_sha256", "vocabulary_version"],
      "properties": {
        "report_id": {"type": "string", "pattern": "^dcvr_[0-9a-f]{24}$"},
        "report_sha256": {"$ref": "#/$defs/sha"},
        "vocabulary_version": {"const": "1.0.0"}
      }
    },
    "demand": {
      "type": "object", "additionalProperties": false,
      "required": ["demand_id", "demand_report_id", "demand_report_sha256", "actionability", "locked_axes"],
      "properties": {
        "demand_id": {"type": "string", "pattern": "^drd_[0-9a-f]{24}$"},
        "demand_report_id": {"type": "string", "pattern": "^drds_[0-9a-f]{24}$"},
        "demand_report_sha256": {"$ref": "#/$defs/sha"},
        "actionability": {"const": "eligible"},
        "locked_axes": {"type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": {"$ref": "#/$defs/assignment"}}
      }
    },
    "registry_snapshot": {
      "type": "object", "additionalProperties": false,
      "required": ["snapshot_id", "snapshot_sha256", "provided_axis_count", "required_axis_count", "complete"],
      "properties": {
        "snapshot_id": {"type": ["string", "null"], "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"},
        "snapshot_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "provided_axis_count": {"type": "integer", "minimum": 0},
        "required_axis_count": {"type": "integer", "minimum": 1},
        "complete": {"type": "boolean"}
      }
    },
    "master_seed": {"type": "integer", "minimum": 0, "maximum": 2147483647},
    "requested_candidate_count": {"type": "integer", "minimum": 10, "maximum": 100},
    "candidates": {"type": "array", "minItems": 10, "maxItems": 100, "items": {"$ref": "#/$defs/candidate"}},
    "distribution": {
      "type": "object", "additionalProperties": false,
      "required": ["discrete_method", "continuous_method", "registry_method", "maximum_unlocked_axis_count_spread", "selected_pair_count", "covered_selected_pair_count", "selected_pair_coverage_ratio", "continuous_axis_count", "continuous_points_in_bounds"],
      "properties": {
        "discrete_method": {"const": "deterministic_greedy_stratified_pairwise"},
        "continuous_method": {"const": "seeded_halton"},
        "registry_method": {"const": "deterministic_weighted_reservoir_without_replacement_under_caps"},
        "maximum_unlocked_axis_count_spread": {"type": "integer", "minimum": 0, "maximum": 1},
        "selected_pair_count": {"type": "integer", "minimum": 0},
        "covered_selected_pair_count": {"type": "integer", "minimum": 0},
        "selected_pair_coverage_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "continuous_axis_count": {"const": 6},
        "continuous_points_in_bounds": {"const": true}
      }
    },
    "summary": {
      "type": "object", "additionalProperties": false,
      "required": ["candidate_count", "registry_complete_candidate_count", "rejected_candidate_count", "rejection_reason_counts", "scored_candidate_count", "selected_candidate_count"],
      "properties": {
        "candidate_count": {"type": "integer", "minimum": 10, "maximum": 100},
        "registry_complete_candidate_count": {"type": "integer", "minimum": 0},
        "rejected_candidate_count": {"type": "integer", "minimum": 0},
        "rejection_reason_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 1}},
        "scored_candidate_count": {"const": 0},
        "selected_candidate_count": {"const": 0}
      }
    },
    "authority": {
      "type": "object", "additionalProperties": false,
      "required": ["stage", "candidates_are_recipes", "candidates_are_feasible_scenes", "candidates_create_gold", "synthetic_counts_close_real_deficits"],
      "properties": {
        "stage": {"const": "unscored_unselected_candidate"},
        "candidates_are_recipes": {"const": false},
        "candidates_are_feasible_scenes": {"const": false},
        "candidates_create_gold": {"const": false},
        "synthetic_counts_close_real_deficits": {"const": false}
      }
    },
    "publication": {"type": "object", "additionalProperties": false, "required": ["immutable", "atomic"], "properties": {"immutable": {"const": true}, "atomic": {"const": true}}}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "assignment": {"type": "object", "additionalProperties": false, "required": ["axis_id", "value"], "properties": {"axis_id": {"type": "string", "minLength": 1}, "value": {"type": ["string", "integer"]}}},
    "continuous": {"type": "object", "additionalProperties": false, "required": ["axis_id", "value"], "properties": {"axis_id": {"type": "string", "minLength": 1}, "value": {"type": "number"}}},
    "rejection": {"type": "object", "additionalProperties": false, "required": ["reason", "axis_id"], "properties": {"reason": {"enum": ["registry_pool_missing", "registry_pool_exhausted", "locked_axis_invalid"]}, "axis_id": {"type": "string", "minLength": 1}}},
    "candidate": {
      "type": "object", "additionalProperties": false,
      "required": ["candidate_id", "candidate_index", "discrete", "continuous", "registry", "rejections", "registry_complete", "scored", "selected"],
      "properties": {
        "candidate_id": {"type": "string", "pattern": "^dc_[0-9a-f]{24}$"},
        "candidate_index": {"type": "integer", "minimum": 0, "maximum": 99},
        "discrete": {"type": "array", "minItems": 56, "maxItems": 56, "items": {"$ref": "#/$defs/assignment"}},
        "continuous": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"$ref": "#/$defs/continuous"}},
        "registry": {"type": "array", "maxItems": 8, "items": {"$ref": "#/$defs/assignment"}},
        "rejections": {"type": "array", "maxItems": 8, "items": {"$ref": "#/$defs/rejection"}},
        "registry_complete": {"type": "boolean"},
        "scored": {"const": false},
        "selected": {"const": false}
      }
    }
  }
}

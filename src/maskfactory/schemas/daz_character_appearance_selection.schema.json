{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_character_appearance_selection.schema.json",
  "title": "Qualified DAZ skin/hair/wardrobe/anatomy composition selection",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "selection_id", "selection_sha256", "graph_id", "graph_sha256", "pool_report_id", "pool_report_sha256", "foundation_selection_id", "foundation_selection_sha256", "request", "candidate_counts", "rejection_counts", "selected", "compatibility_evidence"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "selection_id": {"type": "string", "pattern": "^dcas_[0-9a-f]{24}$"},
    "selection_sha256": {"$ref": "#/$defs/sha256"},
    "graph_id": {"type": "string", "pattern": "^acg_[0-9a-f]{24}$"},
    "graph_sha256": {"$ref": "#/$defs/sha256"},
    "pool_report_id": {"type": "string", "pattern": "^apr_[0-9a-f]{24}$"},
    "pool_report_sha256": {"$ref": "#/$defs/sha256"},
    "foundation_selection_id": {"type": "string", "pattern": "^dcfs_[0-9a-f]{24}$"},
    "foundation_selection_sha256": {"$ref": "#/$defs/sha256"},
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selection_seed", "anatomy_configuration", "hair_mode", "wardrobe_state"],
      "properties": {
        "selection_seed": {"type": "integer", "minimum": 0, "maximum": 18446744073709551615},
        "anatomy_configuration": {"enum": ["adult_male_anatomy", "adult_female_anatomy"]},
        "hair_mode": {"enum": ["none", "required"]},
        "wardrobe_state": {"type": "string", "minLength": 1}
      }
    },
    "candidate_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anatomy_assets", "hair_assets", "wardrobe_assets", "wardrobe_combinations", "appearance_combinations"],
      "properties": {
        "anatomy_assets": {"type": "integer", "minimum": 1},
        "hair_assets": {"type": "integer", "minimum": 0},
        "wardrobe_assets": {"type": "integer", "minimum": 0},
        "wardrobe_combinations": {"type": "integer", "minimum": 1},
        "appearance_combinations": {"type": "integer", "minimum": 1}
      }
    },
    "rejection_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "selected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skin_material_asset_id", "anatomy_asset_id", "hair_asset_id", "wardrobe_state", "wardrobe_items_inner_to_outer"],
      "properties": {
        "skin_material_asset_id": {"$ref": "#/$defs/asset_id"},
        "anatomy_asset_id": {"$ref": "#/$defs/asset_id"},
        "hair_asset_id": {"oneOf": [{"$ref": "#/$defs/asset_id"}, {"type": "null"}]},
        "wardrobe_state": {"type": "string", "minLength": 1},
        "wardrobe_items_inner_to_outer": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["asset_id", "primary_asset_class", "wardrobe_region", "wardrobe_layer", "fit_profile", "opacity_class", "dynamic_behavior"],
            "properties": {
              "asset_id": {"$ref": "#/$defs/asset_id"},
              "primary_asset_class": {"type": "string"},
              "wardrobe_region": {"type": "string"},
              "wardrobe_layer": {"type": "string"},
              "fit_profile": {"type": "string"},
              "opacity_class": {"type": "string"},
              "dynamic_behavior": {"type": "string"}
            }
          }
        }
      }
    },
    "compatibility_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_assets_runtime_qualified", "all_required_dependencies_runtime_qualified", "base_compatibility_passed", "anatomy_mapping_required", "wardrobe_mapping_required", "inner_to_outer_order_defined", "dynamic_behavior_deterministic", "scene_category_match"],
      "properties": {
        "all_assets_runtime_qualified": {"const": true},
        "all_required_dependencies_runtime_qualified": {"const": true},
        "base_compatibility_passed": {"const": true},
        "anatomy_mapping_required": {"const": true},
        "wardrobe_mapping_required": {"const": true},
        "inner_to_outer_order_defined": {"const": true},
        "dynamic_behavior_deterministic": {"const": true},
        "scene_category_match": {"const": true}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "asset_id": {"type": "string", "pattern": "^ast_[0-9a-f]{24}$"}
  }
}

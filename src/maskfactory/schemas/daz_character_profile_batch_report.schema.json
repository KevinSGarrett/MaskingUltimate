{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_character_profile_batch_report.schema.json",
  "title": "DAZ character variation bounded batch report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "policy_version", "policy_sha256", "seed_start", "samples_per_stratum", "profile_count", "anatomy_configurations", "age_categories", "tier_target_shares", "body_tier_shares", "face_tier_shares", "tier_max_abs_deviation", "distribution_passed", "correlations", "declared_correlation_floor", "correlations_passed", "bounds_passed", "constraints_passed", "adjusted_profile_count", "profile_set_sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "report_id": {"type": "string", "pattern": "^dcpr_[0-9a-f]{24}$"},
    "report_sha256": {"$ref": "#/$defs/sha256"},
    "policy_version": {"const": "1.0.0"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "seed_start": {"type": "integer", "minimum": 0, "maximum": 18446744073709551615},
    "samples_per_stratum": {"type": "integer", "minimum": 50},
    "profile_count": {"type": "integer", "minimum": 400},
    "anatomy_configurations": {"const": ["adult_male_anatomy", "adult_female_anatomy"]},
    "age_categories": {"const": ["adult_21_29", "adult_30_44", "adult_45_64", "adult_65_plus"]},
    "tier_target_shares": {"$ref": "#/$defs/tier_shares"},
    "body_tier_shares": {"$ref": "#/$defs/tier_shares"},
    "face_tier_shares": {"$ref": "#/$defs/tier_shares"},
    "tier_max_abs_deviation": {"type": "number", "minimum": 0, "maximum": 0.03},
    "distribution_passed": {"const": true},
    "correlations": {"type": "object", "minProperties": 6, "additionalProperties": {"type": "number", "minimum": -1, "maximum": 1}},
    "declared_correlation_floor": {"const": 0.25},
    "correlations_passed": {"const": true},
    "bounds_passed": {"const": true},
    "constraints_passed": {"const": true},
    "adjusted_profile_count": {"type": "integer", "minimum": 0},
    "profile_set_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "tier_shares": {
      "type": "object",
      "additionalProperties": false,
      "required": ["central", "moderate", "validated_extreme"],
      "properties": {
        "central": {"type": "number", "minimum": 0, "maximum": 1},
        "moderate": {"type": "number", "minimum": 0, "maximum": 1},
        "validated_extreme": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}

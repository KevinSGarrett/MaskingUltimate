{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_character_variation_profile.schema.json",
  "title": "Deterministic correlated adult DAZ body/face/age profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_id", "profile_sha256", "policy_version", "policy_sha256", "seed", "anatomy_configuration", "age_appearance_category", "latent_factors", "body", "face", "age", "constraints"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "profile_id": {"type": "string", "pattern": "^dcvp_[0-9a-f]{24}$"},
    "profile_sha256": {"$ref": "#/$defs/sha256"},
    "policy_version": {"const": "1.0.0"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "seed": {"type": "integer", "minimum": 0, "maximum": 18446744073709551615},
    "anatomy_configuration": {"enum": ["adult_male_anatomy", "adult_female_anatomy"]},
    "age_appearance_category": {"enum": ["adult_21_29", "adult_30_44", "adult_45_64", "adult_65_plus"]},
    "latent_factors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["body", "face", "age_shared"],
      "properties": {
        "body": {"type": "object", "additionalProperties": {"type": "number"}},
        "face": {"type": "object", "additionalProperties": {"type": "number"}},
        "age_shared": {"type": "number"}
      }
    },
    "body": {"$ref": "#/$defs/axis_profile"},
    "face": {"$ref": "#/$defs/axis_profile"},
    "age": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_id", "property_values", "skin_detail_tags", "hair_density_tags", "hair_color_tags", "posture_tags", "asset_property_mapping_required", "final_readback_required"],
      "properties": {
        "profile_id": {"type": "string", "pattern": "^age_[0-9a-f]{24}$"},
        "property_values": {"type": "object", "minProperties": 5, "maxProperties": 5, "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}},
        "skin_detail_tags": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "hair_density_tags": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "hair_color_tags": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "posture_tags": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "asset_property_mapping_required": {"const": true},
        "final_readback_required": {"const": true}
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_passed", "adjustments"],
      "properties": {
        "all_passed": {"const": true},
        "adjustments": {"type": "array", "items": {"type": "string"}}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "axis_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["values", "sampling_tiers", "strata"],
      "properties": {
        "values": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "number", "minimum": -1, "maximum": 1}},
        "sampling_tiers": {"type": "object", "minProperties": 1, "additionalProperties": {"enum": ["central", "moderate", "validated_extreme"]}},
        "strata": {"type": "object", "additionalProperties": {"type": "string"}}
      }
    }
  }
}

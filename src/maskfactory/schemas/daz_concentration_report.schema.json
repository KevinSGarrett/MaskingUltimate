{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_concentration_report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "policy_version", "policy_sha256", "selection", "candidate_batch", "history_snapshot", "rows", "admitted_candidate_id", "satisfied", "summary", "authority", "publication"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "report_id": {"type": "string", "pattern": "^dcon_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"},
    "policy_version": {"const": "1.0.0"}, "policy_sha256": {"$ref": "#/$defs/sha"},
    "selection": {"type": "object", "additionalProperties": false, "required": ["selection_id", "selection_sha256"], "properties": {"selection_id": {"type": "string", "pattern": "^dcsr_[0-9a-f]{24}$"}, "selection_sha256": {"$ref": "#/$defs/sha"}}},
    "candidate_batch": {"type": "object", "additionalProperties": false, "required": ["batch_id", "batch_sha256"], "properties": {"batch_id": {"type": "string", "pattern": "^dcb_[0-9a-f]{24}$"}, "batch_sha256": {"$ref": "#/$defs/sha"}}},
    "history_snapshot": {"type": "object", "additionalProperties": false, "required": ["snapshot_id", "snapshot_sha256", "accepted_record_count", "base_product_ids"], "properties": {"snapshot_id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"}, "snapshot_sha256": {"$ref": "#/$defs/sha"}, "accepted_record_count": {"type": "integer", "minimum": 0}, "base_product_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^daz_product_[A-Za-z0-9_-]+$"}}}},
    "rows": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/row"}},
    "admitted_candidate_id": {"type": ["string", "null"], "pattern": "^dc_[0-9a-f]{24}$"}, "satisfied": {"type": "boolean"},
    "summary": {"type": "object", "additionalProperties": false, "required": ["feasible_candidate_count", "evaluated_count", "passing_count", "limited_count", "admitted_count", "limit_reason_counts", "maximum_projected_share_by_entity_type", "near_duplicate_rate_after_admission"], "properties": {"feasible_candidate_count": {"type": "integer", "minimum": 0}, "evaluated_count": {"type": "integer", "minimum": 0}, "passing_count": {"type": "integer", "minimum": 0}, "limited_count": {"type": "integer", "minimum": 0}, "admitted_count": {"type": "integer", "minimum": 0, "maximum": 1}, "limit_reason_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 1}}, "maximum_projected_share_by_entity_type": {"type": "object", "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}}, "near_duplicate_rate_after_admission": {"type": ["number", "null"], "minimum": 0, "maximum": 1}}},
    "authority": {"type": "object", "additionalProperties": false, "required": ["stage", "admission_is_recipe", "admission_is_render_authority", "admission_creates_gold"], "properties": {"stage": {"const": "technical_concentration_gate"}, "admission_is_recipe": {"const": false}, "admission_is_render_authority": {"const": false}, "admission_creates_gold": {"const": false}}},
    "publication": {"type": "object", "additionalProperties": false, "required": ["immutable", "atomic"], "properties": {"immutable": {"const": true}, "atomic": {"const": true}}}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "contribution": {"type": "object", "additionalProperties": false, "required": ["entity_type", "entity_id", "historical_count", "projected_count", "projected_total", "projected_share", "maximum_share", "allowed_count", "base_product_exempt", "passes"], "properties": {"entity_type": {"enum": ["character_preset_id", "skin_material_asset_id", "hair_asset_id", "complete_outfit_signature", "garment_asset_id", "pose_asset_id", "environment_asset_id", "asset_product_family"]}, "entity_id": {"type": "string", "minLength": 1}, "historical_count": {"type": "integer", "minimum": 0}, "projected_count": {"type": "integer", "minimum": 1}, "projected_total": {"type": "integer", "minimum": 1}, "projected_share": {"type": "number", "minimum": 0, "maximum": 1}, "maximum_share": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}, "allowed_count": {"type": "integer", "minimum": 1}, "base_product_exempt": {"type": "boolean"}, "passes": {"type": "boolean"}}},
    "row": {"type": "object", "additionalProperties": false, "required": ["candidate_id", "original_rank", "scene_family_id", "contributions", "cooldown_failures", "dominance_failures", "exact_repeat", "near_duplicate_count", "near_duplicate_limit", "passes", "admitted"], "properties": {"candidate_id": {"type": "string", "pattern": "^dc_[0-9a-f]{24}$"}, "original_rank": {"type": "integer", "minimum": 1, "maximum": 100}, "scene_family_id": {"type": "string", "pattern": "^dfam_[0-9a-f]{24}$"}, "contributions": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"$ref": "#/$defs/contribution"}}, "cooldown_failures": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "dominance_failures": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "exact_repeat": {"type": "boolean"}, "near_duplicate_count": {"type": "integer", "minimum": 0}, "near_duplicate_limit": {"const": 1}, "passes": {"type": "boolean"}, "admitted": {"type": "boolean"}}}
  }
}

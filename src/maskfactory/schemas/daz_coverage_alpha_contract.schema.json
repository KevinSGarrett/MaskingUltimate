{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_coverage_alpha_contract.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_id", "contract_sha256", "scene_id", "scene_state_sha256", "plan_id", "plan_sha256", "material_contract_id", "material_contract_sha256", "ontology_snapshot_sha256", "mapping_sha256", "policy_sha256", "policy_version", "profile", "boundary", "hair_part_id", "hair_material_id", "hair_certificates", "expected_hair_material_present", "expected_mixed_coverage", "output"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "contract_id": {"type": "string", "pattern": "^dcac_[0-9a-f]{24}$"},
    "contract_sha256": {"$ref": "#/$defs/sha"},
    "scene_id": {"type": "string"},
    "scene_state_sha256": {"$ref": "#/$defs/sha"},
    "plan_id": {"type": "string"},
    "plan_sha256": {"$ref": "#/$defs/sha"},
    "material_contract_id": {"type": "string", "pattern": "^dmpc_[0-9a-f]{24}$"},
    "material_contract_sha256": {"$ref": "#/$defs/sha"},
    "ontology_snapshot_sha256": {"$ref": "#/$defs/sha"},
    "mapping_sha256": {"$ref": "#/$defs/sha"},
    "policy_sha256": {"$ref": "#/$defs/sha"},
    "policy_version": {"const": "1.0.0"},
    "profile": {"enum": ["training_standard", "training_relationship", "diagnostic_full"]},
    "boundary": {"$ref": "#/$defs/boundary"},
    "hair_part_id": {"const": 1},
    "hair_material_id": {"const": 2},
    "hair_certificates": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/certificate"}},
    "expected_hair_material_present": {"type": "boolean"},
    "expected_mixed_coverage": {"type": "boolean"},
    "output": {"$ref": "#/$defs/output"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "boundary": {"type": "object", "additionalProperties": false, "required": ["sample_grid", "sample_count", "visibility_threshold", "minimum_nonzero_code", "binary_ownership_threshold", "hard_owner_minimum_code", "ownership_rule", "tie_break", "transparent_surface_handling", "downsample_filter", "edge_uncertainty_radius_pixels"], "properties": {"sample_grid": {"const": "4x4"}, "sample_count": {"const": 16}, "visibility_threshold": {"const": 0.00392156862745098}, "minimum_nonzero_code": {"const": 257}, "binary_ownership_threshold": {"const": 0.5}, "hard_owner_minimum_code": {"const": 32768}, "ownership_rule": {"const": "maximum_visible_coverage"}, "tie_break": {"const": ["frontmost_depth", "stable_node_id"]}, "transparent_surface_handling": {"const": "evaluated_opacity"}, "downsample_filter": {"const": "box_linear"}, "edge_uncertainty_radius_pixels": {"const": 1}}},
    "certificate": {"type": "object", "additionalProperties": false, "required": ["schema_version", "certificate_id", "certificate_sha256", "asset_id", "asset_sha256", "mapping_sha256", "construction", "renderer_id", "renderer_version", "pass_route", "visibility_threshold", "binary_ownership_threshold", "evaluated_opacity_required", "shadow_ownership_forbidden", "approved"], "properties": {"schema_version": {"const": "1.0.0"}, "certificate_id": {"type": "string", "pattern": "^dhac_[0-9a-f]{24}$"}, "certificate_sha256": {"$ref": "#/$defs/sha"}, "asset_id": {"type": "string", "minLength": 1}, "asset_sha256": {"$ref": "#/$defs/sha"}, "mapping_sha256": {"$ref": "#/$defs/sha"}, "construction": {"enum": ["polygonal", "transmapped_cards", "strand_based", "fibermesh", "mixed"]}, "renderer_id": {"type": "string", "minLength": 1}, "renderer_version": {"type": "string", "minLength": 1}, "pass_route": {"enum": ["ordinary_depth_visibility", "evaluated_opacity", "renderer_coverage_or_exact_opacity", "evaluated_opacity_and_depth"]}, "visibility_threshold": {"const": 0.00392156862745098}, "binary_ownership_threshold": {"const": 0.5}, "evaluated_opacity_required": {"type": "boolean"}, "shadow_ownership_forbidden": {"const": true}, "approved": {"const": true}}},
    "output": {"type": "object", "additionalProperties": false, "required": ["role", "encoding", "resolution", "crop", "color_space", "background_value", "downsample_filter"], "properties": {"role": {"const": "coverage_alpha"}, "encoding": {"const": "uint16_linear_png"}, "resolution": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}}, "crop": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "integer", "minimum": 0}}, "color_space": {"const": "linear"}, "background_value": {"const": 0}, "downsample_filter": {"const": "box_linear"}}}
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_coverage_alpha_report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "scene_id", "contract_id", "contract_sha256", "plan_id", "plan_sha256", "scene_state_sha256", "ontology_snapshot_sha256", "mapping_sha256", "execution_sha256", "file_hashes", "alpha_codec", "material_codec", "part_codec", "instance_codec", "metrics", "findings", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "report_id": {"type": "string", "pattern": "^dcar_[0-9a-f]{24}$"},
    "report_sha256": {"$ref": "#/$defs/sha"},
    "scene_id": {"type": "string"},
    "contract_id": {"type": "string"},
    "contract_sha256": {"$ref": "#/$defs/sha"},
    "plan_id": {"type": "string"},
    "plan_sha256": {"$ref": "#/$defs/sha"},
    "scene_state_sha256": {"$ref": "#/$defs/sha"},
    "ontology_snapshot_sha256": {"$ref": "#/$defs/sha"},
    "mapping_sha256": {"$ref": "#/$defs/sha"},
    "execution_sha256": {"$ref": "#/$defs/sha"},
    "file_hashes": {"type": "object", "additionalProperties": false, "required": ["coverage_alpha", "material", "part", "instance"], "properties": {"coverage_alpha": {"$ref": "#/$defs/sha"}, "material": {"$ref": "#/$defs/sha"}, "part": {"$ref": "#/$defs/sha"}, "instance": {"$ref": "#/$defs/sha"}}},
    "alpha_codec": {"$ref": "#/$defs/codec"},
    "material_codec": {"$ref": "#/$defs/codec"},
    "part_codec": {"$ref": "#/$defs/codec"},
    "instance_codec": {"$ref": "#/$defs/codec"},
    "metrics": {"type": "object", "additionalProperties": false, "required": ["subvisibility_nonzero_pixels", "hard_owner_below_threshold_pixels", "missing_hard_owner_pixels", "hair_part_material_mismatch_pixels", "hair_below_threshold_pixels", "hair_hard_pixels", "mixed_coverage_pixels", "subthreshold_support_pixels", "opaque_pixels"], "properties": {"subvisibility_nonzero_pixels": {"type": "integer", "minimum": -1}, "hard_owner_below_threshold_pixels": {"type": "integer", "minimum": -1}, "missing_hard_owner_pixels": {"type": "integer", "minimum": -1}, "hair_part_material_mismatch_pixels": {"type": "integer", "minimum": -1}, "hair_below_threshold_pixels": {"type": "integer", "minimum": -1}, "hair_hard_pixels": {"type": "integer", "minimum": -1}, "mixed_coverage_pixels": {"type": "integer", "minimum": -1}, "subthreshold_support_pixels": {"type": "integer", "minimum": -1}, "opaque_pixels": {"type": "integer", "minimum": -1}}},
    "findings": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["code", "path", "detail"], "properties": {"code": {"type": "string", "pattern": "^ALPHA_[A-Z0-9_]+$"}, "path": {"type": "string", "pattern": "^/"}, "detail": {"type": "string"}}}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["passed", "finding_count", "failure_codes", "scene_state_unchanged", "thresholds_exact", "hair_certificate_count"], "properties": {"passed": {"type": "boolean"}, "finding_count": {"type": "integer", "minimum": 0}, "failure_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "scene_state_unchanged": {"type": "boolean"}, "thresholds_exact": {"type": "boolean"}, "hair_certificate_count": {"type": "integer", "minimum": 0}}}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "codec": {"type": "object", "additionalProperties": false, "required": ["format", "source_mode", "dtype", "resolution", "minimum", "maximum", "metadata_keys"], "properties": {"format": {"const": "PNG"}, "source_mode": {"type": "string"}, "dtype": {"const": "uint16"}, "resolution": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}}, "minimum": {"type": "integer", "minimum": 0, "maximum": 65535}, "maximum": {"type": "integer", "minimum": 0, "maximum": 65535}, "metadata_keys": {"type": "array", "items": {"type": "string"}}}}
  }
}

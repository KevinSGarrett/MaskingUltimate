{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_coverage_vocabulary_report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "vocabulary_version", "policy_sha256", "scope", "source_snapshots", "axes", "registry_axes", "continuous_axes", "high_risk_intersections", "reporting", "authority", "publication", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "report_id": {"type": "string", "pattern": "^dcvr_[0-9a-f]{24}$"},
    "report_sha256": {"$ref": "#/$defs/sha"},
    "vocabulary_version": {"const": "1.0.0"},
    "policy_sha256": {"$ref": "#/$defs/sha"},
    "scope": {"const": "daz_coverage_planning_and_reporting"},
    "source_snapshots": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"$ref": "#/$defs/source"}},
    "axes": {"type": "array", "minItems": 55, "maxItems": 55, "items": {"$ref": "#/$defs/axis"}},
    "registry_axes": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"$ref": "#/$defs/registryAxis"}},
    "continuous_axes": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"$ref": "#/$defs/continuousAxis"}},
    "high_risk_intersections": {"type": "array", "minItems": 18, "maxItems": 18, "items": {"$ref": "#/$defs/intersection"}},
    "reporting": {
      "type": "object", "additionalProperties": false,
      "required": ["states", "units", "separate_marginal_pairwise_and_selected_three_way", "accepted_only_updates_accepted_coverage", "scene_count_is_not_person_instance_count", "effective_weight_is_not_instance_count"],
      "properties": {
        "states": {"const": ["planned", "attempted", "rendered", "accepted", "packaged", "dataset_selected", "consumed_by_training"]},
        "units": {"const": ["scene", "person_instance", "effective_training_weight"]},
        "separate_marginal_pairwise_and_selected_three_way": {"const": true},
        "accepted_only_updates_accepted_coverage": {"const": true},
        "scene_count_is_not_person_instance_count": {"const": true},
        "effective_weight_is_not_instance_count": {"const": true}
      }
    },
    "authority": {
      "type": "object", "additionalProperties": false,
      "required": ["synthetic_counts_as_gold", "synthetic_counts_as_real_accuracy", "synthetic_diagnostic_is_promotion_authority", "registry_values_require_versioned_snapshot", "unknown_values_fail_closed"],
      "properties": {
        "synthetic_counts_as_gold": {"const": false},
        "synthetic_counts_as_real_accuracy": {"const": false},
        "synthetic_diagnostic_is_promotion_authority": {"const": false},
        "registry_values_require_versioned_snapshot": {"const": true},
        "unknown_values_fail_closed": {"const": true}
      }
    },
    "publication": {
      "type": "object", "additionalProperties": false,
      "required": ["immutable", "atomic"],
      "properties": {"immutable": {"const": true}, "atomic": {"const": true}}
    },
    "summary": {
      "type": "object", "additionalProperties": false,
      "required": ["closed", "source_hashes_match", "canonical_crosswalk_exact", "fixed_axis_count", "fixed_value_count", "registry_axis_count", "continuous_axis_count", "high_risk_intersection_count"],
      "properties": {
        "closed": {"const": true}, "source_hashes_match": {"const": true}, "canonical_crosswalk_exact": {"const": true},
        "fixed_axis_count": {"const": 55}, "fixed_value_count": {"const": 381},
        "registry_axis_count": {"const": 8}, "continuous_axis_count": {"const": 6}, "high_risk_intersection_count": {"const": 18}
      }
    }
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "token": {"type": "string", "minLength": 1},
    "source": {
      "type": "object", "additionalProperties": false,
      "required": ["source_id", "path", "sha256", "bytes"],
      "properties": {"source_id": {"$ref": "#/$defs/token"}, "path": {"$ref": "#/$defs/token"}, "sha256": {"$ref": "#/$defs/sha"}, "bytes": {"type": "integer", "minimum": 1}}
    },
    "axis": {
      "type": "object", "additionalProperties": false,
      "required": ["axis_id", "layer", "unit", "authority", "values", "value_count"],
      "properties": {
        "axis_id": {"$ref": "#/$defs/token"}, "layer": {"enum": ["canonical", "generation", "risk", "image_formation", "render", "label", "multi_person"]},
        "unit": {"enum": ["scene", "person_instance"]}, "authority": {"$ref": "#/$defs/token"},
        "values": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "integer"}]}},
        "value_count": {"type": "integer", "minimum": 1}
      }
    },
    "registryAxis": {
      "type": "object", "additionalProperties": false,
      "required": ["axis_id", "layer", "unit", "registry", "value_pattern"],
      "properties": {
        "axis_id": {"$ref": "#/$defs/token"}, "layer": {"const": "inventory"}, "unit": {"enum": ["scene", "person_instance"]},
        "registry": {"enum": ["daz_asset_registry", "daz_recipe_registry"]}, "value_pattern": {"$ref": "#/$defs/token"}
      }
    },
    "continuousAxis": {
      "type": "object", "additionalProperties": false,
      "required": ["axis_id", "unit", "minimum", "maximum", "authority"],
      "properties": {
        "axis_id": {"$ref": "#/$defs/token"}, "unit": {"enum": ["scene", "person_instance"]},
        "minimum": {"type": "number"}, "maximum": {"type": "number"}, "authority": {"$ref": "#/$defs/token"}
      }
    },
    "intersection": {
      "type": "object", "additionalProperties": false,
      "required": ["intersection_id", "axes"],
      "properties": {"intersection_id": {"$ref": "#/$defs/token"}, "axes": {"type": "array", "minItems": 2, "maxItems": 4, "uniqueItems": true, "items": {"$ref": "#/$defs/token"}}}
    }
  }
}

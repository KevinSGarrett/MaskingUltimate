{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_duo_recipe_selection.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "selection_id", "selection_sha256", "policy_sha256", "request", "selected_template", "slots", "relationship", "evidence_requirements"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "selection_id": {"type": "string", "pattern": "^dcds_[0-9a-f]{24}$"},
    "selection_sha256": {"$ref": "#/$defs/sha"},
    "policy_sha256": {"$ref": "#/$defs/sha"},
    "request": {
      "type": "object", "additionalProperties": false,
      "required": ["selection_seed", "anatomy_family", "relationship_family"],
      "properties": {
        "selection_seed": {"type": "integer", "minimum": 0},
        "anatomy_family": {"enum": ["MM", "MF", "FF"]},
        "relationship_family": {"enum": ["no_contact", "overlap_no_contact", "contact_support"]}
      }
    },
    "selected_template": {"$ref": "#/$defs/selectedTemplate"},
    "slots": {
      "type": "array", "minItems": 2, "maxItems": 2,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["slot_id", "construction_id", "anatomy_configuration", "pose_family", "pose_subfamily", "root_transform", "contact_sites", "mutable_dofs"],
        "properties": {
          "slot_id": {"enum": ["a", "b"]}, "construction_id": {"enum": ["c0", "c1"]},
          "anatomy_configuration": {"enum": ["adult_male", "adult_female"]},
          "pose_family": {"type": "string", "minLength": 1}, "pose_subfamily": {"type": "string", "minLength": 1},
          "root_transform": {"$ref": "#/$defs/transform"},
          "contact_sites": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}},
          "mutable_dofs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}}
        }
      }
    },
    "relationship": {"$ref": "#/$defs/relationship"},
    "evidence_requirements": {
      "type": "object", "additionalProperties": false,
      "required": ["slot_names_are_not_p_indices", "final_p_index_assignment_required", "contact_solver_required", "contact_not_yet_claimed", "final_root_joint_contact_readback_required", "camera_clearance_required", "instance_ownership_validation_required"],
      "properties": {
        "slot_names_are_not_p_indices": {"const": true}, "final_p_index_assignment_required": {"const": true},
        "contact_solver_required": {"type": "boolean"}, "contact_not_yet_claimed": {"const": true},
        "final_root_joint_contact_readback_required": {"const": true}, "camera_clearance_required": {"const": true},
        "instance_ownership_validation_required": {"const": true}
      }
    }
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "clearance": {
      "type": "object", "additionalProperties": false,
      "required": ["minimum_people_margin_fraction", "minimum_visible_fraction_per_slot"],
      "properties": {
        "minimum_people_margin_fraction": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "minimum_visible_fraction_per_slot": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}
      }
    },
    "selectedTemplate": {
      "type": "object", "additionalProperties": false,
      "required": ["template_id", "template_sha256", "relationship_family", "spatial_subfamily", "camera_clearance"],
      "properties": {
        "template_id": {"type": "string", "pattern": "^daz_duo_[a-z0-9_]+$"},
        "template_sha256": {"$ref": "#/$defs/sha"},
        "relationship_family": {"enum": ["no_contact", "overlap_no_contact", "contact_support"]},
        "spatial_subfamily": {"enum": ["separated_side_by_side", "torso_overlap_depth", "hand_to_forearm_contact"]},
        "camera_clearance": {"$ref": "#/$defs/clearance"}
      }
    },
    "relationship": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "participants", "front_slot", "a_site", "b_site", "distance_mm", "maximum_penetration_mm", "template_id", "template_sha256", "policy_sha256"],
      "properties": {
        "type": {"enum": ["separated", "overlap", "contact"]},
        "participants": {"const": ["c0", "c1"]},
        "front_slot": {"type": ["string", "null"], "enum": ["a", "b", null]},
        "a_site": {"type": ["string", "null"], "pattern": "^[a-z][a-z0-9_]*$"},
        "b_site": {"type": ["string", "null"], "pattern": "^[a-z][a-z0-9_]*$"},
        "distance_mm": {
          "oneOf": [
            {"type": "null"},
            {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "number", "minimum": 0, "maximum": 20}}
          ]
        },
        "maximum_penetration_mm": {"type": ["number", "null"], "minimum": 0, "maximum": 20},
        "template_id": {"type": "string", "pattern": "^daz_duo_[a-z0-9_]+$"},
        "template_sha256": {"$ref": "#/$defs/sha"},
        "policy_sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "transform": {
      "type": "object", "additionalProperties": false,
      "required": ["translation_cm", "rotation_deg", "scale"],
      "properties": {
        "translation_cm": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "number", "minimum": -250, "maximum": 250}},
        "rotation_deg": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "number", "minimum": -180, "maximum": 180}},
        "scale": {"type": "number", "minimum": 0.85, "maximum": 1.15}
      }
    }
  }
}

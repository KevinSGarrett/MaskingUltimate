{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_failure_campaign_policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "fixture_only", "required_scenarios", "disk_full", "drive_loss", "gpu_governance_absence", "db_corruption", "crash", "popup", "oom"],
  "properties": {
    "schema_version": {"const": "1.1.0"},
    "fixture_only": {"const": true},
    "required_scenarios": {"const": ["disk_full", "drive_loss", "gpu_governance_absence", "db_corruption", "crash", "popup", "oom"]},
    "disk_full": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture_capacity_bytes", "simulated_free_bytes", "required_free_bytes", "action", "partial_acceptance_allowed"],
      "properties": {
        "fixture_capacity_bytes": {"const": 4096},
        "simulated_free_bytes": {"const": 1024},
        "required_free_bytes": {"const": 2048},
        "action": {"const": "pause_and_drain"},
        "partial_acceptance_allowed": {"const": false}
      }
    },
    "drive_loss": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "partial_acceptance_allowed"],
      "properties": {
        "action": {"const": "pause_and_drain"},
        "partial_acceptance_allowed": {"const": false}
      }
    },
    "db_corruption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preserve_corrupt_original", "restore_to_new_path", "duplicate_acceptance_allowed"],
      "properties": {
        "preserve_corrupt_original": {"const": true},
        "restore_to_new_path": {"const": true},
        "duplicate_acceptance_allowed": {"const": false}
      }
    },
    "crash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["missing_terminal_result_action", "partial_acceptance_allowed"],
      "properties": {
        "missing_terminal_result_action": {"const": "fail"},
        "partial_acceptance_allowed": {"const": false}
      }
    },
    "popup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "process_tree_termination_required", "ui_input_allowed"],
      "properties": {
        "action": {"const": "quarantine"},
        "process_tree_termination_required": {"const": true},
        "ui_input_allowed": {"const": false}
      }
    },
    "gpu_governance_absence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "legacy_marker_may_block", "legacy_marker_may_be_reclaimed"],
      "properties": {
        "action": {"const": "proceed_without_gpu_admission"},
        "legacy_marker_may_block": {"const": false},
        "legacy_marker_may_be_reclaimed": {"const": false}
      }
    },
    "oom": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximum_lower_cost_retries", "persistent_failure_action", "allowed_override_fields", "protected_recipe_fields"],
      "properties": {
        "maximum_lower_cost_retries": {"const": 1},
        "persistent_failure_action": {"const": "quarantine"},
        "allowed_override_fields": {"const": ["render_samples", "tile_size"]},
        "protected_recipe_fields": {
          "const": ["operation", "bundle_version", "content_directories", "payload.renderer", "payload.annotation_width", "payload.annotation_height", "payload.ontology_id"]
        }
      }
    }
  }
}

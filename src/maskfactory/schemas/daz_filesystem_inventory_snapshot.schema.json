{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_filesystem_inventory_snapshot.schema.json",
  "title": "DAZ filesystem inventory snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "snapshot_id",
    "inventory_sha256",
    "roots",
    "summary",
    "reparse_points_followed",
    "files"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "snapshot_id": { "type": "string", "pattern": "^fs_[0-9a-f]{24}$" },
    "inventory_sha256": { "$ref": "#/$defs/sha256" },
    "roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["root_id", "priority", "source_kind", "path_fingerprint"],
        "properties": {
          "root_id": { "type": "string", "minLength": 1 },
          "priority": { "type": "integer" },
          "source_kind": { "type": "string", "minLength": 1 },
          "path_fingerprint": { "$ref": "#/$defs/sha256" }
        }
      }
    },
    "summary": { "$ref": "#/$defs/summary" },
    "reparse_points_followed": { "const": false },
    "files": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "root_id",
              "relative_path",
              "canonical_path",
              "logical_uri",
              "size_bytes",
              "mtime_ns",
              "file_id",
              "extension",
              "user_facing"
            ],
            "properties": {
              "root_id": { "type": "string", "minLength": 1 },
              "relative_path": { "type": "string", "minLength": 1 },
              "canonical_path": { "type": "string", "minLength": 1 },
              "logical_uri": { "type": "string", "pattern": "^/" },
              "size_bytes": { "type": "integer", "minimum": 0 },
              "mtime_ns": { "type": "integer", "minimum": 0 },
              "file_id": { "type": ["string", "null"] },
              "extension": { "type": "string" },
              "user_facing": { "type": "boolean" }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "directory_states",
        "file_count",
        "byte_count",
        "user_facing_file_count",
        "skipped_reparse_point_count",
        "complete"
      ],
      "properties": {
        "directory_states": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "file_count": { "type": "integer", "minimum": 0 },
        "byte_count": { "type": "integer", "minimum": 0 },
        "user_facing_file_count": { "type": "integer", "minimum": 0 },
        "skipped_reparse_point_count": { "type": "integer", "minimum": 0 },
        "complete": { "const": true }
      }
    }
  }
}

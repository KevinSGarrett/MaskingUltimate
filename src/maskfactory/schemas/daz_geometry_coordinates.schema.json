{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_geometry_coordinates.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sidecar_id", "sidecar_sha256", "scene_id", "scene_state_sha256", "camera_id", "projection_type", "near_clip_m", "far_clip_m", "subdivision_level", "resolution", "crop", "world_to_camera", "camera_to_world", "projection_matrix", "coordinate_convention"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "sidecar_id": {"type": "string", "pattern": "^dgc_[0-9a-f]{24}$"},
    "sidecar_sha256": {"$ref": "#/$defs/sha"},
    "scene_id": {"type": "string", "minLength": 1},
    "scene_state_sha256": {"$ref": "#/$defs/sha"},
    "camera_id": {"type": "string", "minLength": 1},
    "projection_type": {"enum": ["perspective", "orthographic"]},
    "near_clip_m": {"type": "number", "exclusiveMinimum": 0},
    "far_clip_m": {"type": "number", "exclusiveMinimum": 0},
    "subdivision_level": {"type": "integer", "minimum": 0, "maximum": 8},
    "resolution": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}},
    "crop": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "integer", "minimum": 0}},
    "world_to_camera": {"$ref": "#/$defs/matrix"},
    "camera_to_world": {"$ref": "#/$defs/matrix"},
    "projection_matrix": {"$ref": "#/$defs/matrix"},
    "coordinate_convention": {"$ref": "#/$defs/convention"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "matrix": {"type": "array", "minItems": 16, "maxItems": 16, "items": {"type": "number"}},
    "convention": {
      "type": "object", "additionalProperties": false,
      "required": ["matrix_layout", "vector_convention", "image_origin", "pixel_center", "ndc_x_range", "ndc_y_range", "ndc_z_range", "matrix_inverse_tolerance", "rotation_orthonormal_tolerance", "rotation_determinant", "perspective_last_row", "orthographic_last_row", "depth_quantity", "depth_unit", "depth_positive_direction", "normal_coordinate_space", "normal_handedness", "normal_axes"],
      "properties": {
        "matrix_layout": {"const": "row_major"}, "vector_convention": {"const": "column_vector"},
        "image_origin": {"const": "top_left"}, "pixel_center": {"const": "half_integer"},
        "ndc_x_range": {"const": [-1.0, 1.0]}, "ndc_y_range": {"const": [-1.0, 1.0]}, "ndc_z_range": {"const": [0.0, 1.0]},
        "matrix_inverse_tolerance": {"const": 0.000001}, "rotation_orthonormal_tolerance": {"const": 0.000001}, "rotation_determinant": {"const": 1.0},
        "perspective_last_row": {"const": [0.0, 0.0, 1.0, 0.0]}, "orthographic_last_row": {"const": [0.0, 0.0, 0.0, 1.0]},
        "depth_quantity": {"const": "camera_view_axis_z"}, "depth_unit": {"const": "meter"}, "depth_positive_direction": {"const": "forward"},
        "normal_coordinate_space": {"const": "camera"}, "normal_handedness": {"const": "right_handed"},
        "normal_axes": {"const": {"x": "right", "y": "down", "z": "forward"}}
      }
    }
  }
}

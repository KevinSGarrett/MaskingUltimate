{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_geometry_pass_report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "scene_id", "contract_id", "contract_sha256", "plan_id", "plan_sha256", "scene_state_sha256", "coordinate_sidecar_id", "coordinate_sidecar_sha256", "execution_sha256", "file_hashes", "depth_codec", "normals_codec", "alpha_codec", "metrics", "statistics", "findings", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "report_id": {"type": "string", "pattern": "^dgpr_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"},
    "scene_id": {"type": "string"}, "contract_id": {"type": "string"}, "contract_sha256": {"$ref": "#/$defs/sha"}, "plan_id": {"type": "string"}, "plan_sha256": {"$ref": "#/$defs/sha"}, "scene_state_sha256": {"$ref": "#/$defs/sha"},
    "coordinate_sidecar_id": {"type": "string"}, "coordinate_sidecar_sha256": {"$ref": "#/$defs/sha"}, "execution_sha256": {"$ref": "#/$defs/sha"},
    "file_hashes": {"type": "object", "additionalProperties": false, "required": ["depth", "normals", "coverage_alpha"], "properties": {"depth": {"$ref": "#/$defs/sha"}, "normals": {"$ref": "#/$defs/sha"}, "coverage_alpha": {"$ref": "#/$defs/sha"}}},
    "depth_codec": {"$ref": "#/$defs/exrCodec"}, "normals_codec": {"$ref": "#/$defs/exrCodec"}, "alpha_codec": {"$ref": "#/$defs/pngCodec"},
    "metrics": {"type": "object", "additionalProperties": false, "required": ["visible_pixels", "background_pixels", "visible_depth_nonfinite_pixels", "visible_depth_clip_pixels", "background_depth_not_positive_inf_pixels", "visible_normal_nonfinite_pixels", "visible_normal_nonunit_pixels", "background_normal_nonzero_pixels"], "properties": {"visible_pixels": {"type": "integer", "minimum": -1}, "background_pixels": {"type": "integer", "minimum": -1}, "visible_depth_nonfinite_pixels": {"type": "integer", "minimum": -1}, "visible_depth_clip_pixels": {"type": "integer", "minimum": -1}, "background_depth_not_positive_inf_pixels": {"type": "integer", "minimum": -1}, "visible_normal_nonfinite_pixels": {"type": "integer", "minimum": -1}, "visible_normal_nonunit_pixels": {"type": "integer", "minimum": -1}, "background_normal_nonzero_pixels": {"type": "integer", "minimum": -1}}},
    "statistics": {"$ref": "#/$defs/statistics"},
    "findings": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["code", "path", "detail"], "properties": {"code": {"type": "string", "pattern": "^GEOMETRY_[A-Z0-9_]+$"}, "path": {"type": "string", "pattern": "^/"}, "detail": {"type": "string"}}}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["passed", "finding_count", "failure_codes", "scene_state_unchanged", "finite_and_convention_exact"], "properties": {"passed": {"type": "boolean"}, "finding_count": {"type": "integer", "minimum": 0}, "failure_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "scene_state_unchanged": {"type": "boolean"}, "finite_and_convention_exact": {"type": "boolean"}}}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "channel": {"type": "object", "additionalProperties": false, "required": ["name", "pixel_type_code", "p_linear", "x_sampling", "y_sampling"], "properties": {"name": {"type": "string"}, "pixel_type_code": {"const": 2}, "p_linear": {"type": "integer"}, "x_sampling": {"const": 1}, "y_sampling": {"const": 1}}},
    "exrCodec": {"type": "object", "additionalProperties": false, "required": ["version", "flags", "compression_code", "data_window_origin", "resolution", "display_window_origin", "display_resolution", "line_order_code", "pixel_aspect_ratio", "channels", "header_attribute_names", "format", "dtype", "bytes"], "properties": {"version": {"const": 2}, "flags": {"const": 0}, "compression_code": {"const": 3}, "data_window_origin": {"const": [0, 0]}, "resolution": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}}, "display_window_origin": {"const": [0, 0]}, "display_resolution": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}}, "line_order_code": {"const": 0}, "pixel_aspect_ratio": {"const": 1.0}, "channels": {"type": "array", "minItems": 1, "maxItems": 3, "items": {"$ref": "#/$defs/channel"}}, "header_attribute_names": {"type": "array", "items": {"type": "string"}}, "format": {"const": "OPENEXR"}, "dtype": {"const": "float32"}, "bytes": {"type": "integer", "minimum": 1}}},
    "pngCodec": {"type": "object", "additionalProperties": false, "required": ["format", "source_mode", "dtype", "resolution", "minimum", "maximum", "metadata_keys"], "properties": {"format": {"const": "PNG"}, "source_mode": {"type": "string"}, "dtype": {"const": "uint16"}, "resolution": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}}, "minimum": {"type": "integer", "minimum": 0, "maximum": 65535}, "maximum": {"type": "integer", "minimum": 0, "maximum": 65535}, "metadata_keys": {"type": "array", "items": {"type": "string"}}}},
    "nullableNumber": {"type": ["number", "null"]},
    "statistics": {"type": "object", "additionalProperties": false, "required": ["depth", "normals"], "properties": {"depth": {"type": "object", "additionalProperties": false, "required": ["finite_count", "positive_infinity_count", "negative_infinity_count", "nan_count", "minimum_finite_m", "maximum_finite_m", "mean_finite_m"], "properties": {"finite_count": {"type": "integer", "minimum": 0}, "positive_infinity_count": {"type": "integer", "minimum": 0}, "negative_infinity_count": {"type": "integer", "minimum": 0}, "nan_count": {"type": "integer", "minimum": 0}, "minimum_finite_m": {"$ref": "#/$defs/nullableNumber"}, "maximum_finite_m": {"$ref": "#/$defs/nullableNumber"}, "mean_finite_m": {"$ref": "#/$defs/nullableNumber"}}}, "normals": {"type": "object", "additionalProperties": false, "required": ["finite_vector_count", "nonfinite_vector_count", "minimum_visible_length", "maximum_visible_length", "mean_visible_length"], "properties": {"finite_vector_count": {"type": "integer", "minimum": 0}, "nonfinite_vector_count": {"type": "integer", "minimum": 0}, "minimum_visible_length": {"$ref": "#/$defs/nullableNumber"}, "maximum_visible_length": {"$ref": "#/$defs/nullableNumber"}, "mean_visible_length": {"$ref": "#/$defs/nullableNumber"}}}}}
  }
}

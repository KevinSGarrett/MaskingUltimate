{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_instance_pass_contract.schema.json",
  "title": "MaskFactory exact DAZ person-instance pass contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "contract_id", "contract_sha256", "scene_id", "resolved_state_id",
    "resolved_state_sha256", "scene_state_sha256", "plan_id", "plan_sha256",
    "policy_sha256", "policy_version", "output", "owners"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "contract_id": {"type": "string", "pattern": "^dipc_[0-9a-f]{24}$"},
    "contract_sha256": {"$ref": "#/$defs/sha256"},
    "scene_id": {"type": "string", "pattern": "^daz_scene_[A-Za-z0-9_-]+$"},
    "resolved_state_id": {"type": "string", "pattern": "^dcrs_[0-9a-f]{24}$"},
    "resolved_state_sha256": {"$ref": "#/$defs/sha256"},
    "scene_state_sha256": {"$ref": "#/$defs/sha256"},
    "plan_id": {"type": "string", "pattern": "^dcrp_[0-9a-f]{24}$"},
    "plan_sha256": {"$ref": "#/$defs/sha256"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "policy_version": {"const": "1.0.0"},
    "output": {
      "type": "object", "additionalProperties": false,
      "required": ["role", "encoding", "resolution", "crop", "background_value", "decode_filter"],
      "properties": {
        "role": {"const": "instance"}, "encoding": {"const": "uint16_png"},
        "resolution": {"$ref": "#/$defs/resolution"}, "crop": {"$ref": "#/$defs/crop"},
        "background_value": {"const": 0}, "decode_filter": {"const": "nearest_neighbor_exact"}
      }
    },
    "owners": {
      "type": "array", "minItems": 1, "maxItems": 4,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["p_index", "instance_id", "construction_id", "node_ids"],
        "properties": {
          "p_index": {"enum": ["p0", "p1", "p2", "p3"]},
          "instance_id": {"type": "integer", "minimum": 1, "maximum": 4},
          "construction_id": {"type": "string", "minLength": 1},
          "node_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "resolution": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}},
    "crop": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "integer", "minimum": 0}}
  }
}

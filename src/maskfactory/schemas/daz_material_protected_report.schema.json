{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_material_protected_report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "scene_id", "contract_id", "contract_sha256", "plan_id", "plan_sha256", "scene_state_sha256", "ontology_snapshot_sha256", "mapping_sha256", "execution_sha256", "file_hashes", "material_codec", "protected_codec", "part_codec", "instance_codec", "observed_material_ids", "observed_protected_ids", "orthogonality", "findings", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "report_id": {"type": "string", "pattern": "^dmpr_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"},
    "scene_id": {"type": "string"}, "contract_id": {"type": "string"}, "contract_sha256": {"$ref": "#/$defs/sha"}, "plan_id": {"type": "string"}, "plan_sha256": {"$ref": "#/$defs/sha"}, "scene_state_sha256": {"$ref": "#/$defs/sha"}, "ontology_snapshot_sha256": {"$ref": "#/$defs/sha"}, "mapping_sha256": {"$ref": "#/$defs/sha"}, "execution_sha256": {"$ref": "#/$defs/sha"},
    "file_hashes": {"type": "object", "additionalProperties": false, "required": ["material", "protected", "part", "instance"], "properties": {"material": {"$ref": "#/$defs/sha"}, "protected": {"oneOf": [{"$ref": "#/$defs/sha"}, {"type": "null"}]}, "part": {"$ref": "#/$defs/sha"}, "instance": {"$ref": "#/$defs/sha"}}},
    "material_codec": {"$ref": "#/$defs/codec"}, "protected_codec": {"oneOf": [{"$ref": "#/$defs/codec"}, {"type": "null"}]}, "part_codec": {"$ref": "#/$defs/codec"}, "instance_codec": {"$ref": "#/$defs/codec"},
    "observed_material_ids": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 0, "maximum": 65535}},
    "observed_protected_ids": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 0, "maximum": 65535}},
    "orthogonality": {"type": "object", "additionalProperties": false, "required": ["visible_without_material_pixels", "orphan_material_pixels", "protected_part_mismatch_pixels", "unprotected_person_part_invalid_pixels", "other_person_protection_mismatch_pixels", "target_marked_other_person_pixels", "protected_material_relation_pixels", "material_protected_relation_pixels", "background_nonzero_pixels"], "properties": {"visible_without_material_pixels": {"type": "integer", "minimum": -1}, "orphan_material_pixels": {"type": "integer", "minimum": -1}, "protected_part_mismatch_pixels": {"type": "integer", "minimum": -1}, "unprotected_person_part_invalid_pixels": {"type": "integer", "minimum": -1}, "other_person_protection_mismatch_pixels": {"type": "integer", "minimum": -1}, "target_marked_other_person_pixels": {"type": "integer", "minimum": -1}, "protected_material_relation_pixels": {"type": "integer", "minimum": -1}, "material_protected_relation_pixels": {"type": "integer", "minimum": -1}, "background_nonzero_pixels": {"type": "integer", "minimum": -1}}},
    "findings": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["code", "path", "detail"], "properties": {"code": {"type": "string", "pattern": "^(MATERIAL|PROTECTED)_[A-Z0-9_]+$"}, "path": {"type": "string", "pattern": "^/"}, "detail": {"type": "string"}}}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["passed", "finding_count", "failure_codes", "material_id_count", "protected_required", "scene_state_unchanged", "orthogonality_exact"], "properties": {"passed": {"type": "boolean"}, "finding_count": {"type": "integer", "minimum": 0}, "failure_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "material_id_count": {"const": 16}, "protected_required": {"type": "boolean"}, "scene_state_unchanged": {"type": "boolean"}, "orthogonality_exact": {"type": "boolean"}}}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "codec": {"type": "object", "additionalProperties": false, "required": ["format", "source_mode", "dtype", "resolution", "minimum", "maximum", "metadata_keys"], "properties": {"format": {"const": "PNG"}, "source_mode": {"type": "string"}, "dtype": {"const": "uint16"}, "resolution": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}}, "minimum": {"type": "integer", "minimum": 0, "maximum": 65535}, "maximum": {"type": "integer", "minimum": 0, "maximum": 65535}, "metadata_keys": {"type": "array", "items": {"type": "string"}}}}
  }
}

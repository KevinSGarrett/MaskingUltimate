{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_monitoring_snapshot.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "captured_at", "machine", "pipeline", "corpus"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "captured_at": {"type": "string", "format": "date-time"},
    "machine": {"$ref": "#/$defs/metrics"},
    "pipeline": {"$ref": "#/$defs/metrics"},
    "corpus": {"$ref": "#/$defs/metrics"}
  },
  "$defs": {
    "metrics": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9_]+$"},
      "additionalProperties": {"type": ["string", "number", "integer", "boolean", "null"]}
    }
  }
}

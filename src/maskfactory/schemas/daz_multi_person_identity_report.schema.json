{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_multi_person_identity_report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "policy_version", "policy_sha256", "validator_set_version", "scene_id", "image_id", "scene_family_id", "contract_id", "contract_sha256", "derivation_report_id", "derivation_report_sha256", "assignment_id", "assignment_sha256", "source_sha256s", "results", "metrics", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "report_id": {"type": "string", "pattern": "^dmiv_[0-9a-f]{24}$"},
    "report_sha256": {"$ref": "#/$defs/sha"},
    "policy_version": {"const": "1.0.0"},
    "policy_sha256": {"$ref": "#/$defs/sha"},
    "validator_set_version": {"const": "1.0.0"},
    "scene_id": {"type": "string", "minLength": 1},
    "image_id": {"type": "string", "minLength": 1},
    "scene_family_id": {"type": "string", "minLength": 1},
    "contract_id": {"type": "string", "pattern": "^dpdc_[0-9a-f]{24}$"},
    "contract_sha256": {"$ref": "#/$defs/sha"},
    "derivation_report_id": {"type": "string", "pattern": "^dpdr_[0-9a-f]{24}$"},
    "derivation_report_sha256": {"$ref": "#/$defs/sha"},
    "assignment_id": {"type": "string", "pattern": "^dpia_[0-9a-f]{24}$"},
    "assignment_sha256": {"$ref": "#/$defs/sha"},
    "source_sha256s": {
      "type": "object", "additionalProperties": false,
      "required": ["construction", "instance", "derived_scene_tree"],
      "properties": {"construction": {"$ref": "#/$defs/sha"}, "instance": {"$ref": "#/$defs/sha"}, "derived_scene_tree": {"$ref": "#/$defs/sha"}}
    },
    "results": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"$ref": "#/$defs/result"}},
    "metrics": {
      "type": "object", "additionalProperties": false,
      "required": ["person_count", "visible_person_pixels", "duplicate_ownership_pixels", "missing_ownership_pixels", "extra_ownership_pixels", "identity_bleed_pixels", "complement_mismatch_pixels", "package_hash_failures", "shared_rgb_failures"],
      "properties": {
        "person_count": {"type": "integer", "minimum": 2, "maximum": 4},
        "visible_person_pixels": {"type": "integer", "minimum": 1},
        "duplicate_ownership_pixels": {"type": "integer", "minimum": 0},
        "missing_ownership_pixels": {"type": "integer", "minimum": 0},
        "extra_ownership_pixels": {"type": "integer", "minimum": 0},
        "identity_bleed_pixels": {"type": "integer", "minimum": 0},
        "complement_mismatch_pixels": {"type": "integer", "minimum": 0},
        "package_hash_failures": {"type": "integer", "minimum": 0},
        "shared_rgb_failures": {"type": "integer", "minimum": 0}
      }
    },
    "summary": {
      "type": "object", "additionalProperties": false,
      "required": ["passed", "acceptance_eligible", "required_count", "passed_count", "failed_count"],
      "properties": {
        "passed": {"type": "boolean"}, "acceptance_eligible": {"type": "boolean"},
        "required_count": {"const": 8}, "passed_count": {"type": "integer", "minimum": 0, "maximum": 8},
        "failed_count": {"type": "integer", "minimum": 0, "maximum": 8}
      }
    }
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "result": {
      "type": "object", "additionalProperties": false,
      "required": ["validator_id", "validator_version", "name", "status", "severity", "reason_code", "observed", "retryability"],
      "properties": {
        "validator_id": {"type": "string", "pattern": "^DAZ-V7-00[1-8]$"},
        "validator_version": {"const": "1.0.0"},
        "name": {"type": "string", "minLength": 1},
        "status": {"enum": ["pass", "fail"]}, "severity": {"const": "BLOCK"},
        "reason_code": {"type": "string", "minLength": 1},
        "observed": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "retryability": {"const": "none"}
      }
    }
  }
}

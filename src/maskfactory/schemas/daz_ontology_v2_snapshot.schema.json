{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_ontology_v2_snapshot.schema.json",
  "title": "Inactive MaskFactory v2 ontology draft snapshot for DAZ (never active mapping authority)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ontology_version",
    "activation_status",
    "mapping_authority",
    "source",
    "left_right_convention",
    "visible_pixel_only",
    "part_id_min",
    "part_id_max",
    "part_label_count",
    "enabled_part_label_count",
    "disabled_part_labels",
    "appended_part_ids",
    "part_labels",
    "material_id_min",
    "material_id_max",
    "material_label_count",
    "material_labels",
    "derived_labels",
    "protected_classes",
    "projected_templates",
    "snapshot_id",
    "canonical_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "ontology_version": { "const": "body_parts_v2" },
    "activation_status": { "const": "approved_design_not_active" },
    "mapping_authority": { "const": false },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locator", "sha256", "loader_locator", "loader_sha256"],
      "properties": {
        "locator": { "const": "configs/ontology_v2.yaml" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "loader_locator": { "const": "src/maskfactory/ontology.py" },
        "loader_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "left_right_convention": { "const": "character_perspective" },
    "visible_pixel_only": { "const": true },
    "part_id_min": { "const": 0 },
    "part_id_max": { "const": 64 },
    "part_label_count": { "const": 65 },
    "enabled_part_label_count": { "type": "integer", "minimum": 0, "maximum": 65 },
    "disabled_part_labels": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "appended_part_ids": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "prefixItems": [
        { "const": 56 },
        { "const": 57 },
        { "const": 58 },
        { "const": 59 },
        { "const": 60 },
        { "const": 61 },
        { "const": 62 },
        { "const": 63 },
        { "const": 64 }
      ]
    },
    "part_labels": {
      "type": "array",
      "minItems": 65,
      "maxItems": 65,
      "items": { "$ref": "#/$defs/label" }
    },
    "material_id_min": { "const": 0 },
    "material_id_max": { "const": 15 },
    "material_label_count": { "const": 16 },
    "material_labels": {
      "type": "array",
      "minItems": 16,
      "maxItems": 16,
      "items": { "$ref": "#/$defs/label" }
    },
    "derived_labels": { "type": "array", "items": { "$ref": "#/$defs/label" } },
    "protected_classes": {
      "type": "array",
      "prefixItems": [
        { "const": "other_person" },
        { "const": "occluding_object" },
        { "const": "support_surface" },
        { "const": "accessory_or_prop" }
      ],
      "minItems": 4,
      "maxItems": 4
    },
    "projected_templates": { "type": "array", "items": { "type": "string" } },
    "snapshot_id": { "type": "string", "pattern": "^ontology_v2_[0-9a-f]{24}$" },
    "canonical_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "label": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "name", "mask_type", "map", "side", "parent_union", "enabled",
        "expected_area_pct_range", "max_components", "exclusivity_group", "swap_partner",
        "visibility_default", "boundary_rule", "formula", "boundary_rule_text"
      ],
      "properties": {
        "id": { "type": ["integer", "null"] },
        "name": { "type": "string", "minLength": 1 },
        "mask_type": { "type": "string", "minLength": 1 },
        "map": { "enum": ["part", "material", "none"] },
        "side": { "type": "string" },
        "parent_union": { "type": ["string", "null"] },
        "enabled": { "type": "boolean" },
        "expected_area_pct_range": {
          "oneOf": [
            { "type": "null" },
            { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 }
          ]
        },
        "max_components": { "type": ["integer", "null"] },
        "exclusivity_group": { "type": ["string", "null"] },
        "swap_partner": { "type": ["string", "null"] },
        "visibility_default": { "type": "string" },
        "boundary_rule": { "type": ["string", "null"] },
        "formula": { "type": ["string", "null"] },
        "boundary_rule_text": { "type": ["string", "null"] }
      }
    }
  }
}

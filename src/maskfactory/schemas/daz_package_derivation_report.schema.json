{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_package_derivation_report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "contract_id", "contract_sha256", "scene_id", "image_id", "scene_family_id", "source_file_sha256s", "source_codecs", "packages", "invariants", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "report_id": {"type": "string", "pattern": "^dpdr_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"}, "contract_id": {"type": "string", "pattern": "^dpdc_[0-9a-f]{24}$"}, "contract_sha256": {"$ref": "#/$defs/sha"},
    "scene_id": {"type": "string"}, "image_id": {"type": "string"}, "scene_family_id": {"type": "string"}, "source_file_sha256s": {"type": "object"}, "source_codecs": {"type": "object"},
    "packages": {"type": "array", "minItems": 1, "maxItems": 4, "items": {"type": "object", "additionalProperties": false, "required": ["p_index", "instance_id", "package_id", "relative_root", "target_pixels", "other_person_pixels", "file_hashes", "package_tree_sha256"], "properties": {"p_index": {"enum": ["p0", "p1", "p2", "p3"]}, "instance_id": {"type": "integer", "minimum": 1, "maximum": 4}, "package_id": {"type": "string", "pattern": "^dppk_[0-9a-f]{24}$"}, "relative_root": {"type": "string"}, "target_pixels": {"type": "integer", "minimum": 1}, "other_person_pixels": {"type": "integer", "minimum": 0}, "file_hashes": {"type": "object", "minProperties": 10, "additionalProperties": {"$ref": "#/$defs/sha"}}, "package_tree_sha256": {"$ref": "#/$defs/sha"}}}},
    "invariants": {"type": "object", "additionalProperties": false, "required": ["all_pixels_vectorized", "target_masks_pairwise_disjoint", "target_union_equals_visible_instance", "per_person_part_mask_exact", "per_person_material_mask_exact", "other_person_complements_exact", "protected_other_person_exact", "shared_rgb_hash_identical", "no_rerender", "forbidden_human_fields_absent"], "properties": {"all_pixels_vectorized": {"const": true}, "target_masks_pairwise_disjoint": {"const": true}, "target_union_equals_visible_instance": {"const": true}, "per_person_part_mask_exact": {"const": true}, "per_person_material_mask_exact": {"const": true}, "other_person_complements_exact": {"const": true}, "protected_other_person_exact": {"const": true}, "shared_rgb_hash_identical": {"const": true}, "no_rerender": {"const": true}, "forbidden_human_fields_absent": {"const": true}}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["passed", "package_count", "visible_person_pixels"], "properties": {"passed": {"const": true}, "package_count": {"type": "integer", "minimum": 1, "maximum": 4}, "visible_person_pixels": {"type": "integer", "minimum": 1}}}
  },
  "$defs": {"sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_part_pass_contract.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "contract_id", "contract_sha256", "scene_id", "resolved_state_id", "resolved_state_sha256", "scene_state_sha256", "plan_id", "plan_sha256", "policy_sha256", "policy_version", "ontology_snapshot_id", "ontology_snapshot_sha256", "ontology_version", "mapping_id", "mapping_sha256", "mapping_set_sha256", "active_part_ids", "disabled_part_ids", "expected_visible_part_ids", "output"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "contract_id": {"type": "string", "pattern": "^dppc_[0-9a-f]{24}$"}, "contract_sha256": {"$ref": "#/$defs/sha"},
    "scene_id": {"type": "string"}, "resolved_state_id": {"type": "string"}, "resolved_state_sha256": {"$ref": "#/$defs/sha"}, "scene_state_sha256": {"$ref": "#/$defs/sha"},
    "plan_id": {"type": "string"}, "plan_sha256": {"$ref": "#/$defs/sha"}, "policy_sha256": {"$ref": "#/$defs/sha"}, "policy_version": {"const": "1.0.0"},
    "ontology_snapshot_id": {"type": "string", "pattern": "^ontology_v1_[0-9a-f]{24}$"}, "ontology_snapshot_sha256": {"$ref": "#/$defs/sha"}, "ontology_version": {"const": "body_parts_v1"},
    "mapping_id": {"type": "string", "pattern": "^dpm_[0-9a-f]{24}$"}, "mapping_sha256": {"$ref": "#/$defs/sha"}, "mapping_set_sha256": {"$ref": "#/$defs/sha"},
    "active_part_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 0, "maximum": 55}},
    "disabled_part_ids": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 0, "maximum": 55}},
    "expected_visible_part_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 1, "maximum": 55}},
    "output": {"type": "object", "additionalProperties": false, "required": ["role", "encoding", "resolution", "crop", "background_value", "decode_filter"], "properties": {
      "role": {"const": "part"}, "encoding": {"const": "uint16_png"}, "resolution": {"$ref": "#/$defs/res"}, "crop": {"$ref": "#/$defs/crop"}, "background_value": {"const": 0}, "decode_filter": {"const": "nearest_neighbor_exact"}
    }}
  },
  "$defs": {"sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "res": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}}, "crop": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "integer", "minimum": 0}}}
}

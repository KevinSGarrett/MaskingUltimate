{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_part_pass_report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "scene_id", "contract_id", "contract_sha256", "plan_id", "plan_sha256", "scene_state_sha256", "ontology_snapshot_sha256", "mapping_sha256", "execution_sha256", "file_sha256", "instance_file_sha256", "bytes", "codec", "observed_ids", "id_pixel_counts", "coverage", "findings", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "report_id": {"type": "string", "pattern": "^dppr_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"},
    "scene_id": {"type": "string"}, "contract_id": {"type": "string"}, "contract_sha256": {"$ref": "#/$defs/sha"}, "plan_id": {"type": "string"}, "plan_sha256": {"$ref": "#/$defs/sha"}, "scene_state_sha256": {"$ref": "#/$defs/sha"},
    "ontology_snapshot_sha256": {"$ref": "#/$defs/sha"}, "mapping_sha256": {"$ref": "#/$defs/sha"}, "execution_sha256": {"$ref": "#/$defs/sha"}, "file_sha256": {"$ref": "#/$defs/sha"}, "instance_file_sha256": {"$ref": "#/$defs/sha"}, "bytes": {"type": "integer", "minimum": 1},
    "codec": {"type": "object", "additionalProperties": false, "required": ["format", "source_mode", "dtype", "resolution", "minimum", "maximum", "metadata_keys"], "properties": {"format": {"const": "PNG"}, "source_mode": {"type": "string"}, "dtype": {"const": "uint16"}, "resolution": {"$ref": "#/$defs/res"}, "minimum": {"type": "integer", "minimum": 0, "maximum": 65535}, "maximum": {"type": "integer", "minimum": 0, "maximum": 65535}, "metadata_keys": {"type": "array", "items": {"type": "string"}}}},
    "observed_ids": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 0, "maximum": 65535}},
    "id_pixel_counts": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["part_id", "pixel_count"], "properties": {"part_id": {"type": "integer"}, "pixel_count": {"type": "integer", "minimum": 1}}}},
    "coverage": {"type": "object", "additionalProperties": false, "required": ["visible_instance_without_part_pixels", "part_without_instance_pixels"], "properties": {"visible_instance_without_part_pixels": {"type": "integer", "minimum": -1}, "part_without_instance_pixels": {"type": "integer", "minimum": -1}}},
    "findings": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["code", "path", "detail"], "properties": {"code": {"type": "string", "pattern": "^PART_[A-Z0-9_]+$"}, "path": {"type": "string", "pattern": "^/"}, "detail": {"type": "string"}}}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["passed", "finding_count", "failure_codes", "active_id_count", "expected_id_count", "scene_state_unchanged", "semantic_replay_identical"], "properties": {"passed": {"type": "boolean"}, "finding_count": {"type": "integer", "minimum": 0}, "failure_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "active_id_count": {"type": "integer", "minimum": 1}, "expected_id_count": {"type": "integer", "minimum": 1}, "scene_state_unchanged": {"type": "boolean"}, "semantic_replay_identical": {"type": "boolean"}}}
  },
  "$defs": {"sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "res": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}}}
}

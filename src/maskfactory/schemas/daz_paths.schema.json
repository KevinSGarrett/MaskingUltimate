{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_paths.schema.json",
  "title": "MaskFactory DAZ paths configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "root",
    "root_identity",
    "daz_studio_executable",
    "daz_studio_executable_sha256",
    "acquisition_database",
    "state_database",
    "expected_top_level_roots",
    "storage_thresholds_gib"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "root": {"type": "string", "minLength": 3},
    "root_identity": {"type": "string", "minLength": 3},
    "daz_studio_executable": {"type": "string", "minLength": 3},
    "daz_studio_executable_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "acquisition_database": {"type": "string", "minLength": 3},
    "state_database": {"type": "string", "minLength": 3},
    "expected_top_level_roots": {
      "type": "array",
      "minItems": 25,
      "maxItems": 25,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[0-9]{2}_[a-z0-9_]+$"}
    },
    "storage_thresholds_gib": {
      "type": "object",
      "additionalProperties": false,
      "required": ["healthy", "soft", "hard", "emergency"],
      "properties": {
        "healthy": {"const": 150},
        "soft": {"const": 150},
        "hard": {"const": 100},
        "emergency": {"const": 60}
      }
    }
  }
}

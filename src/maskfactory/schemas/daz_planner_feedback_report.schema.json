{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_planner_feedback_report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "feedback_version", "policy_sha256", "candidate_batch", "base_qualification_snapshot", "outcome_snapshot", "demand_statistics", "scene_family_statistics", "asset_statistics", "camera_failure_regions", "visibility_statistics", "target_cells", "learned_restrictions", "candidate_adaptations", "adapted_qualification_snapshot", "summary", "history_guarantees", "authority", "publication"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "report_id": {"type": "string", "pattern": "^dpfr_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"},
    "feedback_version": {"const": "1.0.0"}, "policy_sha256": {"$ref": "#/$defs/sha"},
    "candidate_batch": {"type": "object", "additionalProperties": false, "required": ["batch_id", "batch_sha256", "demand_id"], "properties": {"batch_id": {"type": "string", "pattern": "^dcb_[0-9a-f]{24}$"}, "batch_sha256": {"$ref": "#/$defs/sha"}, "demand_id": {"type": "string", "pattern": "^drd_[0-9a-f]{24}$"}}},
    "base_qualification_snapshot": {"$ref": "#/$defs/snapshot_ref"},
    "outcome_snapshot": {"type": "object", "additionalProperties": false, "required": ["snapshot_id", "snapshot_sha256", "observation_count"], "properties": {"snapshot_id": {"$ref": "#/$defs/token"}, "snapshot_sha256": {"$ref": "#/$defs/sha"}, "observation_count": {"type": "integer", "minimum": 0}}},
    "demand_statistics": {"type": "array", "items": {"$ref": "#/$defs/group_stat"}},
    "scene_family_statistics": {"type": "array", "items": {"$ref": "#/$defs/group_stat"}},
    "asset_statistics": {"type": "array", "items": {"$ref": "#/$defs/asset_stat"}},
    "camera_failure_regions": {"type": "array", "items": {"$ref": "#/$defs/group_stat"}},
    "visibility_statistics": {"type": "object", "additionalProperties": false, "required": ["predicted_visible_label_count", "useful_visible_label_count", "achievement_ratio"], "properties": {"predicted_visible_label_count": {"type": "integer", "minimum": 0}, "useful_visible_label_count": {"type": "integer", "minimum": 0}, "achievement_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1}}},
    "target_cells": {"type": "array", "items": {"$ref": "#/$defs/target"}},
    "learned_restrictions": {"type": "array", "items": {"$ref": "#/$defs/restriction"}},
    "candidate_adaptations": {"type": "array", "minItems": 10, "maxItems": 100, "items": {"$ref": "#/$defs/adaptation"}},
    "adapted_qualification_snapshot": {"type": "object", "additionalProperties": false, "required": ["snapshot_id", "source", "rows", "snapshot_sha256"], "properties": {"snapshot_id": {"$ref": "#/$defs/token"}, "source": {"const": "versioned_d3_d5_d7_adaptive_observations"}, "rows": {"type": "array", "minItems": 10, "maxItems": 100, "items": {"$ref": "#/$defs/qualification_row"}}, "snapshot_sha256": {"$ref": "#/$defs/sha"}}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["observation_count", "validation_failure_count", "accepted_certificate_reference_count", "underfilled_target_cell_count", "learned_restriction_count", "adapted_candidate_count"], "properties": {"observation_count": {"type": "integer", "minimum": 0}, "validation_failure_count": {"type": "integer", "minimum": 0}, "accepted_certificate_reference_count": {"type": "integer", "minimum": 0}, "underfilled_target_cell_count": {"type": "integer", "minimum": 0}, "learned_restriction_count": {"type": "integer", "minimum": 0}, "adapted_candidate_count": {"type": "integer", "minimum": 0}}},
    "history_guarantees": {"type": "object", "additionalProperties": false, "required": ["historical_recipes_immutable", "historical_outcomes_immutable", "accepted_counts_require_certificate_reference"], "properties": {"historical_recipes_immutable": {"const": true}, "historical_outcomes_immutable": {"const": true}, "accepted_counts_require_certificate_reference": {"const": true}}},
    "authority": {"type": "object", "additionalProperties": false, "required": ["stage", "feedback_creates_recipe", "feedback_creates_render_authority", "feedback_creates_gold", "synthetic_counts_close_real_deficits"], "properties": {"stage": {"const": "technical_planner_feedback"}, "feedback_creates_recipe": {"const": false}, "feedback_creates_render_authority": {"const": false}, "feedback_creates_gold": {"const": false}, "synthetic_counts_close_real_deficits": {"const": false}}},
    "publication": {"type": "object", "additionalProperties": false, "required": ["immutable", "atomic"], "properties": {"immutable": {"const": true}, "atomic": {"const": true}}}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "token": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"}, "unit": {"type": "number", "minimum": 0, "maximum": 1},
    "snapshot_ref": {"type": "object", "additionalProperties": false, "required": ["snapshot_id", "snapshot_sha256", "source"], "properties": {"snapshot_id": {"$ref": "#/$defs/token"}, "snapshot_sha256": {"$ref": "#/$defs/sha"}, "source": {"enum": ["versioned_d3_d5_feasibility_observations", "versioned_d3_d5_d7_adaptive_observations"]}}},
    "stat_fields": {"type": "object", "required": ["attempt_count", "validation_failure_count", "failure_rate", "accepted_count", "acceptance_yield", "total_gpu_seconds", "cost_per_accept_gpu_seconds", "failure_reason_counts"], "properties": {"attempt_count": {"type": "integer", "minimum": 1}, "validation_failure_count": {"type": "integer", "minimum": 0}, "failure_rate": {"$ref": "#/$defs/unit"}, "accepted_count": {"type": "integer", "minimum": 0}, "acceptance_yield": {"$ref": "#/$defs/unit"}, "total_gpu_seconds": {"type": "number", "minimum": 0}, "cost_per_accept_gpu_seconds": {"type": ["number", "null"], "minimum": 0}, "failure_reason_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 1}}}},
    "group_stat": {"allOf": [{"$ref": "#/$defs/stat_fields"}, {"type": "object", "additionalProperties": false, "required": ["group_id", "attempt_count", "validation_failure_count", "failure_rate", "accepted_count", "acceptance_yield", "total_gpu_seconds", "cost_per_accept_gpu_seconds", "failure_reason_counts"], "properties": {"group_id": {"type": "string", "minLength": 1}, "attempt_count": {}, "validation_failure_count": {}, "failure_rate": {}, "accepted_count": {}, "acceptance_yield": {}, "total_gpu_seconds": {}, "cost_per_accept_gpu_seconds": {}, "failure_reason_counts": {}}}]},
    "asset_stat": {"allOf": [{"$ref": "#/$defs/stat_fields"}, {"type": "object", "additionalProperties": false, "required": ["asset_id", "attempt_count", "validation_failure_count", "failure_rate", "accepted_count", "acceptance_yield", "total_gpu_seconds", "cost_per_accept_gpu_seconds", "failure_reason_counts"], "properties": {"asset_id": {"type": "string", "minLength": 1}, "attempt_count": {}, "validation_failure_count": {}, "failure_rate": {}, "accepted_count": {}, "acceptance_yield": {}, "total_gpu_seconds": {}, "cost_per_accept_gpu_seconds": {}, "failure_reason_counts": {}}}]},
    "target": {"type": "object", "additionalProperties": false, "required": ["target_cell_id", "required_accepted", "current_accepted", "new_accepted", "projected_accepted", "remaining", "underfilled"], "properties": {"target_cell_id": {"$ref": "#/$defs/token"}, "required_accepted": {"type": "integer", "minimum": 1}, "current_accepted": {"type": "integer", "minimum": 0}, "new_accepted": {"type": "integer", "minimum": 0}, "projected_accepted": {"type": "integer", "minimum": 0}, "remaining": {"type": "integer", "minimum": 0}, "underfilled": {"type": "boolean"}}},
    "restriction": {"type": "object", "additionalProperties": false, "required": ["asset_id", "independent_failed_report_count", "failure_rate", "reason_counts", "effect"], "properties": {"asset_id": {"type": "string", "minLength": 1}, "independent_failed_report_count": {"type": "integer", "minimum": 3}, "failure_rate": {"$ref": "#/$defs/unit"}, "reason_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 1}}, "effect": {"const": "compatibility_eligible_false"}}},
    "adaptation": {"type": "object", "additionalProperties": false, "required": ["candidate_id", "scene_family_id", "evidence_scope", "matched_observation_count", "predicted_rejection_cost_before", "predicted_rejection_cost_after", "label_visibility_gain_before", "label_visibility_gain_after", "failure_mining_priority_before", "failure_mining_priority_after", "applied_restriction_asset_ids"], "properties": {"candidate_id": {"type": "string", "pattern": "^dc_[0-9a-f]{24}$"}, "scene_family_id": {"type": "string", "pattern": "^dfam_[0-9a-f]{24}$"}, "evidence_scope": {"enum": ["scene_family", "asset", "none"]}, "matched_observation_count": {"type": "integer", "minimum": 0}, "predicted_rejection_cost_before": {"$ref": "#/$defs/unit"}, "predicted_rejection_cost_after": {"$ref": "#/$defs/unit"}, "label_visibility_gain_before": {"$ref": "#/$defs/unit"}, "label_visibility_gain_after": {"$ref": "#/$defs/unit"}, "failure_mining_priority_before": {"$ref": "#/$defs/unit"}, "failure_mining_priority_after": {"$ref": "#/$defs/unit"}, "applied_restriction_asset_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}},
    "features": {"type": "object", "additionalProperties": false, "required": ["canonical_coverage_deficit_gain", "high_risk_intersection_gain", "label_visibility_gain", "asset_diversity_gain", "failure_mining_priority", "domain_randomization_gain", "multi_person_identity_gain", "recency_need"], "properties": {"canonical_coverage_deficit_gain": {"$ref": "#/$defs/unit"}, "high_risk_intersection_gain": {"$ref": "#/$defs/unit"}, "label_visibility_gain": {"$ref": "#/$defs/unit"}, "asset_diversity_gain": {"$ref": "#/$defs/unit"}, "failure_mining_priority": {"$ref": "#/$defs/unit"}, "domain_randomization_gain": {"$ref": "#/$defs/unit"}, "multi_person_identity_gain": {"$ref": "#/$defs/unit"}, "recency_need": {"$ref": "#/$defs/unit"}}},
    "penalties": {"type": "object", "additionalProperties": false, "required": ["incompatibility_penalty", "dominance_penalty", "recent_repetition_penalty", "predicted_rejection_cost"], "properties": {"incompatibility_penalty": {"$ref": "#/$defs/unit"}, "dominance_penalty": {"$ref": "#/$defs/unit"}, "recent_repetition_penalty": {"$ref": "#/$defs/unit"}, "predicted_rejection_cost": {"$ref": "#/$defs/unit"}}},
    "gates": {"type": "object", "additionalProperties": false, "required": ["mapping_eligible", "compatibility_eligible", "capacity_eligible", "ontology_eligible"], "properties": {"mapping_eligible": {"type": "boolean"}, "compatibility_eligible": {"type": "boolean"}, "capacity_eligible": {"type": "boolean"}, "ontology_eligible": {"type": "boolean"}}},
    "qualification_row": {"type": "object", "additionalProperties": false, "required": ["candidate_id", "features", "penalties", "hard_constraints"], "properties": {"candidate_id": {"type": "string", "pattern": "^dc_[0-9a-f]{24}$"}, "features": {"$ref": "#/$defs/features"}, "penalties": {"$ref": "#/$defs/penalties"}, "hard_constraints": {"$ref": "#/$defs/gates"}}}
  }
}

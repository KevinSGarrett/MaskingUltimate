{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_pristine_rgb_fixture_report.schema.json",
  "title": "MaskFactory pristine DAZ RGB renderer fixture report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "report_id", "report_sha256", "scene_id", "request_id",
    "request_sha256", "plan_id", "plan_sha256", "scene_state_sha256",
    "execution_sha256", "file_sha256", "bytes", "measurements", "findings", "summary"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "report_id": {"type": "string", "pattern": "^dprf_[0-9a-f]{24}$"},
    "report_sha256": {"$ref": "#/$defs/sha256"},
    "scene_id": {"type": "string", "pattern": "^daz_scene_[A-Za-z0-9_-]+$"},
    "request_id": {"type": "string", "pattern": "^dprr_[0-9a-f]{24}$"},
    "request_sha256": {"$ref": "#/$defs/sha256"},
    "plan_id": {"type": "string", "pattern": "^dcrp_[0-9a-f]{24}$"},
    "plan_sha256": {"$ref": "#/$defs/sha256"},
    "scene_state_sha256": {"$ref": "#/$defs/sha256"},
    "execution_sha256": {"$ref": "#/$defs/sha256"},
    "file_sha256": {"$ref": "#/$defs/sha256"},
    "bytes": {"type": "integer", "minimum": 1},
    "measurements": {"$ref": "#/$defs/measurements"},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "path", "detail"],
        "properties": {
          "code": {"type": "string", "pattern": "^PRISTINE_[A-Z0-9_]+$"},
          "path": {"type": "string", "pattern": "^/"},
          "detail": {"type": "string"}
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed", "finding_count", "failure_codes", "scene_state_unchanged",
        "direct_pristine_rgb_verified"
      ],
      "properties": {
        "passed": {"type": "boolean"},
        "finding_count": {"type": "integer", "minimum": 0},
        "failure_codes": {
          "type": "array", "uniqueItems": true,
          "items": {"type": "string", "pattern": "^PRISTINE_[A-Z0-9_]+$"}
        },
        "scene_state_unchanged": {"type": "boolean"},
        "direct_pristine_rgb_verified": {"type": "boolean"}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "measurements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format", "mode", "resolution", "channel_extrema",
        "unique_color_count_lower_bound", "all_black", "all_white"
      ],
      "properties": {
        "format": {"type": ["string", "null"]},
        "mode": {"type": "string"},
        "resolution": {
          "type": "array", "minItems": 2, "maxItems": 2,
          "items": {"type": "integer", "minimum": 1}
        },
        "channel_extrema": {
          "type": "array",
          "items": {
            "type": "array", "minItems": 2, "maxItems": 2,
            "items": {"type": "integer", "minimum": 0, "maximum": 255}
          }
        },
        "unique_color_count_lower_bound": {"type": "integer", "minimum": 0},
        "all_black": {"type": "boolean"},
        "all_white": {"type": "boolean"}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_pristine_rgb_request.schema.json",
  "title": "MaskFactory pristine DAZ RGB render request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "request_id", "request_sha256", "scene_id", "resolved_state_id",
    "resolved_state_sha256", "scene_state_sha256", "plan_id", "plan_sha256",
    "policy_sha256", "policy_version", "output", "renderer_settings"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "request_id": {"type": "string", "pattern": "^dprr_[0-9a-f]{24}$"},
    "request_sha256": {"$ref": "#/$defs/sha256"},
    "scene_id": {"type": "string", "pattern": "^daz_scene_[A-Za-z0-9_-]+$"},
    "resolved_state_id": {"type": "string", "pattern": "^dcrs_[0-9a-f]{24}$"},
    "resolved_state_sha256": {"$ref": "#/$defs/sha256"},
    "scene_state_sha256": {"$ref": "#/$defs/sha256"},
    "plan_id": {"type": "string", "pattern": "^dcrp_[0-9a-f]{24}$"},
    "plan_sha256": {"$ref": "#/$defs/sha256"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "policy_version": {"const": "1.0.0"},
    "output": {"$ref": "#/$defs/output"},
    "renderer_settings": {"$ref": "#/$defs/settings"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "resolution": {
      "type": "array", "minItems": 2, "maxItems": 2,
      "items": {"type": "integer", "minimum": 1}
    },
    "crop": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "items": {"type": "integer", "minimum": 0}
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role", "encoding", "resolution", "crop", "container_format", "pixel_mode",
        "source_kind", "derived_effects"
      ],
      "properties": {
        "role": {"const": "rgb_pristine"},
        "encoding": {"const": "lossless_rgb_png"},
        "resolution": {"$ref": "#/$defs/resolution"},
        "crop": {"$ref": "#/$defs/crop"},
        "container_format": {"const": "PNG"},
        "pixel_mode": {"const": "RGB"},
        "source_kind": {"const": "direct_renderer_pristine"},
        "derived_effects": {"type": "array", "maxItems": 0}
      }
    },
    "depthOfField": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled", "mode"],
      "properties": {
        "enabled": {"type": "boolean"},
        "mode": {"type": "string"}
      }
    },
    "motionBlur": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled", "mode"],
      "properties": {
        "enabled": {"type": "boolean"},
        "mode": {"type": "string"}
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine_id", "engine_version", "render_mode", "render_seed", "max_samples",
        "convergence_ratio", "stop_condition", "pixel_filter", "pixel_filter_radius",
        "tone_mapping_enabled", "denoiser_enabled", "depth_of_field", "motion_blur",
        "transparent_background", "output_color_space", "output_bit_depth",
        "output_encoding", "resolution", "crop", "camera_sha256",
        "lighting_environment_sha256"
      ],
      "properties": {
        "engine_id": {"const": "iray"},
        "engine_version": {"type": "string", "minLength": 1},
        "render_mode": {"const": "photoreal"},
        "render_seed": {"type": "integer", "minimum": 0},
        "max_samples": {"type": "integer", "minimum": 1},
        "convergence_ratio": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "stop_condition": {"const": "samples_or_convergence"},
        "pixel_filter": {"type": "string", "minLength": 1},
        "pixel_filter_radius": {"type": "number", "exclusiveMinimum": 0},
        "tone_mapping_enabled": {"type": "boolean"},
        "denoiser_enabled": {"type": "boolean"},
        "depth_of_field": {"$ref": "#/$defs/depthOfField"},
        "motion_blur": {"$ref": "#/$defs/motionBlur"},
        "transparent_background": {"const": false},
        "output_color_space": {"const": "srgb"},
        "output_bit_depth": {"const": 8},
        "output_encoding": {"const": "lossless_rgb_png"},
        "resolution": {"$ref": "#/$defs/resolution"},
        "crop": {"$ref": "#/$defs/crop"},
        "camera_sha256": {"$ref": "#/$defs/sha256"},
        "lighting_environment_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}

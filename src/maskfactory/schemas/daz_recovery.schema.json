{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_recovery.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tiers", "rebuild_requires", "package_metadata_tier", "unknown_tier_action", "matrix_must_be_complete"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "tiers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["A", "B", "C"],
      "properties": {
        "A": {"$ref": "#/$defs/tierA"},
        "B": {"$ref": "#/$defs/tierB"},
        "C": {"$ref": "#/$defs/tierC"}
      }
    },
    "rebuild_requires": {"const": ["source_sha256", "rebuild_recipe_id", "toolchain_sha256"]},
    "package_metadata_tier": {"const": "A"},
    "unknown_tier_action": {"const": "block"},
    "matrix_must_be_complete": {"const": true}
  },
  "$defs": {
    "tierA": {"type": "object", "additionalProperties": false, "required": ["allowed_strategies", "referenced_requires_backup"], "properties": {"allowed_strategies": {"const": ["backup"]}, "referenced_requires_backup": {"const": true}}},
    "tierB": {"type": "object", "additionalProperties": false, "required": ["allowed_strategies", "referenced_requires_backup"], "properties": {"allowed_strategies": {"const": ["backup", "rebuild"]}, "referenced_requires_backup": {"const": true}}},
    "tierC": {"type": "object", "additionalProperties": false, "required": ["allowed_strategies", "referenced_requires_backup"], "properties": {"allowed_strategies": {"const": ["backup", "rebuild", "omit"]}, "referenced_requires_backup": {"const": false}}}
  }
}

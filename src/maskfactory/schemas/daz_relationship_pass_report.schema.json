{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_relationship_pass_report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "scene_id", "contract_id", "contract_sha256", "plan_id", "plan_sha256", "scene_state_sha256", "instance_contract_sha256", "geometry_contract_sha256", "execution_sha256", "file_hashes", "instance_codec", "depth_codec", "contact_pairs_codec", "front_owner_codec", "boundary_pairs_codec", "pair_records", "directed_relationships", "metrics", "findings", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "report_id": {"type": "string", "pattern": "^drpr_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"},
    "scene_id": {"type": "string"}, "contract_id": {"type": "string"}, "contract_sha256": {"$ref": "#/$defs/sha"}, "plan_id": {"type": "string"}, "plan_sha256": {"$ref": "#/$defs/sha"}, "scene_state_sha256": {"$ref": "#/$defs/sha"}, "instance_contract_sha256": {"$ref": "#/$defs/sha"}, "geometry_contract_sha256": {"$ref": "#/$defs/sha"}, "execution_sha256": {"$ref": "#/$defs/sha"},
    "file_hashes": {"type": "object", "additionalProperties": false, "required": ["instance", "depth", "contact_pairs", "front_owner", "boundary_pairs"], "properties": {"instance": {"$ref": "#/$defs/sha"}, "depth": {"$ref": "#/$defs/sha"}, "contact_pairs": {"$ref": "#/$defs/sha"}, "front_owner": {"$ref": "#/$defs/sha"}, "boundary_pairs": {"$ref": "#/$defs/sha"}, "surface": {"$ref": "#/$defs/sha"}, "facet": {"$ref": "#/$defs/sha"}, "node": {"$ref": "#/$defs/sha"}, "mapping_confidence": {"$ref": "#/$defs/sha"}, "amodal_geometry": {"$ref": "#/$defs/sha"}}},
    "instance_codec": {"$ref": "#/$defs/pngU16"}, "depth_codec": {"type": "object"}, "contact_pairs_codec": {"$ref": "#/$defs/pairPng"}, "front_owner_codec": {"$ref": "#/$defs/pngU16"}, "boundary_pairs_codec": {"$ref": "#/$defs/pairPng"},
    "pair_records": {"type": "array", "items": {"$ref": "#/$defs/pairRecord"}},
    "directed_relationships": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["source_instance_id", "target_instance_id", "type"], "properties": {"source_instance_id": {"type": "integer", "minimum": 1, "maximum": 4}, "target_instance_id": {"type": "integer", "minimum": 1, "maximum": 4}, "type": {"enum": ["contact", "occludes", "occluded_by"]}}}},
    "metrics": {"type": "object", "additionalProperties": false, "required": ["contact_pixels", "boundary_pixels", "invalid_pair_order_pixels", "unknown_pair_pixels", "contact_outside_boundary_pixels", "front_owner_invalid_pixels", "boundary_adjacency_invalid_pixels", "missing_adjacent_pair_count"], "properties": {"contact_pixels": {"type": "integer", "minimum": -1}, "boundary_pixels": {"type": "integer", "minimum": -1}, "invalid_pair_order_pixels": {"type": "integer", "minimum": -1}, "unknown_pair_pixels": {"type": "integer", "minimum": -1}, "contact_outside_boundary_pixels": {"type": "integer", "minimum": -1}, "front_owner_invalid_pixels": {"type": "integer", "minimum": -1}, "boundary_adjacency_invalid_pixels": {"type": "integer", "minimum": -1}, "missing_adjacent_pair_count": {"type": "integer", "minimum": -1}}},
    "findings": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["code", "path", "detail"], "properties": {"code": {"type": "string", "pattern": "^RELATIONSHIP_[A-Z0-9_]+$"}, "path": {"type": "string", "pattern": "^/"}, "detail": {"type": "string"}}}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["passed", "finding_count", "failure_codes", "scene_state_unchanged", "pair_count", "contact_pair_count", "reciprocal_relationships_exact"], "properties": {"passed": {"type": "boolean"}, "finding_count": {"type": "integer", "minimum": 0}, "failure_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "scene_state_unchanged": {"type": "boolean"}, "pair_count": {"type": "integer", "minimum": 0, "maximum": 6}, "contact_pair_count": {"type": "integer", "minimum": 0, "maximum": 6}, "reciprocal_relationships_exact": {"type": "boolean"}}}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "pair": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1, "maximum": 4}},
    "pngU16": {"type": "object"},
    "pairPng": {"type": "object", "additionalProperties": false, "required": ["format", "bit_depth", "color_type", "channels", "resolution", "interlace", "bytes"], "properties": {"format": {"const": "PNG"}, "bit_depth": {"const": 16}, "color_type": {"const": 4}, "channels": {"const": 2}, "resolution": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}}, "interlace": {"const": 0}, "bytes": {"type": "integer", "minimum": 1}}},
    "region": {"type": "object", "additionalProperties": false, "required": ["a_part_id", "b_part_id", "area_mm2"], "properties": {"a_part_id": {"type": "integer", "minimum": 0, "maximum": 65535}, "b_part_id": {"type": "integer", "minimum": 0, "maximum": 65535}, "area_mm2": {"type": "number", "exclusiveMinimum": 0}}},
    "pairRecord": {"type": "object", "additionalProperties": false, "required": ["pair", "minimum_surface_distance_mm", "maximum_penetration_mm", "minimum_normal_dot", "contact", "contact_regions", "visible_boundary_pixels", "front_owner_counts", "depth_sample_count", "depth_tie_count", "occlusion_direction", "depth_order_confidence"], "properties": {"pair": {"$ref": "#/$defs/pair"}, "minimum_surface_distance_mm": {"type": "number", "minimum": 0}, "maximum_penetration_mm": {"type": "number", "minimum": 0}, "minimum_normal_dot": {"type": "number", "minimum": -1, "maximum": 1}, "contact": {"type": "boolean"}, "contact_regions": {"type": "array", "items": {"$ref": "#/$defs/region"}}, "visible_boundary_pixels": {"type": "integer", "minimum": 0}, "front_owner_counts": {"type": "object", "minProperties": 2, "maxProperties": 2, "additionalProperties": {"type": "integer", "minimum": 0}}, "depth_sample_count": {"type": "integer", "minimum": 0}, "depth_tie_count": {"type": "integer", "minimum": 0}, "occlusion_direction": {"enum": ["none", "a_front", "b_front", "mixed"]}, "depth_order_confidence": {"type": "number", "minimum": 0, "maximum": 1}}}
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_render_pass_execution_report.schema.json",
  "title": "MaskFactory DAZ render-pass execution validation report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "report_id", "report_sha256", "scene_id", "plan_id",
    "plan_sha256", "scene_state_sha256", "execution_sha256", "pass_file_map_sha256",
    "findings", "summary"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "report_id": {"type": "string", "pattern": "^dcrx_[0-9a-f]{24}$"},
    "report_sha256": {"$ref": "#/$defs/sha256"},
    "scene_id": {"type": "string", "pattern": "^daz_scene_[A-Za-z0-9_-]+$"},
    "plan_id": {"type": "string", "pattern": "^dcrp_[0-9a-f]{24}$"},
    "plan_sha256": {"$ref": "#/$defs/sha256"},
    "scene_state_sha256": {"$ref": "#/$defs/sha256"},
    "execution_sha256": {"$ref": "#/$defs/sha256"},
    "pass_file_map_sha256": {"$ref": "#/$defs/sha256"},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "path", "detail"],
        "properties": {
          "code": {"type": "string", "pattern": "^PASS_[A-Z0-9_]+$"},
          "path": {"type": "string", "pattern": "^/"},
          "detail": {"type": "string"}
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed", "finding_count", "failure_codes", "pass_count",
        "scene_state_unchanged"
      ],
      "properties": {
        "passed": {"type": "boolean"},
        "finding_count": {"type": "integer", "minimum": 0},
        "failure_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^PASS_[A-Z0-9_]+$"}
        },
        "pass_count": {"type": "integer", "minimum": 1},
        "scene_state_unchanged": {"type": "boolean"}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}

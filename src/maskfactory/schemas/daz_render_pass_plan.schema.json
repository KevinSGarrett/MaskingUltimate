{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_render_pass_plan.schema.json",
  "title": "MaskFactory immutable DAZ render-pass plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "plan_id", "plan_sha256", "scene_id", "resolved_state_id",
    "resolved_state_sha256", "scene_state_sha256", "policy_sha256", "profile",
    "profile_version", "boundary_convention", "integer_map_rules",
    "parent_semantic_set", "semantic_rerender_forbidden", "outputs"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "plan_id": {"type": "string", "pattern": "^dcrp_[0-9a-f]{24}$"},
    "plan_sha256": {"$ref": "#/$defs/sha256"},
    "scene_id": {"type": "string", "pattern": "^daz_scene_[A-Za-z0-9_-]+$"},
    "resolved_state_id": {"type": "string", "pattern": "^dcrs_[0-9a-f]{24}$"},
    "resolved_state_sha256": {"$ref": "#/$defs/sha256"},
    "scene_state_sha256": {"$ref": "#/$defs/sha256"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "profile": {
      "enum": [
        "engineering_minimal", "training_standard", "training_relationship",
        "diagnostic_full", "rgb_variant"
      ]
    },
    "profile_version": {"const": "1.0.0"},
    "boundary_convention": {"$ref": "#/$defs/boundary"},
    "integer_map_rules": {"$ref": "#/$defs/integerRules"},
    "parent_semantic_set": {
      "oneOf": [{"type": "null"}, {"$ref": "#/$defs/parentSemanticSet"}]
    },
    "semantic_rerender_forbidden": {"type": "boolean"},
    "outputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/output"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "resolution": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"type": "integer", "minimum": 1}
    },
    "crop": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"type": "integer", "minimum": 0}
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode", "sample_grid", "alpha_threshold", "ownership_rule", "tie_break",
        "transparent_surface_handling", "hard_map_downsample_filter",
        "coverage_alpha_downsample_filter", "edge_uncertainty_radius_pixels"
      ],
      "properties": {
        "mode": {"const": "supersampled_deterministic_ownership"},
        "sample_grid": {"const": "4x4"},
        "alpha_threshold": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "ownership_rule": {"const": "maximum_visible_coverage"},
        "tie_break": {"const": ["frontmost_depth", "stable_node_id"]},
        "transparent_surface_handling": {"const": "evaluated_opacity"},
        "hard_map_downsample_filter": {"const": "deterministic_ownership"},
        "coverage_alpha_downsample_filter": {"const": "box_linear"},
        "edge_uncertainty_radius_pixels": {"const": 1}
      }
    },
    "integerRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exact_nearest_neighbor_decode", "forbidden", "background_value"],
      "properties": {
        "exact_nearest_neighbor_decode": {"const": true},
        "forbidden": {
          "const": [
            "jpeg", "palette_quantization", "color_management", "tone_mapping",
            "denoising", "bloom", "motion_blur", "depth_of_field", "lossy_resize"
          ]
        },
        "background_value": {"const": 0}
      }
    },
    "parentSemanticSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantic_set_id", "semantic_set_sha256", "scene_state_sha256",
        "resolution", "crop"
      ],
      "properties": {
        "semantic_set_id": {"type": "string", "pattern": "^semantic_[A-Za-z0-9_-]+$"},
        "semantic_set_sha256": {"$ref": "#/$defs/sha256"},
        "scene_state_sha256": {"$ref": "#/$defs/sha256"},
        "resolution": {"$ref": "#/$defs/resolution"},
        "crop": {"$ref": "#/$defs/crop"}
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence", "role", "encoding", "semantic", "train_eligible",
        "scene_state_sha256", "resolution", "crop", "integer_map_rules_required"
      ],
      "properties": {
        "sequence": {"type": "integer", "minimum": 0},
        "role": {"type": "string", "minLength": 1},
        "encoding": {"type": "string", "minLength": 1},
        "semantic": {"type": "boolean"},
        "train_eligible": {"type": "boolean"},
        "scene_state_sha256": {"$ref": "#/$defs/sha256"},
        "resolution": {"$ref": "#/$defs/resolution"},
        "crop": {"$ref": "#/$defs/crop"},
        "integer_map_rules_required": {"type": "boolean"}
      }
    }
  }
}

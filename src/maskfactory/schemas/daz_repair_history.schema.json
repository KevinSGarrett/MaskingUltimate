{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_repair_history.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "history_id", "history_sha256", "demand_id", "entity_id", "authority_freeze", "policy_sha256", "entries", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "history_id": {"type": "string", "pattern": "^drrh_[0-9a-f]{24}$"},
    "history_sha256": {"$ref": "#/$defs/sha"},
    "demand_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "entity_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "authority_freeze": {"$ref": "#/$defs/authority"},
    "policy_sha256": {"$ref": "#/$defs/sha"},
    "entries": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/entry"}},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry_count", "scheduled_count", "rejected_count", "exhausted_count", "coverage_deficit_count", "latest_entry_sha256"],
      "properties": {
        "entry_count": {"type": "integer", "minimum": 1},
        "scheduled_count": {"type": "integer", "minimum": 0},
        "rejected_count": {"type": "integer", "minimum": 0},
        "exhausted_count": {"type": "integer", "minimum": 0},
        "coverage_deficit_count": {"type": "integer", "minimum": 0},
        "latest_entry_sha256": {"$ref": "#/$defs/sha"}
      }
    }
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_sha256", "mapping_set_sha256", "label_table_sha256", "truth_tier", "training_weight_sha256", "required_validator_set_sha256"],
      "properties": {
        "ontology_sha256": {"$ref": "#/$defs/sha"},
        "mapping_set_sha256": {"$ref": "#/$defs/sha"},
        "label_table_sha256": {"$ref": "#/$defs/sha"},
        "truth_tier": {"type": "string", "minLength": 1},
        "training_weight_sha256": {"$ref": "#/$defs/sha"},
        "required_validator_set_sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "request_id", "request_sha256", "validation_report_id", "validation_report_sha256", "validator_id", "reason_code", "defect_code", "reason_family", "disposition", "retry_class", "action", "attempt", "maximum_attempts", "parent_recipe_sha256", "parent_recipe_revision", "next_recipe_revision", "next_recipe_revision_id", "delta", "previous_entry_sha256", "entry_sha256", "full_revalidation_required", "coverage_deficit", "quarantine_recommended"],
      "properties": {
        "sequence": {"type": "integer", "minimum": 1},
        "request_id": {"type": "string", "pattern": "^drrq_[0-9a-f]{24}$"},
        "request_sha256": {"$ref": "#/$defs/sha"},
        "validation_report_id": {"type": "string", "pattern": "^dvsr_[0-9a-f]{24}$"},
        "validation_report_sha256": {"$ref": "#/$defs/sha"},
        "validator_id": {"type": "string", "pattern": "^DAZ-V[0-9]-[0-9]{3}$"},
        "reason_code": {"type": "string"},
        "defect_code": {"type": "string"},
        "reason_family": {"type": "string"},
        "disposition": {"enum": ["scheduled", "rejected_nonrepairable", "budget_exhausted"]},
        "retry_class": {"type": ["string", "null"]},
        "action": {"type": ["string", "null"]},
        "attempt": {"type": "integer", "minimum": 0},
        "maximum_attempts": {"type": "integer", "minimum": 0},
        "parent_recipe_sha256": {"$ref": "#/$defs/sha"},
        "parent_recipe_revision": {"type": "integer", "minimum": 0},
        "next_recipe_revision": {"type": ["integer", "null"], "minimum": 1},
        "next_recipe_revision_id": {"oneOf": [{"type": "null"}, {"type": "string", "pattern": "^daz_recipe_revision_[0-9a-f]{24}$"}]},
        "delta": {"type": "object"},
        "previous_entry_sha256": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/sha"}]},
        "entry_sha256": {"$ref": "#/$defs/sha"},
        "full_revalidation_required": {"const": true},
        "coverage_deficit": {"type": "boolean"},
        "quarantine_recommended": {"type": "boolean"}
      }
    }
  }
}

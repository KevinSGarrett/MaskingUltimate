{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_repair_request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "request_sha256", "demand_id", "entity_id", "parent_recipe_sha256", "parent_recipe_revision", "validation_report_id", "validation_report_sha256", "validator_id", "reason_code", "defect_code", "proposed_delta", "authority_freeze", "policy_sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "request_id": {"type": "string", "pattern": "^drrq_[0-9a-f]{24}$"},
    "request_sha256": {"$ref": "#/$defs/sha"},
    "demand_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "entity_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "parent_recipe_sha256": {"$ref": "#/$defs/sha"},
    "parent_recipe_revision": {"type": "integer", "minimum": 0},
    "validation_report_id": {"type": "string", "pattern": "^dvsr_[0-9a-f]{24}$"},
    "validation_report_sha256": {"$ref": "#/$defs/sha"},
    "validator_id": {"type": "string", "pattern": "^DAZ-V[0-9]-[0-9]{3}$"},
    "reason_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,127}$"},
    "defect_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,127}$"},
    "proposed_delta": {"type": "object"},
    "authority_freeze": {"$ref": "#/$defs/authority"},
    "policy_sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_sha256", "mapping_set_sha256", "label_table_sha256", "truth_tier", "training_weight_sha256", "required_validator_set_sha256"],
      "properties": {
        "ontology_sha256": {"$ref": "#/$defs/sha"},
        "mapping_set_sha256": {"$ref": "#/$defs/sha"},
        "label_table_sha256": {"$ref": "#/$defs/sha"},
        "truth_tier": {"type": "string", "minLength": 1},
        "training_weight_sha256": {"$ref": "#/$defs/sha"},
        "required_validator_set_sha256": {"$ref": "#/$defs/sha"}
      }
    }
  }
}

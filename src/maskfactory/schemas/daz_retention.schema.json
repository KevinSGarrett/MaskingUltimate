{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_retention.schema.json",
  "title": "MaskFactory DAZ storage reservation and retention policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reservation_multiplier_numerator",
    "reservation_multiplier_denominator",
    "classes",
    "protected_classes",
    "file_only_deletion",
    "symlink_deletion_prohibited",
    "active_lease_protection_required",
    "hash_recheck_required",
    "dry_run_default"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "reservation_multiplier_numerator": {"const": 5},
    "reservation_multiplier_denominator": {"const": 4},
    "classes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["R0", "R1", "R2", "R3", "R4", "R5", "R6", "R7"],
      "properties": {
        "R0": {"$ref": "#/$defs/protected_class"},
        "R1": {"$ref": "#/$defs/protected_class"},
        "R2": {"$ref": "#/$defs/protected_class"},
        "R3": {"$ref": "#/$defs/deletable_class"},
        "R4": {"$ref": "#/$defs/deletable_class"},
        "R5": {"$ref": "#/$defs/deletable_class"},
        "R6": {"$ref": "#/$defs/deletable_class"},
        "R7": {"$ref": "#/$defs/protected_class"}
      }
    },
    "protected_classes": {
      "type": "array",
      "prefixItems": [
        {"const": "R0"},
        {"const": "R1"},
        {"const": "R2"},
        {"const": "R7"}
      ],
      "items": false,
      "minItems": 4,
      "maxItems": 4
    },
    "file_only_deletion": {"const": true},
    "symlink_deletion_prohibited": {"const": true},
    "active_lease_protection_required": {"const": true},
    "hash_recheck_required": {"const": true},
    "dry_run_default": {"const": true}
  },
  "$defs": {
    "class": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deletable", "minimum_age_hours", "purge_priority"],
      "properties": {
        "deletable": {"type": "boolean"},
        "minimum_age_hours": {"type": "integer", "minimum": 0},
        "purge_priority": {"type": "integer", "minimum": 0, "maximum": 100}
      }
    },
    "protected_class": {
      "allOf": [
        {"$ref": "#/$defs/class"},
        {"properties": {"deletable": {"const": false}, "purge_priority": {"const": 0}}}
      ]
    },
    "deletable_class": {
      "allOf": [
        {"$ref": "#/$defs/class"},
        {
          "properties": {
            "deletable": {"const": true},
            "purge_priority": {"type": "integer", "minimum": 1, "maximum": 100}
          }
        }
      ]
    }
  }
}

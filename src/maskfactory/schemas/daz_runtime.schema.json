{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_runtime.schema.json",
  "title": "MaskFactory DAZ named runtime profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "profile_id", "instance_name", "execution_mode",
    "process_lifetime", "bundle_version", "startup", "content_directories",
    "runtime_paths", "timeouts_seconds", "watchdog", "safety"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "profile_id": {"const": "maskfactory_daz_hidden_v1"},
    "instance_name": {"const": "MaskFactoryDAZ"},
    "execution_mode": {"const": "hidden_gui"},
    "process_lifetime": {"const": "process_per_job"},
    "bundle_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "startup": {
      "type": "object", "additionalProperties": false,
      "required": ["no_default_scene", "no_prompt", "no_startup_actions", "log_size"],
      "properties": {
        "no_default_scene": {"const": true},
        "no_prompt": {"const": true},
        "no_startup_actions": {"const": true},
        "log_size": {"const": "100m"}
      }
    },
    "content_directories": {
      "type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true,
      "prefixItems": [
        {"const": "F:\\DAZ\\03_content\\libraries\\MaskFactory_DAZ_Library"},
        {"const": "F:\\DAZ\\03_content\\libraries\\MaskFactory_User_Library"}
      ],
      "items": false
    },
    "runtime_paths": {
      "type": "object", "additionalProperties": false,
      "required": [
        "app_profile", "bundle_versions", "active_bundle", "job_partial_root",
        "job_result_root", "worker_log_root", "control_state"
      ],
      "properties": {
        "app_profile": {"const": "F:\\DAZ\\04_runtime\\app_profiles\\MaskFactoryDAZ"},
        "bundle_versions": {"const": "F:\\DAZ\\04_runtime\\scripts\\versions"},
        "active_bundle": {"const": "F:\\DAZ\\04_runtime\\scripts\\active"},
        "job_partial_root": {"const": "F:\\DAZ\\11_scene_state\\partial"},
        "job_result_root": {"const": "F:\\DAZ\\10_queue\\complete"},
        "worker_log_root": {"const": "F:\\DAZ\\17_logs\\workers"},
        "control_state": {"const": "F:\\DAZ\\00_control\\runtime_state.json"}
      }
    },
    "timeouts_seconds": {
      "type": "object", "additionalProperties": false,
      "required": [
        "startup", "asset_load", "assembly", "simulation", "smoke_render",
        "rgb_render", "id_render", "finalize"
      ],
      "properties": {
        "startup": {"const": 180}, "asset_load": {"const": 120},
        "assembly": {"const": 600}, "simulation": {"const": 1800},
        "smoke_render": {"const": 300}, "rgb_render": {"const": 1800},
        "id_render": {"const": 600}, "finalize": {"const": 120}
      }
    },
    "watchdog": {
      "type": "object", "additionalProperties": false,
      "required": [
        "poll_interval_seconds", "quarantine_on_dialog", "terminate_process_tree",
        "dialog_title_patterns"
      ],
      "properties": {
        "poll_interval_seconds": {"type": "number", "minimum": 0.1, "maximum": 5},
        "quarantine_on_dialog": {"const": true},
        "terminate_process_tree": {"const": true},
        "dialog_title_patterns": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "safety": {
      "type": "object", "additionalProperties": false,
      "required": [
        "automatic_asset_install", "automatic_asset_purchase", "automatic_account_login",
        "click_dialogs", "persistent_worker", "minimum_render_free_gib"
      ],
      "properties": {
        "automatic_asset_install": {"const": false},
        "automatic_asset_purchase": {"const": false},
        "automatic_account_login": {"const": false},
        "click_dialogs": {"const": false},
        "persistent_worker": {"const": false},
        "minimum_render_free_gib": {"const": 150}
      }
    }
  }
}

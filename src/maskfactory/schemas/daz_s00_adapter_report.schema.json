{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_s00_adapter_report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "policy_version", "policy_sha256", "certificate_id", "certificate_sha256", "contract_id", "contract_sha256", "scene_id", "image_id", "scene_family_id", "variant_group_id", "ontology_version", "ontology_sha256", "source_record", "packages", "invariants", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "report_id": {"type": "string", "pattern": "^dsar_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"}, "policy_version": {"const": "1.0.0"}, "policy_sha256": {"$ref": "#/$defs/sha"},
    "certificate_id": {"type": "string", "pattern": "^dacc_[0-9a-f]{24}$"}, "certificate_sha256": {"$ref": "#/$defs/sha"}, "contract_id": {"type": "string", "pattern": "^dpdc_[0-9a-f]{24}$"}, "contract_sha256": {"$ref": "#/$defs/sha"},
    "scene_id": {"type": "string"}, "image_id": {"type": "string"}, "scene_family_id": {"type": "string"}, "variant_group_id": {"type": "string"}, "ontology_version": {"enum": ["body_parts_v1", "body_parts_v2"]}, "ontology_sha256": {"$ref": "#/$defs/sha"},
    "source_record": {"type": "object", "additionalProperties": false, "required": ["source_origin", "image_id", "scene_id", "group_id", "pristine_rgb_sha256", "provider_voting_bypassed", "package_verification_bypassed"], "properties": {"source_origin": {"const": "synthetic"}, "image_id": {"type": "string"}, "scene_id": {"type": "string"}, "group_id": {"type": "string"}, "pristine_rgb_sha256": {"$ref": "#/$defs/sha"}, "provider_voting_bypassed": {"const": true}, "package_verification_bypassed": {"const": false}}},
    "packages": {"type": "array", "minItems": 1, "maxItems": 4, "items": {"type": "object", "additionalProperties": false, "required": ["p_index", "instance_id", "source_package_id", "maskfactory_package_id", "manifest_sha256", "source_package_tree_sha256", "output_tree_sha256", "target_pixels", "other_person_pixels", "candidate_bbox", "relative_root"], "properties": {"p_index": {"enum": ["p0", "p1", "p2", "p3"]}, "instance_id": {"type": "integer", "minimum": 1, "maximum": 4}, "source_package_id": {"type": "string"}, "maskfactory_package_id": {"type": "string"}, "manifest_sha256": {"$ref": "#/$defs/sha"}, "source_package_tree_sha256": {"$ref": "#/$defs/sha"}, "output_tree_sha256": {"$ref": "#/$defs/sha"}, "target_pixels": {"type": "integer", "minimum": 1}, "other_person_pixels": {"type": "integer", "minimum": 0}, "candidate_bbox": {"$ref": "#/$defs/bbox"}, "relative_root": {"type": "string", "pattern": "^packages/p[0-3]$"}}}},
    "invariants": {"type": "object", "additionalProperties": false, "required": ["certificate_replayed", "source_tree_hashes_exact", "strict_pngs_decoded", "prominence_mapping_exact", "targets_pairwise_disjoint", "target_union_exact", "other_person_complements_exact", "protected_other_person_exact", "indexed_parts_target_scoped", "materials_target_scoped", "shared_rgb_exact", "canonical_ontology_loaded", "provider_voting_bypassed", "package_verification_preserved", "no_rerender", "source_packages_unchanged", "human_authority_absent"], "properties": {"certificate_replayed": {"const": true}, "source_tree_hashes_exact": {"const": true}, "strict_pngs_decoded": {"const": true}, "prominence_mapping_exact": {"const": true}, "targets_pairwise_disjoint": {"const": true}, "target_union_exact": {"const": true}, "other_person_complements_exact": {"const": true}, "protected_other_person_exact": {"const": true}, "indexed_parts_target_scoped": {"const": true}, "materials_target_scoped": {"const": true}, "shared_rgb_exact": {"const": true}, "canonical_ontology_loaded": {"const": true}, "provider_voting_bypassed": {"const": true}, "package_verification_preserved": {"const": true}, "no_rerender": {"const": true}, "source_packages_unchanged": {"const": true}, "human_authority_absent": {"const": true}}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["passed", "package_count", "visible_person_pixels", "train_eligible_packages"], "properties": {"passed": {"const": true}, "package_count": {"type": "integer", "minimum": 1, "maximum": 4}, "visible_person_pixels": {"type": "integer", "minimum": 1}, "train_eligible_packages": {"type": "integer", "minimum": 1, "maximum": 4}}}
  },
  "$defs": {"sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "bbox": {"type": "array", "prefixItems": [{"type": "integer", "minimum": 0}, {"type": "integer", "minimum": 0}, {"type": "integer", "minimum": 1}, {"type": "integer", "minimum": 1}], "items": false, "minItems": 4, "maxItems": 4}}
}

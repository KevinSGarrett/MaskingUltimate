{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_same_state_replay_report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "scene_id", "plan_id", "plan_sha256", "scene_state_sha256", "profile", "policy_sha256", "policy_version", "original_run_id", "replay_run_id", "original_process_id", "replay_process_id", "authority_sha256s", "original_execution_sha256", "replay_execution_sha256", "semantic_roles", "semantic_records", "rgb_records", "findings", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "report_id": {"type": "string", "pattern": "^dssr_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"},
    "scene_id": {"type": "string"}, "plan_id": {"type": "string"}, "plan_sha256": {"$ref": "#/$defs/sha"}, "scene_state_sha256": {"$ref": "#/$defs/sha"}, "profile": {"type": "string"}, "policy_sha256": {"$ref": "#/$defs/sha"}, "policy_version": {"const": "1.0.0"},
    "original_run_id": {"type": "string"}, "replay_run_id": {"type": "string"}, "original_process_id": {"type": "integer", "minimum": 1}, "replay_process_id": {"type": "integer", "minimum": 1}, "authority_sha256s": {"type": "object", "minProperties": 8, "maxProperties": 8, "additionalProperties": {"$ref": "#/$defs/sha"}}, "original_execution_sha256": {"$ref": "#/$defs/sha"}, "replay_execution_sha256": {"$ref": "#/$defs/sha"},
    "semantic_roles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}, "semantic_records": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/record"}}, "rgb_records": {"type": "array", "items": {"$ref": "#/$defs/record"}},
    "findings": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["code", "path", "detail"], "properties": {"code": {"type": "string", "pattern": "^REPLAY_[A-Z0-9_]+$"}, "path": {"type": "string", "pattern": "^/"}, "detail": {"type": "string"}}}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["passed", "finding_count", "failure_codes", "semantic_role_count", "semantic_hashes_byte_identical", "actual_files_independently_hashed", "scene_state_unchanged", "runs_independent", "authorities_identical"], "properties": {"passed": {"type": "boolean"}, "finding_count": {"type": "integer", "minimum": 0}, "failure_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "semantic_role_count": {"type": "integer", "minimum": 1}, "semantic_hashes_byte_identical": {"type": "boolean"}, "actual_files_independently_hashed": {"const": true}, "scene_state_unchanged": {"type": "boolean"}, "runs_independent": {"type": "boolean"}, "authorities_identical": {"type": "boolean"}}}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "record": {"type": "object", "additionalProperties": false, "required": ["role", "kind", "original_sha256", "replay_sha256", "original_bytes", "replay_bytes", "hash_identical", "bytes_identical", "original_execution_hash_matches", "replay_execution_hash_matches", "original_execution_bytes_match", "replay_execution_bytes_match"], "properties": {"role": {"type": "string"}, "kind": {"enum": ["file", "directory_tree"]}, "original_sha256": {"$ref": "#/$defs/sha"}, "replay_sha256": {"$ref": "#/$defs/sha"}, "original_bytes": {"type": "integer", "minimum": 1}, "replay_bytes": {"type": "integer", "minimum": 1}, "hash_identical": {"type": "boolean"}, "bytes_identical": {"type": "boolean"}, "original_execution_hash_matches": {"type": "boolean"}, "replay_execution_hash_matches": {"type": "boolean"}, "original_execution_bytes_match": {"type": "boolean"}, "replay_execution_bytes_match": {"type": "boolean"}}}
  }
}

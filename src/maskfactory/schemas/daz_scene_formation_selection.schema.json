{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_scene_formation_selection.schema.json",
  "title": "MaskFactory deterministic camera/light/environment/prop selection",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "selection_id", "selection_sha256", "graph_id", "graph_sha256", "pool_report_id", "pool_report_sha256", "foundation_selection_id", "foundation_selection_sha256", "policy_sha256", "descriptor_registry_sha256", "request", "candidate_counts", "rejection_counts", "selected", "evidence_requirements"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "selection_id": {"type": "string", "pattern": "^dcif_[0-9a-f]{24}$"},
    "selection_sha256": {"$ref": "#/$defs/sha256"},
    "graph_id": {"type": "string", "minLength": 1},
    "graph_sha256": {"$ref": "#/$defs/sha256"},
    "pool_report_id": {"type": "string", "minLength": 1},
    "pool_report_sha256": {"$ref": "#/$defs/sha256"},
    "foundation_selection_id": {"type": "string", "minLength": 1},
    "foundation_selection_sha256": {"$ref": "#/$defs/sha256"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "descriptor_registry_sha256": {"$ref": "#/$defs/sha256"},
    "request": {
      "type": "object", "additionalProperties": false,
      "required": ["selection_seed", "person_count", "azimuth_bin", "elevation_bin", "roll_bin", "focal_family", "framing_profile", "aspect_ratio", "resolution_profile", "depth_of_field_mode", "lighting_profile", "exposure_profile", "environment_family", "environment_subfamily", "context_complexity", "prop_mode"],
      "properties": {
        "selection_seed": {"type": "integer", "minimum": 0},
        "person_count": {"type": "integer", "minimum": 1, "maximum": 4},
        "azimuth_bin": {"type": "string", "minLength": 1},
        "elevation_bin": {"type": "string", "minLength": 1},
        "roll_bin": {"type": "string", "minLength": 1},
        "focal_family": {"type": "string", "minLength": 1},
        "framing_profile": {"type": "string", "minLength": 1},
        "aspect_ratio": {"type": "string", "pattern": "^[0-9]+:[0-9]+$"},
        "resolution_profile": {"type": "string", "minLength": 1},
        "depth_of_field_mode": {"type": "string", "minLength": 1},
        "lighting_profile": {"type": "string", "minLength": 1},
        "exposure_profile": {"type": "string", "minLength": 1},
        "environment_family": {"enum": ["controlled", "indoor", "outdoor"]},
        "environment_subfamily": {"type": "string", "minLength": 1},
        "context_complexity": {"type": "string", "minLength": 1},
        "prop_mode": {"enum": ["none", "support_surface", "handheld_worn", "occluder"]}
      }
    },
    "candidate_counts": {
      "type": "object", "additionalProperties": false,
      "required": ["light", "environment", "prop"],
      "properties": {
        "light": {"type": "integer", "minimum": 1},
        "environment": {"type": "integer", "minimum": 1},
        "prop": {"type": "integer", "minimum": 0}
      }
    },
    "rejection_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "selected": {
      "type": "object", "additionalProperties": false,
      "required": ["camera", "light", "environment", "prop", "exposure_profile"],
      "properties": {
        "camera": {"$ref": "#/$defs/camera"},
        "light": {"$ref": "#/$defs/asset"},
        "environment": {"$ref": "#/$defs/asset"},
        "prop": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/asset"}]},
        "exposure_profile": {"type": "string", "minLength": 1}
      }
    },
    "evidence_requirements": {
      "type": "object", "additionalProperties": false,
      "required": ["final_camera_readback_required", "projected_bbox_and_prominence_required", "pristine_annotation_camera_match_required", "final_light_environment_prop_readback_required", "prop_contact_and_occlusion_preflight_required", "undeclared_human_and_reflection_check_required", "finite_nonempty_rgb_required"],
      "properties": {
        "final_camera_readback_required": {"const": true},
        "projected_bbox_and_prominence_required": {"const": true},
        "pristine_annotation_camera_match_required": {"const": true},
        "final_light_environment_prop_readback_required": {"const": true},
        "prop_contact_and_occlusion_preflight_required": {"type": "boolean"},
        "undeclared_human_and_reflection_check_required": {"const": true},
        "finite_nonempty_rgb_required": {"const": true}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "asset": {
      "type": "object", "additionalProperties": false,
      "required": ["asset_id", "descriptor_id", "descriptor_sha256", "descriptor_type", "lighting_profile", "environment_family", "environment_subfamily", "context_complexity", "prop_mode", "prop_role", "anchor_types", "stable_object_id", "final_readback_required"],
      "properties": {
        "asset_id": {"type": "string", "pattern": "^ast_[0-9a-f]{16,64}$"},
        "descriptor_id": {"type": "string", "pattern": "^dcfd_[a-z0-9_]+$"},
        "descriptor_sha256": {"$ref": "#/$defs/sha256"},
        "descriptor_type": {"enum": ["light", "environment", "prop"]},
        "lighting_profile": {"type": ["string", "null"]},
        "environment_family": {"type": ["string", "null"]},
        "environment_subfamily": {"type": ["string", "null"]},
        "context_complexity": {"type": ["string", "null"]},
        "prop_mode": {"type": ["string", "null"]},
        "prop_role": {"type": ["string", "null"]},
        "anchor_types": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "stable_object_id": {"type": ["string", "null"]},
        "final_readback_required": {"const": true}
      }
    },
    "camera": {
      "type": "object", "additionalProperties": false,
      "required": ["projection_type", "azimuth_bin", "azimuth_degrees", "elevation_bin", "elevation_degrees", "roll_bin", "roll_degrees", "focal_family", "focal_length_mm", "orthographic_scale", "look_at_target", "framing_profile", "aspect_ratio", "resolution", "crop", "depth_of_field", "motion_blur", "lens_distortion_state", "projected_bboxes_and_prominence", "annotation_camera_effects_off", "final_readback_required"],
      "properties": {
        "projection_type": {"enum": ["perspective", "orthographic"]},
        "azimuth_bin": {"type": "string", "minLength": 1},
        "azimuth_degrees": {"type": "number", "minimum": -180, "maximum": 180},
        "elevation_bin": {"type": "string", "minLength": 1},
        "elevation_degrees": {"type": "number", "minimum": -35, "maximum": 85},
        "roll_bin": {"type": "string", "minLength": 1},
        "roll_degrees": {"type": "number", "minimum": -30, "maximum": 30},
        "focal_family": {"type": "string", "minLength": 1},
        "focal_length_mm": {"type": ["number", "null"], "minimum": 18, "maximum": 135},
        "orthographic_scale": {"type": ["number", "null"], "minimum": 2, "maximum": 4},
        "look_at_target": {"const": "promoted_people_centroid"},
        "framing_profile": {"type": "string", "minLength": 1},
        "aspect_ratio": {"type": "string", "pattern": "^[0-9]+:[0-9]+$"},
        "resolution": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 512, "maximum": 3641}},
        "crop": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "integer", "minimum": 0, "maximum": 3641}},
        "depth_of_field": {
          "type": "object", "additionalProperties": false,
          "required": ["mode", "enabled", "f_stop"],
          "properties": {"mode": {"type": "string"}, "enabled": {"type": "boolean"}, "f_stop": {"type": ["number", "null"]}}
        },
        "motion_blur": {
          "type": "object", "additionalProperties": false,
          "required": ["mode", "enabled"],
          "properties": {"mode": {"const": "off"}, "enabled": {"const": false}}
        },
        "lens_distortion_state": {"const": "pristine_none"},
        "projected_bboxes_and_prominence": {"const": "required_final_readback"},
        "annotation_camera_effects_off": {"const": true},
        "final_readback_required": {"const": true}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_scene_preflight_report.schema.json",
  "title": "MaskFactory deterministic scene geometry preflight report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "scene_id", "pose_selection_id", "pose_selection_sha256", "formation_selection_id", "formation_selection_sha256", "observation_sha256", "policy_sha256", "checks", "findings", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "report_id": {"type": "string", "pattern": "^dcpf_[0-9a-f]{24}$"},
    "report_sha256": {"$ref": "#/$defs/sha256"},
    "scene_id": {"type": "string", "pattern": "^daz_scene_[A-Za-z0-9_-]+$"},
    "pose_selection_id": {"type": "string", "pattern": "^dcps_[0-9a-f]{24}$"},
    "pose_selection_sha256": {"$ref": "#/$defs/sha256"},
    "formation_selection_id": {"type": "string", "pattern": "^dcif_[0-9a-f]{24}$"},
    "formation_selection_sha256": {"$ref": "#/$defs/sha256"},
    "observation_sha256": {"$ref": "#/$defs/sha256"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "checks": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["passed"],
        "properties": {"passed": {"type": "boolean"}}
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "path", "detail"],
        "properties": {
          "code": {"type": "string", "pattern": "^(ASSEMBLY|GEOMETRY)_[A-Z0-9_]+$"},
          "path": {"type": "string", "pattern": "^/"},
          "detail": {"type": "string"}
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "finding_count", "failure_codes", "disposition", "repair_attempt", "repair_attempts_remaining", "new_recipe_revision_required_for_repair"],
      "properties": {
        "passed": {"type": "boolean"},
        "finding_count": {"type": "integer", "minimum": 0},
        "failure_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^(ASSEMBLY|GEOMETRY)_[A-Z0-9_]+$"}},
        "disposition": {"enum": ["accept", "repair", "reject"]},
        "repair_attempt": {"type": "integer", "minimum": 0},
        "repair_attempts_remaining": {"type": "integer", "minimum": 0, "maximum": 2},
        "new_recipe_revision_required_for_repair": {"type": "boolean"}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}

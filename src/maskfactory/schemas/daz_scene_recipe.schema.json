{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_scene_recipe.schema.json",
  "title": "MaskFactory DAZ worker recipe",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "job_id", "recipe_id", "created_at", "bundle_version",
    "operation", "requires_gpu", "content_directories", "payload"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "job_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"},
    "recipe_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "bundle_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "operation": {"enum": ["runtime_probe", "asset_smoke", "render_scene"]},
    "requires_gpu": {"type": "boolean"},
    "content_directories": {
      "type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true,
      "items": {"type": "string", "minLength": 3}
    },
    "payload": {"type": "object"}
  },
  "allOf": [
    {
      "if": {"properties": {"operation": {"enum": ["asset_smoke", "render_scene"]}}},
      "then": {"properties": {"requires_gpu": {"const": true}}}
    },
    {
      "if": {"properties": {"operation": {"const": "runtime_probe"}}},
      "then": {"properties": {"requires_gpu": {"const": false}}}
    }
  ]
}

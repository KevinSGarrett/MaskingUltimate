{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_solo_pose_selection.schema.json",
  "title": "MaskFactory deterministic qualified solo-pose selection",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "selection_id", "selection_sha256", "graph_id", "graph_sha256", "pool_report_id", "pool_report_sha256", "foundation_selection_id", "foundation_selection_sha256", "policy_sha256", "descriptor_registry_sha256", "request", "candidate_counts", "rejection_counts", "selected", "compatibility_evidence"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "selection_id": {"type": "string", "pattern": "^dcps_[0-9a-f]{24}$"},
    "selection_sha256": {"$ref": "#/$defs/sha256"},
    "graph_id": {"type": "string", "minLength": 1},
    "graph_sha256": {"$ref": "#/$defs/sha256"},
    "pool_report_id": {"type": "string", "minLength": 1},
    "pool_report_sha256": {"$ref": "#/$defs/sha256"},
    "foundation_selection_id": {"type": "string", "minLength": 1},
    "foundation_selection_sha256": {"$ref": "#/$defs/sha256"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "descriptor_registry_sha256": {"$ref": "#/$defs/sha256"},
    "request": {
      "type": "object", "additionalProperties": false,
      "required": ["selection_seed", "pose_family", "pose_subfamily"],
      "properties": {
        "selection_seed": {"type": "integer", "minimum": 0},
        "pose_family": {"type": "string", "minLength": 1},
        "pose_subfamily": {"type": "string", "minLength": 1}
      }
    },
    "candidate_counts": {
      "type": "object", "additionalProperties": false,
      "required": ["qualified_pose_pool_members", "matching_candidates"],
      "properties": {
        "qualified_pose_pool_members": {"type": "integer", "minimum": 1},
        "matching_candidates": {"type": "integer", "minimum": 1}
      }
    },
    "rejection_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "selected": {
      "type": "object", "additionalProperties": false,
      "required": ["pose_asset_id", "descriptor_id", "descriptor_sha256", "primary_asset_class", "pose_family", "pose_subfamily", "root_transform_policy", "root_transform", "owned_bones", "bone_rotations_deg", "support_mode", "support_contacts", "visibility_expectation", "self_occlusion_tags", "asymmetry_tag", "camera_view_suitability", "joint_metrics", "source_readback_required", "final_daz_readback_required"],
      "properties": {
        "pose_asset_id": {"type": "string", "pattern": "^ast_[0-9a-f]{16,64}$"},
        "descriptor_id": {"type": "string", "pattern": "^dcpd_[a-z0-9_]+$"},
        "descriptor_sha256": {"$ref": "#/$defs/sha256"},
        "primary_asset_class": {"enum": ["pose_full_body", "pose_partial_upper", "pose_partial_lower", "pose_hand_left", "pose_hand_right", "pose_foot", "animation"]},
        "pose_family": {"type": "string", "minLength": 1},
        "pose_subfamily": {"type": "string", "minLength": 1},
        "root_transform_policy": {"enum": ["preserve_root", "bounded_root", "support_aligned", "airborne"]},
        "root_transform": {"$ref": "#/$defs/root_transform"},
        "owned_bones": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}},
        "bone_rotations_deg": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/axes"}},
        "support_mode": {"type": "string", "minLength": 1},
        "support_contacts": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}},
        "visibility_expectation": {
          "type": "object", "additionalProperties": false,
          "required": ["hands", "feet"],
          "properties": {
            "hands": {"enum": ["both_visible", "left_visible", "right_visible", "partially_visible", "not_expected"]},
            "feet": {"enum": ["both_visible", "left_visible", "right_visible", "partially_visible", "not_expected"]}
          }
        },
        "self_occlusion_tags": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "asymmetry_tag": {"enum": ["symmetric", "left_dominant", "right_dominant", "bilateral_asymmetric"]},
        "camera_view_suitability": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["front", "back", "left_profile", "right_profile", "overhead", "low_angle"]}},
        "joint_metrics": {
          "type": "object", "additionalProperties": false,
          "required": ["limit_source", "bone_count", "axis_value_count", "maximum_utilization", "minimum_boundary_margin_degrees", "intersection_score", "passed"],
          "properties": {
            "limit_source": {"const": "daz_runtime_property_limits"},
            "bone_count": {"type": "integer", "minimum": 1},
            "axis_value_count": {"type": "integer", "minimum": 3},
            "maximum_utilization": {"type": "number", "minimum": 0, "maximum": 0.98},
            "minimum_boundary_margin_degrees": {"type": "number", "minimum": 0.25},
            "intersection_score": {"type": "number", "minimum": 0, "maximum": 0.05},
            "passed": {"const": true}
          }
        },
        "source_readback_required": {"const": true},
        "final_daz_readback_required": {"const": true}
      }
    },
    "compatibility_evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["asset_runtime_qualified", "required_dependencies_runtime_qualified", "genesis_9_compatible", "solo_only", "taxonomy_match", "root_transform_within_policy", "joint_limits_within_runtime_bounds", "hand_foot_articulation_declared_valid", "intersection_score_within_policy"],
      "properties": {
        "asset_runtime_qualified": {"const": true},
        "required_dependencies_runtime_qualified": {"const": true},
        "genesis_9_compatible": {"const": true},
        "solo_only": {"const": true},
        "taxonomy_match": {"const": true},
        "root_transform_within_policy": {"const": true},
        "joint_limits_within_runtime_bounds": {"const": true},
        "hand_foot_articulation_declared_valid": {"const": true},
        "intersection_score_within_policy": {"const": true}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "axes": {
      "type": "object", "additionalProperties": false,
      "required": ["bend", "twist", "side_side"],
      "properties": {
        "bend": {"type": "number", "minimum": -360, "maximum": 360},
        "twist": {"type": "number", "minimum": -360, "maximum": 360},
        "side_side": {"type": "number", "minimum": -360, "maximum": 360}
      }
    },
    "root_transform": {
      "type": "object", "additionalProperties": false,
      "required": ["translation_cm", "rotation_deg"],
      "properties": {
        "translation_cm": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "number", "minimum": -250, "maximum": 250}},
        "rotation_deg": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "number", "minimum": -180, "maximum": 180}}
      }
    }
  }
}

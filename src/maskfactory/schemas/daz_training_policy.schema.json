{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_training_policy.schema.json",
  "title": "MaskFactory DAZ train-only authority policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_origin",
    "source_role",
    "truth_tier",
    "truth_partition",
    "training_loss_weight",
    "minimum_training_loss_weight",
    "maximum_training_loss_weight",
    "maximum_synthetic_image_fraction",
    "holdout_eligible",
    "calibration_eligible",
    "dataset_volume_eligible",
    "counts_as_human_anchor_gold",
    "counts_as_autonomous_certified_gold",
    "group_by"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "source_origin": {"const": "synthetic"},
    "source_role": {"const": "synthetic_geometry_exact"},
    "truth_tier": {"const": "weighted_pseudo_label"},
    "truth_partition": {"const": "train"},
    "training_loss_weight": {"type": "number", "minimum": 0.10, "maximum": 0.25},
    "minimum_training_loss_weight": {"const": 0.10},
    "maximum_training_loss_weight": {"const": 0.25},
    "maximum_synthetic_image_fraction": {"const": 0.30},
    "holdout_eligible": {"const": false},
    "calibration_eligible": {"const": false},
    "dataset_volume_eligible": {"const": false},
    "counts_as_human_anchor_gold": {"const": false},
    "counts_as_autonomous_certified_gold": {"const": false},
    "group_by": {"const": ["scene_family_id", "pristine_image_id", "variant_family_id"]}
  }
}

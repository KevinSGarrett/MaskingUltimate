{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_validation_result.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["validator_id", "validator_version", "entity_id", "status", "reason_code", "metric", "observed", "expected", "evidence_paths", "retryability", "affected_asset_ids", "affected_mapping_ids"],
  "properties": {
    "validator_id": {"type": "string", "pattern": "^DAZ-V[0-9]-[0-9]{3}$"}, "validator_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}, "entity_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "status": {"enum": ["pass", "fail", "warn", "not_applicable"]}, "reason_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,127}$"}, "metric": {"type": ["string", "null"]}, "observed": {}, "expected": {},
    "evidence_paths": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$"}},
    "retryability": {"enum": ["none", "same_recipe", "adjusted_recipe", "asset_retest"]}, "affected_asset_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "affected_mapping_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  }
}

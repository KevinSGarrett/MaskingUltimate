{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_validation_set_report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "report_id", "report_sha256", "registry_version", "registry_sha256", "entity_id", "scope", "required_validator_ids", "results", "layer_summary", "findings", "summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "report_id": {"type": "string", "pattern": "^dvsr_[0-9a-f]{24}$"}, "report_sha256": {"$ref": "#/$defs/sha"}, "registry_version": {"const": "1.0.0"}, "registry_sha256": {"$ref": "#/$defs/sha"}, "entity_id": {"type": "string"}, "scope": {"enum": ["scene", "corpus"]},
    "required_validator_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "results": {"type": "array", "items": {"type": "object"}},
    "layer_summary": {"type": "object", "additionalProperties": false, "patternProperties": {"^V[0-9]$": {"type": "object", "additionalProperties": false, "required": ["pass", "fail", "warn", "not_applicable", "required_satisfied"], "properties": {"pass": {"type": "integer", "minimum": 0}, "fail": {"type": "integer", "minimum": 0}, "warn": {"type": "integer", "minimum": 0}, "not_applicable": {"type": "integer", "minimum": 0}, "required_satisfied": {"type": "boolean"}}}}},
    "findings": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["code", "path", "detail"], "properties": {"code": {"type": "string", "pattern": "^VALIDATION_[A-Z0-9_]+$"}, "path": {"type": "string", "pattern": "^/"}, "detail": {"type": "string"}}}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["passed", "finding_count", "failure_codes", "result_count", "required_count", "required_pass_count", "required_satisfied_count", "warning_count", "failed_count", "not_applicable_count"], "properties": {"passed": {"type": "boolean"}, "finding_count": {"type": "integer", "minimum": 0}, "failure_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "result_count": {"type": "integer", "minimum": 0}, "required_count": {"type": "integer", "minimum": 0}, "required_pass_count": {"type": "integer", "minimum": 0}, "required_satisfied_count": {"type": "integer", "minimum": 0}, "warning_count": {"type": "integer", "minimum": 0}, "failed_count": {"type": "integer", "minimum": 0}, "not_applicable_count": {"type": "integer", "minimum": 0}}}
  },
  "$defs": {"sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
}

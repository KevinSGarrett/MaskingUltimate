{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_worker.schema.json",
  "title": "MaskFactory DAZ worker defaults",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "enabled",
    "default_disabled",
    "launch_mode",
    "window_visibility",
    "maximum_workers",
    "atomic_file_protocol",
    "job_private_partial_directory",
    "worker_result_written_last",
    "automatic_purchase",
    "automatic_account_login"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "enabled": {"const": false},
    "default_disabled": {"const": true},
    "launch_mode": {"const": "process_per_job"},
    "window_visibility": {"const": "hidden"},
    "maximum_workers": {"type": "integer", "minimum": 1, "maximum": 1},
    "atomic_file_protocol": {"const": true},
    "job_private_partial_directory": {"const": true},
    "worker_result_written_last": {"const": true},
    "automatic_purchase": {"const": false},
    "automatic_account_login": {"const": false}
  }
}

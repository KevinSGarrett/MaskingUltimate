{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_worker_mode_decision_static_report.schema.json",
  "title": "MaskFactory DAZ worker mode decision STATIC report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "proof_tier",
    "authority",
    "selected_production_mode",
    "challenger_mode",
    "debug_mode",
    "decision",
    "profile_bindings",
    "benchmark_matrix",
    "command_contract",
    "live_daz_execution",
    "live_mode_benchmark_complete",
    "headless_promoted",
    "doctor_green_claimed",
    "gold_claimed",
    "visual_qa_pass_claimed",
    "main_complete_claimed",
    "production_evidence_pass_claimed",
    "report_id",
    "seal_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "daz_worker_mode_decision_static_report"},
    "proof_tier": {"const": "STATIC_PASS"},
    "authority": {"const": "daz_worker_isolation_static_only"},
    "selected_production_mode": {"const": "hidden_gui"},
    "challenger_mode": {"const": "headless"},
    "debug_mode": {"const": "interactive_debug"},
    "decision": {
      "const": "retain_hidden_gui_pending_live_headless_parity"
    },
    "profile_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "instance_name",
        "execution_mode",
        "process_lifetime",
        "persistent_worker",
        "no_default_scene",
        "no_prompt"
      ],
      "properties": {
        "profile_id": {"const": "maskfactory_daz_hidden_v1"},
        "instance_name": {"const": "MaskFactoryDAZ"},
        "execution_mode": {"const": "hidden_gui"},
        "process_lifetime": {"const": "process_per_job"},
        "persistent_worker": {"const": false},
        "no_default_scene": {"const": true},
        "no_prompt": {"const": true}
      }
    },
    "benchmark_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimensions",
        "hidden_gui_all_pass",
        "headless_all_pass",
        "headless_promotion_eligible",
        "live_mode_benchmark_complete"
      ],
      "properties": {
        "dimensions": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "hidden_gui_all_pass": {"type": "boolean"},
        "headless_all_pass": {"type": "boolean"},
        "headless_promotion_eligible": {"const": false},
        "live_mode_benchmark_complete": {"const": false}
      }
    },
    "command_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "includes_instance_name",
        "includes_no_default_scene",
        "includes_no_prompt",
        "includes_headless_flag",
        "hidden_window_launch"
      ],
      "properties": {
        "includes_instance_name": {"const": true},
        "includes_no_default_scene": {"const": true},
        "includes_no_prompt": {"const": true},
        "includes_headless_flag": {"const": false},
        "hidden_window_launch": {"const": true}
      }
    },
    "live_daz_execution": {"const": false},
    "live_mode_benchmark_complete": {"const": false},
    "headless_promoted": {"const": false},
    "doctor_green_claimed": {"const": false},
    "gold_claimed": {"const": false},
    "visual_qa_pass_claimed": {"const": false},
    "main_complete_claimed": {"const": false},
    "production_evidence_pass_claimed": {"const": false},
    "report_id": {
      "type": "string",
      "pattern": "^dwmd_[0-9a-f]{24}$"
    },
    "seal_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}

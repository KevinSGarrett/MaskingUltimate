{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/daz_worker_result.schema.json",
  "title": "MaskFactory DAZ terminal worker result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "job_id", "recipe_id", "bundle_version", "instance_name",
    "status", "started_at", "finished_at", "reason", "artifacts", "runtime"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "job_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"},
    "recipe_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"},
    "bundle_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "instance_name": {"const": "MaskFactoryDAZ"},
    "status": {"enum": ["success", "failed", "quarantined"]},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "reason": {"type": "string", "minLength": 1},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 0}
        }
      }
    },
    "runtime": {
      "type": "object", "additionalProperties": false,
      "required": ["daz_version", "content_directories"],
      "properties": {
        "daz_version": {"type": "string", "minLength": 1},
        "content_directories": {
          "type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true,
          "items": {"type": "string", "minLength": 3}
        }
      }
    }
  }
}

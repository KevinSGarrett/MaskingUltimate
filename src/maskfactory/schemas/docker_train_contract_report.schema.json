{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/docker_train_contract_report.schema.json",
  "title": "MaskFactory Docker train-image STATIC contract report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "proof_tier",
    "authority",
    "checked_at",
    "lock_ref",
    "dockerfile_ref",
    "compose_ref",
    "compose_service",
    "image_tag",
    "dockerfile_checks",
    "compose_checks",
    "checks",
    "build_attempted",
    "image_built_claimed",
    "mmcv_ext_sm120_compiled_claimed",
    "training_doctor_green_claimed",
    "champion_claimed",
    "certified_training_corpus_claimed",
    "gold_claimed",
    "honest_non_claims",
    "report_id",
    "seal_sha256",
    "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "docker_train_contract_report"},
    "proof_tier": {"const": "STATIC_PASS"},
    "authority": {
      "const": "docker_train_image_spec_coherence_only_no_build_no_doctor_green_no_champion"
    },
    "checked_at": {"type": "string", "minLength": 1},
    "lock_ref": {"const": "env/openmmlab_training_stack.lock.json"},
    "dockerfile_ref": {"const": "docker/Dockerfile.train"},
    "compose_ref": {"const": "docker/compose.gpu.yml"},
    "compose_service": {"const": "maskfactory-train"},
    "image_tag": {"const": "maskfactory/train:cu128"},
    "dockerfile_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_devel_image_provides_nvcc",
        "base_cuda_matches_lock",
        "torch_pin_matches_lock",
        "torch_cu128_index_used",
        "torch_build_assertion_present",
        "mmcv_cloned_and_checked_out_locked_commit",
        "mmcv_ops_build_env_forced",
        "mmcv_arch_list_matches_compute_capability",
        "mmcv_version_and_ext_asserted",
        "mmengine_pin_matches_lock",
        "mmsegmentation_pin_matches_lock",
        "mmdet_pin_matches_lock",
        "maskfactory_package_installed",
        "training_doctor_default_cmd",
        "container_runtime_env_declared"
      ],
      "properties": {
        "base_devel_image_provides_nvcc": {"const": true},
        "base_cuda_matches_lock": {"const": true},
        "torch_pin_matches_lock": {"const": true},
        "torch_cu128_index_used": {"const": true},
        "torch_build_assertion_present": {"const": true},
        "mmcv_cloned_and_checked_out_locked_commit": {"const": true},
        "mmcv_ops_build_env_forced": {"const": true},
        "mmcv_arch_list_matches_compute_capability": {"const": true},
        "mmcv_version_and_ext_asserted": {"const": true},
        "mmengine_pin_matches_lock": {"const": true},
        "mmsegmentation_pin_matches_lock": {"const": true},
        "mmdet_pin_matches_lock": {"const": true},
        "maskfactory_package_installed": {"const": true},
        "training_doctor_default_cmd": {"const": true},
        "container_runtime_env_declared": {"const": true}
      }
    },
    "compose_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "train_service_present",
        "image_tag_matches",
        "build_dockerfile_matches",
        "gpus_all_requested",
        "repo_bind_mount_present",
        "shm_size_sufficient",
        "pull_policy_never",
        "no_lan_exposed_ports",
        "training_doctor_command",
        "container_runtime_env_declared"
      ],
      "properties": {
        "train_service_present": {"const": true},
        "image_tag_matches": {"const": true},
        "build_dockerfile_matches": {"const": true},
        "gpus_all_requested": {"const": true},
        "repo_bind_mount_present": {"const": true},
        "shm_size_sufficient": {"const": true},
        "pull_policy_never": {"const": true},
        "no_lan_exposed_ports": {"const": true},
        "training_doctor_command": {"const": true},
        "container_runtime_env_declared": {"const": true}
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dockerfile_spec_coherence", "compose_service_coherence"],
      "properties": {
        "dockerfile_spec_coherence": {"const": "pass"},
        "compose_service_coherence": {"const": "pass"}
      }
    },
    "build_attempted": {"const": false},
    "image_built_claimed": {"const": false},
    "mmcv_ext_sm120_compiled_claimed": {"const": false},
    "training_doctor_green_claimed": {"const": false},
    "champion_claimed": {"const": false},
    "certified_training_corpus_claimed": {"const": false},
    "gold_claimed": {"const": false},
    "honest_non_claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "report_id": {"type": "string", "pattern": "^dtc_[a-f0-9]{24}$"},
    "seal_sha256": {"$ref": "#/$defs/sha256"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}

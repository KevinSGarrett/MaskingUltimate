{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/external_adapter_conformance_evidence.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "decided_at",
    "policy_id",
    "policy_sha256",
    "adapter_identity",
    "producer_state",
    "contract_bindings",
    "boundary_observations",
    "status",
    "rejection_reasons",
    "decision_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "external_adapter_conformance_evidence" },
    "decided_at": { "type": "string", "format": "date-time" },
    "policy_id": { "type": "string", "minLength": 1 },
    "policy_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "adapter_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_name",
        "package_version",
        "package_sha256",
        "git_commit",
        "git_tree",
        "repository_clean",
        "install_mode"
      ],
      "properties": {
        "package_name": { "type": "string", "minLength": 1 },
        "package_version": { "type": "string", "minLength": 1 },
        "package_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "git_tree": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "repository_clean": { "type": "boolean" },
        "install_mode": { "enum": ["wheel", "sdist", "editable", "path"] }
      }
    },
    "producer_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release_status", "adoption_decision", "repository_clean"],
      "properties": {
        "release_status": { "type": "string", "minLength": 1 },
        "adoption_decision": { "type": "string", "minLength": 1 },
        "repository_clean": { "type": "boolean" }
      }
    },
    "contract_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bridge_contract",
        "api_contract",
        "package_format",
        "ontology_version",
        "node_pack_version",
        "wire_schemas",
        "used_openapi_paths"
      ],
      "properties": {
        "bridge_contract": { "type": "string", "minLength": 1 },
        "api_contract": { "type": "string", "minLength": 1 },
        "package_format": { "type": "string", "minLength": 1 },
        "ontology_version": { "type": "string", "minLength": 1 },
        "node_pack_version": { "type": "string", "minLength": 1 },
        "wire_schemas": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "version"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "version": { "type": "string", "minLength": 1 }
            }
          }
        },
        "used_openapi_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "boundary_observations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "imports",
        "documented_dependencies",
        "comfyui_node_ids",
        "mutable_path_dependencies"
      ],
      "properties": {
        "imports": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "documented_dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "comfyui_node_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "mutable_path_dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "status": { "enum": ["accepted", "rejected"] },
    "rejection_reasons": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "decision_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}

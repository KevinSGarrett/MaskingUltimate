{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/external_supervision_holdout_ablation_report.schema.json",
  "title": "External supervision holdout ablation report (STATIC; no live holdout)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "proof_tier",
    "authority",
    "live_holdout_executed",
    "admission_ready",
    "any_source_admitted_live",
    "gold_claimed",
    "frozen_holdout",
    "active_source_label_scopes",
    "inactive_source_label_scopes",
    "active_count",
    "inactive_count",
    "seal_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "artifact_type": {
      "const": "external_supervision_holdout_ablation_report"
    },
    "proof_tier": { "const": "STATIC_PASS" },
    "authority": {
      "const": "external_supervision_holdout_ablation_static_only_no_live_holdout"
    },
    "live_holdout_executed": { "const": false },
    "admission_ready": { "const": false },
    "any_source_admitted_live": { "const": false },
    "gold_claimed": { "const": false },
    "frozen_holdout": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "frozen_holdout_id",
        "fingerprint_sha256",
        "truth_tier",
        "truth_partition"
      ],
      "properties": {
        "frozen_holdout_id": { "type": "string", "minLength": 1 },
        "fingerprint_sha256": { "$ref": "#/$defs/sha256" },
        "truth_tier": { "const": "human_anchor_gold" },
        "truth_partition": {
          "type": "string",
          "enum": ["holdout", "test_holdout", "hard_case_holdout"]
        },
        "source_role": { "type": ["string", "null"] },
        "external_labels_may_enter_holdout": { "type": "boolean" }
      }
    },
    "active_source_label_scopes": {
      "type": "array",
      "items": { "$ref": "#/$defs/scope_row" }
    },
    "inactive_source_label_scopes": {
      "type": "array",
      "items": { "$ref": "#/$defs/scope_row" }
    },
    "active_count": { "type": "integer", "minimum": 0 },
    "inactive_count": { "type": "integer", "minimum": 0 },
    "seal_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "scope_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "label_scope",
        "primary_metric",
        "observed_delta",
        "noninferiority_margin",
        "reason"
      ],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "label_scope": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "primary_metric": { "type": "string", "minLength": 1 },
        "observed_delta": { "type": "number" },
        "noninferiority_margin": { "type": "number", "minimum": 0 },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}

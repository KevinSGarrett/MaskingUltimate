{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/external_supervision_identity_evidence.schema.json",
  "title": "LV-MHP external supervision instance identity evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "source", "gate", "status", "identity_rule", "image_count", "annotation_count", "person_count_distribution", "records", "seal_sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "external_supervision_identity_evidence"},
    "source": {"const": "lv_mhp_v1"},
    "gate": {"const": "instance_identity_validated"},
    "status": {"const": "PASS"},
    "identity_rule": {"type": "string", "minLength": 1},
    "image_count": {"type": "integer", "minimum": 1},
    "annotation_count": {"type": "integer", "minimum": 1},
    "person_count_distribution": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {"^[1-9][0-9]*$": {"type": "integer", "minimum": 1}},
      "additionalProperties": false
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["image_id", "image_path", "person_count", "instance_ids", "annotation_paths"],
        "properties": {
          "image_id": {"type": "string", "pattern": "^[0-9]+$"},
          "image_path": {"type": "string", "pattern": "^images/[^/]+\\.jpg$"},
          "person_count": {"type": "integer", "minimum": 1},
          "instance_ids": {"type": "array", "minItems": 1, "items": {"type": "integer", "minimum": 1}, "uniqueItems": true},
          "annotation_paths": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^annotations/[^/]+\\.png$"}, "uniqueItems": true}
        }
      }
    },
    "seal_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}

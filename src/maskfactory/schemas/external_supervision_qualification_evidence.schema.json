{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/external_supervision_qualification_evidence.schema.json",
  "title": "External supervision qualification evidence bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "source",
    "gates",
    "seal_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "artifact_type": {
      "const": "external_supervision_qualification_evidence_bundle"
    },
    "source": {
      "enum": [
        "celebamask_hq",
        "lapa",
        "lv_mhp_v1"
      ]
    },
    "gates": {
      "type": "array",
      "minItems": 5,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gate",
          "artifact_type",
          "artifact_path",
          "artifact_sha256"
        ],
        "properties": {
          "gate": {
            "enum": [
              "official_license_recorded",
              "deterministic_remap_tested",
              "source_hash_manifested",
              "visual_alignment_qa_passed",
              "instance_identity_validated",
              "split_dedup_passed"
            ]
          },
          "artifact_type": {
            "enum": [
              "external_supervision_license_evidence",
              "external_supervision_remap_evidence",
              "external_supervision_source_hash_manifest",
              "external_supervision_alignment_evidence",
              "external_supervision_identity_evidence",
              "external_supervision_split_dedup_evidence"
            ]
          },
          "artifact_path": {
            "type": "string",
            "minLength": 1
          },
          "artifact_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "seal_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}

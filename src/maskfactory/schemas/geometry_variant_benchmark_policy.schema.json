{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/geometry_variant_benchmark_policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_id", "frozen_at", "eligible_truth", "required_contexts", "providers", "normalization", "pass_requirements", "zero_regression_metrics", "source_hashes", "authority_boundary", "sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "policy_id": {"const": "geometry_variant_benchmark_v1"},
    "frozen_at": {"type": "string", "format": "date-time"},
    "eligible_truth": {"const": {"tier": "human_anchor_gold", "partition": "holdout"}},
    "required_contexts": {"const": ["geometry_prior", "contact", "crowding", "identity_ambiguity", "occlusion", "rear_view", "front_view", "scale_disparity", "truncation"]},
    "providers": {
      "type": "object", "additionalProperties": false,
      "required": ["densepose_r50_fpn_s1x", "sam3d_body"],
      "properties": {
        "densepose_r50_fpn_s1x": {"$ref": "#/$defs/provider"},
        "sam3d_body": {"$ref": "#/$defs/provider"}
      }
    },
    "normalization": {
      "const": {
        "projection_consistency": "consistent_projected_points_over_evaluated_projected_points",
        "visible_surface_recall": "visible_surface_hit_points_over_visible_surface_truth_points",
        "bleed": "background_or_cross_person_points_over_predicted_surface_points",
        "side_semantics": "character_anatomical_left_right",
        "view_semantics": "source_image_front_back_truth"
      }
    },
    "pass_requirements": {
      "const": {
        "minimum_overall_projection_consistency_improvement": 0.01,
        "max_context_projection_consistency_drop": 0.02,
        "max_context_visible_surface_recall_drop": 0.02,
        "max_zero_regression_rate_delta": 0.0,
        "max_peak_vram_bytes": 8589934592,
        "max_oom_or_crash_count": 0,
        "require_deterministic_repeats": 2,
        "require_fallback_to": "densepose_r50_fpn_s1x"
      }
    },
    "zero_regression_metrics": {"const": ["background_bleed_rate", "cross_person_bleed_rate", "front_back_error_rate", "hard_qa_failure_rate", "identity_assignment_error_rate", "left_right_error_rate"]},
    "source_hashes": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/sha256"}},
    "authority_boundary": {"const": "pre_result_contract_only_no_installation_performance_promotion_mask_or_gold_authority"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "provider": {
      "type": "object", "additionalProperties": false,
      "required": ["role", "model_family", "source_revision", "checkpoint_revision", "required_artifact_keys", "frozen_artifact_hashes", "authority"],
      "properties": {
        "role": {"enum": ["incumbent_rollback", "modern_challenger"]},
        "model_family": {"type": "string", "minLength": 1},
        "source_revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
        "checkpoint_revision": {"type": "string", "minLength": 1},
        "required_artifact_keys": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "frozen_artifact_hashes": {"type": "object", "additionalProperties": {"$ref": "#/$defs/sha256"}},
        "authority": {"enum": ["active_and_rollback", "planned_source_only_until_governed_installation"]}
      }
    }
  }
}

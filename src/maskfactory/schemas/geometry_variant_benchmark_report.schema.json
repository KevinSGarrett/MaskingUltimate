{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/geometry_variant_benchmark_report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "benchmark_id", "evaluated_at", "policy_sha256", "source_cases_sha256", "truth_manifest_sha256", "pipeline_fingerprint_sha256", "hardware_fingerprint_sha256", "providers", "comparison", "fallback_drill", "findings", "result", "authority", "sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "benchmark_id": {"type": "string", "minLength": 1},
    "evaluated_at": {"type": "string", "format": "date-time"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "source_cases_sha256": {"$ref": "#/$defs/sha256"},
    "truth_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "pipeline_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
    "hardware_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
    "providers": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "object"}},
    "comparison": {"type": "object"},
    "fallback_drill": {"type": "object"},
    "findings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "result": {"enum": ["pass", "fail"]},
    "authority": {"const": "benchmark_evidence_only_no_installation_promotion_mask_or_gold_authority"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}

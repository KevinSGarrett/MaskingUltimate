{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/interactive_provider_promotion_certificate.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "certificate_id", "issued_at", "reviewer",
    "target_role", "candidate_key", "incumbent_key",
    "candidate_artifact_key", "incumbent_artifact_key",
    "benchmark_certificate_sha256", "candidate_checkpoint_sha256",
    "incumbent_checkpoint_sha256", "candidate_runtime_lock_sha256",
    "matrix_certificate_id", "matrix_certificate_sha256", "matrix_identity",
    "rollback_evidence", "authority", "signer_public_key_sha256",
    "signature_algorithm", "payload_sha256", "signature", "certificate_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "certificate_id": {"type": "string", "pattern": "^[a-f0-9]{24}$"},
    "issued_at": {"type": "string", "format": "date-time"},
    "reviewer": {"type": "string", "minLength": 1},
    "target_role": {"const": "interactive_segmenter"},
    "candidate_key": {"$ref": "#/$defs/key"},
    "incumbent_key": {"$ref": "#/$defs/key"},
    "candidate_artifact_key": {"$ref": "#/$defs/key"},
    "incumbent_artifact_key": {"$ref": "#/$defs/key"},
    "benchmark_certificate_sha256": {"$ref": "#/$defs/sha256"},
    "candidate_checkpoint_sha256": {"$ref": "#/$defs/sha256"},
    "incumbent_checkpoint_sha256": {"$ref": "#/$defs/sha256"},
    "candidate_runtime_lock_sha256": {"$ref": "#/$defs/sha256"},
    "matrix_certificate_id": {"type": "string", "pattern": "^[a-f0-9]{24}$"},
    "matrix_certificate_sha256": {"$ref": "#/$defs/sha256"},
    "matrix_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_sha256", "observations_sha256", "report_sha256", "shared_identity_sha256"],
      "properties": {
        "manifest_sha256": {"$ref": "#/$defs/sha256"},
        "observations_sha256": {"$ref": "#/$defs/sha256"},
        "report_sha256": {"$ref": "#/$defs/sha256"},
        "shared_identity_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "rollback_evidence": {"$ref": "#/$defs/rollbackEvidence"},
    "authority": {"const": "signed_matrix_bound_interactive_promotion_prerequisite_only_no_activation_serving_mask_or_gold_authority"},
    "signer_public_key_sha256": {"$ref": "#/$defs/sha256"},
    "signature_algorithm": {"const": "ed25519"},
    "payload_sha256": {"$ref": "#/$defs/sha256"},
    "signature": {"type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$"},
    "certificate_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "key": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]{1,79}$"},
    "rollbackEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version", "target_role", "candidate_provider", "incumbent_provider",
        "pipeline_before_sha256", "pipeline_promoted_sha256", "pipeline_restored_sha256",
        "candidate_smoke_sha256", "incumbent_smoke_sha256", "rollback_observed",
        "restore_observed", "tested_at", "sha256"
      ],
      "properties": {
        "schema_version": {"const": "1.0.0"},
        "target_role": {"const": "interactive_segmenter"},
        "candidate_provider": {"$ref": "#/$defs/key"},
        "incumbent_provider": {"$ref": "#/$defs/key"},
        "pipeline_before_sha256": {"$ref": "#/$defs/sha256"},
        "pipeline_promoted_sha256": {"$ref": "#/$defs/sha256"},
        "pipeline_restored_sha256": {"$ref": "#/$defs/sha256"},
        "candidate_smoke_sha256": {"$ref": "#/$defs/sha256"},
        "incumbent_smoke_sha256": {"$ref": "#/$defs/sha256"},
        "rollback_observed": {"const": true},
        "restore_observed": {"const": true},
        "tested_at": {"type": "string", "format": "date-time"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}

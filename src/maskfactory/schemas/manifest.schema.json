{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/manifest.schema.json",
  "title": "MaskFactory per-instance package manifest",
  "description": "Authoritative manifest for one promoted person instance (doc 04 §1; doc 17 §6).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "image_id",
    "mask_ontology_version",
    "left_right_convention",
    "source",
    "person",
    "interperson",
    "parts",
    "inpaint_derivatives",
    "tooling",
    "review",
    "qa",
    "files"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "image_id": { "$ref": "#/$defs/imageId" },
    "mask_ontology_version": {
      "type": "string",
      "pattern": "^body_parts_v[1-9][0-9]*(?:\\.[0-9]+)?$"
    },
    "left_right_convention": { "const": "character_perspective" },
    "source": { "$ref": "#/$defs/source" },
    "person": { "$ref": "#/$defs/person" },
    "interperson": {
      "type": "array",
      "items": { "$ref": "#/$defs/interpersonRelationship" },
      "default": []
    },
    "parts": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "$ref": "#/$defs/labelName" },
      "additionalProperties": { "$ref": "#/$defs/partEntry" }
    },
    "inpaint_derivatives": {
      "type": "array",
      "items": { "$ref": "#/$defs/inpaintDerivative" },
      "default": []
    },
    "tooling": { "$ref": "#/$defs/tooling" },
    "review": { "$ref": "#/$defs/review" },
    "qa": { "$ref": "#/$defs/qa" },
    "files": { "$ref": "#/$defs/files" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$"
    },
    "imageId": {
      "type": "string",
      "pattern": "^img_[a-f0-9]{12}$"
    },
    "instanceId": {
      "type": "string",
      "pattern": "^img_[a-f0-9]{12}_p[0-9]+$"
    },
    "labelName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "bbox": {
      "type": "array",
      "prefixItems": [
        { "type": "integer", "minimum": 0 },
        { "type": "integer", "minimum": 0 },
        { "type": "integer", "minimum": 1 },
        { "type": "integer", "minimum": 1 }
      ],
      "items": false,
      "minItems": 4,
      "maxItems": 4
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_file",
        "source_sha256",
        "source_width",
        "source_height",
        "source_origin",
        "origin_note",
        "ingested_at",
        "exif_stripped"
      ],
      "properties": {
        "source_file": { "$ref": "#/$defs/relativePath" },
        "source_sha256": { "$ref": "#/$defs/sha256" },
        "source_width": { "type": "integer", "minimum": 1 },
        "source_height": { "type": "integer", "minimum": 1 },
        "source_origin": {
          "enum": ["generated", "owned_photo", "licensed", "consented_subject"]
        },
        "origin_note": { "type": "string" },
        "ingested_at": { "$ref": "#/$defs/timestamp" },
        "exif_stripped": { "const": true },
        "phash64": { "type": "string", "pattern": "^[a-fA-F0-9]{16}$" }
      }
    },
    "person": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_person_bbox",
        "person_count",
        "view",
        "pose_tags",
        "estimated_person_height_px"
      ],
      "properties": {
        "primary_person_bbox": { "$ref": "#/$defs/bbox" },
        "person_count": { "type": "integer", "minimum": 1 },
        "view": {
          "enum": [
            "front",
            "back",
            "left_profile",
            "right_profile",
            "left_3_4",
            "right_3_4"
          ]
        },
        "pose_tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/labelName" }
        },
        "estimated_person_height_px": { "type": "integer", "minimum": 1 }
      }
    },
    "interpersonRelationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["other_instance_id", "relationship", "contact_band_file"],
      "properties": {
        "other_instance_id": { "$ref": "#/$defs/instanceId" },
        "relationship": { "enum": ["contact", "occludes", "occluded_by"] },
        "contact_band_file": { "$ref": "#/$defs/relativePath" }
      }
    },
    "visibility": {
      "enum": [
        "visible",
        "partially_visible",
        "occluded",
        "cropped_out",
        "not_visible",
        "ambiguous_do_not_use",
        "n/a"
      ]
    },
    "partStatus": {
      "enum": [
        "draft_model_generated",
        "human_corrected",
        "human_approved_gold",
        "rejected_needs_fix",
        "deprecated",
        "n/a"
      ]
    },
    "occlusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["occluded_by", "occludes", "layer"],
      "properties": {
        "occluded_by": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/labelName" }
        },
        "occludes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/labelName" }
        },
        "layer": {
          "enum": ["front_layer", "middle_layer", "back_layer", "unknown"]
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["draft_source", "sam2_prompt_id", "human_edit"],
      "properties": {
        "draft_source": { "type": ["string", "null"] },
        "sam2_prompt_id": { "type": ["string", "null"] },
        "human_edit": { "type": "boolean" }
      }
    },
    "partEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mask_type", "visibility", "mask_file", "status"],
      "properties": {
        "mask_type": {
          "enum": ["atomic_exclusive", "protected_qa", "region_band", "derived_union", "projected_amodal"]
        },
        "visibility": { "$ref": "#/$defs/visibility" },
        "basis": { "type": "string", "minLength": 1 },
        "mask_file": {
          "oneOf": [{ "$ref": "#/$defs/relativePath" }, { "type": "null" }]
        },
        "mask_sha256": {
          "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
        },
        "mask_area_px": { "type": ["integer", "null"], "minimum": 0 },
        "mask_bbox": {
          "oneOf": [{ "$ref": "#/$defs/bbox" }, { "type": "null" }]
        },
        "components": { "type": ["integer", "null"], "minimum": 0 },
        "status": { "$ref": "#/$defs/partStatus" },
        "annotated_on": {
          "type": "string",
          "pattern": "^(?:full|crop:[a-z][a-z0-9]*(?:_[a-z0-9]+)*)$"
        },
        "occlusion": { "$ref": "#/$defs/occlusion" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "notes": { "type": "string" }
      }
    },
    "inpaintDerivative": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "file",
        "dilate_px",
        "feather_px",
        "ref_scale",
        "source_gold_sha256"
      ],
      "properties": {
        "label": { "$ref": "#/$defs/labelName" },
        "file": { "$ref": "#/$defs/relativePath" },
        "dilate_px": { "type": "integer", "minimum": 0 },
        "feather_px": { "type": "integer", "minimum": 0 },
        "ref_scale": { "type": "integer", "minimum": 1 },
        "source_gold_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "tooling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "annotation_tool",
        "annotation_tool_version",
        "pipeline_version",
        "model_versions_used",
        "config_hashes"
      ],
      "properties": {
        "annotation_tool": { "const": "cvat" },
        "annotation_tool_version": { "type": "string", "minLength": 1 },
        "pipeline_version": { "type": "string", "minLength": 1 },
        "model_versions_used": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "config_hashes": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "pattern": "^[^/\\\\]+\\.(?:ya?ml|json)$" },
          "additionalProperties": { "$ref": "#/$defs/sha256" }
        }
      }
    },
    "secondReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "reviewer", "result", "at"],
      "properties": {
        "required": { "type": "boolean" },
        "reviewer": { "type": ["string", "null"] },
        "result": { "enum": ["pass", "fail", "pending", "not_required"] },
        "at": {
          "oneOf": [{ "$ref": "#/$defs/timestamp" }, { "type": "null" }]
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer", "approved_at", "second_review", "review_time_sec"],
      "properties": {
        "reviewer": { "type": ["string", "null"] },
        "approved_at": {
          "oneOf": [{ "$ref": "#/$defs/timestamp" }, { "type": "null" }]
        },
        "second_review": { "$ref": "#/$defs/secondReview" },
        "review_time_sec": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "qa": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qa_report_file", "qa_overall", "qa_score"],
      "properties": {
        "qa_report_file": { "$ref": "#/$defs/relativePath" },
        "qa_overall": { "enum": ["pass", "fail", "needs_human", "pending"] },
        "qa_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      }
    },
    "files": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/relativePath" },
      "additionalProperties": { "$ref": "#/$defs/sha256" }
    }
  }
}

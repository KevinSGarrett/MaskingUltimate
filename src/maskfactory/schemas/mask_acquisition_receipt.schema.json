{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/mask_acquisition_receipt.schema.json",
  "title": "MaskFactory acquisition receipt and authority decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "record_type", "receipt_id", "request_id", "request_payload_sha256",
    "project_id", "run_id", "job_id", "pass_id", "attempt_id", "attempt_number", "hypothesis_id",
    "idempotency_key", "completed_at", "authentication", "trust_binding", "canonicalization", "result", "access_mode", "media_scope", "release_binding", "execution_observation",
    "source_binding", "subject_binding", "provider_binding", "artifacts", "transform_validation",
    "qa", "authority", "truth_tier", "lineage", "use_eligibility", "error", "receipt_payload_sha256", "signature"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "mask_acquisition_receipt"},
    "receipt_id": {"type": "string", "pattern": "^mfarec_[0-9a-f]{24}$"},
    "request_id": {"type": "string", "pattern": "^mfareq_[0-9a-f]{24}$"},
    "request_payload_sha256": {"$ref": "#/$defs/sha256"},
    "project_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "job_id": {"type": "string", "minLength": 1},
    "pass_id": {"type": "string", "minLength": 1},
    "attempt_id": {"type": "string", "minLength": 1},
    "attempt_number": {"type": "integer", "minimum": 1},
    "hypothesis_id": {"type": "string", "minLength": 1},
    "idempotency_key": {"type": "string", "minLength": 16},
    "completed_at": {"$ref": "#/$defs/timestamp"},
    "authentication": {"$ref": "#/$defs/authentication"},
    "trust_binding": {"$ref": "#/$defs/trustBinding"},
    "canonicalization": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "excluded_top_level_fields"],
      "properties": {
        "algorithm": {"const": "maskfactory-canonical-json-v1"},
        "excluded_top_level_fields": {"type": "array", "prefixItems": [{"const": "receipt_payload_sha256"}, {"const": "signature"}], "minItems": 2, "maxItems": 2}
      }
    },
    "result": {"enum": ["succeeded", "blocked", "failed"]},
    "access_mode": {"$ref": "#/$defs/accessMode"},
    "media_scope": {"$ref": "#/$defs/mediaScope"},
    "execution_observation": {
      "type": "object", "additionalProperties": false,
      "required": ["admitted_at", "queued_at", "started_at", "completed_at", "queue_ms", "runtime_ms", "total_ms", "deadline_met", "outcome_class", "worker", "resources", "route_selection"],
      "properties": {
        "admitted_at": {"$ref": "#/$defs/timestamp"},
        "queued_at": {"$ref": "#/$defs/timestamp"},
        "started_at": {"$ref": "#/$defs/timestamp"},
        "completed_at": {"$ref": "#/$defs/timestamp"},
        "queue_ms": {"type": "integer", "minimum": 0},
        "runtime_ms": {"type": "integer", "minimum": 0},
        "total_ms": {"type": "integer", "minimum": 0},
        "deadline_met": {"type": "boolean"},
        "outcome_class": {"enum": ["success", "blocked_deadline", "blocked_resource", "blocked_compatibility", "blocked_authority", "failed_execution"]},
        "worker": {
          "type": "object", "additionalProperties": false,
          "required": ["worker_id", "device_id", "device_kind", "lease_id", "lease_acquired_at", "lease_expires_at"],
          "properties": {"worker_id": {"type": "string", "minLength": 1}, "device_id": {"type": "string", "minLength": 1}, "device_kind": {"enum": ["cuda", "directml", "cpu", "remote_gpu"]}, "lease_id": {"type": "string", "minLength": 1}, "lease_acquired_at": {"$ref": "#/$defs/timestamp"}, "lease_expires_at": {"$ref": "#/$defs/timestamp"}}
        },
        "resources": {
          "type": "object", "additionalProperties": false,
          "required": ["peak_vram_mb", "peak_ram_mb", "output_bytes"],
          "properties": {"peak_vram_mb": {"type": "integer", "minimum": 0}, "peak_ram_mb": {"type": "integer", "minimum": 0}, "output_bytes": {"type": "integer", "minimum": 0}}
        },
        "route_selection": {
          "type": "object", "additionalProperties": false,
          "required": ["selected_route_id", "selected_route_sha256", "eligible_alternatives", "selection_reason", "selection_evidence_sha256"],
          "properties": {
            "selected_route_id": {"type": "string", "minLength": 1},
            "selected_route_sha256": {"$ref": "#/$defs/sha256"},
            "eligible_alternatives": {"type": "array", "uniqueItems": true, "items": {"type": "object", "additionalProperties": false, "required": ["route_id", "route_sha256", "score"], "properties": {"route_id": {"type": "string", "minLength": 1}, "route_sha256": {"$ref": "#/$defs/sha256"}, "score": {"type": "number"}}}},
            "selection_reason": {"type": "string", "minLength": 1},
            "selection_evidence_sha256": {"$ref": "#/$defs/sha256"}
          }
        }
      }
    },
    "release_binding": {
      "type": "object", "additionalProperties": false,
      "required": ["release_id", "release_payload_sha256", "capability_snapshot_id", "capability_snapshot_sha256", "bridge_contract", "wire_schema_name", "wire_schema_version", "wire_schema_sha256"],
      "properties": {
        "release_id": {"type": "string", "pattern": "^mfr_[0-9]{8}_[0-9a-f]{12}$"},
        "release_payload_sha256": {"$ref": "#/$defs/sha256"},
        "capability_snapshot_id": {"type": "string", "pattern": "^mfcap_[0-9a-f]{24}$"},
        "capability_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "bridge_contract": {"const": "maskfactory-comfyui-bridge/1.0"},
        "wire_schema_name": {"const": "mask_acquisition_receipt"},
        "wire_schema_version": {"const": "1.0.0"},
        "wire_schema_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "source_binding": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "encoded_sha256", "decoded_pixel_sha256", "decoder_id", "decoder_version", "decoder_binary_sha256", "exif_orientation", "orientation_applied", "width", "height", "channel_layout", "alpha_mode", "bit_depth", "dtype", "color_space", "icc_profile_sha256", "color_transform_sha256", "frame_extraction_sha256", "coordinate_space"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "encoded_sha256": {"$ref": "#/$defs/sha256"},
        "decoded_pixel_sha256": {"$ref": "#/$defs/sha256"},
        "decoder_id": {"type": "string", "minLength": 1},
        "decoder_version": {"type": "string", "minLength": 1},
        "decoder_binary_sha256": {"$ref": "#/$defs/sha256"},
        "exif_orientation": {"type": "integer", "minimum": 1, "maximum": 8},
        "orientation_applied": {"type": "boolean"},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "channel_layout": {"enum": ["GRAY", "RGB", "RGBA"]},
        "alpha_mode": {"enum": ["none", "straight", "premultiplied", "discarded"]},
        "bit_depth": {"enum": [8, 16, 32]},
        "dtype": {"enum": ["uint8", "uint16", "float32"]},
        "color_space": {"enum": ["sRGB", "linear_sRGB"]},
        "icc_profile_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "color_transform_sha256": {"$ref": "#/$defs/sha256"},
        "frame_extraction_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "coordinate_space": {"const": "source_pixel"}
      }
    },
    "subject_binding": {
      "type": "object", "additionalProperties": false,
      "required": ["scene_id", "shot_id", "take_id", "character_id", "character_revision", "scene_instance_id", "canonical_person_id", "person_index", "provider_person_index", "assignment_evidence_sha256"],
      "properties": {
        "scene_id": {"type": "string", "minLength": 1},
        "shot_id": {"type": "string", "minLength": 1},
        "take_id": {"type": "string", "minLength": 1},
        "character_id": {"type": "string", "minLength": 1},
        "character_revision": {"type": "string", "minLength": 1},
        "scene_instance_id": {"type": "string", "minLength": 1},
        "canonical_person_id": {"type": "string", "minLength": 1},
        "person_index": {"type": "integer", "minimum": 0},
        "provider_person_index": {"type": "integer", "minimum": 0},
        "assignment_evidence_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "provider_binding": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["stack_id", "stack_sha256", "model_artifacts", "workflow", "runtime", "execution_fingerprint_sha256"],
      "properties": {
        "stack_id": {"type": "string", "minLength": 1},
        "stack_sha256": {"$ref": "#/$defs/sha256"},
        "model_artifacts": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["model_id", "sha256"],
            "properties": {
              "model_id": {"type": "string", "minLength": 1},
              "sha256": {"$ref": "#/$defs/sha256"}
            }
          }
        },
        "workflow": {
          "type": "object", "additionalProperties": false,
          "required": ["workflow_id", "sha256"],
          "properties": {
            "workflow_id": {"type": "string", "minLength": 1},
            "sha256": {"$ref": "#/$defs/sha256"}
          }
        },
        "runtime": {
          "type": "object", "additionalProperties": false,
          "required": ["runtime_kind", "runtime_id", "runtime_version", "environment_lock_sha256", "interpreter_build_sha256", "venv_manifest_sha256", "container_sha256"],
          "properties": {
            "runtime_kind": {"enum": ["native_venv", "container"]},
            "runtime_id": {"type": "string", "minLength": 1},
            "runtime_version": {"type": "string", "minLength": 1},
            "environment_lock_sha256": {"$ref": "#/$defs/sha256"},
            "interpreter_build_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
            "venv_manifest_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
            "container_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
          },
          "allOf": [
            {"if": {"properties": {"runtime_kind": {"const": "native_venv"}}, "required": ["runtime_kind"]}, "then": {"properties": {"interpreter_build_sha256": {"type": "string"}, "venv_manifest_sha256": {"type": "string"}, "container_sha256": {"type": "null"}}}},
            {"if": {"properties": {"runtime_kind": {"const": "container"}}, "required": ["runtime_kind"]}, "then": {"properties": {"interpreter_build_sha256": {"type": "null"}, "venv_manifest_sha256": {"type": "null"}, "container_sha256": {"type": "string"}}}}
          ]
        },
        "execution_fingerprint_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["artifact_id", "intent_id", "label", "artifact_kind", "mask_type", "owner", "artifact_identity_sha256", "encoded_sha256", "decoded_mask_sha256", "format", "channel_layout", "dtype", "allowed_values", "visibility", "empty_semantics", "content_summary", "source_decoded_pixel_sha256", "width", "height", "coordinate_space", "transform_chain_sha256", "relative_path", "size_bytes"],
        "properties": {
          "artifact_id": {"type": "string", "minLength": 1},
          "intent_id": {"type": "string", "minLength": 1},
          "label": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "artifact_kind": {"type": "string", "minLength": 1},
          "mask_type": {"enum": ["atomic", "derived", "inpaint", "matte", "label_map"]},
          "owner": {
            "type": "object", "additionalProperties": false,
            "required": ["owner_kind", "entity_id", "scene_instance_id", "canonical_person_id", "person_index"],
            "properties": {"owner_kind": {"const": "character_instance"}, "entity_id": {"type": "string", "minLength": 1}, "scene_instance_id": {"type": "string", "minLength": 1}, "canonical_person_id": {"type": "string", "minLength": 1}, "person_index": {"type": "integer", "minimum": 0}}
          },
          "artifact_identity_sha256": {"$ref": "#/$defs/sha256"},
          "encoded_sha256": {"$ref": "#/$defs/sha256"},
          "decoded_mask_sha256": {"$ref": "#/$defs/sha256"},
          "format": {"enum": ["PNG", "TIFF", "NPY", "LABEL_MAP"]},
          "channel_layout": {"enum": ["L", "LA", "RGBA", "LABEL_INDEX"]},
          "dtype": {"enum": ["uint8", "uint16", "float32"]},
          "allowed_values": {"enum": ["binary_0_1", "binary_0_255", "matte_0_1", "label_indices"]},
          "visibility": {"enum": ["visible", "occluded_inferred", "complete_map"]},
          "empty_semantics": {"enum": ["forbidden", "allowed_explicit_absence", "allowed_no_visible_pixels"]},
          "content_summary": {"type": "object", "additionalProperties": false, "required": ["bounds", "area_pixels", "area_ppm", "is_empty"], "properties": {"bounds": {"type": ["object", "null"], "additionalProperties": false, "required": ["x", "y", "width", "height"], "properties": {"x": {"type": "integer", "minimum": 0}, "y": {"type": "integer", "minimum": 0}, "width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1}}}, "area_pixels": {"type": "integer", "minimum": 0}, "area_ppm": {"type": "integer", "minimum": 0, "maximum": 1000000}, "is_empty": {"type": "boolean"}}},
          "source_decoded_pixel_sha256": {"$ref": "#/$defs/sha256"},
          "width": {"type": "integer", "minimum": 1},
          "height": {"type": "integer", "minimum": 1},
          "coordinate_space": {"enum": ["source_pixel", "crop_pixel", "output_pixel"]},
          "transform_chain_sha256": {"$ref": "#/$defs/sha256"},
          "relative_path": {"type": "string", "pattern": "^(?![A-Za-z]:|/|.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"},
          "size_bytes": {"type": "integer", "minimum": 1}
        }
      }
    },
    "transform_validation": {
      "type": "object", "additionalProperties": false,
      "required": ["transform_chain_id", "transform_chain_sha256", "source_coordinate_space", "source_width", "source_height", "output_coordinate_space", "output_width", "output_height", "executed_step_sha256s", "roundtrip_checked", "roundtrip_passed", "maximum_roundtrip_error_px"],
      "properties": {
        "transform_chain_id": {"type": "string", "minLength": 1},
        "transform_chain_sha256": {"$ref": "#/$defs/sha256"},
        "source_coordinate_space": {"const": "source_pixel"},
        "source_width": {"type": "integer", "minimum": 1},
        "source_height": {"type": "integer", "minimum": 1},
        "output_coordinate_space": {"enum": ["source_pixel", "crop_pixel", "output_pixel"]},
        "output_width": {"type": "integer", "minimum": 1},
        "output_height": {"type": "integer", "minimum": 1},
        "executed_step_sha256s": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}},
        "roundtrip_checked": {"const": true},
        "roundtrip_passed": {"type": "boolean"},
        "maximum_roundtrip_error_px": {"type": "number", "minimum": 0}
      }
    },
    "qa": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "report_sha256", "blocking_failures", "uncertainty"],
      "properties": {
        "status": {"enum": ["pass", "fail", "not_run"]},
        "report_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "blocking_failures": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "uncertainty": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
      }
    },
    "authority": {
      "type": "object", "additionalProperties": false,
      "required": ["authority_state", "issuer_kind", "decision_basis", "certificate_kind", "certificate_id", "certificate_sha256", "certificate_status", "certificate_exact_scope_match", "revocation_checked_at", "revocation_index_sha256"],
      "properties": {
        "authority_state": {"$ref": "#/$defs/authorityState"},
        "issuer_kind": {"$ref": "#/$defs/issuerKind"},
        "decision_basis": {"enum": ["package_certificate", "exact_output_certificate", "qa_only", "no_authority"]},
        "certificate_kind": {"$ref": "#/$defs/certificateKind"},
        "certificate_id": {"type": ["string", "null"], "minLength": 1},
        "certificate_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "certificate_status": {"enum": ["active", "expired", "revoked", "superseded", "none"]},
        "certificate_exact_scope_match": {"type": "boolean"},
        "revocation_checked_at": {"type": ["string", "null"], "format": "date-time"},
        "revocation_index_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "truth_tier": {"$ref": "#/$defs/truthTier"},
    "lineage": {
      "type": "object", "additionalProperties": false,
      "required": ["operation_kind", "package_id", "package_revision", "package_manifest_sha256", "package_certificate_kind", "package_certificate_id", "package_certificate_sha256", "package_certificate_status", "package_certificate_exact_scope_match", "parents", "input_target_regions", "input_protected_regions", "output_artifact_identity_sha256s"],
      "properties": {
        "operation_kind": {"enum": ["original_prediction", "package_read", "refinement", "derived_union", "inpaint_derivative", "projection"]},
        "package_id": {"type": ["string", "null"]},
        "package_revision": {"type": ["string", "null"]},
        "package_manifest_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "package_certificate_kind": {"$ref": "#/$defs/certificateKind"},
        "package_certificate_id": {"type": ["string", "null"], "minLength": 1},
        "package_certificate_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "package_certificate_status": {"enum": ["active", "expired", "revoked", "superseded", "none"]},
        "package_certificate_exact_scope_match": {"type": "boolean"},
        "parents": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["artifact_sha256", "authority_state", "truth_tier", "certificate_kind", "certificate_id", "certificate_sha256", "certificate_status", "certificate_exact_scope_match"],
            "properties": {
              "artifact_sha256": {"$ref": "#/$defs/sha256"},
              "authority_state": {"$ref": "#/$defs/authorityState"},
              "truth_tier": {"$ref": "#/$defs/truthTier"},
              "certificate_kind": {"$ref": "#/$defs/certificateKind"},
              "certificate_id": {"type": ["string", "null"], "minLength": 1},
              "certificate_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
              "certificate_status": {"enum": ["active", "expired", "revoked", "superseded", "none"]},
              "certificate_exact_scope_match": {"type": "boolean"}
            },
            "allOf": [
              {
                "if": {"properties": {"authority_state": {"const": "certified"}}, "required": ["authority_state"]},
                "then": {
                  "properties": {
                    "certificate_kind": {"const": "exact_serving_route_output"},
                    "certificate_id": {"type": "string"},
                    "certificate_sha256": {"type": "string"},
                    "certificate_status": {"const": "active"},
                    "certificate_exact_scope_match": {"const": true}
                  }
                }
              }
            ]
          }
        },
        "input_target_regions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/inputRegionBinding"}},
        "input_protected_regions": {"type": "array", "items": {"$ref": "#/$defs/inputRegionBinding"}},
        "output_artifact_identity_sha256s": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}}
      },
      "allOf": [
        {
          "if": {"properties": {"operation_kind": {"const": "original_prediction"}}, "required": ["operation_kind"]},
          "then": {
            "properties": {
              "parents": {"maxItems": 0},
              "package_id": {"type": "null"},
              "package_revision": {"type": "null"},
              "package_manifest_sha256": {"type": "null"},
              "package_certificate_kind": {"const": "none"},
              "package_certificate_id": {"type": "null"},
              "package_certificate_sha256": {"type": "null"},
              "package_certificate_status": {"const": "none"},
              "package_certificate_exact_scope_match": {"const": false}
            }
          }
        },
        {
          "if": {"properties": {"operation_kind": {"const": "package_read"}}, "required": ["operation_kind"]},
          "then": {
            "properties": {
              "parents": {"maxItems": 0},
              "package_id": {"type": "string"},
              "package_revision": {"type": "string"},
              "package_manifest_sha256": {"type": "string"},
              "package_certificate_kind": {"enum": ["autonomous_package", "human_anchor_optional"]},
              "package_certificate_id": {"type": "string"},
              "package_certificate_sha256": {"type": "string"},
              "package_certificate_status": {"const": "active"},
              "package_certificate_exact_scope_match": {"const": true}
            }
          }
        },
        {
          "if": {"properties": {"operation_kind": {"enum": ["refinement", "derived_union", "inpaint_derivative", "projection"]}}, "required": ["operation_kind"]},
          "then": {
            "properties": {
              "parents": {"minItems": 1},
              "package_id": {"type": "null"},
              "package_revision": {"type": "null"},
              "package_manifest_sha256": {"type": "null"},
              "package_certificate_kind": {"const": "none"},
              "package_certificate_id": {"type": "null"},
              "package_certificate_sha256": {"type": "null"},
              "package_certificate_status": {"const": "none"},
              "package_certificate_exact_scope_match": {"const": false}
            }
          }
        }
      ]
    },
    "use_eligibility": {
      "type": "object", "additionalProperties": false,
      "required": ["policy_id", "policy_sha256", "required_authority_state", "exact_use_scope", "eligible", "reasons"],
      "properties": {
        "policy_id": {"type": "string", "minLength": 1},
        "policy_sha256": {"$ref": "#/$defs/sha256"},
        "required_authority_state": {"$ref": "#/$defs/authorityState"},
        "exact_use_scope": {"enum": ["production_conditioning", "downstream_promotion_support", "repair_seed", "qa", "diagnostic"]},
        "eligible": {"type": "boolean"},
        "reasons": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "error": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object", "additionalProperties": false,
          "required": ["error_id", "code", "retryable"],
          "properties": {
            "error_id": {"type": "string", "pattern": "^mferr_[0-9a-f]{24}$"},
            "code": {"type": "string", "minLength": 1},
            "retryable": {"type": "boolean"}
          }
        }
      ]
    },
    "receipt_payload_sha256": {"$ref": "#/$defs/sha256"},
    "signature": {"$ref": "#/$defs/signature"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"},
    "authentication": {
      "type": "object", "additionalProperties": false,
      "required": ["principal_id", "authority", "role", "nonce", "issued_at", "expires_at", "replay_window_seconds", "credential_material_included"],
      "properties": {
        "principal_id": {"type": "string", "minLength": 1},
        "authority": {"const": "MaskFactory"},
        "role": {"const": "producer_receipt"},
        "nonce": {"type": "string", "pattern": "^[A-Za-z0-9_-]{24,128}$"},
        "issued_at": {"$ref": "#/$defs/timestamp"},
        "expires_at": {"$ref": "#/$defs/timestamp"},
        "replay_window_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "credential_material_included": {"const": false}
      }
    },
    "trustBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["key_set_id", "key_set_version", "key_set_sha256", "key_role", "signing_key_id", "signing_public_key_sha256", "rotation_policy_sha256", "revocation_policy_sha256"],
      "properties": {
        "key_set_id": {"type": "string", "minLength": 1}, "key_set_version": {"type": "string", "minLength": 1}, "key_set_sha256": {"$ref": "#/$defs/sha256"},
        "key_role": {"const": "producer_receipt"}, "signing_key_id": {"type": "string", "minLength": 1}, "signing_public_key_sha256": {"$ref": "#/$defs/sha256"},
        "rotation_policy_sha256": {"$ref": "#/$defs/sha256"}, "revocation_policy_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "signature": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "key_id", "public_key_base64", "signed_payload_sha256", "signed_payload_format", "value_base64"],
      "properties": {"algorithm": {"const": "ed25519"}, "key_id": {"type": "string", "minLength": 1}, "public_key_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{43}=$"}, "signed_payload_sha256": {"$ref": "#/$defs/sha256"}, "signed_payload_format": {"const": "sha256_digest_bytes"}, "value_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{40,}={0,2}$"}}
    },
    "mediaScope": {
      "type": "object", "additionalProperties": false,
      "required": ["scope_kind", "sequence_id", "shot_id", "take_id", "source_video_sha256", "decoded_frame_sha256", "frame_index", "pts", "timebase_numerator", "timebase_denominator", "timestamp_ns", "frame_span", "neighbor_frames"],
      "properties": {
        "scope_kind": {"enum": ["still_image", "video_frame", "frame_span"]}, "sequence_id": {"type": "string", "minLength": 1}, "shot_id": {"type": "string", "minLength": 1}, "take_id": {"type": "string", "minLength": 1}, "source_video_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}, "decoded_frame_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}, "frame_index": {"type": ["integer", "null"], "minimum": 0}, "pts": {"type": ["integer", "null"]}, "timebase_numerator": {"type": ["integer", "null"], "minimum": 1}, "timebase_denominator": {"type": ["integer", "null"], "minimum": 1}, "timestamp_ns": {"type": ["integer", "null"], "minimum": 0},
        "frame_span": {"oneOf": [{"type": "null"}, {"type": "object", "additionalProperties": false, "required": ["start_frame", "end_frame", "frame_manifest_sha256"], "properties": {"start_frame": {"type": "integer", "minimum": 0}, "end_frame": {"type": "integer", "minimum": 0}, "frame_manifest_sha256": {"$ref": "#/$defs/sha256"}}}]},
        "neighbor_frames": {"type": "array", "uniqueItems": true, "items": {"type": "object", "additionalProperties": false, "required": ["relation", "frame_index", "decoded_frame_sha256"], "properties": {"relation": {"enum": ["previous", "next", "span_member"]}, "frame_index": {"type": "integer", "minimum": 0}, "decoded_frame_sha256": {"$ref": "#/$defs/sha256"}}}}
      }
    },
    "accessMode": {"enum": ["mode_a_package_read", "mode_b_live_predict", "mode_b_live_refine"]},
    "authorityState": {"enum": ["invalid", "hypothesis", "draft", "qa_passed_noncertified", "certified"]},
    "truthTier": {"enum": ["invalid", "machine_candidate", "qa_passed_machine_candidate", "operationally_certified_artifact", "autonomous_certified_gold", "human_anchor_gold"]},
    "certificateKind": {"enum": ["exact_serving_route_output", "autonomous_package", "human_anchor_optional", "none"]},
    "inputRegionBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["region_id", "artifact_identity_sha256", "encoded_sha256", "decoded_mask_sha256", "source_decoded_pixel_sha256", "artifact_type", "owner_identity_sha256", "coordinate_space", "width", "height", "transform_chain_sha256", "transform_step_sequence", "required_minimum_authority_state", "authority_state", "issuer_kind", "certificate_kind", "certificate_id", "certificate_sha256", "certificate_scope_sha256", "certificate_status", "certificate_exact_scope_match", "revocation_checked_at", "revocation_checkpoint_sha256"],
      "properties": {
        "region_id": {"type": "string", "minLength": 1},
        "artifact_identity_sha256": {"$ref": "#/$defs/sha256"},
        "encoded_sha256": {"$ref": "#/$defs/sha256"},
        "decoded_mask_sha256": {"$ref": "#/$defs/sha256"},
        "source_decoded_pixel_sha256": {"$ref": "#/$defs/sha256"},
        "artifact_type": {"type": "string", "minLength": 1},
        "owner_identity_sha256": {"$ref": "#/$defs/sha256"},
        "coordinate_space": {"enum": ["source_pixel", "crop_pixel", "output_pixel"]},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "transform_chain_sha256": {"$ref": "#/$defs/sha256"},
        "transform_step_sequence": {"type": ["integer", "null"], "minimum": 0},
        "required_minimum_authority_state": {"$ref": "#/$defs/authorityState"},
        "authority_state": {"$ref": "#/$defs/authorityState"},
        "issuer_kind": {"type": "string", "minLength": 1},
        "certificate_kind": {"$ref": "#/$defs/certificateKind"},
        "certificate_id": {"type": ["string", "null"]},
        "certificate_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "certificate_scope_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "certificate_status": {"enum": ["active", "expired", "revoked", "superseded", "none"]},
        "certificate_exact_scope_match": {"type": "boolean"},
        "revocation_checked_at": {"type": ["string", "null"], "format": "date-time"},
        "revocation_checkpoint_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "issuerKind": {"enum": ["maskfactory_autonomous", "human_anchor_optional", "none"]}
  },
  "allOf": [
    {
      "if": {"properties": {"access_mode": {"const": "mode_a_package_read"}}, "required": ["access_mode"]},
      "then": {"properties": {"lineage": {"properties": {"operation_kind": {"const": "package_read"}}}}}
    },
    {
      "if": {"properties": {"access_mode": {"const": "mode_b_live_predict"}}, "required": ["access_mode"]},
      "then": {"properties": {"lineage": {"properties": {"operation_kind": {"const": "original_prediction"}, "parents": {"maxItems": 0}}}}}
    },
    {
      "if": {"properties": {"access_mode": {"const": "mode_b_live_refine"}}, "required": ["access_mode"]},
      "then": {"properties": {"lineage": {"properties": {"operation_kind": {"const": "refinement"}, "parents": {"minItems": 1}}}}}
    },
    {
      "if": {"properties": {"result": {"const": "succeeded"}}, "required": ["result"]},
      "then": {
        "properties": {
          "artifacts": {"minItems": 1},
          "error": {"type": "null"},
          "transform_validation": {"properties": {"roundtrip_passed": {"const": true}}}
        }
      }
    },
    {
      "if": {"properties": {"result": {"enum": ["blocked", "failed"]}}, "required": ["result"]},
      "then": {
        "properties": {
          "artifacts": {"maxItems": 0},
          "error": {"type": "object"},
          "use_eligibility": {"properties": {"eligible": {"const": false}}}
        }
      }
    },
    {
      "if": {"properties": {"authority": {"properties": {"authority_state": {"const": "certified"}}, "required": ["authority_state"]}}, "required": ["authority"]},
      "then": {
        "properties": {
          "authority": {
            "properties": {
              "issuer_kind": {"const": "maskfactory_autonomous"},
              "certificate_kind": {"const": "exact_serving_route_output"},
              "certificate_id": {"type": "string"},
              "certificate_sha256": {"type": "string"},
              "certificate_status": {"const": "active"},
              "certificate_exact_scope_match": {"const": true},
              "revocation_checked_at": {"type": "string"},
              "revocation_index_sha256": {"type": "string"}
            }
          },
          "qa": {"properties": {"status": {"const": "pass"}}},
          "transform_validation": {"properties": {"roundtrip_passed": {"const": true}}},
          "result": {"const": "succeeded"}
        }
      }
    },
    {
      "if": {"properties": {"authority": {"properties": {"authority_state": {"const": "invalid"}}, "required": ["authority_state"]}}, "required": ["authority"]},
      "then": {"properties": {"truth_tier": {"const": "invalid"}}}
    },
    {
      "if": {"properties": {"authority": {"properties": {"authority_state": {"enum": ["hypothesis", "draft"]}}, "required": ["authority_state"]}}, "required": ["authority"]},
      "then": {"properties": {"truth_tier": {"const": "machine_candidate"}}}
    },
    {
      "if": {"properties": {"authority": {"properties": {"authority_state": {"const": "qa_passed_noncertified"}}, "required": ["authority_state"]}}, "required": ["authority"]},
      "then": {"properties": {"truth_tier": {"const": "qa_passed_machine_candidate"}}}
    },
    {
      "if": {"properties": {"authority": {"properties": {"authority_state": {"const": "certified"}, "issuer_kind": {"const": "maskfactory_autonomous"}}, "required": ["authority_state", "issuer_kind"]}}, "required": ["authority"]},
      "then": {"properties": {"truth_tier": {"const": "operationally_certified_artifact"}}}
    },
    {
      "if": {"properties": {"authority": {"properties": {"authority_state": {"const": "certified"}, "issuer_kind": {"const": "human_anchor_optional"}}, "required": ["authority_state", "issuer_kind"]}}, "required": ["authority"]},
      "then": {"properties": {"truth_tier": {"const": "human_anchor_gold"}}}
    },
    {
      "if": {"properties": {"access_mode": {"enum": ["mode_b_live_predict", "mode_b_live_refine"]}}, "required": ["access_mode"]},
      "then": {"properties": {"provider_binding": {"type": "object"}}}
    },
    {
      "if": {
        "properties": {
          "access_mode": {"enum": ["mode_b_live_predict", "mode_b_live_refine"]},
          "authority": {"properties": {"authority_state": {"const": "certified"}}, "required": ["authority_state"]}
        },
        "required": ["access_mode", "authority"]
      },
      "then": {
        "properties": {
          "authority": {
            "properties": {
              "certificate_kind": {"const": "exact_serving_route_output"},
              "decision_basis": {"const": "exact_output_certificate"},
              "issuer_kind": {"const": "maskfactory_autonomous"}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "access_mode": {"const": "mode_b_live_refine"},
          "authority": {"properties": {"authority_state": {"const": "certified"}}, "required": ["authority_state"]}
        },
        "required": ["access_mode", "authority"]
      },
      "then": {
        "properties": {
          "lineage": {
            "properties": {
              "parents": {
                "items": {
                  "properties": {
                    "authority_state": {"const": "certified"},
                    "certificate_status": {"const": "active"},
                    "certificate_exact_scope_match": {"const": true}
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}

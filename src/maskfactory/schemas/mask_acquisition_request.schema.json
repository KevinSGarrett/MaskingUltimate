{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/mask_acquisition_request.schema.json",
  "title": "Mode-explicit MaskFactory mask acquisition request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "record_type", "request_id", "project_id", "run_id", "correlation_id", "job_id", "pass_id",
    "attempt_id", "attempt_number", "hypothesis", "idempotency_key", "created_at", "deadline_at", "authentication", "trust_binding", "canonicalization", "access_mode", "media_scope", "source", "subject",
    "mask_intents", "target_regions", "protected_regions", "protected_owner_roster", "transform_chain", "compatibility",
    "minimum_authority_state", "accepted_authority", "resource_envelope", "retry_policy",
    "mode_payload", "request_payload_sha256", "signature"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "mask_acquisition_request"},
    "request_id": {"type": "string", "pattern": "^mfareq_[0-9a-f]{24}$"},
    "project_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "correlation_id": {"type": "string", "minLength": 1},
    "job_id": {"type": "string", "minLength": 1},
    "pass_id": {"type": "string", "minLength": 1},
    "attempt_id": {"type": "string", "minLength": 1},
    "attempt_number": {"type": "integer", "minimum": 1},
    "hypothesis": {
      "type": "object", "additionalProperties": false,
      "required": ["hypothesis_id", "hypothesis_class", "material_change_sha256", "retry_kind"],
      "properties": {
        "hypothesis_id": {"type": "string", "minLength": 1},
        "hypothesis_class": {"enum": ["initial", "geometry", "ownership", "boundary", "model_route", "prompt_control", "transform", "transport_replay"]},
        "material_change_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "retry_kind": {"enum": ["initial", "quality_hypothesis", "transport_replay"]}
      },
      "allOf": [
        {"if": {"properties": {"retry_kind": {"const": "quality_hypothesis"}}, "required": ["retry_kind"]}, "then": {"properties": {"material_change_sha256": {"type": "string"}}}},
        {"if": {"properties": {"retry_kind": {"const": "transport_replay"}}, "required": ["retry_kind"]}, "then": {"properties": {"hypothesis_class": {"const": "transport_replay"}}}}
      ]
    },
    "idempotency_key": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{16,128}$"},
    "created_at": {"$ref": "#/$defs/timestamp"},
    "deadline_at": {"$ref": "#/$defs/timestamp"},
    "authentication": {"$ref": "#/$defs/authentication"},
    "trust_binding": {"$ref": "#/$defs/trustBinding"},
    "canonicalization": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "excluded_top_level_fields"],
      "properties": {
        "algorithm": {"const": "maskfactory-canonical-json-v1"},
        "excluded_top_level_fields": {"type": "array", "prefixItems": [{"const": "request_payload_sha256"}, {"const": "signature"}], "minItems": 2, "maxItems": 2}
      }
    },
    "access_mode": {"$ref": "#/$defs/accessMode"},
    "media_scope": {"$ref": "#/$defs/mediaScope"},
    "source": {"$ref": "#/$defs/sourceArtifact"},
    "subject": {"$ref": "#/$defs/subject"},
    "mask_intents": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["intent_id", "label", "artifact_kind", "purpose", "target_coordinate_space", "target_region_ids", "protected_region_ids"],
        "properties": {
          "intent_id": {"type": "string", "pattern": "^[A-Za-z0-9._:-]+$"},
          "label": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "artifact_kind": {"enum": ["atomic_visible", "protected_qa", "region_band", "derived_union", "inpaint_derivative", "label_map"]},
          "purpose": {"enum": ["conditioning", "inpaint_target", "protected_region", "qa", "ownership"]},
          "target_coordinate_space": {"enum": ["source_pixel", "crop_pixel", "output_pixel"]},
          "target_region_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "protected_region_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        }
      }
    },
    "target_regions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/regionBinding"}},
    "protected_regions": {"type": "array", "items": {"$ref": "#/$defs/regionBinding"}},
    "protected_owner_roster": {
      "type": "array", "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["owner", "relationship", "authorization_policy_id", "authorization_policy_sha256"],
        "properties": {
          "owner": {"$ref": "#/$defs/owner"},
          "relationship": {"enum": ["self", "other_character", "prop", "environment"]},
          "authorization_policy_id": {"type": "string", "minLength": 1},
          "authorization_policy_sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "transform_chain": {"$ref": "#/$defs/transformChain"},
    "compatibility": {
      "type": "object", "additionalProperties": false,
      "required": ["bridge_contract", "release_id", "capability_snapshot_id", "capability_snapshot_sha256", "api_contract", "package_format", "ontology_version", "ontology_sha256"],
      "properties": {
        "bridge_contract": {"const": "maskfactory-comfyui-bridge/1.0"},
        "release_id": {"type": "string", "pattern": "^mfr_[0-9]{8}_[0-9a-f]{12}$"},
        "capability_snapshot_id": {"type": "string", "pattern": "^mfcap_[0-9a-f]{24}$"},
        "capability_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "api_contract": {"type": "string", "minLength": 1},
        "package_format": {"type": "string", "minLength": 1},
        "ontology_version": {"type": "string", "minLength": 1},
        "ontology_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "minimum_authority_state": {"$ref": "#/$defs/authorityState"},
    "accepted_authority": {
      "type": "object", "additionalProperties": false,
      "required": ["issuer_kinds", "certificate_kinds", "required_certificate_scope_sha256", "require_active_certificate", "require_exact_scope_match"],
      "properties": {
        "issuer_kinds": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"enum": ["maskfactory_autonomous", "human_anchor_optional", "none"]}
        },
        "certificate_kinds": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"$ref": "#/$defs/certificateKind"}
        },
        "required_certificate_scope_sha256": {"$ref": "#/$defs/sha256"},
        "require_active_certificate": {"type": "boolean"},
        "require_exact_scope_match": {"type": "boolean"}
      }
    },
    "resource_envelope": {
      "type": "object", "additionalProperties": false,
      "required": ["maximum_runtime_ms", "maximum_queue_ms", "maximum_vram_mb", "maximum_ram_mb", "maximum_output_bytes", "priority", "allow_cpu_fallback"],
      "properties": {
        "maximum_runtime_ms": {"type": "integer", "minimum": 1},
        "maximum_queue_ms": {"type": "integer", "minimum": 0},
        "maximum_vram_mb": {"type": "integer", "minimum": 0},
        "maximum_ram_mb": {"type": "integer", "minimum": 1},
        "maximum_output_bytes": {"type": "integer", "minimum": 1},
        "priority": {"enum": ["low", "normal", "high", "critical"]},
        "allow_cpu_fallback": {"type": "boolean"}
      }
    },
    "retry_policy": {
      "type": "object", "additionalProperties": false,
      "required": ["maximum_attempts", "retry_only_typed_transient_errors", "allow_silent_fallback"],
      "properties": {
        "maximum_attempts": {"type": "integer", "minimum": 1, "maximum": 10},
        "retry_only_typed_transient_errors": {"const": true},
        "allow_silent_fallback": {"const": false}
      }
    },
    "mode_payload": {
      "oneOf": [
        {"$ref": "#/$defs/modeAPackageRead"},
        {"$ref": "#/$defs/modeBPredict"},
        {"$ref": "#/$defs/modeBRefine"}
      ]
    },
    "request_payload_sha256": {"$ref": "#/$defs/sha256"},
    "signature": {"$ref": "#/$defs/signature"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"},
    "authentication": {
      "type": "object", "additionalProperties": false,
      "required": ["principal_id", "authority", "role", "nonce", "issued_at", "expires_at", "replay_window_seconds", "credential_material_included"],
      "properties": {
        "principal_id": {"type": "string", "minLength": 1},
        "authority": {"const": "Comfy_UI_Main"},
        "role": {"const": "consumer_request"},
        "nonce": {"type": "string", "pattern": "^[A-Za-z0-9_-]{24,128}$"},
        "issued_at": {"$ref": "#/$defs/timestamp"},
        "expires_at": {"$ref": "#/$defs/timestamp"},
        "replay_window_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "credential_material_included": {"const": false}
      }
    },
    "trustBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["key_set_id", "key_set_version", "key_set_sha256", "key_role", "signing_key_id", "signing_public_key_sha256", "rotation_policy_sha256", "revocation_policy_sha256"],
      "properties": {
        "key_set_id": {"type": "string", "minLength": 1},
        "key_set_version": {"type": "string", "minLength": 1},
        "key_set_sha256": {"$ref": "#/$defs/sha256"},
        "key_role": {"const": "consumer_request"},
        "signing_key_id": {"type": "string", "minLength": 1},
        "signing_public_key_sha256": {"$ref": "#/$defs/sha256"},
        "rotation_policy_sha256": {"$ref": "#/$defs/sha256"},
        "revocation_policy_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "signature": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "key_id", "public_key_base64", "signed_payload_sha256", "signed_payload_format", "value_base64"],
      "properties": {
        "algorithm": {"const": "ed25519"},
        "key_id": {"type": "string", "minLength": 1},
        "public_key_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{43}=$"},
        "signed_payload_sha256": {"$ref": "#/$defs/sha256"},
        "signed_payload_format": {"const": "sha256_digest_bytes"},
        "value_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{40,}={0,2}$"}
      }
    },
    "accessMode": {"enum": ["mode_a_package_read", "mode_b_live_predict", "mode_b_live_refine"]},
    "mediaScope": {
      "type": "object", "additionalProperties": false,
      "required": ["scope_kind", "sequence_id", "shot_id", "take_id", "source_video_sha256", "decoded_frame_sha256", "frame_index", "pts", "timebase_numerator", "timebase_denominator", "timestamp_ns", "frame_span", "neighbor_frames"],
      "properties": {
        "scope_kind": {"enum": ["still_image", "video_frame", "frame_span"]}, "sequence_id": {"type": "string", "minLength": 1}, "shot_id": {"type": "string", "minLength": 1}, "take_id": {"type": "string", "minLength": 1}, "source_video_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}, "decoded_frame_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}, "frame_index": {"type": ["integer", "null"], "minimum": 0}, "pts": {"type": ["integer", "null"]}, "timebase_numerator": {"type": ["integer", "null"], "minimum": 1}, "timebase_denominator": {"type": ["integer", "null"], "minimum": 1}, "timestamp_ns": {"type": ["integer", "null"], "minimum": 0},
        "frame_span": {"oneOf": [{"type": "null"}, {"type": "object", "additionalProperties": false, "required": ["start_frame", "end_frame", "frame_manifest_sha256"], "properties": {"start_frame": {"type": "integer", "minimum": 0}, "end_frame": {"type": "integer", "minimum": 0}, "frame_manifest_sha256": {"$ref": "#/$defs/sha256"}}}]},
        "neighbor_frames": {"type": "array", "uniqueItems": true, "items": {"type": "object", "additionalProperties": false, "required": ["relation", "frame_index", "decoded_frame_sha256"], "properties": {"relation": {"enum": ["previous", "next", "span_member"]}, "frame_index": {"type": "integer", "minimum": 0}, "decoded_frame_sha256": {"$ref": "#/$defs/sha256"}}}}
      }
    },
    "authorityState": {"enum": ["invalid", "hypothesis", "draft", "qa_passed_noncertified", "certified"]},
    "truthTier": {"enum": ["invalid", "machine_candidate", "qa_passed_machine_candidate", "operationally_certified_artifact", "autonomous_certified_gold", "human_anchor_gold"]},
    "certificateKind": {"enum": ["exact_serving_route_output", "autonomous_package", "human_anchor_optional", "none"]},
    "subject": {
      "type": "object", "additionalProperties": false,
      "required": ["scene_id", "shot_id", "take_id", "character_id", "character_revision", "scene_instance_id", "canonical_person_id", "person_index", "provider_person_index", "assignment_evidence"],
      "properties": {
        "scene_id": {"type": "string", "minLength": 1},
        "shot_id": {"type": "string", "minLength": 1},
        "take_id": {"type": "string", "minLength": 1},
        "character_id": {"type": "string", "minLength": 1},
        "character_revision": {"type": "string", "minLength": 1},
        "scene_instance_id": {"type": "string", "minLength": 1},
        "canonical_person_id": {"type": "string", "minLength": 1},
        "person_index": {"type": "integer", "minimum": 0}
        ,"provider_person_index": {"type": "integer", "minimum": 0}
        ,"assignment_evidence": {
          "type": "object", "additionalProperties": false,
          "required": ["mapping_id", "mapping_sha256", "status", "bbox_sha256", "skeleton_sha256", "silhouette_sha256", "depth_sha256"],
          "properties": {
            "mapping_id": {"type": "string", "minLength": 1},
            "mapping_sha256": {"$ref": "#/$defs/sha256"},
            "status": {"const": "unambiguous"},
            "bbox_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
            "skeleton_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
            "silhouette_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
            "depth_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
          },
          "anyOf": [
            {"properties": {"bbox_sha256": {"type": "string"}}},
            {"properties": {"skeleton_sha256": {"type": "string"}}},
            {"properties": {"silhouette_sha256": {"type": "string"}}},
            {"properties": {"depth_sha256": {"type": "string"}}}
          ]
        }
      }
    },
    "sourceArtifact": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "encoded_sha256", "decoded_pixel_sha256", "decoder", "exif_orientation", "orientation_applied", "width", "height", "channel_layout", "alpha_mode", "bit_depth", "dtype", "color_space", "icc_profile_sha256", "color_transform", "frame_extraction", "coordinate_space"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "encoded_sha256": {"$ref": "#/$defs/sha256"},
        "decoded_pixel_sha256": {"$ref": "#/$defs/sha256"},
        "decoder": {"type": "object", "additionalProperties": false, "required": ["decoder_id", "version", "binary_sha256"], "properties": {"decoder_id": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}, "binary_sha256": {"$ref": "#/$defs/sha256"}}},
        "exif_orientation": {"type": "integer", "minimum": 1, "maximum": 8},
        "orientation_applied": {"type": "boolean"},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "channel_layout": {"enum": ["GRAY", "RGB", "RGBA"]},
        "alpha_mode": {"enum": ["none", "straight", "premultiplied", "discarded"]},
        "bit_depth": {"enum": [8, 16, 32]},
        "dtype": {"enum": ["uint8", "uint16", "float32"]},
        "color_space": {"enum": ["sRGB", "linear_sRGB"]},
        "icc_profile_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "color_transform": {"type": "object", "additionalProperties": false, "required": ["transform_id", "transform_sha256"], "properties": {"transform_id": {"type": "string", "minLength": 1}, "transform_sha256": {"$ref": "#/$defs/sha256"}}},
        "frame_extraction": {"oneOf": [{"type": "null"}, {"type": "object", "additionalProperties": false, "required": ["source_video_sha256", "frame_index", "pts", "timebase_numerator", "timebase_denominator", "extractor_sha256"], "properties": {"source_video_sha256": {"$ref": "#/$defs/sha256"}, "frame_index": {"type": "integer", "minimum": 0}, "pts": {"type": "integer"}, "timebase_numerator": {"type": "integer", "minimum": 1}, "timebase_denominator": {"type": "integer", "minimum": 1}, "extractor_sha256": {"$ref": "#/$defs/sha256"}}}]},
        "coordinate_space": {"const": "source_pixel"}
      }
    },
    "owner": {
      "type": "object", "additionalProperties": false,
      "required": ["owner_kind", "entity_id", "scene_instance_id", "canonical_person_id", "person_index"],
      "properties": {
        "owner_kind": {"enum": ["character_instance", "prop", "environment"]},
        "entity_id": {"type": "string", "minLength": 1},
        "scene_instance_id": {"type": ["string", "null"], "minLength": 1},
        "canonical_person_id": {"type": ["string", "null"], "minLength": 1},
        "person_index": {"type": ["integer", "null"], "minimum": 0}
      },
      "allOf": [
        {"if": {"properties": {"owner_kind": {"const": "character_instance"}}, "required": ["owner_kind"]}, "then": {"properties": {"scene_instance_id": {"type": "string"}, "canonical_person_id": {"type": "string"}, "person_index": {"type": "integer"}}}},
        {"if": {"properties": {"owner_kind": {"enum": ["prop", "environment"]}}, "required": ["owner_kind"]}, "then": {"properties": {"scene_instance_id": {"type": "null"}, "canonical_person_id": {"type": "null"}, "person_index": {"type": "null"}}}}
      ]
    },
    "regionBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["region_id", "artifact_id", "artifact_identity_sha256", "encoded_sha256", "decoded_mask_sha256", "format", "channel_layout", "dtype", "allowed_values", "mask_type", "artifact_kind", "visibility", "empty_semantics", "content_summary", "source_decoded_pixel_sha256", "owner", "label", "coordinate_space", "width", "height", "transform_chain_sha256", "transform_step_sequence", "required_minimum_authority_state", "authority_binding"],
      "properties": {
        "region_id": {"type": "string", "minLength": 1},
        "artifact_id": {"type": "string", "minLength": 1},
        "artifact_identity_sha256": {"$ref": "#/$defs/sha256"},
        "encoded_sha256": {"$ref": "#/$defs/sha256"},
        "decoded_mask_sha256": {"$ref": "#/$defs/sha256"},
        "format": {"enum": ["PNG", "TIFF", "NPY", "LABEL_MAP"]},
        "channel_layout": {"enum": ["L", "LA", "RGBA", "LABEL_INDEX"]},
        "dtype": {"enum": ["uint8", "uint16", "float32"]},
        "allowed_values": {"enum": ["binary_0_1", "binary_0_255", "matte_0_1", "label_indices"]},
        "mask_type": {"enum": ["atomic", "derived", "inpaint", "matte", "label_map", "roi_control"]},
        "artifact_kind": {"enum": ["atomic_visible", "protected_qa", "region_band", "derived_union", "inpaint_derivative", "label_map"]},
        "visibility": {"enum": ["visible", "occluded_inferred", "complete_map", "control_only"]},
        "empty_semantics": {"enum": ["forbidden", "allowed_explicit_absence", "allowed_no_visible_pixels"]},
        "content_summary": {"type": "object", "additionalProperties": false, "required": ["bounds", "area_pixels", "area_ppm", "is_empty"], "properties": {"bounds": {"type": ["object", "null"], "additionalProperties": false, "required": ["x", "y", "width", "height"], "properties": {"x": {"type": "integer", "minimum": 0}, "y": {"type": "integer", "minimum": 0}, "width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1}}}, "area_pixels": {"type": "integer", "minimum": 0}, "area_ppm": {"type": "integer", "minimum": 0, "maximum": 1000000}, "is_empty": {"type": "boolean"}}},
        "source_decoded_pixel_sha256": {"$ref": "#/$defs/sha256"},
        "owner": {"$ref": "#/$defs/owner"},
        "label": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "coordinate_space": {"enum": ["source_pixel", "crop_pixel", "output_pixel"]},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "transform_chain_sha256": {"$ref": "#/$defs/sha256"},
        "transform_step_sequence": {"type": ["integer", "null"], "minimum": 0},
        "required_minimum_authority_state": {"$ref": "#/$defs/authorityState"},
        "authority_binding": {
          "type": "object", "additionalProperties": false,
          "required": ["authority_state", "issuer_kind", "certificate_kind", "certificate_id", "certificate_sha256", "certificate_status", "certificate_scope_sha256", "certificate_exact_scope_match", "revocation_checked_at", "revocation_checkpoint_sha256"],
          "properties": {
            "authority_state": {"$ref": "#/$defs/authorityState"},
            "issuer_kind": {"enum": ["maskfactory_autonomous", "human_anchor_optional", "consumer_advisory", "none"]},
            "certificate_kind": {"$ref": "#/$defs/certificateKind"},
            "certificate_id": {"type": ["string", "null"], "minLength": 1},
            "certificate_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
            "certificate_status": {"enum": ["active", "expired", "revoked", "superseded", "none"]},
            "certificate_scope_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
            "certificate_exact_scope_match": {"type": "boolean"},
            "revocation_checked_at": {"type": ["string", "null"], "format": "date-time"},
            "revocation_checkpoint_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
          }
        }
      }
    },
    "coordinateState": {
      "type": "object", "additionalProperties": false,
      "required": ["coordinate_space", "width", "height"],
      "properties": {
        "coordinate_space": {"enum": ["source_pixel", "crop_pixel", "output_pixel"]},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1}
      }
    },
    "transformParameters": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["parameter_type", "x", "y", "width", "height"],
          "properties": {"parameter_type": {"const": "crop"}, "x": {"type": "integer", "minimum": 0}, "y": {"type": "integer", "minimum": 0}, "width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["parameter_type", "width", "height", "interpolation", "rounding", "antialias"],
          "properties": {"parameter_type": {"const": "resize"}, "width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1}, "interpolation": {"enum": ["nearest", "bilinear", "bicubic", "lanczos"]}, "rounding": {"enum": ["floor", "ceil", "half_even", "half_away_from_zero"]}, "antialias": {"type": "boolean"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["parameter_type", "left", "right", "top", "bottom", "mode", "value"],
          "properties": {"parameter_type": {"const": "pad"}, "left": {"type": "integer", "minimum": 0}, "right": {"type": "integer", "minimum": 0}, "top": {"type": "integer", "minimum": 0}, "bottom": {"type": "integer", "minimum": 0}, "mode": {"enum": ["constant", "reflect", "edge"]}, "value": {"type": ["number", "null"], "minimum": 0, "maximum": 1}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["parameter_type", "axis", "character_side_swap"],
          "properties": {"parameter_type": {"const": "horizontal_flip"}, "axis": {"const": "horizontal"}, "character_side_swap": {"const": true}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["parameter_type", "matrix_3x3", "clip_policy", "rounding"],
          "properties": {"parameter_type": {"enum": ["project", "inverse_project"]}, "matrix_3x3": {"type": "array", "minItems": 9, "maxItems": 9, "items": {"type": "number"}}, "clip_policy": {"enum": ["clip", "pad", "reject_out_of_bounds"]}, "rounding": {"enum": ["floor", "ceil", "half_even", "half_away_from_zero"]}}
        }
      ]
    },
    "transformStep": {
      "type": "object", "additionalProperties": false,
      "required": ["sequence", "operation", "input", "output", "parameters", "inverse_strategy", "step_sha256"],
      "properties": {
        "sequence": {"type": "integer", "minimum": 0},
        "operation": {"enum": ["crop", "resize", "pad", "horizontal_flip", "project", "inverse_project"]},
        "input": {"$ref": "#/$defs/coordinateState"},
        "output": {"$ref": "#/$defs/coordinateState"},
        "parameters": {"$ref": "#/$defs/transformParameters"},
        "inverse_strategy": {"enum": ["exact_inverse", "reproject_with_context", "none"]},
        "step_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "transformChain": {
      "type": "object", "additionalProperties": false,
      "required": ["chain_id", "chain_sha256", "source", "output", "steps", "roundtrip_policy"],
      "properties": {
        "chain_id": {"type": "string", "minLength": 1},
        "chain_sha256": {"$ref": "#/$defs/sha256"},
        "source": {"$ref": "#/$defs/coordinateState"},
        "output": {"$ref": "#/$defs/coordinateState"},
        "steps": {"type": "array", "items": {"$ref": "#/$defs/transformStep"}},
        "roundtrip_policy": {
          "type": "object", "additionalProperties": false,
          "required": ["required", "maximum_error_px", "reject_noninvertible"],
          "properties": {"required": {"const": true}, "maximum_error_px": {"type": "number", "minimum": 0}, "reject_noninvertible": {"const": true}}
        }
      }
    },
    "point": {
      "type": "object", "additionalProperties": false,
      "required": ["x", "y", "coordinate_space"],
      "properties": {
        "x": {"type": "number", "minimum": 0},
        "y": {"type": "number", "minimum": 0},
        "coordinate_space": {"enum": ["source_pixel", "crop_pixel", "output_pixel", "normalized_0_1"]}
      }
    },
    "box": {
      "type": "object", "additionalProperties": false,
      "required": ["x0", "y0", "x1", "y1", "coordinate_space"],
      "properties": {
        "x0": {"type": "number", "minimum": 0},
        "y0": {"type": "number", "minimum": 0},
        "x1": {"type": "number", "exclusiveMinimum": 0},
        "y1": {"type": "number", "exclusiveMinimum": 0},
        "coordinate_space": {"enum": ["source_pixel", "crop_pixel", "output_pixel", "normalized_0_1"]}
      }
    },
    "parentArtifact": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "artifact_identity_sha256", "encoded_sha256", "decoded_mask_sha256", "source_decoded_pixel_sha256", "owner", "label", "mask_type", "coordinate_space", "width", "height", "transform_chain_sha256", "transform_step_sequence", "authority_state", "truth_tier", "certificate_kind", "certificate_id", "certificate_sha256", "certificate_status", "certificate_scope_sha256", "certificate_exact_scope_match", "revocation_checked_at", "revocation_checkpoint_sha256"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "artifact_identity_sha256": {"$ref": "#/$defs/sha256"},
        "encoded_sha256": {"$ref": "#/$defs/sha256"},
        "decoded_mask_sha256": {"$ref": "#/$defs/sha256"},
        "source_decoded_pixel_sha256": {"$ref": "#/$defs/sha256"},
        "owner": {"$ref": "#/$defs/owner"},
        "label": {"type": "string", "minLength": 1},
        "mask_type": {"enum": ["atomic", "derived", "inpaint", "matte", "label_map", "roi_control"]},
        "coordinate_space": {"enum": ["source_pixel", "crop_pixel", "output_pixel"]},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "transform_chain_sha256": {"$ref": "#/$defs/sha256"},
        "transform_step_sequence": {"type": ["integer", "null"], "minimum": 0},
        "authority_state": {"$ref": "#/$defs/authorityState"},
        "truth_tier": {"$ref": "#/$defs/truthTier"},
        "certificate_kind": {"$ref": "#/$defs/certificateKind"},
        "certificate_id": {"type": ["string", "null"], "minLength": 1},
        "certificate_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "certificate_status": {"enum": ["active", "expired", "revoked", "superseded", "none"]},
        "certificate_scope_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "certificate_exact_scope_match": {"type": "boolean"},
        "revocation_checked_at": {"type": ["string", "null"], "format": "date-time"},
        "revocation_checkpoint_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      },
      "allOf": [
        {
          "if": {"properties": {"authority_state": {"const": "certified"}}, "required": ["authority_state"]},
          "then": {
            "properties": {
              "certificate_kind": {"enum": ["exact_serving_route_output", "autonomous_package", "human_anchor_optional"]},
              "certificate_id": {"type": "string"},
              "certificate_sha256": {"type": "string"},
              "certificate_status": {"const": "active"},
              "certificate_exact_scope_match": {"const": true}
            }
          }
        }
      ]
    },
    "modeAPackageRead": {
      "type": "object", "additionalProperties": false,
      "required": ["payload_type", "package_selector", "artifact_selectors", "mode_payload_sha256"],
      "properties": {
        "payload_type": {"const": "mode_a_package_read"},
        "package_selector": {
          "type": "object", "additionalProperties": false,
          "required": ["package_id", "package_revision", "package_manifest_sha256", "package_certificate_kind", "package_certificate_id", "package_certificate_sha256", "package_certificate_status", "package_certificate_exact_scope_match"],
          "properties": {
            "package_id": {"type": "string", "minLength": 1},
            "package_revision": {"type": "string", "minLength": 1},
            "package_manifest_sha256": {"$ref": "#/$defs/sha256"},
            "package_certificate_kind": {"enum": ["autonomous_package", "human_anchor_optional"]},
            "package_certificate_id": {"type": "string", "minLength": 1},
            "package_certificate_sha256": {"$ref": "#/$defs/sha256"},
            "package_certificate_status": {"const": "active"},
            "package_certificate_exact_scope_match": {"const": true}
          }
        },
        "artifact_selectors": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["artifact_id", "artifact_identity_sha256", "encoded_sha256", "decoded_mask_sha256", "label", "artifact_kind", "canonical_person_id", "person_index", "coordinate_space"],
            "properties": {
              "artifact_id": {"type": "string", "minLength": 1},
              "artifact_identity_sha256": {"$ref": "#/$defs/sha256"},
              "encoded_sha256": {"$ref": "#/$defs/sha256"},
              "decoded_mask_sha256": {"$ref": "#/$defs/sha256"},
              "label": {"type": "string", "minLength": 1},
              "artifact_kind": {"type": "string", "minLength": 1},
              "canonical_person_id": {"type": "string", "minLength": 1},
              "person_index": {"type": "integer", "minimum": 0},
              "coordinate_space": {"enum": ["source_pixel", "crop_pixel", "output_pixel"]}
            }
          }
        },
        "mode_payload_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "modeBPredict": {
      "type": "object", "additionalProperties": false,
      "required": ["payload_type", "prompt", "positive_points", "negative_points", "boxes", "spatial_prior", "mode_payload_sha256"],
      "properties": {
        "payload_type": {"const": "mode_b_live_predict"},
        "prompt": {
          "type": "object", "additionalProperties": false,
          "required": ["text", "sha256"],
          "properties": {
            "text": {"type": "string", "minLength": 1},
            "sha256": {"$ref": "#/$defs/sha256"}
          }
        },
        "positive_points": {"type": "array", "items": {"$ref": "#/$defs/point"}},
        "negative_points": {"type": "array", "items": {"$ref": "#/$defs/point"}},
        "boxes": {"type": "array", "items": {"$ref": "#/$defs/box"}},
        "spatial_prior": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/regionBinding"}]},
        "mode_payload_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "modeBRefine": {
      "type": "object", "additionalProperties": false,
      "required": ["payload_type", "parent_artifacts", "prior_mask", "refinement_prompt", "positive_clicks", "negative_clicks", "boxes", "mode_payload_sha256"],
      "properties": {
        "payload_type": {"const": "mode_b_live_refine"},
        "parent_artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/parentArtifact"}},
        "prior_mask": {"$ref": "#/$defs/regionBinding"},
        "refinement_prompt": {"type": ["string", "null"], "minLength": 1},
        "positive_clicks": {"type": "array", "items": {"$ref": "#/$defs/point"}},
        "negative_clicks": {"type": "array", "items": {"$ref": "#/$defs/point"}},
        "boxes": {"type": "array", "items": {"$ref": "#/$defs/box"}},
        "mode_payload_sha256": {"$ref": "#/$defs/sha256"}
      },
      "anyOf": [
        {"properties": {"refinement_prompt": {"type": "string", "minLength": 1}}},
        {"properties": {"positive_clicks": {"minItems": 1}}},
        {"properties": {"negative_clicks": {"minItems": 1}}},
        {"properties": {"boxes": {"minItems": 1}}}
      ]
    }
  },
  "oneOf": [
    {
      "properties": {
        "access_mode": {"const": "mode_a_package_read"},
        "mode_payload": {"$ref": "#/$defs/modeAPackageRead"}
      }
    },
    {
      "properties": {
        "access_mode": {"const": "mode_b_live_predict"},
        "mode_payload": {"$ref": "#/$defs/modeBPredict"}
      }
    },
    {
      "properties": {
        "access_mode": {"const": "mode_b_live_refine"},
        "mode_payload": {"$ref": "#/$defs/modeBRefine"}
      }
    }
  ],
  "allOf": [
    {
      "if": {"properties": {"minimum_authority_state": {"const": "certified"}}, "required": ["minimum_authority_state"]},
      "then": {
        "properties": {
          "accepted_authority": {
            "properties": {
              "issuer_kinds": {"prefixItems": [{"const": "maskfactory_autonomous"}], "minItems": 1, "maxItems": 1},
              "certificate_kinds": {"prefixItems": [{"const": "exact_serving_route_output"}], "minItems": 1, "maxItems": 1},
              "require_active_certificate": {"const": true},
              "require_exact_scope_match": {"const": true}
            }
          }
        }
      }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/mask_repair_feedback.schema.json",
  "title": "Authenticated, exact-bound and advisory downstream repair feedback",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "record_type", "feedback_id", "project_id", "run_id", "job_id", "pass_id", "attempt_id", "created_at",
    "consumer", "authentication", "trust_binding", "canonicalization", "parent_receipt_binding", "release_binding", "policy_binding",
    "certificate_binding", "source_binding", "media_scope_sha256", "subject_binding", "provider_binding", "output_artifact_bindings",
    "protected_artifact_bindings", "transform_binding", "qa_binding", "authority_binding", "defects", "hypothesis", "requested_action",
    "retry_budget", "progress_guard", "immutable_accepted_parent", "advisory_only", "consumer_may_mutate_gold",
    "consumer_may_escalate_authority", "feedback_payload_sha256", "signature"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "record_type": {"const": "mask_repair_feedback"},
    "feedback_id": {"type": "string", "pattern": "^mffb_[0-9a-f]{24}$"},
    "project_id": {"type": "string", "minLength": 1}, "run_id": {"type": "string", "minLength": 1}, "job_id": {"type": "string", "minLength": 1}, "pass_id": {"type": "string", "minLength": 1}, "attempt_id": {"type": "string", "minLength": 1},
    "created_at": {"$ref": "#/$defs/timestamp"}, "consumer": {"const": "Comfy_UI_Main"},
    "authentication": {"$ref": "#/$defs/authentication"}, "trust_binding": {"$ref": "#/$defs/trustBinding"},
    "canonicalization": {"type": "object", "additionalProperties": false, "required": ["algorithm", "excluded_top_level_fields"], "properties": {"algorithm": {"const": "maskfactory-canonical-json-v1"}, "excluded_top_level_fields": {"type": "array", "prefixItems": [{"const": "feedback_payload_sha256"}, {"const": "signature"}], "minItems": 2, "maxItems": 2}}},
    "parent_receipt_binding": {"type": "object", "additionalProperties": false, "required": ["receipt_id", "receipt_payload_sha256", "request_id", "request_payload_sha256"], "properties": {"receipt_id": {"type": "string", "pattern": "^mfarec_[0-9a-f]{24}$"}, "receipt_payload_sha256": {"$ref": "#/$defs/sha256"}, "request_id": {"type": "string", "pattern": "^mfareq_[0-9a-f]{24}$"}, "request_payload_sha256": {"$ref": "#/$defs/sha256"}}},
    "release_binding": {"type": "object", "additionalProperties": false, "required": ["release_id", "release_payload_sha256", "capability_snapshot_id", "capability_snapshot_sha256", "semantic_profile_sha256"], "properties": {"release_id": {"type": "string", "minLength": 1}, "release_payload_sha256": {"$ref": "#/$defs/sha256"}, "capability_snapshot_id": {"type": "string", "minLength": 1}, "capability_snapshot_sha256": {"$ref": "#/$defs/sha256"}, "semantic_profile_sha256": {"$ref": "#/$defs/sha256"}}},
    "policy_binding": {"type": "object", "additionalProperties": false, "required": ["policy_id", "policy_sha256"], "properties": {"policy_id": {"type": "string", "minLength": 1}, "policy_sha256": {"$ref": "#/$defs/sha256"}}},
    "certificate_binding": {"type": "object", "additionalProperties": false, "required": ["certificate_id", "certificate_sha256", "certificate_scope_sha256", "status", "revocation_checked_at", "revocation_checkpoint_sha256"], "properties": {"certificate_id": {"type": ["string", "null"]}, "certificate_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}, "certificate_scope_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}, "status": {"enum": ["active", "expired", "revoked", "superseded", "none"]}, "revocation_checked_at": {"type": ["string", "null"], "format": "date-time"}, "revocation_checkpoint_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}}},
    "source_binding": {"type": "object", "additionalProperties": false, "required": ["artifact_id", "encoded_sha256", "decoded_pixel_sha256", "decoder_binary_sha256"], "properties": {"artifact_id": {"type": "string", "minLength": 1}, "encoded_sha256": {"$ref": "#/$defs/sha256"}, "decoded_pixel_sha256": {"$ref": "#/$defs/sha256"}, "decoder_binary_sha256": {"$ref": "#/$defs/sha256"}}},
    "media_scope_sha256": {"$ref": "#/$defs/sha256"},
    "subject_binding": {"type": "object", "additionalProperties": false, "required": ["scene_instance_id", "canonical_person_id", "person_index", "provider_person_index", "assignment_evidence_sha256"], "properties": {"scene_instance_id": {"type": "string", "minLength": 1}, "canonical_person_id": {"type": "string", "minLength": 1}, "person_index": {"type": "integer", "minimum": 0}, "provider_person_index": {"type": "integer", "minimum": 0}, "assignment_evidence_sha256": {"$ref": "#/$defs/sha256"}}},
    "provider_binding": {"type": "object", "additionalProperties": false, "required": ["stack_id", "stack_sha256", "execution_fingerprint_sha256"], "properties": {"stack_id": {"type": "string", "minLength": 1}, "stack_sha256": {"$ref": "#/$defs/sha256"}, "execution_fingerprint_sha256": {"$ref": "#/$defs/sha256"}}},
    "output_artifact_bindings": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/artifactBinding"}},
    "protected_artifact_bindings": {"type": "array", "items": {"$ref": "#/$defs/artifactBinding"}},
    "transform_binding": {"type": "object", "additionalProperties": false, "required": ["transform_chain_id", "transform_chain_sha256", "executed_step_sha256s", "roundtrip_report_sha256"], "properties": {"transform_chain_id": {"type": "string", "minLength": 1}, "transform_chain_sha256": {"$ref": "#/$defs/sha256"}, "executed_step_sha256s": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}}, "roundtrip_report_sha256": {"$ref": "#/$defs/sha256"}}},
    "qa_binding": {"type": "object", "additionalProperties": false, "required": ["qa_policy_sha256", "qa_report_sha256", "blocking_failure_ids"], "properties": {"qa_policy_sha256": {"$ref": "#/$defs/sha256"}, "qa_report_sha256": {"$ref": "#/$defs/sha256"}, "blocking_failure_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}},
    "authority_binding": {"type": "object", "additionalProperties": false, "required": ["authority_state", "truth_tier", "issuer_kind"], "properties": {"authority_state": {"enum": ["invalid", "hypothesis", "draft", "qa_passed_noncertified", "certified"]}, "truth_tier": {"enum": ["invalid", "machine_candidate", "qa_passed_machine_candidate", "operationally_certified_artifact"]}, "issuer_kind": {"enum": ["maskfactory_autonomous", "none"]}}},
    "defects": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["defect_id", "class", "labels", "severity", "observation_sha256", "target_artifact_identity_sha256"], "properties": {"defect_id": {"type": "string", "minLength": 1}, "class": {"enum": ["missing_region", "overreach", "underreach", "boundary", "ownership_bleed", "left_right_swap", "topology", "temporal_instability", "transform_alignment", "uncertain_semantics"]}, "labels": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "severity": {"enum": ["low", "medium", "high", "blocking"]}, "observation_sha256": {"$ref": "#/$defs/sha256"}, "target_artifact_identity_sha256": {"$ref": "#/$defs/sha256"}}}},
    "hypothesis": {"type": "object", "additionalProperties": false, "required": ["hypothesis_id", "parent_hypothesis_id", "material_change", "material_change_sha256", "description", "expected_effect"], "properties": {"hypothesis_id": {"type": "string", "minLength": 1}, "parent_hypothesis_id": {"type": ["string", "null"], "minLength": 1}, "material_change": {"enum": ["provider_reroute", "prompt_or_point_change", "crop_change", "refinement_change", "threshold_change", "ontology_mapping_change"]}, "material_change_sha256": {"$ref": "#/$defs/sha256"}, "description": {"type": "string", "minLength": 1}, "expected_effect": {"type": "string", "minLength": 1}}},
    "requested_action": {"enum": ["mode_b_live_refine", "mode_b_live_predict", "package_revalidation", "provider_rebenchmark", "quarantine_and_abstain"]},
    "retry_budget": {"type": "object", "additionalProperties": false, "required": ["attempt", "maximum_attempts", "remaining_attempts", "same_hypothesis_retry_allowed"], "properties": {"attempt": {"type": "integer", "minimum": 1}, "maximum_attempts": {"type": "integer", "minimum": 1, "maximum": 10}, "remaining_attempts": {"type": "integer", "minimum": 0, "maximum": 9}, "same_hypothesis_retry_allowed": {"const": false}}},
    "progress_guard": {"type": "object", "additionalProperties": false, "required": ["no_progress_count", "maximum_no_progress_count", "previous_score_ppm", "current_score_ppm", "minimum_improvement_ppm", "abstain_when_exhausted"], "properties": {"no_progress_count": {"type": "integer", "minimum": 0}, "maximum_no_progress_count": {"type": "integer", "minimum": 1}, "previous_score_ppm": {"type": "integer", "minimum": 0, "maximum": 1000000}, "current_score_ppm": {"type": "integer", "minimum": 0, "maximum": 1000000}, "minimum_improvement_ppm": {"type": "integer", "minimum": 0}, "abstain_when_exhausted": {"const": true}}},
    "immutable_accepted_parent": {"const": true}, "advisory_only": {"const": true}, "consumer_may_mutate_gold": {"const": false}, "consumer_may_escalate_authority": {"const": false},
    "feedback_payload_sha256": {"$ref": "#/$defs/sha256"}, "signature": {"$ref": "#/$defs/signature"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "timestamp": {"type": "string", "format": "date-time"},
    "authentication": {"type": "object", "additionalProperties": false, "required": ["principal_id", "authority", "role", "nonce", "issued_at", "expires_at", "replay_window_seconds", "credential_material_included"], "properties": {"principal_id": {"type": "string", "minLength": 1}, "authority": {"const": "Comfy_UI_Main"}, "role": {"const": "consumer_feedback"}, "nonce": {"type": "string", "pattern": "^[A-Za-z0-9_-]{24,128}$"}, "issued_at": {"$ref": "#/$defs/timestamp"}, "expires_at": {"$ref": "#/$defs/timestamp"}, "replay_window_seconds": {"type": "integer", "minimum": 1, "maximum": 3600}, "credential_material_included": {"const": false}}},
    "trustBinding": {"type": "object", "additionalProperties": false, "required": ["key_set_id", "key_set_version", "key_set_sha256", "key_role", "signing_key_id", "signing_public_key_sha256", "rotation_policy_sha256", "revocation_policy_sha256"], "properties": {"key_set_id": {"type": "string", "minLength": 1}, "key_set_version": {"type": "string", "minLength": 1}, "key_set_sha256": {"$ref": "#/$defs/sha256"}, "key_role": {"const": "consumer_feedback"}, "signing_key_id": {"type": "string", "minLength": 1}, "signing_public_key_sha256": {"$ref": "#/$defs/sha256"}, "rotation_policy_sha256": {"$ref": "#/$defs/sha256"}, "revocation_policy_sha256": {"$ref": "#/$defs/sha256"}}},
    "artifactBinding": {"type": "object", "additionalProperties": false, "required": ["artifact_id", "artifact_identity_sha256", "encoded_sha256", "decoded_mask_sha256", "source_decoded_pixel_sha256", "owner_identity_sha256", "coordinate_space", "transform_chain_sha256", "authority_state", "certificate_sha256", "revocation_checkpoint_sha256"], "properties": {"artifact_id": {"type": "string", "minLength": 1}, "artifact_identity_sha256": {"$ref": "#/$defs/sha256"}, "encoded_sha256": {"$ref": "#/$defs/sha256"}, "decoded_mask_sha256": {"$ref": "#/$defs/sha256"}, "source_decoded_pixel_sha256": {"$ref": "#/$defs/sha256"}, "owner_identity_sha256": {"$ref": "#/$defs/sha256"}, "coordinate_space": {"enum": ["source_pixel", "crop_pixel", "output_pixel"]}, "transform_chain_sha256": {"$ref": "#/$defs/sha256"}, "authority_state": {"enum": ["invalid", "hypothesis", "draft", "qa_passed_noncertified", "certified"]}, "certificate_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}, "revocation_checkpoint_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}}},
    "signature": {"type": "object", "additionalProperties": false, "required": ["algorithm", "key_id", "public_key_base64", "signed_payload_sha256", "signed_payload_format", "value_base64"], "properties": {"algorithm": {"const": "ed25519"}, "key_id": {"type": "string", "minLength": 1}, "public_key_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{43}=$"}, "signed_payload_sha256": {"$ref": "#/$defs/sha256"}, "signed_payload_format": {"const": "sha256_digest_bytes"}, "value_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{40,}={0,2}$"}}}
  }
}

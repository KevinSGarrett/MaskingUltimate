{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/maskfactory_adoption_receipt.schema.json",
  "title": "ComfyUI adoption decision for one immutable MaskFactory release",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "record_type", "adoption_id", "decided_at", "adoption_scope", "evidence_context", "fixture_only", "production_use_authorized", "consumer",
    "release_id", "release_payload_sha256", "capability_snapshot_id", "capability_snapshot_sha256",
    "consumer_requirements_id", "consumer_requirements_sha256", "qualification_bundle_id", "qualification_bundle_sha256", "trust_binding", "journal_checkpoint",
    "decision", "required_capabilities_satisfied", "compatibility_checks", "capability_decisions", "pinned_artifacts",
    "accepted_capabilities", "rejected_capabilities", "valid_until", "use_time_recheck_required", "revalidation_triggers",
    "adoption_payload_sha256", "signature"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "maskfactory_adoption_receipt"},
    "adoption_id": {"type": "string", "pattern": "^mfadopt_[0-9a-f]{24}$"},
    "decided_at": {"$ref": "#/$defs/timestamp"},
    "adoption_scope": {"enum": ["conformance_validation", "production_authority"]},
    "evidence_context": {"enum": ["conformance_fixture", "runtime_evidence"]},
    "fixture_only": {"type": "boolean"},
    "production_use_authorized": {"type": "boolean"},
    "consumer": {
      "type": "object", "additionalProperties": false,
      "required": ["project", "controller_version", "git_commit"],
      "properties": {
        "project": {"const": "Comfy_UI_Main"},
        "controller_version": {"$ref": "#/$defs/semver"},
        "git_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "release_id": {"type": "string", "pattern": "^mfr_[0-9]{8}_[0-9a-f]{12}$"},
    "release_payload_sha256": {"$ref": "#/$defs/sha256"},
    "capability_snapshot_id": {"type": "string", "pattern": "^mfcap_[0-9a-f]{24}$"},
    "capability_snapshot_sha256": {"$ref": "#/$defs/sha256"},
    "consumer_requirements_id": {"type": "string", "pattern": "^mfreq_[0-9a-f]{24}$"},
    "consumer_requirements_sha256": {"$ref": "#/$defs/sha256"},
    "qualification_bundle_id": {"type": "string", "pattern": "^mfqual_[0-9a-f]{24}$"},
    "qualification_bundle_sha256": {"$ref": "#/$defs/sha256"},
    "trust_binding": {
      "type": "object", "additionalProperties": false,
      "required": ["producer_key_set_id", "producer_key_set_version", "producer_key_set_sha256", "producer_release_key_id", "producer_release_public_key_sha256", "consumer_key_set_id", "consumer_key_set_version", "consumer_key_set_sha256", "consumer_adoption_key_id", "consumer_adoption_public_key_sha256", "rotation_policy_sha256", "revocation_policy_sha256"],
      "properties": {
        "producer_key_set_id": {"type": "string", "minLength": 1},
        "producer_key_set_version": {"type": "string", "minLength": 1},
        "producer_key_set_sha256": {"$ref": "#/$defs/sha256"},
        "producer_release_key_id": {"type": "string", "minLength": 1},
        "producer_release_public_key_sha256": {"$ref": "#/$defs/sha256"},
        "consumer_key_set_id": {"type": "string", "minLength": 1},
        "consumer_key_set_version": {"type": "string", "minLength": 1},
        "consumer_key_set_sha256": {"$ref": "#/$defs/sha256"},
        "consumer_adoption_key_id": {"type": "string", "minLength": 1},
        "consumer_adoption_public_key_sha256": {"$ref": "#/$defs/sha256"},
        "rotation_policy_sha256": {"$ref": "#/$defs/sha256"},
        "revocation_policy_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "journal_checkpoint": {
      "type": "object", "additionalProperties": false,
      "required": ["stream_id", "genesis_event_id", "genesis_event_sha256", "first_sequence", "last_sequence", "event_count", "head_event_id", "head_event_sha256", "revocation_state_sha256", "active_revocation_count", "validator_sha256", "checkpointed_at", "fresh_until"],
      "properties": {
        "stream_id": {"type": "string", "minLength": 1},
        "genesis_event_id": {"type": "string", "minLength": 1}, "genesis_event_sha256": {"$ref": "#/$defs/sha256"},
        "first_sequence": {"const": 1}, "last_sequence": {"type": "integer", "minimum": 1}, "event_count": {"type": "integer", "minimum": 1},
        "head_event_id": {"type": "string", "minLength": 1}, "head_event_sha256": {"$ref": "#/$defs/sha256"},
        "revocation_state_sha256": {"$ref": "#/$defs/sha256"}, "active_revocation_count": {"type": "integer", "minimum": 0}, "validator_sha256": {"$ref": "#/$defs/sha256"},
        "checkpointed_at": {"$ref": "#/$defs/timestamp"}, "fresh_until": {"$ref": "#/$defs/timestamp"}
      }
    },
    "decision": {"enum": ["conformance_only", "adopted", "partially_adopted", "rejected"]},
    "required_capabilities_satisfied": {"type": "boolean"},
    "compatibility_checks": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["check", "result", "evidence_sha256"],
        "properties": {
          "check": {"enum": ["trust_anchor", "signature", "release_hash", "canonicalization", "signed_journal", "revocation_freshness", "artifact_security", "wire_schemas", "api_contract", "package_format", "ontology", "node_pack", "capabilities", "media_scope", "authority_policy", "contract_tests"]},
          "result": {"enum": ["pass", "fail", "not_applicable"]},
          "evidence_sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "pinned_artifacts": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["kind", "sha256"],
        "properties": {
          "kind": {"type": "string", "minLength": 1},
          "sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "capability_decisions": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["capability_id", "requirement_class", "decision", "reason", "evidence_sha256"],
        "properties": {
          "capability_id": {"type": "string", "minLength": 1},
          "requirement_class": {"enum": ["required", "optional", "producer_extra"]},
          "decision": {"enum": ["accepted", "rejected"]},
          "reason": {"type": "string", "minLength": 1},
          "evidence_sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "accepted_capabilities": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "rejected_capabilities": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "valid_until": {"$ref": "#/$defs/timestamp"},
    "use_time_recheck_required": {"const": true},
    "revalidation_triggers": {
      "type": "array", "minItems": 27, "maxItems": 27, "uniqueItems": true,
      "items": {"enum": [
        "release_superseded", "release_revoked", "producer_signing_key_revoked", "producer_signing_key_rotated",
        "consumer_adoption_key_revoked", "consumer_adoption_key_rotated", "trust_policy_changed",
        "wire_schema_changed", "semantic_invariant_profile_changed", "api_contract_changed", "package_format_changed",
        "ontology_changed", "node_pack_changed", "capability_snapshot_changed", "capability_policy_changed",
        "package_invalidated", "artifact_invalidated", "artifact_hash_drift", "certificate_expired", "certificate_revoked",
        "provider_stack_changed", "consumer_requirements_changed", "signed_journal_stale",
        "signed_journal_fork_detected", "revocation_checkpoint_stale", "validity_expired", "qa_regression"
      ]}
    },
    "adoption_payload_sha256": {"$ref": "#/$defs/sha256"},
    "signature": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "key_id", "public_key_base64", "signed_payload_sha256", "signed_payload_format", "value_base64"],
      "properties": {
        "algorithm": {"const": "ed25519"},
        "key_id": {"type": "string", "pattern": "^comfy-main-[a-z0-9-]+$"},
        "public_key_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{43}=$"},
        "signed_payload_sha256": {"$ref": "#/$defs/sha256"},
        "signed_payload_format": {"const": "sha256_digest_bytes"},
        "value_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{40,}={0,2}$"}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"},
    "semver": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}
  },
  "allOf": [
    {
      "if": {"properties": {"adoption_scope": {"const": "conformance_validation"}}, "required": ["adoption_scope"]},
      "then": {
        "properties": {
          "evidence_context": {"const": "conformance_fixture"},
          "fixture_only": {"const": true},
          "production_use_authorized": {"const": false},
          "decision": {"const": "conformance_only"},
          "required_capabilities_satisfied": {"const": false},
          "pinned_artifacts": {"maxItems": 0},
          "accepted_capabilities": {"maxItems": 0}
        }
      }
    },
    {
      "if": {"properties": {"adoption_scope": {"const": "production_authority"}}, "required": ["adoption_scope"]},
      "then": {
        "properties": {
          "evidence_context": {"const": "runtime_evidence"},
          "fixture_only": {"const": false},
          "decision": {"enum": ["adopted", "partially_adopted", "rejected"]}
        }
      }
    },
    {
      "if": {"properties": {"decision": {"const": "adopted"}}, "required": ["decision"]},
      "then": {
        "properties": {
          "production_use_authorized": {"const": true},
          "rejected_capabilities": {"maxItems": 0},
          "required_capabilities_satisfied": {"const": true},
          "pinned_artifacts": {"minItems": 1},
          "compatibility_checks": {"not": {"contains": {"properties": {"result": {"const": "fail"}}, "required": ["result"]}}}
        }
      }
    },
    {
      "if": {"properties": {"decision": {"const": "partially_adopted"}}, "required": ["decision"]},
      "then": {
        "properties": {
          "production_use_authorized": {"const": true},
          "required_capabilities_satisfied": {"const": true},
          "accepted_capabilities": {"minItems": 1},
          "rejected_capabilities": {"minItems": 1},
          "capability_decisions": {
            "not": {
              "contains": {
                "properties": {"requirement_class": {"const": "required"}, "decision": {"const": "rejected"}},
                "required": ["requirement_class", "decision"]
              }
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"decision": {"const": "rejected"}}, "required": ["decision"]},
      "then": {
        "properties": {
          "production_use_authorized": {"const": false},
          "accepted_capabilities": {"maxItems": 0},
          "required_capabilities_satisfied": {"const": false},
          "pinned_artifacts": {"maxItems": 0},
          "compatibility_checks": {"contains": {"properties": {"result": {"const": "fail"}}, "required": ["result"]}}
        }
      }
    }
  ]
}

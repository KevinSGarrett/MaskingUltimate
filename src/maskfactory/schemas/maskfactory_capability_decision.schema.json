{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/maskfactory_capability_decision.schema.json",
  "title": "MaskFactory capability qualification decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "record_type", "decision_id", "decided_at", "policy_id",
    "policy_sha256", "release_binding", "snapshot_binding", "ledger_head_sha256",
    "revocation_head_sha256", "qualified_routes", "challenger_routes",
    "rollback_bindings", "status", "rejection_reasons", "decision_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "maskfactory_capability_decision"},
    "decision_id": {"type": "string", "pattern": "^mfcapdec_[0-9a-f]{24}$"},
    "decided_at": {"type": "string", "format": "date-time"},
    "policy_id": {"const": "maskfactory-bridge-capability-qualification-v1"},
    "policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "release_binding": {"$ref": "#/$defs/binding"},
    "snapshot_binding": {"$ref": "#/$defs/binding"},
    "ledger_head_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "revocation_head_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "qualified_routes": {"type": "array", "items": {"$ref": "#/$defs/route"}},
    "challenger_routes": {"type": "array", "items": {"$ref": "#/$defs/route"}},
    "rollback_bindings": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["route_id", "current_stack_sha256", "rollback_stack_sha256", "tested_ledger_entry_sha256"],
        "properties": {
          "route_id": {"type": "string", "minLength": 1},
          "current_stack_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "rollback_stack_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "tested_ledger_entry_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "status": {"enum": ["accepted", "rejected"]},
    "rejection_reasons": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "decision_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "binding": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "route": {
      "type": "object", "additionalProperties": false,
      "required": ["route_id", "stack_id", "stack_sha256", "lifecycle", "certificate_id"],
      "properties": {
        "route_id": {"type": "string", "minLength": 1},
        "stack_id": {"type": "string", "minLength": 1},
        "stack_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "lifecycle": {"enum": ["promoted", "benchmarked", "draft", "suspended", "retired"]},
        "certificate_id": {"type": ["string", "null"], "minLength": 1}
      }
    }
  }
}

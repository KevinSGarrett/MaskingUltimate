{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/maskfactory_capability_snapshot.schema.json",
  "title": "MaskFactory release-bound capability snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "record_type", "snapshot_id", "release_id", "generated_at", "evidence_context", "fixture_only", "canonicalization",
    "bridge_contract", "access_modes", "endpoints", "package_formats", "ontologies",
    "labels", "artifact_kinds", "coordinate_spaces", "transform_operations", "limits",
    "authority_policy", "authority_crosswalk", "provider_stacks", "availability", "snapshot_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "maskfactory_capability_snapshot"},
    "snapshot_id": {"type": "string", "pattern": "^mfcap_[0-9a-f]{24}$"},
    "release_id": {"type": "string", "pattern": "^mfr_[0-9]{8}_[0-9a-f]{12}$"},
    "generated_at": {"$ref": "#/$defs/timestamp"},
    "evidence_context": {"enum": ["conformance_fixture", "runtime_evidence"]},
    "fixture_only": {"type": "boolean"},
    "canonicalization": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "excluded_top_level_fields"],
      "properties": {
        "algorithm": {"const": "maskfactory-canonical-json-v1"},
        "excluded_top_level_fields": {"type": "array", "prefixItems": [{"const": "snapshot_sha256"}], "minItems": 1, "maxItems": 1}
      }
    },
    "bridge_contract": {"const": "maskfactory-comfyui-bridge/1.0"},
    "access_modes": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"enum": ["mode_a_package_read", "mode_b_live_predict", "mode_b_live_refine"]}
    },
    "endpoints": {
      "type": "array", "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["operation", "method", "path", "enabled"],
        "properties": {
          "operation": {"enum": ["health", "models", "predict", "refine"]},
          "method": {"enum": ["GET", "POST"]},
          "path": {"enum": ["/health", "/models", "/predict", "/refine"]},
          "enabled": {"type": "boolean"}
        }
      }
    },
    "package_formats": {"$ref": "#/$defs/nonemptyUniqueStrings"},
    "ontologies": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["version", "sha256", "left_right_convention"],
        "properties": {
          "version": {"type": "string", "minLength": 1},
          "sha256": {"$ref": "#/$defs/sha256"},
          "left_right_convention": {"const": "character_perspective"}
        }
      }
    },
    "labels": {"$ref": "#/$defs/nonemptyUniqueStrings"},
    "artifact_kinds": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"enum": ["atomic_visible", "protected_qa", "region_band", "derived_union", "inpaint_derivative", "label_map"]}
    },
    "coordinate_spaces": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"enum": ["source_pixel", "normalized_0_1", "crop_pixel", "output_pixel"]}
    },
    "transform_operations": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"enum": ["crop", "resize", "pad", "horizontal_flip", "inverse_project"]}
    },
    "limits": {
      "type": "object", "additionalProperties": false,
      "required": ["max_person_count", "max_source_width", "max_source_height", "max_request_bytes", "default_timeout_ms"],
      "properties": {
        "max_person_count": {"type": "integer", "minimum": 1},
        "max_source_width": {"type": "integer", "minimum": 1},
        "max_source_height": {"type": "integer", "minimum": 1},
        "max_request_bytes": {"type": "integer", "minimum": 1},
        "default_timeout_ms": {"type": "integer", "minimum": 1}
      }
    },
    "authority_policy": {
      "type": "object", "additionalProperties": false,
      "required": ["mode_a_truth_tiers", "uncertified_output_default_authority_state", "access_mode_determines_authority", "certified_requires_exact_output_certificate", "draft_can_override_certified", "producer_owns_truth_escalation"],
      "properties": {
        "mode_a_truth_tiers": {"$ref": "#/$defs/nonemptyUniqueStrings"},
        "uncertified_output_default_authority_state": {"const": "draft"},
        "access_mode_determines_authority": {"const": false},
        "certified_requires_exact_output_certificate": {"const": true},
        "draft_can_override_certified": {"const": false},
        "producer_owns_truth_escalation": {"const": true}
      }
    },
    "authority_crosswalk": {
      "type": "object", "additionalProperties": false,
      "required": ["mode_a_package_read", "mode_b_live_predict", "mode_b_live_refine"],
      "properties": {
        "mode_a_package_read": {"$ref": "#/$defs/modeAEligibility"},
        "mode_b_live_predict": {"$ref": "#/$defs/modeBEligibility"},
        "mode_b_live_refine": {"$ref": "#/$defs/modeBEligibility"}
      }
    },
    "provider_stacks": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["stack_id", "stack_sha256", "capability_ids", "roles", "labels", "access_modes", "media_scopes", "model_artifacts", "workflow", "runtime", "hardware", "route_key", "performance_profile", "champion_binding", "qualification_scope", "lifecycle", "certificate_ids"],
        "properties": {
          "stack_id": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"},
          "stack_sha256": {"$ref": "#/$defs/sha256"},
          "capability_ids": {"$ref": "#/$defs/nonemptyUniqueStrings"},
          "roles": {"$ref": "#/$defs/nonemptyUniqueStrings"},
          "labels": {"$ref": "#/$defs/nonemptyUniqueStrings"},
          "access_modes": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": {"enum": ["mode_a_package_read", "mode_b_live_predict", "mode_b_live_refine"]}
          },
          "media_scopes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["still_image", "video_frame", "frame_span"]}},
          "model_artifacts": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["model_id", "sha256"],
              "properties": {
                "model_id": {"type": "string", "minLength": 1},
                "sha256": {"$ref": "#/$defs/sha256"}
              }
            }
          },
          "workflow": {
            "type": "object", "additionalProperties": false,
            "required": ["workflow_id", "sha256"],
            "properties": {
              "workflow_id": {"type": "string", "minLength": 1},
              "sha256": {"$ref": "#/$defs/sha256"}
            }
          },
          "runtime": {
            "type": "object", "additionalProperties": false,
            "required": ["runtime_kind", "runtime_id", "runtime_version", "environment_lock_sha256", "interpreter_build_sha256", "venv_manifest_sha256", "container_sha256"],
            "properties": {
              "runtime_kind": {"enum": ["native_venv", "container"]},
              "runtime_id": {"type": "string", "minLength": 1},
              "runtime_version": {"type": "string", "minLength": 1},
              "environment_lock_sha256": {"$ref": "#/$defs/sha256"},
              "interpreter_build_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
              "venv_manifest_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
              "container_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
            },
            "allOf": [
              {"if": {"properties": {"runtime_kind": {"const": "native_venv"}}, "required": ["runtime_kind"]}, "then": {"properties": {"interpreter_build_sha256": {"type": "string"}, "venv_manifest_sha256": {"type": "string"}, "container_sha256": {"type": "null"}}}},
              {"if": {"properties": {"runtime_kind": {"const": "container"}}, "required": ["runtime_kind"]}, "then": {"properties": {"interpreter_build_sha256": {"type": "null"}, "venv_manifest_sha256": {"type": "null"}, "container_sha256": {"type": "string"}}}}
            ]
          },
          "hardware": {
            "type": "object", "additionalProperties": false,
            "required": ["hardware_profile_id", "hardware_profile_sha256", "minimum_vram_mb", "minimum_ram_mb", "accelerators"],
            "properties": {
              "hardware_profile_id": {"type": "string", "minLength": 1},
              "hardware_profile_sha256": {"$ref": "#/$defs/sha256"},
              "minimum_vram_mb": {"type": "integer", "minimum": 0},
              "minimum_ram_mb": {"type": "integer", "minimum": 1},
              "accelerators": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
            }
          },
          "route_key": {"type": "object", "additionalProperties": false, "required": ["route_key_id", "sha256"], "properties": {"route_key_id": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}}},
          "performance_profile": {"type": "object", "additionalProperties": false, "required": ["profile_id", "sha256", "observed_at"], "properties": {"profile_id": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "observed_at": {"$ref": "#/$defs/timestamp"}}},
          "champion_binding": {"type": "object", "additionalProperties": false, "required": ["champion_id", "champion_sha256", "status"], "properties": {"champion_id": {"type": "string", "minLength": 1}, "champion_sha256": {"$ref": "#/$defs/sha256"}, "status": {"const": "current"}}},
          "qualification_scope": {
            "type": "object", "additionalProperties": false,
            "required": ["scope_sha256", "labels", "contexts", "artifact_kinds", "max_person_count", "max_width", "max_height", "benchmark_certificate_sha256", "valid_until"],
            "properties": {
              "scope_sha256": {"$ref": "#/$defs/sha256"},
              "labels": {"$ref": "#/$defs/nonemptyUniqueStrings"},
              "contexts": {"$ref": "#/$defs/nonemptyUniqueStrings"},
              "artifact_kinds": {"$ref": "#/$defs/nonemptyUniqueStrings"},
              "max_person_count": {"type": "integer", "minimum": 1},
              "max_width": {"type": "integer", "minimum": 1},
              "max_height": {"type": "integer", "minimum": 1},
              "benchmark_certificate_sha256": {"$ref": "#/$defs/sha256"},
              "valid_until": {"$ref": "#/$defs/timestamp"}
            }
          },
          "lifecycle": {"enum": ["draft", "benchmarked", "promoted", "suspended", "retired"]},
          "certificate_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        }
      }
    },
    "availability": {
      "type": "object", "additionalProperties": false,
      "required": ["mode_a", "mode_b_predict", "mode_b_refine", "observed_at", "valid_until", "health_evidence_sha256", "mode_eligibility"],
      "properties": {
        "mode_a": {"enum": ["available", "degraded", "unavailable"]},
        "mode_b_predict": {"enum": ["available", "degraded", "unavailable"]},
        "mode_b_refine": {"enum": ["available", "degraded", "unavailable"]},
        "observed_at": {"$ref": "#/$defs/timestamp"},
        "valid_until": {"$ref": "#/$defs/timestamp"},
        "health_evidence_sha256": {"$ref": "#/$defs/sha256"},
        "mode_eligibility": {
          "type": "array", "minItems": 3, "maxItems": 3,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["access_mode", "eligible", "route_ids", "certificate_ids", "reason_codes"],
            "properties": {
              "access_mode": {"enum": ["mode_a_package_read", "mode_b_live_predict", "mode_b_live_refine"]},
              "eligible": {"type": "boolean"},
              "route_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
              "certificate_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
              "reason_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
            }
          }
        }
      }
    },
    "snapshot_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"},
    "nonemptyUniqueStrings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "modeAEligibility": {
      "type": "object", "additionalProperties": false,
      "required": ["default_authority_state", "maximum_authority_state", "permitted_issuer_kinds", "certified_certificate_kinds", "promotion_eligibility"],
      "properties": {
        "default_authority_state": {"const": "draft"},
        "maximum_authority_state": {"const": "certified"},
        "permitted_issuer_kinds": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"enum": ["maskfactory_autonomous", "human_anchor_optional", "none"]}
        },
        "certified_certificate_kinds": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"enum": ["exact_serving_route_output", "autonomous_package", "human_anchor_optional"]}
        },
        "promotion_eligibility": {"const": "certificate_scope_qa_and_lineage_derived"}
      }
    },
    "modeBEligibility": {
      "type": "object", "additionalProperties": false,
      "required": ["default_authority_state", "maximum_authority_state", "permitted_issuer_kinds", "certified_certificate_kinds", "promotion_eligibility"],
      "properties": {
        "default_authority_state": {"const": "draft"},
        "maximum_authority_state": {"const": "certified"},
        "permitted_issuer_kinds": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"enum": ["maskfactory_autonomous", "none"]}
        },
        "certified_certificate_kinds": {
          "type": "array", "minItems": 1, "maxItems": 1,
          "items": {"const": "exact_serving_route_output"}
        },
        "promotion_eligibility": {"const": "certificate_scope_qa_and_lineage_derived"}
      }
    }
  },
  "allOf": [
    {"if": {"properties": {"fixture_only": {"const": true}}, "required": ["fixture_only"]}, "then": {"properties": {"evidence_context": {"const": "conformance_fixture"}}}},
    {"if": {"properties": {"fixture_only": {"const": false}}, "required": ["fixture_only"]}, "then": {"properties": {"evidence_context": {"const": "runtime_evidence"}}}}
  ]
}

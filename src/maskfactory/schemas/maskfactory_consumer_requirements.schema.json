{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/maskfactory_consumer_requirements.schema.json",
  "title": "ComfyUI control-plane requirements offered to MaskFactory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "record_type", "requirements_id", "consumer", "created_at", "authentication", "trust_binding", "canonicalization",
    "bridge_contract", "accepted_wire_schemas", "required_semantic_invariant_profile", "trusted_signing_key_sets", "required_access_modes", "required_capabilities", "optional_capabilities", "compatibility", "required_labels",
    "required_artifact_kinds", "required_coordinate_spaces", "required_transform_operations",
    "minimum_person_count", "accepted_media_scopes", "authority_requirements", "runtime_requirements", "requirements_sha256", "signature"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "maskfactory_consumer_requirements"},
    "requirements_id": {"type": "string", "pattern": "^mfreq_[0-9a-f]{24}$"},
    "consumer": {
      "type": "object", "additionalProperties": false,
      "required": ["project", "controller_version", "git_commit"],
      "properties": {
        "project": {"const": "Comfy_UI_Main"},
        "controller_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "git_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "created_at": {"$ref": "#/$defs/timestamp"},
    "authentication": {"$ref": "#/$defs/authentication"},
    "trust_binding": {"$ref": "#/$defs/trustBinding"},
    "canonicalization": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "excluded_top_level_fields"],
      "properties": {"algorithm": {"const": "maskfactory-canonical-json-v1"}, "excluded_top_level_fields": {"type": "array", "prefixItems": [{"const": "requirements_sha256"}, {"const": "signature"}], "minItems": 2, "maxItems": 2}}
    },
    "bridge_contract": {"const": "maskfactory-comfyui-bridge/1.0"},
    "accepted_wire_schemas": {
      "type": "array", "minItems": 12, "maxItems": 12, "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["name", "schema_id", "version", "relative_path", "sha256"],
        "properties": {
          "name": {
            "enum": [
              "maskfactory_release_snapshot", "maskfactory_capability_snapshot",
              "maskfactory_consumer_requirements", "mask_acquisition_request",
              "mask_acquisition_receipt", "mask_bridge_error", "maskfactory_adoption_receipt",
              "mask_authority_invalidation_event", "mask_repair_feedback", "mask_bridge_event",
              "operational_autonomy_certificate", "mask_bridge_semantic_invariant_profile"
            ]
          },
          "schema_id": {"type": "string", "format": "uri"},
          "version": {"const": "1.0.0"},
          "relative_path": {"type": "string", "pattern": "^src/maskfactory/schemas/[a-z0-9_]+\\.schema\\.json$"},
          "sha256": {"$ref": "#/$defs/sha256"}
        }
      },
      "allOf": [
        {"contains": {"properties": {"name": {"const": "maskfactory_release_snapshot"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "maskfactory_capability_snapshot"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "maskfactory_consumer_requirements"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_acquisition_request"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_acquisition_receipt"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_bridge_error"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "maskfactory_adoption_receipt"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_authority_invalidation_event"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_repair_feedback"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_bridge_event"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "operational_autonomy_certificate"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_bridge_semantic_invariant_profile"}}, "required": ["name"]}}
      ]
    },
    "required_semantic_invariant_profile": {
      "type": "object", "additionalProperties": false,
      "required": ["profile_id", "profile_version", "sha256", "require_all_validation_layers"],
      "properties": {
        "profile_id": {"const": "maskfactory-comfyui-bridge-semantics"},
        "profile_version": {"const": "1.0.0"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "require_all_validation_layers": {"const": true}
      }
    },
    "trusted_signing_key_sets": {
      "type": "array", "minItems": 2,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["authority", "key_set_id", "key_set_version", "key_set_sha256", "trusted_keys", "rotation_policy_id", "rotation_policy_sha256", "revocation_policy_id", "revocation_policy_sha256"],
        "properties": {
          "authority": {"enum": ["MaskFactory", "Comfy_UI_Main"]},
          "key_set_id": {"type": "string", "minLength": 1},
          "key_set_version": {"type": "string", "minLength": 1},
          "key_set_sha256": {"$ref": "#/$defs/sha256"},
          "trusted_keys": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["key_id", "public_key_sha256", "roles", "usage_scope", "status", "valid_from", "valid_until"],
              "properties": {
                "key_id": {"type": "string", "minLength": 1},
                "public_key_sha256": {"$ref": "#/$defs/sha256"},
                "roles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["producer_release", "producer_authority", "producer_receipt", "producer_journal", "consumer_requirements", "consumer_request", "consumer_feedback", "consumer_qualification", "consumer_adoption", "consumer_journal"]}},
                "usage_scope": {"enum": ["conformance_only", "production"]},
                "status": {"enum": ["active", "revoked", "suspended"]},
                "valid_from": {"$ref": "#/$defs/timestamp"},
                "valid_until": {"$ref": "#/$defs/timestamp"}
              }
            }
          },
          "rotation_policy_id": {"type": "string", "minLength": 1},
          "rotation_policy_sha256": {"$ref": "#/$defs/sha256"},
          "revocation_policy_id": {"type": "string", "minLength": 1},
          "revocation_policy_sha256": {"$ref": "#/$defs/sha256"}
        }
      },
      "allOf": [
        {"contains": {"properties": {"authority": {"const": "MaskFactory"}}, "required": ["authority"]}},
        {"contains": {"properties": {"authority": {"const": "Comfy_UI_Main"}}, "required": ["authority"]}}
      ]
    },
    "required_access_modes": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"enum": ["mode_a_package_read", "mode_b_live_predict", "mode_b_live_refine"]}
    },
    "required_capabilities": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/capabilityRequirement"}},
    "optional_capabilities": {"type": "array", "items": {"$ref": "#/$defs/capabilityRequirement"}},
    "compatibility": {
      "type": "object", "additionalProperties": false,
      "required": ["api_contracts", "package_formats", "ontology_versions", "node_pack_versions"],
      "properties": {
        "api_contracts": {"$ref": "#/$defs/nonemptyUniqueStrings"},
        "package_formats": {"$ref": "#/$defs/nonemptyUniqueStrings"},
        "ontology_versions": {"$ref": "#/$defs/nonemptyUniqueStrings"},
        "node_pack_versions": {"$ref": "#/$defs/nonemptyUniqueStrings"}
      }
    },
    "required_labels": {"$ref": "#/$defs/nonemptyUniqueStrings"},
    "required_artifact_kinds": {"$ref": "#/$defs/nonemptyUniqueStrings"},
    "required_coordinate_spaces": {"$ref": "#/$defs/nonemptyUniqueStrings"},
    "required_transform_operations": {"$ref": "#/$defs/nonemptyUniqueStrings"},
    "minimum_person_count": {"type": "integer", "minimum": 1},
    "accepted_media_scopes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["still_image", "video_frame", "frame_span"]}},
    "authority_requirements": {
      "type": "object", "additionalProperties": false,
      "required": ["accepted_mode_a_truth_tiers", "accepted_certificate_kinds", "accepted_issuer_kinds", "require_unrevoked_certificate", "require_exact_scope_match", "access_mode_determines_authority", "allow_consumer_truth_escalation"],
      "properties": {
        "accepted_mode_a_truth_tiers": {"$ref": "#/$defs/nonemptyUniqueStrings"},
        "accepted_certificate_kinds": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"enum": ["exact_serving_route_output", "autonomous_package", "human_anchor_optional"]}
        },
        "accepted_issuer_kinds": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"enum": ["maskfactory_autonomous", "human_anchor_optional", "none"]}
        },
        "require_unrevoked_certificate": {"const": true},
        "require_exact_scope_match": {"const": true},
        "access_mode_determines_authority": {"const": false},
        "allow_consumer_truth_escalation": {"const": false}
      }
    },
    "runtime_requirements": {
      "type": "object", "additionalProperties": false,
      "required": ["request_timeout_ms", "maximum_queue_ms", "maximum_p50_latency_ms", "maximum_p95_latency_ms", "maximum_vram_mb", "maximum_ram_mb", "maximum_output_bytes", "minimum_concurrency", "maximum_retries", "idempotency_required", "fail_closed_on_mismatch", "circuit_breaker_required"],
      "properties": {
        "request_timeout_ms": {"type": "integer", "minimum": 100},
        "maximum_queue_ms": {"type": "integer", "minimum": 0},
        "maximum_p50_latency_ms": {"type": "integer", "minimum": 1},
        "maximum_p95_latency_ms": {"type": "integer", "minimum": 1},
        "maximum_vram_mb": {"type": "integer", "minimum": 0},
        "maximum_ram_mb": {"type": "integer", "minimum": 1},
        "maximum_output_bytes": {"type": "integer", "minimum": 1},
        "minimum_concurrency": {"type": "integer", "minimum": 1},
        "maximum_retries": {"type": "integer", "minimum": 0, "maximum": 10},
        "idempotency_required": {"const": true},
        "fail_closed_on_mismatch": {"const": true},
        "circuit_breaker_required": {"const": true}
      }
    },
    "requirements_sha256": {"$ref": "#/$defs/sha256"},
    "signature": {"$ref": "#/$defs/signature"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"},
    "authentication": {
      "type": "object", "additionalProperties": false,
      "required": ["principal_id", "authority", "role", "nonce", "issued_at", "expires_at", "replay_window_seconds", "credential_material_included"],
      "properties": {"principal_id": {"type": "string", "minLength": 1}, "authority": {"const": "Comfy_UI_Main"}, "role": {"const": "consumer_requirements"}, "nonce": {"type": "string", "pattern": "^[A-Za-z0-9_-]{24,128}$"}, "issued_at": {"$ref": "#/$defs/timestamp"}, "expires_at": {"$ref": "#/$defs/timestamp"}, "replay_window_seconds": {"type": "integer", "minimum": 1, "maximum": 3600}, "credential_material_included": {"const": false}}
    },
    "trustBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["key_set_id", "key_set_version", "key_set_sha256", "key_role", "signing_key_id", "signing_public_key_sha256", "rotation_policy_sha256", "revocation_policy_sha256"],
      "properties": {"key_set_id": {"type": "string", "minLength": 1}, "key_set_version": {"type": "string", "minLength": 1}, "key_set_sha256": {"$ref": "#/$defs/sha256"}, "key_role": {"const": "consumer_requirements"}, "signing_key_id": {"type": "string", "minLength": 1}, "signing_public_key_sha256": {"$ref": "#/$defs/sha256"}, "rotation_policy_sha256": {"$ref": "#/$defs/sha256"}, "revocation_policy_sha256": {"$ref": "#/$defs/sha256"}}
    },
    "signature": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "key_id", "public_key_base64", "signed_payload_sha256", "signed_payload_format", "value_base64"],
      "properties": {"algorithm": {"const": "ed25519"}, "key_id": {"type": "string", "minLength": 1}, "public_key_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{43}=$"}, "signed_payload_sha256": {"$ref": "#/$defs/sha256"}, "signed_payload_format": {"const": "sha256_digest_bytes"}, "value_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{40,}={0,2}$"}}
    },
    "nonemptyUniqueStrings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "capabilityRequirement": {
      "type": "object", "additionalProperties": false,
      "required": ["capability_id", "access_mode", "labels", "artifact_kinds", "minimum_authority_state"],
      "properties": {
        "capability_id": {"type": "string", "minLength": 1},
        "access_mode": {"enum": ["mode_a_package_read", "mode_b_live_predict", "mode_b_live_refine"]},
        "labels": {"$ref": "#/$defs/nonemptyUniqueStrings"},
        "artifact_kinds": {"$ref": "#/$defs/nonemptyUniqueStrings"},
        "minimum_authority_state": {"enum": ["invalid", "hypothesis", "draft", "qa_passed_noncertified", "certified"]}
      }
    }
  }
}

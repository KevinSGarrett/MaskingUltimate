{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/maskfactory_consumer_requirements_admission.schema.json",
  "title": "Additive MaskFactory consumer-requirements admission decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "requirements", "offered_capabilities"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "maskfactory_consumer_requirements_admission"},
    "requirements": {"type": "object"},
    "offered_capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "capability_id", "access_modes", "labels", "artifact_kinds", "media_scopes",
          "transform_operations", "maximum_person_count", "authority_states", "truth_tiers",
          "certificate_kinds", "issuer_kinds", "versions", "runtime", "evidence"
        ],
        "properties": {
          "capability_id": {"type": "string", "minLength": 1},
          "access_modes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "labels": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "artifact_kinds": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "media_scopes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "transform_operations": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "maximum_person_count": {"type": "integer", "minimum": 1},
          "authority_states": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "truth_tiers": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "certificate_kinds": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "issuer_kinds": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "versions": {
            "type": "object",
            "additionalProperties": false,
            "required": ["api_contracts", "package_formats", "ontology_versions", "node_pack_versions"],
            "properties": {
              "api_contracts": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
              "package_formats": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
              "ontology_versions": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
              "node_pack_versions": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
            }
          },
          "runtime": {"type": "object"},
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["evidence_id", "kind", "sha256"],
              "properties": {
                "evidence_id": {"type": "string", "minLength": 1},
                "kind": {"type": "string", "minLength": 1},
                "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
              }
            }
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/maskfactory_integration_release_evidence.schema.json",
  "title": "MaskFactory integration release acceptance evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "evidence_id",
    "decided_at",
    "policy_id",
    "policy_sha256",
    "release_id",
    "status",
    "rejection_reasons",
    "prerequisites",
    "source_authority",
    "source_inventories",
    "installed_inventories",
    "inventory_parity",
    "activation",
    "verification_receipt",
    "rollback",
    "claim_boundary",
    "evidence_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "maskfactory_integration_release_evidence" },
    "evidence_id": {
      "type": "string",
      "pattern": "^mfirel_[0-9]{8}_[0-9a-f]{12}$"
    },
    "decided_at": { "type": "string", "format": "date-time" },
    "policy_id": { "const": "maskfactory-integration-release-acceptance-v1" },
    "policy_sha256": { "$ref": "#/$defs/sha256" },
    "release_id": {
      "type": "string",
      "pattern": "^mfr_[0-9]{8}_[0-9a-f]{12}$"
    },
    "publication_payload_sha256": { "$ref": "#/$defs/sha256" },
    "status": { "enum": ["accepted", "rejected", "rolled_back"] },
    "rejection_reasons": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "prerequisites": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_publication",
        "capability_decision",
        "clean_installation",
        "recovery_evidence"
      ],
      "properties": {
        "release_publication": { "$ref": "#/$defs/prerequisite" },
        "capability_decision": { "$ref": "#/$defs/prerequisite" },
        "clean_installation": { "$ref": "#/$defs/prerequisite" },
        "recovery_evidence": { "$ref": "#/$defs/prerequisite" }
      }
    },
    "source_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_clean",
        "allow_dirty_source",
        "allow_editable_install",
        "git_commit",
        "git_tree"
      ],
      "properties": {
        "repository_clean": { "type": "boolean" },
        "allow_dirty_source": { "const": false },
        "allow_editable_install": { "const": false },
        "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "git_tree": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
      }
    },
    "source_inventories": { "$ref": "#/$defs/inventoryBundle" },
    "installed_inventories": { "$ref": "#/$defs/inventoryBundle" },
    "inventory_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exact_match", "mismatches"],
      "properties": {
        "exact_match": { "type": "boolean" },
        "mismatches": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["inventory", "code", "path"],
            "properties": {
              "inventory": { "type": "string", "minLength": 1 },
              "code": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "activation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "active_release_id",
        "previous_release_id",
        "commit_order",
        "receipt_last"
      ],
      "properties": {
        "strategy": { "const": "atomic_pointer_switch" },
        "active_release_id": {
          "type": ["string", "null"],
          "pattern": "^mfr_[0-9]{8}_[0-9a-f]{12}$"
        },
        "previous_release_id": {
          "type": ["string", "null"],
          "pattern": "^mfr_[0-9]{8}_[0-9a-f]{12}$"
        },
        "commit_order": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "receipt_last": { "type": "boolean" }
      }
    },
    "verification_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_at",
        "service_identity_sha256",
        "openapi_sha256",
        "node_inventory_sha256",
        "workflow_inventory_sha256",
        "schema_inventory_sha256",
        "active_pointer_sha256",
        "receipt_sha256"
      ],
      "properties": {
        "verified_at": { "type": ["string", "null"], "format": "date-time" },
        "service_identity_sha256": { "$ref": "#/$defs/sha256OrNull" },
        "openapi_sha256": { "$ref": "#/$defs/sha256OrNull" },
        "node_inventory_sha256": { "$ref": "#/$defs/sha256OrNull" },
        "workflow_inventory_sha256": { "$ref": "#/$defs/sha256OrNull" },
        "schema_inventory_sha256": { "$ref": "#/$defs/sha256OrNull" },
        "active_pointer_sha256": { "$ref": "#/$defs/sha256OrNull" },
        "receipt_sha256": { "$ref": "#/$defs/sha256OrNull" }
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "performed",
        "target_release_id",
        "proof_sha256",
        "evidence_present"
      ],
      "properties": {
        "performed": { "type": "boolean" },
        "target_release_id": {
          "type": ["string", "null"],
          "pattern": "^mfr_[0-9]{8}_[0-9a-f]{12}$"
        },
        "proof_sha256": { "$ref": "#/$defs/sha256OrNull" },
        "evidence_present": { "type": "boolean" }
      }
    },
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer_side_only", "notes"],
      "properties": {
        "producer_side_only": { "const": true },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "evidence_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "sha256OrNull": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    },
    "prerequisite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["present", "accepted", "binding_sha256"],
      "properties": {
        "present": { "type": "boolean" },
        "accepted": { "type": "boolean" },
        "binding_sha256": { "$ref": "#/$defs/sha256OrNull" }
      }
    },
    "inventoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relative_path", "sha256", "size_bytes"],
      "properties": {
        "relative_path": {
          "type": "string",
          "pattern": "^(?![A-Za-z]:|/|.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
        },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "inventoryBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes", "workflows", "schemas", "api_openapi", "policies"],
      "properties": {
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/inventoryEntry" } },
        "workflows": { "type": "array", "items": { "$ref": "#/$defs/inventoryEntry" } },
        "schemas": { "type": "array", "items": { "$ref": "#/$defs/inventoryEntry" } },
        "api_openapi": { "type": "array", "items": { "$ref": "#/$defs/inventoryEntry" } },
        "policies": { "type": "array", "items": { "$ref": "#/$defs/inventoryEntry" } }
      }
    }
  }
}

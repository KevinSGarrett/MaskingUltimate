{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/maskfactory_qualification_bundle.schema.json",
  "title": "Executed and byte-verified MaskFactory consumer qualification bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "record_type", "qualification_id", "executed_at", "evidence_context", "fixture_only",
    "consumer", "canonicalization", "authentication", "trust_binding", "release_binding", "requirements_binding",
    "semantic_profile_binding", "core_completion_profile_binding", "executor_manifest", "environment_manifest",
    "compatibility_checks", "installation_verification", "vertical_slices", "evidence_catalog", "evidence_catalog_sha256",
    "all_required_checks_passed", "claim_limits", "qualification_payload_sha256", "signature"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "maskfactory_qualification_bundle"},
    "qualification_id": {"type": "string", "pattern": "^mfqual_[0-9a-f]{24}$"},
    "executed_at": {"$ref": "#/$defs/timestamp"},
    "evidence_context": {"enum": ["conformance_fixture", "runtime_evidence"]},
    "fixture_only": {"type": "boolean"},
    "consumer": {"type": "object", "additionalProperties": false, "required": ["project", "controller_version", "git_commit"], "properties": {"project": {"const": "Comfy_UI_Main"}, "controller_version": {"$ref": "#/$defs/semver"}, "git_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}}},
    "canonicalization": {"type": "object", "additionalProperties": false, "required": ["algorithm", "excluded_top_level_fields"], "properties": {"algorithm": {"const": "maskfactory-canonical-json-v1"}, "excluded_top_level_fields": {"type": "array", "prefixItems": [{"const": "qualification_payload_sha256"}, {"const": "signature"}], "minItems": 2, "maxItems": 2}}},
    "authentication": {"$ref": "#/$defs/authentication"},
    "trust_binding": {"$ref": "#/$defs/trustBinding"},
    "release_binding": {"type": "object", "additionalProperties": false, "required": ["release_id", "release_payload_sha256", "capability_snapshot_id", "capability_snapshot_sha256", "adopted_wire_schema_manifest_sha256"], "properties": {"release_id": {"type": "string", "minLength": 1}, "release_payload_sha256": {"$ref": "#/$defs/sha256"}, "capability_snapshot_id": {"type": "string", "minLength": 1}, "capability_snapshot_sha256": {"$ref": "#/$defs/sha256"}, "adopted_wire_schema_manifest_sha256": {"$ref": "#/$defs/sha256"}}},
    "requirements_binding": {"type": "object", "additionalProperties": false, "required": ["requirements_id", "requirements_sha256"], "properties": {"requirements_id": {"type": "string", "minLength": 1}, "requirements_sha256": {"$ref": "#/$defs/sha256"}}},
    "semantic_profile_binding": {"type": "object", "additionalProperties": false, "required": ["profile_id", "profile_sha256", "verifier_sha256"], "properties": {"profile_id": {"const": "maskfactory-comfyui-bridge-semantics"}, "profile_sha256": {"$ref": "#/$defs/sha256"}, "verifier_sha256": {"$ref": "#/$defs/sha256"}}},
    "core_completion_profile_binding": {"type": "object", "additionalProperties": false, "required": ["profile_id", "policy_sha256"], "properties": {"profile_id": {"const": "core_autonomous_runtime"}, "policy_sha256": {"$ref": "#/$defs/sha256"}}},
    "executor_manifest": {"type": "object", "additionalProperties": false, "required": ["executor_id", "executor_version", "executable_sha256", "command_manifest_sha256", "test_registry_sha256"], "properties": {"executor_id": {"type": "string", "minLength": 1}, "executor_version": {"type": "string", "minLength": 1}, "executable_sha256": {"$ref": "#/$defs/sha256"}, "command_manifest_sha256": {"$ref": "#/$defs/sha256"}, "test_registry_sha256": {"$ref": "#/$defs/sha256"}}},
    "environment_manifest": {"type": "object", "additionalProperties": false, "required": ["environment_id", "os_sha256", "python_sha256", "dependency_lock_sha256", "node_inventory_sha256", "hardware_profile_sha256"], "properties": {"environment_id": {"type": "string", "minLength": 1}, "os_sha256": {"$ref": "#/$defs/sha256"}, "python_sha256": {"$ref": "#/$defs/sha256"}, "dependency_lock_sha256": {"$ref": "#/$defs/sha256"}, "node_inventory_sha256": {"$ref": "#/$defs/sha256"}, "hardware_profile_sha256": {"$ref": "#/$defs/sha256"}}},
    "compatibility_checks": {"type": "array", "minItems": 16, "maxItems": 16, "items": {"$ref": "#/$defs/checkResult"}},
    "installation_verification": {"$ref": "#/$defs/executionResult"},
    "vertical_slices": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "object", "additionalProperties": false, "required": ["access_mode", "execution", "request_payload_sha256", "receipt_payload_sha256", "certificate_payload_sha256", "observed_authority_state"], "properties": {"access_mode": {"enum": ["mode_a_package_read", "mode_b_live_predict", "mode_b_live_refine"]}, "execution": {"$ref": "#/$defs/executionResult"}, "request_payload_sha256": {"$ref": "#/$defs/sha256"}, "receipt_payload_sha256": {"$ref": "#/$defs/sha256"}, "certificate_payload_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}, "observed_authority_state": {"enum": ["draft", "qa_passed_noncertified", "certified"]}}}},
    "evidence_catalog": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["evidence_id", "relative_path", "sha256", "size_bytes", "media_type"], "properties": {"evidence_id": {"type": "string", "minLength": 1}, "relative_path": {"$ref": "#/$defs/relativePath"}, "sha256": {"$ref": "#/$defs/sha256"}, "size_bytes": {"type": "integer", "minimum": 1}, "media_type": {"type": "string", "minLength": 1}}}},
    "evidence_catalog_sha256": {"$ref": "#/$defs/sha256"},
    "all_required_checks_passed": {"type": "boolean"},
    "claim_limits": {"type": "object", "additionalProperties": false, "required": ["establishes_adoption_evidence_only", "operational_artifact_authority_claim", "training_gold_claim", "independent_accuracy_claim"], "properties": {"establishes_adoption_evidence_only": {"const": true}, "operational_artifact_authority_claim": {"const": false}, "training_gold_claim": {"const": false}, "independent_accuracy_claim": {"const": false}}},
    "qualification_payload_sha256": {"$ref": "#/$defs/sha256"},
    "signature": {"$ref": "#/$defs/signature"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"},
    "semver": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "relativePath": {"type": "string", "pattern": "^(?![A-Za-z]:|/|.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"},
    "authentication": {"type": "object", "additionalProperties": false, "required": ["principal_id", "authority", "role", "nonce", "issued_at", "expires_at", "replay_window_seconds", "credential_material_included"], "properties": {"principal_id": {"type": "string", "minLength": 1}, "authority": {"const": "Comfy_UI_Main"}, "role": {"const": "consumer_qualification"}, "nonce": {"type": "string", "pattern": "^[A-Za-z0-9_-]{24,128}$"}, "issued_at": {"$ref": "#/$defs/timestamp"}, "expires_at": {"$ref": "#/$defs/timestamp"}, "replay_window_seconds": {"type": "integer", "minimum": 1, "maximum": 3600}, "credential_material_included": {"const": false}}},
    "trustBinding": {"type": "object", "additionalProperties": false, "required": ["key_set_id", "key_set_version", "key_set_sha256", "key_role", "signing_key_id", "signing_public_key_sha256", "rotation_policy_sha256", "revocation_policy_sha256"], "properties": {"key_set_id": {"type": "string", "minLength": 1}, "key_set_version": {"type": "string", "minLength": 1}, "key_set_sha256": {"$ref": "#/$defs/sha256"}, "key_role": {"const": "consumer_qualification"}, "signing_key_id": {"type": "string", "minLength": 1}, "signing_public_key_sha256": {"$ref": "#/$defs/sha256"}, "rotation_policy_sha256": {"$ref": "#/$defs/sha256"}, "revocation_policy_sha256": {"$ref": "#/$defs/sha256"}}},
    "signature": {"type": "object", "additionalProperties": false, "required": ["algorithm", "key_id", "public_key_base64", "signed_payload_sha256", "signed_payload_format", "value_base64"], "properties": {"algorithm": {"const": "ed25519"}, "key_id": {"type": "string", "minLength": 1}, "public_key_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{43}=$"}, "signed_payload_sha256": {"$ref": "#/$defs/sha256"}, "signed_payload_format": {"const": "sha256_digest_bytes"}, "value_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{40,}={0,2}$"}}},
    "checkResult": {"type": "object", "additionalProperties": false, "required": ["check", "result", "test_ids", "execution", "evidence_ids", "result_sha256"], "properties": {"check": {"enum": ["trust_anchor", "signature", "release_hash", "canonicalization", "signed_journal", "revocation_freshness", "artifact_security", "wire_schemas", "api_contract", "package_format", "ontology", "node_pack", "capabilities", "media_scope", "authority_policy", "contract_tests"]}, "result": {"enum": ["pass", "fail"]}, "test_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "execution": {"$ref": "#/$defs/executionResult"}, "evidence_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "result_sha256": {"$ref": "#/$defs/sha256"}}},
    "executionResult": {"type": "object", "additionalProperties": false, "required": ["execution_id", "command_sha256", "started_at", "completed_at", "exit_code", "status", "stdout_sha256", "stderr_sha256"], "properties": {"execution_id": {"type": "string", "minLength": 1}, "command_sha256": {"$ref": "#/$defs/sha256"}, "started_at": {"$ref": "#/$defs/timestamp"}, "completed_at": {"$ref": "#/$defs/timestamp"}, "exit_code": {"type": "integer"}, "status": {"enum": ["pass", "fail"]}, "stdout_sha256": {"$ref": "#/$defs/sha256"}, "stderr_sha256": {"$ref": "#/$defs/sha256"}}}
  },
  "allOf": [
    {"if": {"properties": {"fixture_only": {"const": true}}, "required": ["fixture_only"]}, "then": {"properties": {"evidence_context": {"const": "conformance_fixture"}}}},
    {"if": {"properties": {"fixture_only": {"const": false}}, "required": ["fixture_only"]}, "then": {"properties": {"evidence_context": {"const": "runtime_evidence"}, "all_required_checks_passed": {"const": true}}}}
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/maskfactory_release_snapshot.schema.json",
  "title": "Immutable MaskFactory producer release snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "record_type", "release_id", "release_status", "published_at", "evidence_context", "fixture_only", "canonicalization",
    "producer", "signing_trust", "canonicalization_spec", "artifact_security_policy", "journal_checkpoint", "compatibility", "wire_schemas", "semantic_invariant_profile", "completion_profiles", "artifacts", "openapi", "capability_snapshot",
    "workflow_inventory", "node_inventory", "certificate_index", "evidence_index",
    "known_limitations", "breaking_changes", "installation", "rollback",
    "supersedes_release_id", "revoked_release_ids",
    "release_payload_sha256", "signature"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "maskfactory_release_snapshot"},
    "release_id": {"type": "string", "pattern": "^mfr_[0-9]{8}_[0-9a-f]{12}$"},
    "release_status": {"enum": ["fixture", "published", "superseded", "revoked"]},
    "published_at": {"$ref": "#/$defs/timestamp"},
    "evidence_context": {"enum": ["conformance_fixture", "runtime_evidence"]},
    "fixture_only": {"type": "boolean"},
    "canonicalization": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "excluded_top_level_fields"],
      "properties": {
        "algorithm": {"const": "maskfactory-canonical-json-v1"},
        "excluded_top_level_fields": {
          "type": "array", "prefixItems": [{"const": "release_payload_sha256"}, {"const": "signature"}], "minItems": 2, "maxItems": 2
        }
      }
    },
    "producer": {
      "type": "object", "additionalProperties": false,
      "required": ["project", "repository_id", "git_commit", "git_tree", "dirty"],
      "properties": {
        "project": {"const": "MaskFactory"},
        "repository_id": {"type": "string", "minLength": 1},
        "git_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "git_tree": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "dirty": {"const": false}
      }
    },
    "signing_trust": {
      "type": "object", "additionalProperties": false,
      "required": ["key_set_id", "key_set_version", "key_set_sha256", "release_signing_key_id", "release_signing_public_key_sha256", "rotation_policy_id", "rotation_policy_sha256", "revocation_policy_id", "revocation_policy_sha256"],
      "properties": {
        "key_set_id": {"type": "string", "minLength": 1},
        "key_set_version": {"type": "string", "minLength": 1},
        "key_set_sha256": {"$ref": "#/$defs/sha256"},
        "release_signing_key_id": {"type": "string", "pattern": "^mf-release-[a-z0-9-]+$"},
        "release_signing_public_key_sha256": {"$ref": "#/$defs/sha256"},
        "rotation_policy_id": {"type": "string", "minLength": 1},
        "rotation_policy_sha256": {"$ref": "#/$defs/sha256"},
        "revocation_policy_id": {"type": "string", "minLength": 1},
        "revocation_policy_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "canonicalization_spec": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "spec_version", "relative_path", "sha256", "golden_vectors_relative_path", "golden_vectors_sha256", "unicode_normalization", "encoding", "object_key_order", "duplicate_keys", "number_encoding", "negative_zero", "nonfinite_numbers", "timestamp_normalization"],
      "properties": {
        "algorithm": {"const": "maskfactory-canonical-json-v1"}, "spec_version": {"const": "1.0.0"},
        "relative_path": {"$ref": "#/$defs/relativePath"}, "sha256": {"$ref": "#/$defs/sha256"},
        "golden_vectors_relative_path": {"$ref": "#/$defs/relativePath"}, "golden_vectors_sha256": {"$ref": "#/$defs/sha256"},
        "unicode_normalization": {"const": "NFC"}, "encoding": {"const": "UTF-8"}, "object_key_order": {"const": "unicode_codepoint"},
        "duplicate_keys": {"const": "reject"}, "number_encoding": {"const": "shortest_roundtrip_decimal"}, "negative_zero": {"const": "zero"},
        "nonfinite_numbers": {"const": "reject"}, "timestamp_normalization": {"const": "RFC3339_UTC_Z"}
      }
    },
    "artifact_security_policy": {
      "type": "object", "additionalProperties": false,
      "required": ["policy_id", "policy_sha256", "allowed_root_manifest_relative_path", "allowed_root_manifest_sha256", "reject_absolute_paths", "reject_parent_traversal", "reject_drive_or_unc_paths", "reject_symlink_hardlink_reparse", "reject_case_collisions", "reject_unmanifested_files", "maximum_file_bytes", "maximum_archive_files", "maximum_archive_expanded_bytes", "maximum_compression_ratio"],
      "properties": {
        "policy_id": {"type": "string", "minLength": 1}, "policy_sha256": {"$ref": "#/$defs/sha256"},
        "allowed_root_manifest_relative_path": {"$ref": "#/$defs/relativePath"}, "allowed_root_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "reject_absolute_paths": {"const": true}, "reject_parent_traversal": {"const": true}, "reject_drive_or_unc_paths": {"const": true},
        "reject_symlink_hardlink_reparse": {"const": true}, "reject_case_collisions": {"const": true}, "reject_unmanifested_files": {"const": true},
        "maximum_file_bytes": {"type": "integer", "minimum": 1}, "maximum_archive_files": {"type": "integer", "minimum": 1},
        "maximum_archive_expanded_bytes": {"type": "integer", "minimum": 1}, "maximum_compression_ratio": {"type": "integer", "minimum": 1, "maximum": 1000}
      }
    },
    "journal_checkpoint": {
      "type": "object", "additionalProperties": false,
      "required": ["stream_id", "genesis_event_id", "genesis_event_sha256", "first_sequence", "last_sequence", "event_count", "head_event_id", "head_event_sha256", "revocation_state_sha256", "active_revocation_count", "validator_sha256", "checkpointed_at", "fresh_until"],
      "properties": {
        "stream_id": {"type": "string", "minLength": 1},
        "genesis_event_id": {"type": "string", "minLength": 1}, "genesis_event_sha256": {"$ref": "#/$defs/sha256"},
        "first_sequence": {"const": 1}, "last_sequence": {"type": "integer", "minimum": 1}, "event_count": {"type": "integer", "minimum": 1},
        "head_event_id": {"type": "string", "minLength": 1}, "head_event_sha256": {"$ref": "#/$defs/sha256"},
        "revocation_state_sha256": {"$ref": "#/$defs/sha256"}, "active_revocation_count": {"type": "integer", "minimum": 0}, "validator_sha256": {"$ref": "#/$defs/sha256"},
        "checkpointed_at": {"$ref": "#/$defs/timestamp"}, "fresh_until": {"$ref": "#/$defs/timestamp"}
      }
    },
    "compatibility": {
      "type": "object", "additionalProperties": false,
      "required": ["bridge_contract", "api_contract", "package_format", "ontology_version", "node_pack_version", "minimum_consumer_contract"],
      "properties": {
        "bridge_contract": {"const": "maskfactory-comfyui-bridge/1.0"},
        "api_contract": {"type": "string", "pattern": "^maskfactory-api/[1-9][0-9]*\\.[0-9]+$"},
        "package_format": {"type": "string", "pattern": "^maskfactory-package/[1-9][0-9]*\\.[0-9]+$"},
        "ontology_version": {"type": "string", "pattern": "^body_parts_v[1-9][0-9]*(?:\\.[0-9]+)?$"},
        "node_pack_version": {"$ref": "#/$defs/semver"},
        "minimum_consumer_contract": {"$ref": "#/$defs/semver"}
      }
    },
    "wire_schemas": {
      "type": "array", "minItems": 12, "maxItems": 12, "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["name", "schema_id", "version", "relative_path", "sha256"],
        "properties": {
          "name": {
            "enum": [
              "maskfactory_release_snapshot", "maskfactory_capability_snapshot",
              "maskfactory_consumer_requirements", "mask_acquisition_request",
              "mask_acquisition_receipt", "mask_bridge_error", "maskfactory_adoption_receipt",
              "mask_authority_invalidation_event", "mask_repair_feedback", "mask_bridge_event",
              "operational_autonomy_certificate", "mask_bridge_semantic_invariant_profile"
            ]
          },
          "schema_id": {"type": "string", "format": "uri"},
          "version": {"const": "1.0.0"},
          "relative_path": {"type": "string", "pattern": "^src/maskfactory/schemas/[a-z0-9_]+\\.schema\\.json$"},
          "sha256": {"$ref": "#/$defs/sha256"}
        }
      },
      "allOf": [
        {"contains": {"properties": {"name": {"const": "maskfactory_release_snapshot"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "maskfactory_capability_snapshot"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "maskfactory_consumer_requirements"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_acquisition_request"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_acquisition_receipt"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_bridge_error"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "maskfactory_adoption_receipt"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_authority_invalidation_event"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_repair_feedback"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_bridge_event"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "operational_autonomy_certificate"}}, "required": ["name"]}},
        {"contains": {"properties": {"name": {"const": "mask_bridge_semantic_invariant_profile"}}, "required": ["name"]}}
      ]
    },
    "semantic_invariant_profile": {"$ref": "#/$defs/boundSemanticProfile"},
    "completion_profiles": {
      "type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["profile_id", "profile_version", "relative_path", "policy_sha256", "document_sha256", "required_for_core_runtime"],
        "properties": {
          "profile_id": {"enum": ["core_autonomous_runtime", "independent_real_accuracy", "scale_daz_maturity"]},
          "profile_version": {"$ref": "#/$defs/semver"},
          "relative_path": {"type": "string", "pattern": "^qa/governance/completion/[a-z0-9_]+_v[0-9]+\\.json$"},
          "policy_sha256": {"$ref": "#/$defs/sha256"},
          "document_sha256": {"$ref": "#/$defs/sha256"},
          "required_for_core_runtime": {"type": "boolean"}
        }
      },
      "allOf": [
        {"contains": {"properties": {"profile_id": {"const": "core_autonomous_runtime"}, "required_for_core_runtime": {"const": true}}, "required": ["profile_id", "required_for_core_runtime"]}},
        {"contains": {"properties": {"profile_id": {"const": "independent_real_accuracy"}, "required_for_core_runtime": {"const": false}}, "required": ["profile_id", "required_for_core_runtime"]}},
        {"contains": {"properties": {"profile_id": {"const": "scale_daz_maturity"}, "required_for_core_runtime": {"const": false}}, "required": ["profile_id", "required_for_core_runtime"]}}
      ]
    },
    "artifacts": {
      "type": "array", "minItems": 6, "maxItems": 6,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["kind", "relative_path", "sha256", "size_bytes"],
        "properties": {
          "kind": {"enum": ["python_wheel", "comfyui_node_pack", "schema_bundle", "openapi_document", "compatibility_manifest", "certificate_index"]},
          "relative_path": {"$ref": "#/$defs/relativePath"},
          "sha256": {"$ref": "#/$defs/sha256"},
          "size_bytes": {"type": "integer", "minimum": 1}
        }
      },
      "allOf": [
        {"contains": {"properties": {"kind": {"const": "python_wheel"}}, "required": ["kind"]}},
        {"contains": {"properties": {"kind": {"const": "comfyui_node_pack"}}, "required": ["kind"]}},
        {"contains": {"properties": {"kind": {"const": "schema_bundle"}}, "required": ["kind"]}},
        {"contains": {"properties": {"kind": {"const": "openapi_document"}}, "required": ["kind"]}},
        {"contains": {"properties": {"kind": {"const": "compatibility_manifest"}}, "required": ["kind"]}},
        {"contains": {"properties": {"kind": {"const": "certificate_index"}}, "required": ["kind"]}}
      ]
    },
    "openapi": {
      "type": "object", "additionalProperties": false,
      "required": ["version", "relative_path", "sha256"],
      "properties": {
        "version": {"type": "string", "pattern": "^3\\.(?:0|1)\\.[0-9]+$"},
        "relative_path": {"$ref": "#/$defs/relativePath"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "capability_snapshot": {"$ref": "#/$defs/boundCapabilitySnapshot"},
    "workflow_inventory": {"$ref": "#/$defs/boundInventory"},
    "node_inventory": {"$ref": "#/$defs/boundInventory"},
    "certificate_index": {
      "type": "object", "additionalProperties": false,
      "required": ["relative_path", "sha256", "active_certificate_count", "revocation_index_sha256"],
      "properties": {
        "relative_path": {"$ref": "#/$defs/relativePath"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "active_certificate_count": {"type": "integer", "minimum": 0},
        "revocation_index_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "evidence_index": {"$ref": "#/$defs/boundInventory"},
    "known_limitations": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["limitation_id", "scope", "description", "mitigation"],
        "properties": {
          "limitation_id": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "mitigation": {"type": "string", "minLength": 1}
        }
      }
    },
    "breaking_changes": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["change_id", "affected_contract", "description", "migration_id", "migration_sha256"],
        "properties": {
          "change_id": {"type": "string", "minLength": 1},
          "affected_contract": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "migration_id": {"type": "string", "minLength": 1},
          "migration_sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "installation": {
      "type": "object", "additionalProperties": false,
      "required": ["installer_id", "installer_sha256", "install_manifest_sha256", "verification_workflow_id", "verification_workflow_sha256"],
      "properties": {
        "installer_id": {"type": "string", "minLength": 1},
        "installer_sha256": {"$ref": "#/$defs/sha256"},
        "install_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "verification_workflow_id": {"type": "string", "minLength": 1},
        "verification_workflow_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "rollback": {
      "type": "object", "additionalProperties": false,
      "required": ["rollback_id", "rollback_sha256", "target_release_id", "verification_evidence_sha256"],
      "properties": {
        "rollback_id": {"type": "string", "minLength": 1},
        "rollback_sha256": {"$ref": "#/$defs/sha256"},
        "target_release_id": {"type": ["string", "null"], "pattern": "^mfr_[0-9]{8}_[0-9a-f]{12}$"},
        "verification_evidence_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "supersedes_release_id": {"type": ["string", "null"], "pattern": "^mfr_[0-9]{8}_[0-9a-f]{12}$"},
    "revoked_release_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^mfr_[0-9]{8}_[0-9a-f]{12}$"}},
    "release_payload_sha256": {"$ref": "#/$defs/sha256"},
    "signature": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "key_id", "public_key_base64", "signed_payload_sha256", "signed_payload_format", "value_base64"],
      "properties": {
        "algorithm": {"const": "ed25519"},
        "key_id": {"type": "string", "pattern": "^mf-release-[a-z0-9-]+$"},
        "public_key_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{43}=$"},
        "signed_payload_sha256": {"$ref": "#/$defs/sha256"},
        "signed_payload_format": {"const": "sha256_digest_bytes"},
        "value_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{40,}={0,2}$"}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"},
    "semver": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "relativePath": {"type": "string", "pattern": "^(?![A-Za-z]:|/|.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"},
    "boundDocument": {
      "type": "object", "additionalProperties": false,
      "required": ["record_id", "relative_path", "sha256"],
      "properties": {
        "record_id": {"type": "string", "minLength": 1},
        "relative_path": {"$ref": "#/$defs/relativePath"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "boundSemanticProfile": {
      "type": "object", "additionalProperties": false,
      "required": ["record_id", "relative_path", "profile_sha256", "document_sha256"],
      "properties": {
        "record_id": {"type": "string", "minLength": 1},
        "relative_path": {"$ref": "#/$defs/relativePath"},
        "profile_sha256": {"$ref": "#/$defs/sha256"},
        "document_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "boundCapabilitySnapshot": {
      "type": "object", "additionalProperties": false,
      "required": ["record_id", "relative_path", "payload_sha256", "document_sha256"],
      "properties": {
        "record_id": {"type": "string", "minLength": 1},
        "relative_path": {"$ref": "#/$defs/relativePath"},
        "payload_sha256": {"$ref": "#/$defs/sha256"},
        "document_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "boundInventory": {
      "type": "object", "additionalProperties": false,
      "required": ["inventory_id", "relative_path", "sha256", "record_count"],
      "properties": {
        "inventory_id": {"type": "string", "minLength": 1},
        "relative_path": {"$ref": "#/$defs/relativePath"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "record_count": {"type": "integer", "minimum": 0}
      }
    }
  },
  "allOf": [
    {"if": {"properties": {"fixture_only": {"const": true}}, "required": ["fixture_only"]}, "then": {"properties": {"release_status": {"const": "fixture"}, "evidence_context": {"const": "conformance_fixture"}}}},
    {"if": {"properties": {"fixture_only": {"const": false}}, "required": ["fixture_only"]}, "then": {"properties": {"evidence_context": {"const": "runtime_evidence"}, "release_status": {"enum": ["published", "superseded", "revoked"]}}}}
  ]
}

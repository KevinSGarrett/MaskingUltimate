{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/matrix_promotion_certificate.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "certificate_id", "issued_at", "reviewer", "signer_public_key_sha256", "matrix_identity", "role_bindings", "authority", "signature_algorithm", "payload_sha256", "signature", "certificate_sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "certificate_id": {"type": "string", "pattern": "^[a-f0-9]{24}$"},
    "issued_at": {"type": "string", "format": "date-time"},
    "reviewer": {"type": "string", "minLength": 1},
    "signer_public_key_sha256": {"$ref": "#/$defs/sha256"},
    "matrix_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_sha256", "manifest_sha256", "observations_sha256", "report_sha256", "shared_identity_sha256"],
      "properties": {
        "policy_sha256": {"$ref": "#/$defs/sha256"},
        "manifest_sha256": {"$ref": "#/$defs/sha256"},
        "observations_sha256": {"$ref": "#/$defs/sha256"},
        "report_sha256": {"$ref": "#/$defs/sha256"},
        "shared_identity_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "role_bindings": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {"$ref": "#/$defs/roleBinding"}
    },
    "authority": {"const": "validated_signed_matrix_bound_prerequisites_only_no_role_promotion_serving_mask_or_gold_authority"},
    "signature_algorithm": {"const": "ed25519"},
    "payload_sha256": {"$ref": "#/$defs/sha256"},
    "signature": {"type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$"},
    "certificate_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "roleBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "candidate_key", "incumbent_provider", "prerequisite_kind", "prerequisite_sha256", "prerequisite_summary_sha256", "rollback_evidence_sha256", "rollback_tested_at", "matrix_binding_mode", "matrix_provider_artifact_key", "matrix_cell_id", "matrix_cell_identity_sha256", "matrix_cell_observations_sha256", "matrix_cell_result_sha256"],
      "properties": {
        "role": {"type": "string", "minLength": 1},
        "candidate_key": {"type": "string", "minLength": 1},
        "incumbent_provider": {"type": "string", "minLength": 1},
        "prerequisite_kind": {"enum": ["specialist_promotion_packet", "custom_segmenter_certificate"]},
        "prerequisite_sha256": {"$ref": "#/$defs/sha256"},
        "prerequisite_summary_sha256": {"$ref": "#/$defs/sha256"},
        "rollback_evidence_sha256": {"$ref": "#/$defs/sha256"},
        "rollback_tested_at": {"type": "string", "format": "date-time"},
        "matrix_binding_mode": {"enum": ["candidate_artifact", "pipeline_context"]},
        "matrix_provider_artifact_key": {"type": ["string", "null"]},
        "matrix_cell_id": {"type": "string", "minLength": 1},
        "matrix_cell_identity_sha256": {"$ref": "#/$defs/sha256"},
        "matrix_cell_observations_sha256": {"$ref": "#/$defs/sha256"},
        "matrix_cell_result_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/mediapipe_vote_ablation_cases.schema.json",
  "title": "MediaPipe handedness-vote ablation cases",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_id",
    "results_opened_at",
    "policy_sha256",
    "truth_tier",
    "truth_partition",
    "truth_manifest_sha256",
    "pipeline_fingerprint_sha256",
    "hand_landmarker_artifact_sha256",
    "cases",
    "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "benchmark_id": {"type": "string", "minLength": 1},
    "results_opened_at": {"type": "string", "format": "date-time"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "truth_tier": {"const": "human_anchor_gold"},
    "truth_partition": {"const": "holdout"},
    "truth_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "pipeline_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
    "hand_landmarker_artifact_sha256": {"$ref": "#/$defs/sha256"},
    "cases": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "#/$defs/case"}
    },
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "side": {"enum": ["left", "right"]},
    "vote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["side", "evidence_sha256"],
      "properties": {
        "side": {"$ref": "#/$defs/side"},
        "evidence_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "nullableVote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["side", "evidence_sha256"],
      "properties": {
        "side": {"oneOf": [{"$ref": "#/$defs/side"}, {"type": "null"}]},
        "evidence_sha256": {
          "oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
        }
      }
    },
    "landmark": {
      "type": "array",
      "prefixItems": [
        {"type": "number", "minimum": 0, "maximum": 1},
        {"type": "number", "minimum": 0, "maximum": 1},
        {"type": "number"}
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "mediapipeVote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["side", "score", "landmarks", "evidence_sha256"],
      "properties": {
        "side": {"$ref": "#/$defs/side"},
        "score": {"type": "number", "minimum": 0, "maximum": 1},
        "landmarks": {
          "type": "array",
          "minItems": 21,
          "maxItems": 21,
          "items": {"$ref": "#/$defs/landmark"}
        },
        "evidence_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "kind",
        "mirror_pair_id",
        "image_id",
        "package_id",
        "truth_label",
        "truth_side",
        "source_image_sha256",
        "truth_mask_sha256",
        "pose_skeleton",
        "densepose_surface",
        "mediapipe_handedness"
      ],
      "properties": {
        "case_id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["human_anchor", "side_swap_fixture"]},
        "mirror_pair_id": {"type": ["string", "null"]},
        "image_id": {"type": "string", "minLength": 1},
        "package_id": {"type": "string", "minLength": 1},
        "truth_label": {"type": "string", "minLength": 1},
        "truth_side": {"$ref": "#/$defs/side"},
        "source_image_sha256": {"$ref": "#/$defs/sha256"},
        "truth_mask_sha256": {"$ref": "#/$defs/sha256"},
        "pose_skeleton": {"$ref": "#/$defs/vote"},
        "densepose_surface": {"$ref": "#/$defs/nullableVote"},
        "mediapipe_handedness": {"$ref": "#/$defs/mediapipeVote"}
      }
    }
  }
}

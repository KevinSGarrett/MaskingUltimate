{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/mediapipe_vote_ablation_report.schema.json",
  "title": "MediaPipe handedness-vote ablation report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_id",
    "evaluated_at",
    "policy_sha256",
    "source_cases_sha256",
    "truth_manifest_sha256",
    "pipeline_fingerprint_sha256",
    "hand_landmarker_artifact_sha256",
    "human_anchor_case_count",
    "distinct_image_count",
    "side_swap_pair_count",
    "baseline_metrics",
    "with_mediapipe_metrics",
    "delta",
    "case_results",
    "findings",
    "result",
    "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "benchmark_id": {"type": "string", "minLength": 1},
    "evaluated_at": {"type": "string", "format": "date-time"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "source_cases_sha256": {"$ref": "#/$defs/sha256"},
    "truth_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "pipeline_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
    "hand_landmarker_artifact_sha256": {"$ref": "#/$defs/sha256"},
    "human_anchor_case_count": {"type": "integer", "minimum": 1},
    "distinct_image_count": {"type": "integer", "minimum": 1},
    "side_swap_pair_count": {"type": "integer", "minimum": 1},
    "baseline_metrics": {"$ref": "#/$defs/metrics"},
    "with_mediapipe_metrics": {"$ref": "#/$defs/metrics"},
    "delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["correct", "wrong_side", "abstain", "coverage"],
      "properties": {
        "correct": {"type": "integer"},
        "wrong_side": {"type": "integer"},
        "abstain": {"type": "integer"},
        "coverage": {"type": "number", "minimum": -1, "maximum": 1}
      }
    },
    "case_results": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/caseResult"}
    },
    "findings": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "result": {"enum": ["pass", "fail"]},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "unit": {"type": "number", "minimum": 0, "maximum": 1},
    "sideOrNull": {"enum": ["left", "right", null]},
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "correct",
        "wrong_side",
        "abstain",
        "decided",
        "coverage",
        "accuracy_when_decided",
        "wrong_side_rate"
      ],
      "properties": {
        "total": {"type": "integer", "minimum": 1},
        "correct": {"type": "integer", "minimum": 0},
        "wrong_side": {"type": "integer", "minimum": 0},
        "abstain": {"type": "integer", "minimum": 0},
        "decided": {"type": "integer", "minimum": 0},
        "coverage": {"$ref": "#/$defs/unit"},
        "accuracy_when_decided": {"$ref": "#/$defs/unit"},
        "wrong_side_rate": {"$ref": "#/$defs/unit"}
      }
    },
    "caseResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "truth_side",
        "baseline_decision",
        "full_decision",
        "baseline_outcome",
        "full_outcome",
        "mediapipe_used"
      ],
      "properties": {
        "case_id": {"type": "string", "minLength": 1},
        "truth_side": {"enum": ["left", "right"]},
        "baseline_decision": {"$ref": "#/$defs/sideOrNull"},
        "full_decision": {"$ref": "#/$defs/sideOrNull"},
        "baseline_outcome": {"enum": ["correct", "wrong_side", "abstain"]},
        "full_outcome": {"enum": ["correct", "wrong_side", "abstain"]},
        "mediapipe_used": {"type": "boolean"}
      }
    }
  }
}

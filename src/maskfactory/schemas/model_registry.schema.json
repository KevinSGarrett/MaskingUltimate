{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/model_registry.schema.json",
  "title": "MaskFactory model registry",
  "description": "Authoritative active registry for file-backed checkpoints, managed Ollama models, and governed trained candidates (doc 04 §3).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "use_profile",
    "distribution_allowed",
    "commercial_deployment",
    "content_compatibility",
    "models"
  ],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "use_profile": { "const": "private_personal_noncommercial" },
    "distribution_allowed": { "const": false },
    "commercial_deployment": { "const": false },
    "content_compatibility": { "$ref": "#/$defs/contentCompatibility" },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/fileBackedModel" },
          { "$ref": "#/$defs/ollamaModel" },
          { "$ref": "#/$defs/trainedModel" }
        ]
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "contentCompatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adult_nonexplicit", "consensual_explicit_adult"],
      "properties": {
        "adult_nonexplicit": { "enum": ["allowed", "prohibited", "unclear"] },
        "consensual_explicit_adult": { "enum": ["allowed", "prohibited", "unclear"] }
      }
    },
    "lifecycleState": {
      "enum": ["installed", "benchmarked", "promoted", "retired"]
    },
    "licenseReview": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "source_url", "snapshot_sha256", "reviewed_at"],
          "properties": {
            "status": { "const": "verified" },
            "source_url": { "type": "string", "format": "uri", "pattern": "^https://" },
            "snapshot_sha256": { "$ref": "#/$defs/sha256" },
            "reviewed_at": { "$ref": "#/$defs/timestamp" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": { "status": { "const": "pending" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": { "status": { "const": "not_required" } }
        }
      ]
    },
    "licenseLayerEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "source_url", "snapshot_sha256", "reviewed_at"],
      "properties": {
        "decision": { "enum": ["allowed", "prohibited", "unclear"] },
        "source_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "snapshot_sha256": { "$ref": "#/$defs/sha256" },
        "reviewed_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "licenseLayers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "checkpoint", "effective_scope", "evidence_bundle_sha256"],
      "properties": {
        "repository": { "$ref": "#/$defs/licenseLayerEvidence" },
        "checkpoint": { "$ref": "#/$defs/licenseLayerEvidence" },
        "effective_scope": { "const": "checkpoint" },
        "evidence_bundle_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^models/(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+(?:/[^\\\\]+)*$"
    },
    "smokeTest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "output_sha256", "runner", "verified_at"],
      "properties": {
        "image": {
          "type": "string",
          "pattern": "^(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+(?:/[^\\\\]+)*$"
        },
        "output_sha256": { "$ref": "#/$defs/sha256" },
        "runner": { "$ref": "#/$defs/key" },
        "verified_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "fileBackedModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "role",
        "lifecycle_state",
        "content_compatibility",
        "license_review",
        "source_url",
        "file",
        "sha256",
        "version_tag",
        "license",
        "runtime",
        "vram_note",
        "downloaded_at",
        "verified",
        "smoke_test"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "role": { "$ref": "#/$defs/key" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycleState" },
        "content_compatibility": { "$ref": "#/$defs/contentCompatibility" },
        "license_review": { "$ref": "#/$defs/licenseReview" },
        "license_layers": { "$ref": "#/$defs/licenseLayers" },
        "source_url": { "type": "string", "format": "uri", "pattern": "^(?:https|file)://" },
        "file": { "$ref": "#/$defs/relativePath" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "version_tag": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string", "minLength": 1 },
        "vram_note": { "type": "string", "minLength": 1 },
        "downloaded_at": { "$ref": "#/$defs/timestamp" },
        "verified": { "const": true },
        "smoke_test": { "$ref": "#/$defs/smokeTest" },
        "target_champion_role": { "$ref": "#/$defs/key" },
        "inference_config": { "$ref": "#/$defs/relativePath" },
        "inference_config_sha256": { "$ref": "#/$defs/sha256" },
        "class_names": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "class_names_sha256": { "$ref": "#/$defs/sha256" },
        "ontology_version": { "type": "string", "minLength": 1 },
        "artifact_hashes": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/sha256" }
        },
        "benchmark_certificate": { "$ref": "#/$defs/benchmarkCertificate" }
      }
    },
    "ollamaModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "role",
        "lifecycle_state",
        "content_compatibility",
        "license_review",
        "managed",
        "manager",
        "ollama_name",
        "digest",
        "sha256",
        "ollama_list_id",
        "availability_check",
        "family",
        "format",
        "parameter_size",
        "quantization",
        "size",
        "registered_at",
        "verified"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "role": { "$ref": "#/$defs/key" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycleState" },
        "content_compatibility": { "$ref": "#/$defs/contentCompatibility" },
        "license_review": { "$ref": "#/$defs/licenseReview" },
        "license_layers": { "$ref": "#/$defs/licenseLayers" },
        "managed": { "const": true },
        "manager": { "const": "ollama" },
        "ollama_name": { "type": "string", "pattern": "^[^:]+:[^:]+$" },
        "digest": { "$ref": "#/$defs/sha256" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "ollama_list_id": { "type": "string", "pattern": "^[a-f0-9]{12}$" },
        "availability_check": { "const": "api_tags+ollama_list_digest_match" },
        "family": { "type": "string", "minLength": 1 },
        "format": { "const": "gguf" },
        "parameter_size": { "type": "string", "minLength": 1 },
        "quantization": { "type": "string", "minLength": 1 },
        "size": { "type": "integer", "minimum": 1 },
        "registered_at": { "$ref": "#/$defs/timestamp" },
        "verified": { "const": true }
      }
    },
    "trainedModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "role",
        "lifecycle_state",
        "content_compatibility",
        "license_review",
        "file",
        "sha256",
        "version_tag",
        "runtime",
        "license",
        "registered_at",
        "verified",
        "training_run",
        "dataset_ref"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "role": { "$ref": "#/$defs/key" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycleState" },
        "content_compatibility": { "$ref": "#/$defs/contentCompatibility" },
        "license_review": { "$ref": "#/$defs/licenseReview" },
        "license_layers": { "$ref": "#/$defs/licenseLayers" },
        "file": { "$ref": "#/$defs/relativePath" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "version_tag": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 },
        "registered_at": { "$ref": "#/$defs/timestamp" },
        "verified": { "const": true },
        "training_run": { "type": "string", "minLength": 1 },
        "dataset_ref": { "type": "string", "minLength": 1 },
        "target_champion_role": { "$ref": "#/$defs/key" },
        "inference_config": { "$ref": "#/$defs/relativePath" },
        "inference_config_sha256": { "$ref": "#/$defs/sha256" },
        "class_names": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "class_names_sha256": { "$ref": "#/$defs/sha256" },
        "ontology_version": { "type": "string", "minLength": 1 },
        "artifact_hashes": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/sha256" }
        },
        "dataset_dvc_md5": { "type": ["string", "null"] },
        "git_sha": { "type": ["string", "null"] },
        "benchmark_certificate": { "$ref": "#/$defs/benchmarkCertificate" },
        "source_url": { "type": "string", "format": "uri", "pattern": "^(?:https|file)://" },
        "vram_note": { "type": "string" },
        "downloaded_at": { "$ref": "#/$defs/timestamp" },
        "smoke_test": { "$ref": "#/$defs/smokeTest" }
      }
    },
    "benchmarkCertificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "target_role",
        "primary_win_or_labor_reduction",
        "hard_bucket_results",
        "frozen_eval_sha256",
        "issued_at",
        "sha256"
      ],
      "properties": {
        "schema_version": { "const": "1.0.0" },
        "target_role": { "$ref": "#/$defs/key" },
        "primary_win_or_labor_reduction": { "const": true },
        "hard_bucket_results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["bucket", "observed_delta", "noninferiority_margin", "passed"],
            "properties": {
              "bucket": { "type": "string", "minLength": 1 },
              "observed_delta": { "type": "number" },
              "noninferiority_margin": { "type": "number", "minimum": 0 },
              "passed": { "type": "boolean" }
            }
          }
        },
        "frozen_eval_sha256": { "$ref": "#/$defs/sha256" },
        "issued_at": { "$ref": "#/$defs/timestamp" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}

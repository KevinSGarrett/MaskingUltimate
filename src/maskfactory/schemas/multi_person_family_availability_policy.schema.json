{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/multi_person_family_availability_policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_id", "eligible_registry_lifecycles", "eligible_runtime_statuses", "families", "sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "policy_id": {"const": "multi_person_family_availability_v1"},
    "eligible_registry_lifecycles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["installed", "benchmarked", "promoted"]}
    },
    "eligible_runtime_statuses": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"const": "live_smoke_passed"}
    },
    "families": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deterministic_repair", "fusion", "geometry", "pose", "rf_detr_detection", "sam21_refinement", "sam31_exhaustive_discovery", "sam31_refinement", "silhouette", "specialist"],
      "properties": {
        "deterministic_repair": {"$ref": "#/$defs/family"},
        "fusion": {"$ref": "#/$defs/family"},
        "geometry": {"$ref": "#/$defs/family"},
        "pose": {"$ref": "#/$defs/family"},
        "rf_detr_detection": {"$ref": "#/$defs/family"},
        "sam21_refinement": {"$ref": "#/$defs/family"},
        "sam31_exhaustive_discovery": {"$ref": "#/$defs/family"},
        "sam31_refinement": {"$ref": "#/$defs/family"},
        "silhouette": {"$ref": "#/$defs/family"},
        "specialist": {"$ref": "#/$defs/family"}
      }
    },
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "$defs": {
    "family": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clauses"],
      "properties": {
        "clauses": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/clause"}
        }
      }
    },
    "clause": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_kind", "keys"],
      "properties": {
        "source_kind": {"enum": ["internal_all", "registry_any", "runtime_any"]},
        "keys": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/multi_person_lifecycle_route.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "evaluated_at", "image_id", "source_image_sha256",
    "instance_context", "pipeline_fingerprint", "execution_report_sha256",
    "revocation_snapshot", "selected_for_audit", "image_truth_partition",
    "instance_truth_partitions", "target_count", "served_target_count",
    "residual_target_count", "audit_target_count", "targets",
    "measurement_binding", "authority", "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "evaluated_at": {"type": "string", "format": "date-time"},
    "image_id": {"type": "string", "pattern": "^img_[0-9a-f]{12}$"},
    "source_image_sha256": {"$ref": "#/$defs/sha256"},
    "instance_context": {"enum": ["duo", "small_group"]},
    "pipeline_fingerprint": {"type": "string", "minLength": 1},
    "execution_report_sha256": {"$ref": "#/$defs/sha256"},
    "revocation_snapshot": {"$ref": "#/$defs/revocation_snapshot"},
    "selected_for_audit": {"type": "boolean"},
    "image_truth_partition": {"enum": ["train", "residual"]},
    "instance_truth_partitions": {
      "type": "object",
      "minProperties": 2,
      "propertyNames": {"pattern": "^p[0-9]+$"},
      "additionalProperties": {"enum": ["train", "residual"]}
    },
    "target_count": {"type": "integer", "minimum": 2},
    "served_target_count": {"type": "integer", "minimum": 0},
    "residual_target_count": {"type": "integer", "minimum": 0},
    "audit_target_count": {"type": "integer", "minimum": 0},
    "targets": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/target"}},
    "measurement_binding": {"$ref": "#/$defs/measurement_binding"},
    "authority": {"const": "multi_person_lifecycle_routing_evidence_only_no_serving_publication_training_audit_gold_or_completion_authority"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "nullable_sha256": {
      "anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
    },
    "revocation_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root_exists", "files", "sha256"],
      "properties": {
        "root_exists": {"type": "boolean"},
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": {"type": "string", "minLength": 1},
              "sha256": {"$ref": "#/$defs/sha256"}
            }
          }
        },
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "serving_status", "truth_tier", "historical_truth_tier", "authoritative_human_gold", "certificate", "routing"],
      "properties": {
        "schema_version": {"const": "1.0.0"},
        "serving_status": {"enum": ["certified_output", "withheld_for_residual_review", "withheld_for_preselected_audit"]},
        "truth_tier": {"enum": ["autonomous_certified_gold", "machine_candidate"]},
        "historical_truth_tier": {"enum": ["autonomous_certified_gold", "machine_candidate", "weighted_pseudo_label", "human_anchor_gold"]},
        "authoritative_human_gold": {"const": false},
        "certificate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "reason", "sha256", "scope"],
          "properties": {
            "status": {"enum": ["valid", "invalid"]},
            "reason": {"type": "string", "minLength": 1},
            "sha256": {"$ref": "#/$defs/nullable_sha256"},
            "scope": {
              "anyOf": [
                {"type": "null"},
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["risk_bucket", "covered_labels", "covered_contexts", "pipeline_fingerprint"],
                  "properties": {
                    "risk_bucket": {"type": "string", "minLength": 1},
                    "covered_labels": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
                    "covered_contexts": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
                    "pipeline_fingerprint": {"type": "string", "minLength": 1}
                  }
                }
              ]
            }
          }
        },
        "routing": {
          "type": "object",
          "additionalProperties": false,
          "required": ["destination", "residual_reason", "audit_reason"],
          "properties": {
            "destination": {"enum": ["served_without_routine_review", "cvat_residual_review", "cvat_preselected_audit"]},
            "residual_reason": {"type": ["string", "null"]},
            "audit_reason": {"type": ["string", "null"]}
          }
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "person_id", "instance_id", "label", "promoted_instance_id",
        "lifecycle_file_sha256", "lifecycle_document_sha256",
        "certificate_document_sha256", "certificate_claimed_sha256",
        "tournament_status", "route", "route_sha256"
      ],
      "properties": {
        "person_id": {"type": "string", "minLength": 1},
        "instance_id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "promoted_instance_id": {"type": "string", "pattern": "^p[0-9]+$"},
        "lifecycle_file_sha256": {"$ref": "#/$defs/sha256"},
        "lifecycle_document_sha256": {"$ref": "#/$defs/sha256"},
        "certificate_document_sha256": {"$ref": "#/$defs/nullable_sha256"},
        "certificate_claimed_sha256": {"$ref": "#/$defs/nullable_sha256"},
        "tournament_status": {"enum": ["residual_human_queue", "machine_verified_candidate", "calibrated_auto_accepted"]},
        "route": {"$ref": "#/$defs/route"},
        "route_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "measurement_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_image_sha256", "execution_report_sha256", "target_route_sha256s", "preselected_audit", "authority"],
      "properties": {
        "source_image_sha256": {"$ref": "#/$defs/sha256"},
        "execution_report_sha256": {"$ref": "#/$defs/sha256"},
        "target_route_sha256s": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/sha256"}},
        "preselected_audit": {"type": "boolean"},
        "authority": {"const": "receipt_identity_only_no_headline_metric_or_performance_authority"}
      }
    }
  }
}

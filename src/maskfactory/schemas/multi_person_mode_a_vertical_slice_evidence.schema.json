{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/multi_person_mode_a_vertical_slice_evidence.schema.json",
  "title": "Multi-person Mode A vertical slice producer evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "decided_at",
    "policy_id",
    "policy_sha256",
    "fixture_truth_tier",
    "status",
    "rejection_reasons",
    "package_fixture",
    "person_reads",
    "ownership_evidence",
    "multi_person_gate",
    "seeded_faults",
    "ambiguity_verdict",
    "external_probe",
    "claim_boundary",
    "decision_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "multi_person_mode_a_vertical_slice_evidence" },
    "decided_at": { "type": "string", "minLength": 1 },
    "policy_id": {
      "const": "maskfactory-bridge-multi-person-mode-a-vertical-slice-v1"
    },
    "policy_sha256": { "$ref": "#/$defs/sha256" },
    "fixture_truth_tier": { "const": "synthetic_contract_fixture" },
    "status": { "enum": ["accepted", "rejected", "producer_partial"] },
    "rejection_reasons": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "package_fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_id",
        "instance_context",
        "relationship_kind",
        "source_encoded_sha256",
        "source_decoded_pixel_sha256",
        "persons",
        "distinct_character_instances",
        "catalog_sha256"
      ],
      "properties": {
        "image_id": { "type": "string", "minLength": 1 },
        "instance_context": { "const": "duo" },
        "relationship_kind": { "const": "contact" },
        "source_encoded_sha256": { "$ref": "#/$defs/sha256" },
        "source_decoded_pixel_sha256": { "$ref": "#/$defs/sha256" },
        "persons": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "$ref": "#/$defs/person_fixture" }
        },
        "distinct_character_instances": { "const": true },
        "catalog_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "person_reads": {
      "type": "object",
      "additionalProperties": false,
      "required": ["p0", "p1", "both_accepted", "distinct_package_ids"],
      "properties": {
        "p0": { "$ref": "#/$defs/person_read_summary" },
        "p1": { "$ref": "#/$defs/person_read_summary" },
        "both_accepted": { "type": "boolean" },
        "distinct_package_ids": { "type": "boolean" }
      }
    },
    "ownership_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ownership_masks_bound",
        "skeleton_catalog_bound",
        "protected_regions_bound",
        "transform_chains_bound",
        "ownership_mask_sha256s",
        "skeleton_sha256s",
        "protected_region_count",
        "transform_chain_sha256s"
      ],
      "properties": {
        "ownership_masks_bound": { "type": "boolean" },
        "skeleton_catalog_bound": { "type": "boolean" },
        "protected_regions_bound": { "type": "boolean" },
        "transform_chains_bound": { "type": "boolean" },
        "ownership_mask_sha256s": {
          "type": "object",
          "additionalProperties": false,
          "required": ["p0", "p1"],
          "properties": {
            "p0": { "$ref": "#/$defs/sha256" },
            "p1": { "$ref": "#/$defs/sha256" }
          }
        },
        "skeleton_sha256s": {
          "type": "object",
          "additionalProperties": false,
          "required": ["p0", "p1"],
          "properties": {
            "p0": { "$ref": "#/$defs/sha256" },
            "p1": { "$ref": "#/$defs/sha256" }
          }
        },
        "protected_region_count": { "type": "integer", "minimum": 2 },
        "transform_chain_sha256s": {
          "type": "object",
          "additionalProperties": false,
          "required": ["p0", "p1"],
          "properties": {
            "p0": { "$ref": "#/$defs/sha256" },
            "p1": { "$ref": "#/$defs/sha256" }
          }
        }
      }
    },
    "multi_person_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instance_context",
        "promoted_instances",
        "passed",
        "blockers",
        "gate_sha256"
      ],
      "properties": {
        "instance_context": { "const": "duo" },
        "promoted_instances": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "enum": ["p0", "p1"] }
        },
        "passed": { "type": "boolean" },
        "blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "gate_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "seeded_faults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wrong_person", "cross_instance"],
      "properties": {
        "wrong_person": { "$ref": "#/$defs/seeded_fault" },
        "cross_instance": { "$ref": "#/$defs/seeded_fault" }
      }
    },
    "ambiguity_verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zero_ownership_ambiguity",
        "cross_instance_bleed_absent",
        "protected_region_violation_absent",
        "reciprocal_contact_present",
        "verdict_sha256"
      ],
      "properties": {
        "zero_ownership_ambiguity": { "type": "boolean" },
        "cross_instance_bleed_absent": { "type": "boolean" },
        "protected_region_violation_absent": { "type": "boolean" },
        "reciprocal_contact_present": { "type": "boolean" },
        "verdict_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "external_probe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adopted_package_transaction",
        "main_adapter_execution",
        "downstream_comfyui_result_history"
      ],
      "properties": {
        "adopted_package_transaction": { "type": "boolean" },
        "main_adapter_execution": { "type": "boolean" },
        "downstream_comfyui_result_history": { "type": "boolean" },
        "authority_kind": {
          "type": ["string", "null"],
          "enum": [null, "fixture_authority"]
        },
        "detail": { "type": "string" }
      }
    },
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_fixture_slice_complete",
        "mf_p6_12_02_prerequisite_complete",
        "main_adapter_execution_complete",
        "mf_p6_12_03_complete",
        "fixture_main_bound",
        "independent_real_accuracy_claim"
      ],
      "properties": {
        "producer_fixture_slice_complete": { "type": "boolean" },
        "mf_p6_12_02_prerequisite_complete": { "const": false },
        "main_adapter_execution_complete": { "const": false },
        "mf_p6_12_03_complete": { "const": false },
        "fixture_main_bound": { "type": "boolean" },
        "independent_real_accuracy_claim": { "const": false },
        "notes": { "type": "string" }
      }
    },
    "decision_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "person_fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "person_index",
        "instance_id",
        "owner_id",
        "scene_instance_id",
        "character_revision",
        "character_instance_id",
        "label",
        "package_id",
        "ownership_mask_sha256",
        "skeleton_sha256",
        "transform_chain_sha256",
        "protected_region_id"
      ],
      "properties": {
        "person_index": { "type": "integer", "minimum": 0, "maximum": 1 },
        "instance_id": { "enum": ["p0", "p1"] },
        "owner_id": { "type": "string", "minLength": 1 },
        "scene_instance_id": { "type": "string", "minLength": 1 },
        "character_revision": { "type": "string", "minLength": 1 },
        "character_instance_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "package_id": { "type": "string", "minLength": 1 },
        "ownership_mask_sha256": { "$ref": "#/$defs/sha256" },
        "skeleton_sha256": { "$ref": "#/$defs/sha256" },
        "transform_chain_sha256": { "$ref": "#/$defs/sha256" },
        "protected_region_id": { "type": "string", "minLength": 1 }
      }
    },
    "person_read_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "person_index",
        "owner_id",
        "scene_instance_id",
        "character_revision",
        "package_id",
        "decision_sha256",
        "transform_roundtrip_passed"
      ],
      "properties": {
        "status": { "enum": ["accepted", "rejected"] },
        "person_index": { "type": "integer", "minimum": 0, "maximum": 1 },
        "owner_id": { "type": ["string", "null"] },
        "scene_instance_id": { "type": ["string", "null"] },
        "character_revision": { "type": ["string", "null"] },
        "package_id": { "type": ["string", "null"] },
        "decision_sha256": { "$ref": "#/$defs/sha256" },
        "transform_roundtrip_passed": { "type": ["boolean", "null"] }
      }
    },
    "seeded_fault": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "injected",
        "rejected",
        "blocking_reason_codes",
        "decision_sha256"
      ],
      "properties": {
        "injected": { "const": true },
        "rejected": { "type": "boolean" },
        "blocking_reason_codes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "decision_sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}

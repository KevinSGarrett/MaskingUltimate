{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/multi_person_static_contracts_report.schema.json",
  "title": "MaskFactory multi-person STATIC contracts report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "proof_tier",
    "authority",
    "checked_at",
    "seeded_gate_blocks",
    "seeded_routing_checks",
    "checks",
    "mf_p8_11_07_demo_complete",
    "kevin_multi_person_sources_required",
    "real_10_20_image_demo_claimed",
    "doctor_green_claimed",
    "gold_claimed",
    "visual_qa_pass_claimed",
    "main_complete_claimed",
    "production_evidence_pass_claimed",
    "honest_non_claims",
    "report_id",
    "seal_sha256",
    "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "multi_person_static_contracts_report"},
    "proof_tier": {"const": "STATIC_PASS"},
    "authority": {
      "const": "multi_person_static_contracts_only_no_real_demo_kevin_sources_or_production_authority"
    },
    "checked_at": {"type": "string", "minLength": 1},
    "seeded_gate_blocks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exclusivity_qc035",
        "bleed_qc036",
        "identity_containment_aut_mp_001",
        "contact_reciprocity_aut_mp_002_003"
      ],
      "properties": {
        "exclusivity_qc035": {"const": true},
        "bleed_qc036": {"const": true},
        "identity_containment_aut_mp_001": {"const": true},
        "contact_reciprocity_aut_mp_002_003": {"const": true}
      }
    },
    "seeded_routing_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failed_gate_routes_residual",
        "mixed_certified_residual_one_truth_partition",
        "certified_duo_serves_without_routine_review"
      ],
      "properties": {
        "failed_gate_routes_residual": {"const": true},
        "mixed_certified_residual_one_truth_partition": {"const": true},
        "certified_duo_serves_without_routine_review": {"const": true}
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exclusivity_bleed_identity_contact_gates",
        "residual_routing_and_split_integrity"
      ],
      "properties": {
        "exclusivity_bleed_identity_contact_gates": {"const": "pass"},
        "residual_routing_and_split_integrity": {"const": "pass"}
      }
    },
    "mf_p8_11_07_demo_complete": {"const": false},
    "kevin_multi_person_sources_required": {"const": true},
    "real_10_20_image_demo_claimed": {"const": false},
    "doctor_green_claimed": {"const": false},
    "gold_claimed": {"const": false},
    "visual_qa_pass_claimed": {"const": false},
    "main_complete_claimed": {"const": false},
    "production_evidence_pass_claimed": {"const": false},
    "honest_non_claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "report_id": {"type": "string", "pattern": "^mpsc_[a-f0-9]{24}$"},
    "seal_sha256": {"$ref": "#/$defs/sha256"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/pose_variant_benchmark_cases.schema.json",
  "title": "Pose-variant benchmark observations",
  "type": "object", "additionalProperties": false,
  "required": [
    "schema_version", "benchmark_id", "results_opened_at", "policy_sha256",
    "truth_tier", "truth_partition", "truth_manifest_sha256",
    "pipeline_fingerprint_sha256", "hardware_fingerprint_sha256",
    "providers", "fallback_drills", "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "benchmark_id": {"type": "string", "minLength": 1},
    "results_opened_at": {"type": "string", "format": "date-time"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "truth_tier": {"const": "human_anchor_gold"},
    "truth_partition": {"const": "holdout"},
    "truth_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "pipeline_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
    "hardware_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
    "providers": {
      "type": "object", "additionalProperties": false,
      "required": ["dwpose_133", "rtmw_x", "rtmo_crowd"],
      "properties": {
        "dwpose_133": {"$ref": "#/$defs/providerEvidence"},
        "rtmw_x": {"$ref": "#/$defs/providerEvidence"},
        "rtmo_crowd": {"$ref": "#/$defs/providerEvidence"}
      }
    },
    "fallback_drills": {
      "type": "array", "minItems": 2, "maxItems": 2,
      "items": {"$ref": "#/$defs/fallback"}
    },
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "context": {"enum": ["whole_body", "hands", "feet", "rear", "contact", "occlusion", "crowded_scene"]},
    "observation": {
      "type": "object", "additionalProperties": false,
      "required": ["context", "joint", "visible_count", "correct_pck_005_count", "correct_pck_010_count", "normalized_error_sum"],
      "properties": {
        "context": {"$ref": "#/$defs/context"},
        "joint": {"type": "string", "minLength": 1},
        "visible_count": {"type": "integer", "minimum": 0},
        "correct_pck_005_count": {"type": "integer", "minimum": 0},
        "correct_pck_010_count": {"type": "integer", "minimum": 0},
        "normalized_error_sum": {"type": "number", "minimum": 0}
      }
    },
    "countMetric": {
      "type": "object", "additionalProperties": false,
      "required": ["context", "eligible_count", "correct_count", "error_count"],
      "properties": {
        "context": {"$ref": "#/$defs/context"},
        "eligible_count": {"type": "integer", "minimum": 0},
        "correct_count": {"type": "integer", "minimum": 0},
        "error_count": {"type": "integer", "minimum": 0}
      }
    },
    "runtime": {
      "type": "object", "additionalProperties": false,
      "required": ["cold_latency_ms", "warm_latency_ms", "peak_vram_bytes", "oom_count", "crash_count", "repeat_count", "deterministic_output_sha256"],
      "properties": {
        "cold_latency_ms": {"type": "number", "minimum": 0},
        "warm_latency_ms": {"type": "number", "minimum": 0},
        "peak_vram_bytes": {"type": "integer", "minimum": 0},
        "oom_count": {"type": "integer", "minimum": 0},
        "crash_count": {"type": "integer", "minimum": 0},
        "repeat_count": {"type": "integer", "minimum": 1},
        "deterministic_output_sha256": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/sha256"}}
      }
    },
    "providerEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_hashes", "runtime_fingerprint", "observations", "side_metrics", "identity_metrics", "runtime_metrics"],
      "properties": {
        "artifact_hashes": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/sha256"}},
        "runtime_fingerprint": {"type": "string", "minLength": 1},
        "observations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/observation"}},
        "side_metrics": {"type": "array", "minItems": 7, "maxItems": 7, "items": {"$ref": "#/$defs/countMetric"}},
        "identity_metrics": {"type": "array", "minItems": 7, "maxItems": 7, "items": {"$ref": "#/$defs/countMetric"}},
        "runtime_metrics": {"$ref": "#/$defs/runtime"}
      }
    },
    "fallback": {
      "type": "object", "additionalProperties": false,
      "required": ["challenger", "injected_failure", "expected_provider", "observed_provider", "output_sha256", "active_provider_after", "rollback_provider_after"],
      "properties": {
        "challenger": {"enum": ["rtmw_x", "rtmo_crowd"]},
        "injected_failure": {"type": "string", "minLength": 1},
        "expected_provider": {"const": "dwpose_133"},
        "observed_provider": {"type": "string", "minLength": 1},
        "output_sha256": {"$ref": "#/$defs/sha256"},
        "active_provider_after": {"type": "string", "minLength": 1},
        "rollback_provider_after": {"type": "string", "minLength": 1}
      }
    }
  }
}

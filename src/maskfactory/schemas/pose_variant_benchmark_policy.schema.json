{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/pose_variant_benchmark_policy.schema.json",
  "title": "Frozen pose-variant benchmark policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "policy_id", "frozen_at", "eligible_truth",
    "required_contexts", "normalization", "providers", "comparison_roles", "comparison_joint_rule",
    "pass_requirements", "source_hashes", "authority_boundary", "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "policy_id": {"const": "pose_variant_benchmark_v1"},
    "frozen_at": {"type": "string", "format": "date-time"},
    "eligible_truth": {
      "type": "object", "additionalProperties": false,
      "required": ["tier", "partition"],
      "properties": {
        "tier": {"const": "human_anchor_gold"},
        "partition": {"const": "holdout"}
      }
    },
    "required_contexts": {
      "const": ["whole_body", "hands", "feet", "rear", "contact", "occlusion", "crowded_scene"]
    },
    "normalization": {
      "type": "object", "additionalProperties": false,
      "required": ["distance", "pck_thresholds", "side_semantics"],
      "properties": {
        "distance": {"const": "euclidean_pixels_over_truth_person_bbox_diagonal"},
        "pck_thresholds": {"const": [0.05, 0.1]},
        "side_semantics": {"const": "character_anatomical_left_right"}
      }
    },
    "providers": {
      "type": "object", "additionalProperties": false,
      "required": ["dwpose_133", "rtmw_x", "rtmo_crowd"],
      "properties": {
        "dwpose_133": {"$ref": "#/$defs/provider"},
        "rtmw_x": {"$ref": "#/$defs/provider"},
        "rtmo_crowd": {"$ref": "#/$defs/provider"}
      }
    },
    "comparison_roles": {
      "type": "object", "additionalProperties": false,
      "required": ["rtmw_x", "rtmo_crowd"],
      "properties": {
        "rtmw_x": {"const": ["whole_body", "hands", "feet", "rear", "contact", "occlusion", "crowded_scene"]},
        "rtmo_crowd": {"const": ["crowded_scene"]}
      }
    },
    "comparison_joint_rule": {"const": "exact_name_intersection_only"},
    "pass_requirements": {
      "type": "object", "additionalProperties": false,
      "required": [
        "max_pck_010_drop", "max_wrong_side_rate_delta", "max_cross_person_rate_delta",
        "max_oom_or_crash_count", "require_deterministic_repeats", "require_fallback_to"
      ],
      "properties": {
        "max_pck_010_drop": {"const": 0.02},
        "max_wrong_side_rate_delta": {"const": 0.0},
        "max_cross_person_rate_delta": {"const": 0.0},
        "max_oom_or_crash_count": {"const": 0},
        "require_deterministic_repeats": {"const": 2},
        "require_fallback_to": {"const": "dwpose_133"}
      }
    },
    "source_hashes": {
      "type": "object", "minProperties": 1,
      "additionalProperties": {"$ref": "#/$defs/sha256"}
    },
    "authority_boundary": {"type": "string", "minLength": 1},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "provider": {
      "type": "object", "additionalProperties": false,
      "required": ["role", "model_family", "joint_vocabulary", "artifact_hashes", "runtime_fingerprint", "authority"],
      "properties": {
        "role": {"enum": ["incumbent_rollback", "wholebody_challenger", "crowd_challenger"]},
        "model_family": {"type": "string", "minLength": 1},
        "joint_vocabulary": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "artifact_hashes": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/sha256"}},
        "runtime_fingerprint": {"type": "string", "minLength": 1},
        "authority": {"enum": ["active_and_rollback", "installed_shadow_only"]}
      }
    }
  }
}

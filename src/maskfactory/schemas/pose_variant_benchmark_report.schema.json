{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/pose_variant_benchmark_report.schema.json",
  "title": "Recomputed pose-variant benchmark report",
  "type": "object", "additionalProperties": false,
  "required": [
    "schema_version", "benchmark_id", "evaluated_at", "policy_sha256",
    "source_cases_sha256", "truth_manifest_sha256", "pipeline_fingerprint_sha256",
    "hardware_fingerprint_sha256", "providers", "comparisons", "fallback_drills",
    "findings", "result", "authority", "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "benchmark_id": {"type": "string", "minLength": 1},
    "evaluated_at": {"type": "string", "format": "date-time"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "source_cases_sha256": {"$ref": "#/$defs/sha256"},
    "truth_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "pipeline_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
    "hardware_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
    "providers": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/providerReport"}},
    "comparisons": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/comparison"}},
    "fallback_drills": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "object"}},
    "findings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "result": {"enum": ["pass", "fail"]},
    "authority": {"const": "benchmark_evidence_only_no_gold_or_production_authority"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "aggregate": {
      "type": "object",
      "required": ["visible_count", "correct_pck_005_count", "correct_pck_010_count", "normalized_error_sum", "pck_005", "pck_010", "mean_normalized_error"],
      "properties": {
        "visible_count": {"type": "integer", "minimum": 0},
        "correct_pck_005_count": {"type": "integer", "minimum": 0},
        "correct_pck_010_count": {"type": "integer", "minimum": 0},
        "normalized_error_sum": {"type": "number", "minimum": 0},
        "pck_005": {"type": "number", "minimum": 0, "maximum": 1},
        "pck_010": {"type": "number", "minimum": 0, "maximum": 1},
        "mean_normalized_error": {"type": "number", "minimum": 0}
      }
    },
    "jointMetric": {
      "allOf": [
        {"$ref": "#/$defs/aggregate"},
        {"type": "object", "required": ["joint"], "properties": {"joint": {"type": "string", "minLength": 1}}}
      ]
    },
    "contextMetric": {
      "allOf": [
        {"$ref": "#/$defs/aggregate"},
        {"type": "object", "required": ["context", "side_eligible_count", "side_correct_count", "wrong_side_count", "wrong_side_rate", "identity_eligible_count", "identity_correct_count", "cross_person_count", "cross_person_rate"],
         "properties": {
           "context": {"type": "string"},
           "side_eligible_count": {"type": "integer", "minimum": 0},
           "side_correct_count": {"type": "integer", "minimum": 0},
           "wrong_side_count": {"type": "integer", "minimum": 0},
           "wrong_side_rate": {"type": "number", "minimum": 0, "maximum": 1},
           "identity_eligible_count": {"type": "integer", "minimum": 0},
           "identity_correct_count": {"type": "integer", "minimum": 0},
           "cross_person_count": {"type": "integer", "minimum": 0},
           "cross_person_rate": {"type": "number", "minimum": 0, "maximum": 1}
         }}
      ]
    },
    "providerReport": {
      "type": "object", "additionalProperties": false,
      "required": ["provider", "joint_vocabulary", "joint_metrics", "context_metrics", "overall_metrics", "runtime_metrics"],
      "properties": {
        "provider": {"enum": ["dwpose_133", "rtmw_x", "rtmo_crowd"]},
        "joint_vocabulary": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "joint_metrics": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/jointMetric"}},
        "context_metrics": {"type": "array", "minItems": 7, "maxItems": 7, "items": {"$ref": "#/$defs/contextMetric"}},
        "overall_metrics": {"$ref": "#/$defs/aggregate"},
        "runtime_metrics": {"type": "object"}
      }
    },
    "comparison": {
      "type": "object", "additionalProperties": false,
      "required": ["challenger", "contexts", "joint_intersection_count", "challenger_visible_count", "baseline_visible_count", "challenger_pck_010", "baseline_pck_010", "pck_010_delta", "wrong_side_rate_delta", "cross_person_rate_delta", "findings", "result"],
      "properties": {
        "challenger": {"enum": ["rtmw_x", "rtmo_crowd"]},
        "contexts": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "joint_intersection_count": {"type": "integer", "minimum": 1},
        "challenger_visible_count": {"type": "integer", "minimum": 0},
        "baseline_visible_count": {"type": "integer", "minimum": 0},
        "challenger_pck_010": {"type": "number", "minimum": 0, "maximum": 1},
        "baseline_pck_010": {"type": "number", "minimum": 0, "maximum": 1},
        "pck_010_delta": {"type": "number", "minimum": -1, "maximum": 1},
        "wrong_side_rate_delta": {"type": "number", "minimum": -1, "maximum": 1},
        "cross_person_rate_delta": {"type": "number", "minimum": -1, "maximum": 1},
        "findings": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "result": {"enum": ["pass", "fail"]}
      }
    }
  }
}

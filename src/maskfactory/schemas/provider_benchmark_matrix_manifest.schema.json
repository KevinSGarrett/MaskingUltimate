{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/provider_benchmark_matrix_manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "matrix_id", "opened_at", "policy_sha256", "authority", "shared_identity", "screening_cells", "finalist_selection", "enrichment_cells", "sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "matrix_id": {"const": "provider_benchmark_matrix_v1"},
    "opened_at": {"type": "string", "format": "date-time"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "authority": {"const": "immutable_matrix_identity_only_no_metric_result_or_authority"},
    "shared_identity": {"$ref": "#/$defs/sharedIdentity"},
    "screening_cells": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"type": "object"}},
    "finalist_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["screening_result_sha256", "selected_routes"],
      "properties": {
        "screening_result_sha256": {"$ref": "#/$defs/sha256"},
        "selected_routes": {"type": "array", "minItems": 1, "maxItems": 6, "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "enrichment_cells": {"type": "array", "minItems": 60, "items": {"type": "object"}},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "sharedIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["truth_tier", "truth_partition", "image_disjoint", "evaluation_set_sha256", "prompt_set_sha256", "part_set_sha256", "hardware_profile_sha256", "qa_sha256", "pipeline_sha256", "ontology_sha256", "measurement_bundle_sha256", "provider_artifact_sha256"],
      "properties": {
        "truth_tier": {"type": "string"},
        "truth_partition": {"type": "string"},
        "image_disjoint": {"type": "boolean"},
        "evaluation_set_sha256": {"$ref": "#/$defs/sha256"},
        "prompt_set_sha256": {"$ref": "#/$defs/sha256"},
        "part_set_sha256": {"$ref": "#/$defs/sha256"},
        "hardware_profile_sha256": {"$ref": "#/$defs/sha256"},
        "qa_sha256": {"$ref": "#/$defs/sha256"},
        "pipeline_sha256": {"$ref": "#/$defs/sha256"},
        "ontology_sha256": {"$ref": "#/$defs/sha256"},
        "measurement_bundle_sha256": {"$ref": "#/$defs/sha256"},
        "provider_artifact_sha256": {"type": "object", "minProperties": 14, "maxProperties": 14, "additionalProperties": {"$ref": "#/$defs/sha256"}}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/provider_benchmark_matrix_observations.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "matrix_id", "results_opened_at", "policy_sha256", "manifest_sha256", "cells", "sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "matrix_id": {"const": "provider_benchmark_matrix_v1"},
    "results_opened_at": {"type": "string", "format": "date-time"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "manifest_sha256": {"$ref": "#/$defs/sha256"},
    "cells": {"type": "array", "minItems": 66, "items": {"$ref": "#/$defs/cell"}},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "label": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "truth_pixels", "predicted_pixels", "intersection_pixels", "union_pixels", "boundary_tp", "boundary_fp", "boundary_fn"],
      "properties": {
        "name": {"type": "string"},
        "truth_pixels": {"type": "integer", "minimum": 1},
        "predicted_pixels": {"type": "integer", "minimum": 0},
        "intersection_pixels": {"type": "integer", "minimum": 0},
        "union_pixels": {"type": "integer", "minimum": 1},
        "boundary_tp": {"type": "integer", "minimum": 0},
        "boundary_fp": {"type": "integer", "minimum": 0},
        "boundary_fn": {"type": "integer", "minimum": 0}
      }
    },
    "cell": {
      "type": "object", "additionalProperties": false,
      "required": ["cell_id", "cell_identity_sha256", "label_observations", "aggregate_counts", "artifact_hashes", "observations_sha256"],
      "properties": {
        "cell_id": {"type": "string"},
        "cell_identity_sha256": {"$ref": "#/$defs/sha256"},
        "label_observations": {"type": "array", "minItems": 66, "maxItems": 66, "items": {"$ref": "#/$defs/label"}},
        "aggregate_counts": {"type": "object"},
        "artifact_hashes": {"type": "object", "minProperties": 4, "maxProperties": 4, "additionalProperties": {"$ref": "#/$defs/sha256"}},
        "observations_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}

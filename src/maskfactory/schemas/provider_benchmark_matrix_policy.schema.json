{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/provider_benchmark_matrix_policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_id", "frozen_at", "authority", "truth_contract", "screening_routes", "finalist_contract", "enrichment_dimensions", "required_provider_artifact_keys", "required_measurements", "source_hashes", "sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "policy_id": {"const": "provider_benchmark_matrix_v1"},
    "frozen_at": {"type": "string", "format": "date-time"},
    "authority": {"const": "pre_result_matrix_design_only_no_benchmark_promotion_serving_mask_or_gold_authority"},
    "truth_contract": {"type": "object"},
    "screening_routes": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"type": "object"}},
    "finalist_contract": {"type": "object"},
    "enrichment_dimensions": {"type": "object"},
    "required_provider_artifact_keys": {"type": "array", "minItems": 14, "maxItems": 14, "uniqueItems": true, "items": {"type": "string"}},
    "required_measurements": {"type": "array", "minItems": 19, "uniqueItems": true, "items": {"type": "string"}},
    "source_hashes": {"type": "object", "minProperties": 19, "additionalProperties": {"$ref": "#/$defs/sha256"}},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}

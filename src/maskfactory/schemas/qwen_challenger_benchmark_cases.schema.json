{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/qwen_challenger_benchmark_cases.schema.json",
  "title": "Qwen challenger benchmark observations",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "benchmark_id", "evaluated_at", "policy_sha256", "dataset_manifests", "training_image_ids", "cases", "providers", "rollback_drills", "sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "benchmark_id": {"type": "string", "minLength": 1},
    "evaluated_at": {"type": "string", "format": "date-time"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "dataset_manifests": {
      "type": "object", "additionalProperties": false,
      "required": ["teacher_holdout", "local_40_panel", "incremental_200"],
      "properties": {
        "teacher_holdout": {"$ref": "#/$defs/manifestRef"},
        "local_40_panel": {"$ref": "#/$defs/manifestRef"},
        "incremental_200": {"$ref": "#/$defs/manifestRef"}
      }
    },
    "training_image_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "cases": {"type": "array", "minItems": 241, "items": {"$ref": "#/$defs/case"}},
    "providers": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/provider"}},
    "rollback_drills": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/rollback"}},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "manifestRef": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}}
    },
    "case": {
      "type": "object", "additionalProperties": false,
      "required": ["case_id", "image_id", "dataset", "label", "contexts", "truth_verdict", "severity", "natural_error", "human_anchor_sha256"],
      "properties": {
        "case_id": {"type": "string", "minLength": 1}, "image_id": {"type": "string", "minLength": 1},
        "dataset": {"enum": ["teacher_holdout", "local_40_panel", "incremental_200"]},
        "label": {"type": "string", "minLength": 1},
        "contexts": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "truth_verdict": {"enum": ["pass", "fail"]}, "severity": {"enum": ["none", "minor", "serious"]},
        "natural_error": {"type": "boolean"}, "human_anchor_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "observation": {
      "type": "object", "additionalProperties": false,
      "required": ["case_id", "verdict", "correction_useful", "reviewer_time_sec"],
      "properties": {
        "case_id": {"type": "string", "minLength": 1}, "verdict": {"enum": ["pass", "fail", "uncertain"]},
        "correction_useful": {"type": ["boolean", "null"]}, "reviewer_time_sec": {"type": "number", "minimum": 0}
      }
    },
    "runtime": {
      "type": "object", "additionalProperties": false,
      "required": ["cold_latency_ms", "warm_latency_ms", "peak_vram_bytes", "oom_count", "crash_count", "repeat_count", "deterministic_output_sha256"],
      "properties": {
        "cold_latency_ms": {"type": "number", "minimum": 0}, "warm_latency_ms": {"type": "number", "minimum": 0},
        "peak_vram_bytes": {"type": "integer", "minimum": 0}, "oom_count": {"type": "integer", "minimum": 0},
        "crash_count": {"type": "integer", "minimum": 0}, "repeat_count": {"type": "integer", "minimum": 1},
        "deterministic_output_sha256": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/sha256"}}
      }
    },
    "provider": {
      "type": "object", "additionalProperties": false,
      "required": ["provider", "identity", "observations", "runtime"],
      "properties": {
        "provider": {"enum": ["qwen2_5_vl_7b", "qwen3_vl_4b", "qwen3_vl_8b_quantized"]},
        "identity": {"type": "object"},
        "observations": {"type": "array", "minItems": 241, "items": {"$ref": "#/$defs/observation"}},
        "runtime": {"$ref": "#/$defs/runtime"}
      }
    },
    "rollback": {
      "type": "object", "additionalProperties": false,
      "required": ["challenger", "failure_injected", "incumbent_before", "returned_provider", "incumbent_after", "returned_output_sha256"],
      "properties": {
        "challenger": {"enum": ["qwen3_vl_4b", "qwen3_vl_8b_quantized"]}, "failure_injected": {"const": true},
        "incumbent_before": {"const": "qwen2_5_vl_7b"}, "returned_provider": {"const": "qwen2_5_vl_7b"},
        "incumbent_after": {"const": "qwen2_5_vl_7b"}, "returned_output_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/qwen_challenger_benchmark_policy.schema.json",
  "title": "Frozen Qwen challenger benchmark policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_id", "frozen_at", "eligible_truth", "datasets", "high_risk_contexts", "providers", "challengers", "incumbent", "rollback_provider", "fallback_provider", "generation_options", "provider_identities", "pass_requirements", "source_hashes", "authority", "sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "policy_id": {"const": "qwen_challenger_benchmark_v1"},
    "frozen_at": {"type": "string", "format": "date-time"},
    "eligible_truth": {"const": {"authority": "human_anchor_gold", "partition": "holdout", "image_disjoint": true}},
    "datasets": {"const": ["teacher_holdout", "local_40_panel", "incremental_200"]},
    "high_risk_contexts": {"type": "array", "minItems": 10, "maxItems": 10, "uniqueItems": true, "items": {"type": "string"}},
    "providers": {"const": ["qwen2_5_vl_7b", "qwen3_vl_4b", "qwen3_vl_8b_quantized"]},
    "challengers": {"const": ["qwen3_vl_4b", "qwen3_vl_8b_quantized"]},
    "incumbent": {"const": "qwen2_5_vl_7b"},
    "rollback_provider": {"const": "qwen2_5_vl_7b"},
    "fallback_provider": {"const": "llava_13b"},
    "generation_options": {
      "type": "object", "additionalProperties": false,
      "required": ["temperature", "seed", "num_predict", "num_ctx", "think"],
      "properties": {
        "temperature": {"const": 0}, "seed": {"const": 1337},
        "num_predict": {"const": 192}, "num_ctx": {"const": 4096}, "think": {"const": false}
      }
    },
    "provider_identities": {
      "type": "object", "additionalProperties": false,
      "required": ["qwen2_5_vl_7b", "qwen3_vl_4b", "qwen3_vl_8b_quantized"],
      "properties": {
        "qwen2_5_vl_7b": {"$ref": "#/$defs/identity"},
        "qwen3_vl_4b": {"$ref": "#/$defs/identity"},
        "qwen3_vl_8b_quantized": {"$ref": "#/$defs/identity"}
      }
    },
    "pass_requirements": {
      "type": "object", "additionalProperties": false,
      "required": ["minimum_serious_defect_recall", "minimum_overall_defect_recall", "minimum_precision", "maximum_false_pass_rate", "minimum_correction_usefulness", "minimum_recall_improvement_over_incumbent", "minimum_reviewer_time_reduction_fraction", "maximum_warm_latency_regression_fraction", "maximum_peak_vram_bytes", "required_deterministic_repeats"],
      "properties": {
        "minimum_serious_defect_recall": {"const": 0.95},
        "minimum_overall_defect_recall": {"const": 0.9},
        "minimum_precision": {"const": 0.8},
        "maximum_false_pass_rate": {"const": 0.02},
        "minimum_correction_usefulness": {"const": 0.7},
        "minimum_recall_improvement_over_incumbent": {"const": 0.01},
        "minimum_reviewer_time_reduction_fraction": {"const": 0.05},
        "maximum_warm_latency_regression_fraction": {"const": 0.5},
        "maximum_peak_vram_bytes": {"const": 8589934592},
        "required_deterministic_repeats": {"const": 2}
      }
    },
    "source_hashes": {"type": "object", "minProperties": 10, "maxProperties": 10, "additionalProperties": {"$ref": "#/$defs/sha256"}},
    "authority": {"const": "pre_result_policy_only_no_provider_mask_gold_or_block_clearance_authority"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "identity": {
      "type": "object", "additionalProperties": false,
      "required": ["model", "manifest_sha256", "model_blob_sha256", "source_revision", "prompt_identity_sha256", "runtime_lock_sha256", "candidate_kind"],
      "properties": {
        "model": {"type": "string", "minLength": 1},
        "manifest_sha256": {"$ref": "#/$defs/sha256"},
        "model_blob_sha256": {"$ref": "#/$defs/sha256"},
        "source_revision": {"type": "string", "minLength": 1},
        "prompt_identity_sha256": {"$ref": "#/$defs/sha256"},
        "runtime_lock_sha256": {"$ref": "#/$defs/sha256"},
        "candidate_kind": {"enum": ["incumbent_base_model", "challenger_base_model"]}
      }
    }
  }
}

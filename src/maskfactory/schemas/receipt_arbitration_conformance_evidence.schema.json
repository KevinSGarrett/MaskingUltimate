{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/receipt_arbitration_conformance_evidence.schema.json",
  "title": "Additive Mode A/Mode B receipt arbitration conformance evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "decided_at",
    "policy_id",
    "policy_sha256",
    "comparable_scope_sha256",
    "producer_heads",
    "candidates",
    "eligible_candidate_ids",
    "rejected_candidates",
    "normalized_scores",
    "dominance_eliminations",
    "oracle_decision",
    "main_decision",
    "status",
    "rejection_reasons",
    "decision_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "receipt_arbitration_conformance_evidence" },
    "decided_at": { "type": "string", "format": "date-time" },
    "policy_id": { "type": "string", "minLength": 1 },
    "policy_sha256": { "$ref": "#/$defs/sha256" },
    "comparable_scope_sha256": { "$ref": "#/$defs/sha256" },
    "producer_heads": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_payload_sha256",
        "capability_snapshot_sha256",
        "revocation_index_sha256",
        "ontology_version",
        "required_authority_floor",
        "required_qa_status",
        "max_preservation_risk",
        "max_total_ms",
        "max_peak_vram_mb",
        "max_uncertainty"
      ],
      "properties": {
        "release_payload_sha256": { "$ref": "#/$defs/sha256" },
        "capability_snapshot_sha256": { "$ref": "#/$defs/sha256" },
        "revocation_index_sha256": { "$ref": "#/$defs/sha256" },
        "ontology_version": { "type": "string", "minLength": 1 },
        "required_authority_floor": {
          "enum": ["invalid", "hypothesis", "draft", "qa_passed_noncertified", "certified"]
        },
        "required_qa_status": { "enum": ["pass", "fail", "not_run"] },
        "max_preservation_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "max_total_ms": { "type": "integer", "minimum": 0 },
        "max_peak_vram_mb": { "type": "integer", "minimum": 0 },
        "max_uncertainty": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "receipt_payload_sha256",
          "access_mode",
          "authority_state",
          "comparable_scope_sha256",
          "eligible",
          "ineligibility_reasons"
        ],
        "properties": {
          "candidate_id": { "type": "string", "minLength": 1 },
          "receipt_payload_sha256": { "$ref": "#/$defs/sha256" },
          "access_mode": { "type": "string", "minLength": 1 },
          "authority_state": {
            "enum": ["invalid", "hypothesis", "draft", "qa_passed_noncertified", "certified"]
          },
          "comparable_scope_sha256": { "$ref": "#/$defs/sha256" },
          "eligible": { "type": "boolean" },
          "ineligibility_reasons": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "eligible_candidate_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "rejected_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "reasons"],
        "properties": {
          "candidate_id": { "type": "string", "minLength": 1 },
          "reasons": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "normalized_scores": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "authority",
          "qa",
          "freshness",
          "preservation_safety",
          "cost_efficiency",
          "composite"
        ],
        "properties": {
          "candidate_id": { "type": "string", "minLength": 1 },
          "authority": { "type": "number" },
          "qa": { "type": "number" },
          "freshness": { "type": "number" },
          "preservation_safety": { "type": "number" },
          "cost_efficiency": { "type": "number" },
          "composite": { "type": "number" }
        }
      }
    },
    "dominance_eliminations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "reason"],
        "properties": {
          "candidate_id": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "oracle_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "selected_candidate_ids", "reason_codes"],
      "properties": {
        "outcome": { "enum": ["choose", "branch", "abstain"] },
        "selected_candidate_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "main_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome",
        "selected_candidate_ids",
        "comparable_scope_sha256",
        "receipt_payload_sha256s",
        "policy_sha256",
        "signature_present"
      ],
      "properties": {
        "outcome": {
          "type": ["string", "null"],
          "enum": ["choose", "branch", "abstain", null]
        },
        "selected_candidate_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "comparable_scope_sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "receipt_payload_sha256s": {
          "type": "array",
          "items": { "$ref": "#/$defs/sha256" }
        },
        "policy_sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "signature_present": { "type": "boolean" }
      }
    },
    "status": { "enum": ["accepted", "rejected"] },
    "rejection_reasons": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "decision_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/residual_blocker_inventory_report.schema.json",
  "title": "MaskFactory residual-blocker inventory (post-STATIC wave)",
  "description": "STATIC_PASS inventory of unfinished tracker items that remain non-delegable (Kevin CVAT, AWAITING_MAIN, disk-heavy corpus, live DAZ/GPU). Never completes items or claims production authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "proof_tier",
    "authority",
    "checked_at",
    "tracker_path",
    "unfinished_item_count",
    "residual_class_counts",
    "host_side_static_gaps_remain",
    "scan_basis",
    "items",
    "doctor_green_claimed",
    "gold_claimed",
    "visual_qa_pass_claimed",
    "main_complete_claimed",
    "production_evidence_pass_claimed",
    "any_item_completed_by_this_inventory",
    "honest_non_claims",
    "implementation",
    "report_id",
    "seal_sha256",
    "sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "artifact_type": { "const": "residual_blocker_inventory_report" },
    "proof_tier": { "const": "STATIC_PASS" },
    "authority": {
      "const": "residual_blocker_inventory_static_only_no_item_completion_or_production_authority"
    },
    "checked_at": { "type": "string", "minLength": 1 },
    "tracker_path": { "const": "Plan/Tracker/tracker.json" },
    "unfinished_item_count": { "type": "integer", "minimum": 1 },
    "residual_class_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "NEEDS_KEVIN_CVAT",
        "NEEDS_KEVIN_OTHER",
        "AWAITING_MAIN",
        "DISK_HEAVY_CORPUS",
        "LIVE_DAZ_STUDIO",
        "LIVE_GPU_WSL",
        "HUMAN_ANCHOR_HOLDOUT",
        "DEPENDENCY_ON_NON_DELEGABLE",
        "PROVIDER_PROMOTION_LIVE"
      ],
      "properties": {
        "NEEDS_KEVIN_CVAT": { "type": "integer", "minimum": 0 },
        "NEEDS_KEVIN_OTHER": { "type": "integer", "minimum": 0 },
        "AWAITING_MAIN": { "type": "integer", "minimum": 0 },
        "DISK_HEAVY_CORPUS": { "type": "integer", "minimum": 0 },
        "LIVE_DAZ_STUDIO": { "type": "integer", "minimum": 0 },
        "LIVE_GPU_WSL": { "type": "integer", "minimum": 0 },
        "HUMAN_ANCHOR_HOLDOUT": { "type": "integer", "minimum": 0 },
        "DEPENDENCY_ON_NON_DELEGABLE": { "type": "integer", "minimum": 0 },
        "PROVIDER_PROMOTION_LIVE": { "type": "integer", "minimum": 0 }
      }
    },
    "host_side_static_gaps_remain": { "const": false },
    "scan_basis": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "phase",
          "status",
          "percent_complete",
          "hard_blocker",
          "residual_class",
          "why_non_delegable",
          "blocked_reason",
          "description"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "phase": { "type": ["string", "null"] },
          "status": {
            "type": "string",
            "enum": ["open", "in_progress", "partially_complete", "blocked", "failed"]
          },
          "percent_complete": { "type": "integer", "minimum": 0, "maximum": 100 },
          "hard_blocker": { "type": "boolean" },
          "residual_class": {
            "type": "string",
            "enum": [
              "NEEDS_KEVIN_CVAT",
              "NEEDS_KEVIN_OTHER",
              "AWAITING_MAIN",
              "DISK_HEAVY_CORPUS",
              "LIVE_DAZ_STUDIO",
              "LIVE_GPU_WSL",
              "HUMAN_ANCHOR_HOLDOUT",
              "DEPENDENCY_ON_NON_DELEGABLE",
              "PROVIDER_PROMOTION_LIVE"
            ]
          },
          "why_non_delegable": { "type": "string", "minLength": 1 },
          "blocked_reason": { "type": ["string", "null"] },
          "description": { "type": "string" }
        }
      }
    },
    "doctor_green_claimed": { "const": false },
    "gold_claimed": { "const": false },
    "visual_qa_pass_claimed": { "const": false },
    "main_complete_claimed": { "const": false },
    "production_evidence_pass_claimed": { "const": false },
    "any_item_completed_by_this_inventory": { "const": false },
    "honest_non_claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module", "tests", "related_static_seal"],
      "properties": {
        "module": { "type": "string", "minLength": 1 },
        "tests": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "related_static_seal": { "type": "string", "minLength": 1 }
      }
    },
    "report_id": { "type": "string", "pattern": "^rbi_[a-f0-9]{24}$" },
    "seal_sha256": { "$ref": "#/$defs/sha256" },
    "sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}

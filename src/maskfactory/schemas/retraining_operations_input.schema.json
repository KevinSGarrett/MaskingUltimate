{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/retraining_operations_input.schema.json",
  "title": "MaskFactory retraining operations input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "operation_id", "observed_at", "policy_sha256", "trigger",
    "fingerprints", "training_run", "evidence_decisions", "affected_strata",
    "role_decision", "promotion_transaction", "rollback_drill", "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "operation_id": {"type": "string", "minLength": 1},
    "observed_at": {"type": "string", "format": "date-time"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "trigger": {"type": "object"},
    "fingerprints": {"type": "object"},
    "training_run": {"type": "object"},
    "evidence_decisions": {"type": "array", "minItems": 7, "maxItems": 7},
    "affected_strata": {"type": "array", "minItems": 1},
    "role_decision": {"type": "object"},
    "promotion_transaction": {"type": ["object", "null"]},
    "rollback_drill": {"type": ["object", "null"]},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/runpod_autonomous_mission_report.schema.json",
  "title": "MaskFactory RunPod autonomous work-cell mission report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mission_id",
    "manifest_sha256",
    "mission_state",
    "record_count",
    "terminal_record_count",
    "remaining_record_count",
    "stage_counts",
    "outcome_counts",
    "stage_status_counts",
    "last_error_counts",
    "stage_receipt_count",
    "repair_attempt_count",
    "bulk_policy_sha256",
    "reporting_mode",
    "material_incidents",
    "milestones",
    "integrity_errors",
    "queue_state_sha256",
    "self_sha256"
  ],
  "properties": {
    "schema_version": {"const": "maskfactory.runpod_autonomous_mission_report.v1"},
    "mission_id": {"type": "string", "minLength": 1},
    "manifest_sha256": {"$ref": "#/$defs/sha256"},
    "mission_state": {"enum": ["admitted", "running", "complete", "failed"]},
    "record_count": {"type": "integer", "minimum": 0},
    "terminal_record_count": {"type": "integer", "minimum": 0},
    "remaining_record_count": {"type": "integer", "minimum": 0},
    "stage_counts": {"$ref": "#/$defs/countMap"},
    "outcome_counts": {"$ref": "#/$defs/countMap"},
    "stage_status_counts": {"$ref": "#/$defs/countMap"},
    "last_error_counts": {"$ref": "#/$defs/countMap"},
    "stage_receipt_count": {"type": "integer", "minimum": 0},
    "repair_attempt_count": {"type": "integer", "minimum": 0},
    "bulk_policy_sha256": {"$ref": "#/$defs/sha256"},
    "reporting_mode": {"const": "milestone_only"},
    "material_incidents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "incident_type",
          "count",
          "record_count",
          "fraction",
          "threshold_fraction"
        ],
        "properties": {
          "incident_type": {"enum": ["stage_executor_failure_rate"]},
          "count": {"type": "integer", "minimum": 0},
          "record_count": {"type": "integer", "minimum": 1},
          "fraction": {"type": "number", "minimum": 0, "maximum": 1},
          "threshold_fraction": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}
        }
      }
    },
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sequence", "terminal_record_count"],
        "properties": {
          "sequence": {"type": "integer", "minimum": 1},
          "terminal_record_count": {"type": "integer", "minimum": 1}
        }
      }
    },
    "integrity_errors": {"type": "array", "items": {"type": "string"}},
    "queue_state_sha256": {"$ref": "#/$defs/sha256"},
    "self_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "countMap": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    }
  }
}

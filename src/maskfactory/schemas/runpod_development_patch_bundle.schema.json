{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/runpod_development_patch_bundle.schema.json",
  "title": "MaskFactory isolated self-hosted development patch bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mission_id",
    "base_commit",
    "repository_sha256",
    "model",
    "allowed_paths",
    "changed_files",
    "patch_path",
    "patch_sha256",
    "validators",
    "risk",
    "limitations",
    "authority",
    "bundle_sha256"
  ],
  "properties": {
    "schema_version": {"const": "maskfactory.runpod_development_patch_bundle.v1"},
    "mission_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{7,127}$"},
    "base_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "repository_sha256": {"$ref": "#/$defs/sha256"},
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_id", "family", "revision_sha256", "runtime_sha256"],
      "properties": {
        "model_id": {"type": "string", "minLength": 1},
        "family": {"type": "string", "minLength": 1},
        "revision_sha256": {"$ref": "#/$defs/sha256"},
        "runtime_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/repositoryPath"}
    },
    "changed_files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"$ref": "#/$defs/repositoryPath"},
          "sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "patch_path": {"$ref": "#/$defs/repositoryPath"},
    "patch_sha256": {"$ref": "#/$defs/sha256"},
    "validators": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["validator_id", "command", "status", "output_sha256"],
        "properties": {
          "validator_id": {"type": "string", "minLength": 1},
          "command": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "status": {"const": "pass"},
          "output_sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "risk": {"enum": ["low", "medium"]},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "authority": {"const": "prepared_patch_only_requires_codex_adoption"},
    "bundle_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "repositoryPath": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
    }
  }
}

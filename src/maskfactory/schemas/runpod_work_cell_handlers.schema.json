{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/runpod_work_cell_handlers.schema.json",
  "title": "MaskFactory RunPod autonomous work-cell stage handlers",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "handlers"],
  "properties": {
    "schema_version": {"const": "maskfactory.runpod_work_cell_handlers.v1"},
    "handlers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_decode",
        "detection_ownership",
        "provider_tournament",
        "hard_qc",
        "primary_visual_review",
        "independent_visual_review",
        "repair_planning",
        "repair_execution",
        "package_freeze",
        "certification"
      ],
      "properties": {
        "source_decode": {"$ref": "#/$defs/handler"},
        "detection_ownership": {"$ref": "#/$defs/handler"},
        "provider_tournament": {"$ref": "#/$defs/handler"},
        "hard_qc": {"$ref": "#/$defs/handler"},
        "primary_visual_review": {"$ref": "#/$defs/handler"},
        "independent_visual_review": {"$ref": "#/$defs/handler"},
        "repair_planning": {"$ref": "#/$defs/handler"},
        "repair_execution": {"$ref": "#/$defs/handler"},
        "package_freeze": {"$ref": "#/$defs/handler"},
        "certification": {"$ref": "#/$defs/handler"}
      }
    }
  },
  "$defs": {
    "handler": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "implementation_sha256"],
      "properties": {
        "kind": {"enum": ["python_callable", "subprocess_json"]},
        "source_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
        },
        "callable": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
        "implementation_sha256": {"$ref": "#/$defs/sha256"},
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 86400},
        "cwd": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
        },
        "env": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "binding_files": {
          "type": "array",
          "items": {"$ref": "#/$defs/binding_file"}
        },
        "description": {"type": "string"}
      },
      "allOf": [
        {
          "if": {"properties": {"kind": {"const": "python_callable"}}},
          "then": {"required": ["source_path", "callable"]}
        },
        {
          "if": {"properties": {"kind": {"const": "subprocess_json"}}},
          "then": {"required": ["command", "timeout_seconds"]}
        }
      ]
    },
    "binding_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
        },
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}

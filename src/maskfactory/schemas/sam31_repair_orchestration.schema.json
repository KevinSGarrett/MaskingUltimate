{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/sam31_repair_orchestration.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "provider_key", "lifecycle_state", "status", "reason",
    "source_image_sha256", "source_width", "source_height", "parent_instance_key",
    "expected_provider_identity", "pipeline_sha256_before", "pipeline_sha256_after",
    "authority", "request_count", "proposal_count", "accepted_candidate_count",
    "requests", "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "provider_key": {"const": "sam3_1"},
    "lifecycle_state": {"enum": ["planned", "installed", "benchmarked", "promoted"]},
    "status": {"enum": ["complete", "complete_no_candidates", "skipped_unavailable", "failed"]},
    "reason": {"type": ["string", "null"], "minLength": 1},
    "source_image_sha256": {"$ref": "#/$defs/sha256"},
    "source_width": {"type": "integer", "minimum": 1},
    "source_height": {"type": "integer", "minimum": 1},
    "parent_instance_key": {"type": "string", "minLength": 1},
    "expected_provider_identity": {"$ref": "#/$defs/identity"},
    "pipeline_sha256_before": {"$ref": "#/$defs/sha256"},
    "pipeline_sha256_after": {"$ref": "#/$defs/sha256"},
    "authority": {"const": "official_sam31_repair_proposals_only_no_active_map_semantic_mask_serving_or_gold_authority"},
    "request_count": {"type": "integer", "minimum": 0},
    "proposal_count": {"type": "integer", "minimum": 0},
    "accepted_candidate_count": {"type": "integer", "minimum": 0},
    "requests": {"type": "array", "items": {"$ref": "#/$defs/request"}},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "complete"}}},
      "then": {
        "properties": {
          "reason": {"type": "null"},
          "request_count": {"type": "integer", "minimum": 1}
        }
      },
      "else": {
        "properties": {
          "reason": {"type": "string", "minLength": 1},
          "request_count": {"const": 0},
          "proposal_count": {"const": 0},
          "accepted_candidate_count": {"const": 0},
          "requests": {"maxItems": 0}
        }
      }
    }
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "point": {
      "type": "array", "minItems": 2, "maxItems": 2,
      "items": {"type": "integer", "minimum": 0}
    },
    "box": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "items": {"type": "integer", "minimum": 0}
    },
    "identity": {
      "type": "object", "additionalProperties": false,
      "required": ["provider_key", "role", "model_family", "source_commit", "runtime_fingerprint", "contract_version", "provenance_aliases"],
      "properties": {
        "provider_key": {"const": "sam3_1"},
        "role": {"const": "interactive_segmenter"},
        "model_family": {"const": "sam3"},
        "source_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
        "runtime_fingerprint": {"$ref": "#/$defs/sha256"},
        "contract_version": {"const": "1.0.0"},
        "provenance_aliases": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "guard": {
      "type": "object", "additionalProperties": false,
      "required": ["eligible", "reconstruction_mode", "changed_fraction", "protected_overlap_fraction", "outside_roi_fraction", "area_px", "area_fraction_of_person", "component_count", "vetoes"],
      "properties": {
        "eligible": {"type": "boolean"},
        "reconstruction_mode": {"type": "boolean"},
        "changed_fraction": {"type": "number", "minimum": 0},
        "protected_overlap_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "outside_roi_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "area_px": {"type": "integer", "minimum": 1},
        "area_fraction_of_person": {"type": ["number", "null"], "minimum": 0},
        "component_count": {"type": "integer", "minimum": 1},
        "vetoes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "proposal": {
      "type": "object", "additionalProperties": false,
      "required": ["candidate_id", "confidence", "prompt_fingerprint", "eligible", "guard", "mask_sha256", "candidate_path", "candidate_file_sha256"],
      "properties": {
        "candidate_id": {"type": "string", "pattern": "^sam31-repair-[0-9]{3}-[0-9]{2}$"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "prompt_fingerprint": {"$ref": "#/$defs/sha256"},
        "eligible": {"type": "boolean"},
        "guard": {"$ref": "#/$defs/guard"},
        "mask_sha256": {"$ref": "#/$defs/sha256"},
        "candidate_path": {"type": ["string", "null"], "pattern": "^candidates/sam31-repair-[0-9]{3}-[0-9]{2}\\.png$"},
        "candidate_file_sha256": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]}
      }
    },
    "request": {
      "type": "object", "additionalProperties": false,
      "required": ["label", "roi_xyxy", "positive_points", "negative_points", "current_mask_sha256", "protected_mask_sha256", "person_bbox_xyxy", "proposals"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "roi_xyxy": {"$ref": "#/$defs/box"},
        "positive_points": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/point"}},
        "negative_points": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/point"}},
        "current_mask_sha256": {"$ref": "#/$defs/sha256"},
        "protected_mask_sha256": {"$ref": "#/$defs/sha256"},
        "person_bbox_xyxy": {"anyOf": [{"$ref": "#/$defs/box"}, {"type": "null"}]},
        "proposals": {"type": "array", "maxItems": 12, "items": {"$ref": "#/$defs/proposal"}}
      }
    }
  }
}

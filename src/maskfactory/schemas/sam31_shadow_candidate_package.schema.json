{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/sam31_shadow_candidate_package.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "provider_key", "model_family", "source_image_sha256", "source_width", "source_height", "pipeline_sha256_before", "pipeline_sha256_after", "runtime_lock_sha256", "source_commit", "checkpoint_sha256", "enabled_lanes", "candidate_count", "candidates", "authority", "sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "provider_key": {"const": "sam3_1"},
    "model_family": {"const": "sam3"},
    "source_image_sha256": {"$ref": "#/$defs/sha256"},
    "source_width": {"type": "integer", "minimum": 1},
    "source_height": {"type": "integer", "minimum": 1},
    "pipeline_sha256_before": {"$ref": "#/$defs/sha256"},
    "pipeline_sha256_after": {"$ref": "#/$defs/sha256"},
    "runtime_lock_sha256": {"$ref": "#/$defs/sha256"},
    "source_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "checkpoint_sha256": {"$ref": "#/$defs/sha256"},
    "enabled_lanes": {"type": "array", "minItems": 1, "maxItems": 7, "uniqueItems": true, "items": {"enum": ["accessory", "chest_pelvic", "clothing", "foot_toe", "hair", "hand_finger", "repeated_instance"]}},
    "candidate_count": {"type": "integer", "minimum": 1},
    "candidates": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/candidate"}},
    "authority": {"const": "isolated_sam31_specialist_candidates_only_no_active_map_serving_semantic_mask_or_gold_authority"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "candidate": {
      "type": "object", "additionalProperties": false,
      "required": ["candidate_id", "lane", "benchmark_role", "semantic_label", "instance_key", "mask_path", "mask_sha256", "foreground_pixels", "bbox_xyxy", "confidence", "prompt_fingerprint", "provider_role", "provider_runtime_fingerprint"],
      "properties": {
        "candidate_id": {"type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.-]{0,127}$"},
        "lane": {"type": "string"}, "benchmark_role": {"type": "string"}, "semantic_label": {"type": "string"}, "instance_key": {"type": "string", "minLength": 1},
        "mask_path": {"type": "string", "pattern": "^masks/[a-z_]+/[a-zA-Z0-9][a-zA-Z0-9_.-]{0,127}\\.png$"},
        "mask_sha256": {"$ref": "#/$defs/sha256"}, "foreground_pixels": {"type": "integer", "minimum": 1},
        "bbox_xyxy": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "integer", "minimum": 0}},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}, "prompt_fingerprint": {"$ref": "#/$defs/sha256"},
        "provider_role": {"enum": ["concept_detector", "interactive_segmenter"]}, "provider_runtime_fingerprint": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}

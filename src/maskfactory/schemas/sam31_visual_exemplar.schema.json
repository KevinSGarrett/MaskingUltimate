{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/sam31_visual_exemplar.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "kind", "source_image_file_sha256", "source_image_rgb_sha256",
    "source_width", "source_height", "bbox_xyxy", "polarity", "authority", "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "kind": {"const": "same_image_visual_box"},
    "source_image_file_sha256": {"$ref": "#/$defs/sha256"},
    "source_image_rgb_sha256": {"$ref": "#/$defs/sha256"},
    "source_width": {"type": "integer", "minimum": 1},
    "source_height": {"type": "integer", "minimum": 1},
    "bbox_xyxy": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "items": {"type": "number", "minimum": 0}
    },
    "polarity": {"enum": ["positive", "negative"]},
    "authority": {"const": "same_image_visual_prompt_only_no_mask_or_gold_authority"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}

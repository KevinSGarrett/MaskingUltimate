{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/serving_provenance.schema.json",
  "title": "MaskFactory serving provenance",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "models", "provider", "truth_tier", "certification", "routing"],
  "properties": {
    "source": {"const": "champion_models"},
    "models": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "role", "lifecycle_state", "content_compatibility", "license_eligibility", "benchmark_certificate", "rollback"],
      "properties": {
        "key": {"type": "string", "minLength": 1},
        "role": {"type": "string", "minLength": 1},
        "lifecycle_state": {"enum": ["planned", "installed", "benchmarked", "promoted", "reference_only", "retired", "unregistered"]},
        "content_compatibility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["adult_nonexplicit", "consensual_explicit_adult"],
          "properties": {
            "adult_nonexplicit": {"enum": ["allowed", "prohibited", "unclear"]},
            "consensual_explicit_adult": {"enum": ["allowed", "prohibited", "unclear"]}
          }
        },
        "license_eligibility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "eligible"],
          "properties": {
            "status": {"type": "string", "minLength": 1},
            "eligible": {"type": "boolean"}
          }
        },
        "benchmark_certificate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "target_role", "issued_at", "sha256"],
          "properties": {
            "status": {"enum": ["current", "missing"]},
            "target_role": {"type": ["string", "null"]},
            "issued_at": {"type": ["string", "null"]},
            "sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
          }
        },
        "rollback": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "provider_key"],
          "properties": {
            "status": {"enum": ["declared", "missing"]},
            "provider_key": {"type": ["string", "null"]}
          }
        }
      }
    },
    "truth_tier": {"const": "machine_candidate"},
    "certification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "scope"],
      "properties": {
        "status": {"const": "not_certified"},
        "scope": {"type": "null"}
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["destination", "residual_reason", "audit_reason"],
      "properties": {
        "destination": {"const": "review_draft"},
        "residual_reason": {"const": "model_draft_has_no_autonomy_certificate"},
        "audit_reason": {"type": "null"}
      }
    }
  }
}

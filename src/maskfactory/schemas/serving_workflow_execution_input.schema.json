{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/serving_workflow_execution_input.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "policy_sha256",
    "prepared_at",
    "api_url",
    "output_root",
    "sources",
    "role_bindings",
    "authority",
    "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "policy_id": {"const": "serving_workflow_performance_v1"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "prepared_at": {"type": "string", "format": "date-time"},
    "api_url": {"type": "string", "minLength": 1},
    "output_root": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"$ref": "#/$defs/source"}
    },
    "role_bindings": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"$ref": "#/$defs/role_binding"}
    },
    "authority": {
      "const": "execution_preflight_only_no_serving_mutation_mask_truth_gold_promotion_or_completion_authority"
    },
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "scope",
        "image_id",
        "image_path",
        "image_sha256",
        "governance_decision_path",
        "governance_decision_sha256",
        "person_count",
        "unseen_before_measurement",
        "image_disjoint",
        "package_manifest_path",
        "package_manifest_sha256",
        "package_tree_sha256",
        "truth_tier"
      ],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "scope": {"enum": ["single_person", "multi_person"]},
        "image_id": {"type": "string", "minLength": 1},
        "image_path": {"type": "string", "minLength": 1},
        "image_sha256": {"$ref": "#/$defs/sha256"},
        "governance_decision_path": {"type": "string", "minLength": 1},
        "governance_decision_sha256": {"$ref": "#/$defs/sha256"},
        "person_count": {"type": "integer", "minimum": 1, "maximum": 4},
        "unseen_before_measurement": {"const": true},
        "image_disjoint": {"const": true},
        "package_manifest_path": {"type": "string", "minLength": 1},
        "package_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "package_tree_sha256": {"$ref": "#/$defs/sha256"},
        "truth_tier": {"enum": ["human_anchor_gold", "autonomous_certified_gold"]}
      }
    },
    "role_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "active_provider",
        "rollback_provider",
        "active_lifecycle_state",
        "rollback_lifecycle_state",
        "active_checkpoint_path",
        "active_checkpoint_sha256",
        "active_runtime_path",
        "active_runtime_sha256",
        "benchmark_certificate_path",
        "benchmark_certificate_file_sha256",
        "benchmark_certificate_sha256",
        "rollback_checkpoint_path",
        "rollback_checkpoint_sha256",
        "rollback_command"
      ],
      "properties": {
        "role": {"enum": ["champion_bodypart", "champion_hand", "champion_clothing", "interactive_segmenter"]},
        "active_provider": {"type": "string", "minLength": 1},
        "rollback_provider": {"type": "string", "minLength": 1},
        "active_lifecycle_state": {"enum": ["benchmarked", "promoted"]},
        "rollback_lifecycle_state": {"enum": ["benchmarked", "promoted"]},
        "active_checkpoint_path": {"type": "string", "minLength": 1},
        "active_checkpoint_sha256": {"$ref": "#/$defs/sha256"},
        "active_runtime_path": {"type": "string", "minLength": 1},
        "active_runtime_sha256": {"$ref": "#/$defs/sha256"},
        "benchmark_certificate_path": {"type": "string", "minLength": 1},
        "benchmark_certificate_file_sha256": {"$ref": "#/$defs/sha256"},
        "benchmark_certificate_sha256": {"$ref": "#/$defs/sha256"},
        "rollback_checkpoint_path": {"type": "string", "minLength": 1},
        "rollback_checkpoint_sha256": {"$ref": "#/$defs/sha256"},
        "rollback_command": {"type": "string", "minLength": 1}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/serving_workflow_performance_policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_id", "frozen_at", "item_ids", "source_scopes", "source_requirements", "cases", "mode_a_requirements", "common_requirements", "rollback_roles", "rollback_requirements", "source_hashes", "authority", "sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "policy_id": {"const": "serving_workflow_performance_v1"},
    "frozen_at": {"type": "string", "format": "date-time"},
    "item_ids": {"type": "array", "minItems": 4, "uniqueItems": true, "items": {"type": "string", "pattern": "^MF-P[0-9]-"}},
    "source_scopes": {"type": "object", "required": ["single_person", "multi_person"], "additionalProperties": {"$ref": "#/$defs/scope"}},
    "source_requirements": {"type": "object"},
    "cases": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"$ref": "#/$defs/case"}},
    "mode_a_requirements": {"type": "object"},
    "common_requirements": {"type": "object"},
    "rollback_roles": {"type": "array", "minItems": 4, "maxItems": 4, "uniqueItems": true, "items": {"type": "string"}},
    "rollback_requirements": {"type": "object"},
    "source_hashes": {"type": "object", "minProperties": 10, "additionalProperties": {"$ref": "#/$defs/sha256"}},
    "authority": {"const": "pre_result_measurement_policy_only_no_serving_training_mask_truth_gold_promotion_or_completion_authority"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "scope": {"type": "object", "additionalProperties": false, "required": ["minimum_people", "maximum_people"], "properties": {"minimum_people": {"type": "integer", "minimum": 1}, "maximum_people": {"type": "integer", "minimum": 1}}},
    "latency": {"type": "object", "additionalProperties": false, "required": ["minimum_samples", "maximum_seconds"], "properties": {"minimum_samples": {"type": "integer", "minimum": 1}, "maximum_seconds": {"type": ["number", "null"], "minimum": 0}}},
    "case": {"type": "object", "additionalProperties": false, "required": ["case_id", "mode", "operation", "source_scope", "required_provider_roles", "required_latency_checks"], "properties": {"case_id": {"type": "string"}, "mode": {"enum": ["mode_a", "mode_b"]}, "operation": {"enum": ["predict", "refine", "package_read"]}, "source_scope": {"enum": ["single_person", "multi_person"]}, "required_provider_roles": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "required_latency_checks": {"type": "object", "minProperties": 2, "additionalProperties": {"$ref": "#/$defs/latency"}}}}
  }
}

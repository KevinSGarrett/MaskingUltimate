{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/serving_workflow_performance_report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "policy_sha256",
    "measured_at",
    "pipeline_fingerprint",
    "sources",
    "case_results",
    "rollback_results",
    "result",
    "authority",
    "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "policy_id": {"const": "serving_workflow_performance_v1"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "measured_at": {"type": "string", "format": "date-time"},
    "pipeline_fingerprint": {"$ref": "#/$defs/sha256"},
    "sources": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"$ref": "#/$defs/source"}
    },
    "case_results": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {"$ref": "#/$defs/case_result"}
    },
    "rollback_results": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"$ref": "#/$defs/rollback"}
    },
    "result": {"const": "pass_complete_live_measurements"},
    "authority": {"const": "measurement_evidence_only_no_serving_training_mask_truth_gold_promotion_or_completion_authority"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "scope",
        "image_id",
        "image_path",
        "image_sha256",
        "governance_decision_path",
        "governance_decision_sha256",
        "person_count",
        "unseen_before_measurement",
        "image_disjoint"
      ],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "scope": {"enum": ["single_person", "multi_person"]},
        "image_id": {"type": "string", "minLength": 1},
        "image_path": {"type": "string", "minLength": 1},
        "image_sha256": {"$ref": "#/$defs/sha256"},
        "governance_decision_path": {"type": "string", "minLength": 1},
        "governance_decision_sha256": {"$ref": "#/$defs/sha256"},
        "person_count": {"type": "integer", "minimum": 1, "maximum": 4},
        "unseen_before_measurement": {"const": true},
        "image_disjoint": {"const": true}
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "provider_key",
        "lifecycle_state",
        "checkpoint_sha256",
        "runtime_sha256",
        "benchmark_certificate_sha256"
      ],
      "properties": {
        "role": {"type": "string"},
        "provider_key": {"type": "string", "minLength": 1},
        "lifecycle_state": {"enum": ["benchmarked", "promoted"]},
        "checkpoint_sha256": {"$ref": "#/$defs/sha256"},
        "runtime_sha256": {"$ref": "#/$defs/sha256"},
        "benchmark_certificate_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "latency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["samples_seconds"],
      "properties": {
        "samples_seconds": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "number", "minimum": 0}
        }
      }
    },
    "read_only": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_manifest_path",
        "package_manifest_sha256",
        "truth_tier",
        "package_tree_sha256_before",
        "package_tree_sha256_after",
        "model_load_count",
        "write_attempt_count"
      ],
      "properties": {
        "package_manifest_path": {"type": "string", "minLength": 1},
        "package_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "truth_tier": {"enum": ["human_anchor_gold", "autonomous_certified_gold"]},
        "package_tree_sha256_before": {"$ref": "#/$defs/sha256"},
        "package_tree_sha256_after": {"$ref": "#/$defs/sha256"},
        "model_load_count": {"type": "integer", "minimum": 0},
        "write_attempt_count": {"type": "integer", "minimum": 0}
      }
    },
    "case_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "source_id",
        "mode",
        "operation",
        "providers",
        "latency",
        "vram",
        "oom_count",
        "crash_count",
        "determinism",
        "strict_output",
        "provenance_path",
        "provenance_sha256",
        "output_artifact_path",
        "output_artifact_sha256",
        "read_only",
        "passed"
      ],
      "properties": {
        "case_id": {"type": "string"},
        "source_id": {"type": "string"},
        "mode": {"enum": ["mode_a", "mode_b"]},
        "operation": {"enum": ["predict", "refine", "package_read"]},
        "providers": {"type": "array", "items": {"$ref": "#/$defs/provider"}},
        "latency": {
          "type": "object",
          "minProperties": 2,
          "additionalProperties": {"$ref": "#/$defs/latency"}
        },
        "vram": {
          "type": "object",
          "additionalProperties": false,
          "required": ["before_bytes", "peak_bytes", "after_bytes"],
          "properties": {
            "before_bytes": {"type": "integer", "minimum": 0},
            "peak_bytes": {"type": "integer", "minimum": 0},
            "after_bytes": {"type": "integer", "minimum": 0}
          }
        },
        "oom_count": {"type": "integer", "minimum": 0},
        "crash_count": {"type": "integer", "minimum": 0},
        "determinism": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repetitions", "output_sha256s"],
          "properties": {
            "repetitions": {"type": "integer", "minimum": 2},
            "output_sha256s": {
              "type": "array",
              "minItems": 2,
              "items": {"$ref": "#/$defs/sha256"}
            }
          }
        },
        "strict_output": {"const": true},
        "provenance_path": {"type": "string", "minLength": 1},
        "provenance_sha256": {"$ref": "#/$defs/sha256"},
        "output_artifact_path": {"type": "string", "minLength": 1},
        "output_artifact_sha256": {"$ref": "#/$defs/sha256"},
        "read_only": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/read_only"}]
        },
        "passed": {"const": true}
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "active_provider",
        "rollback_provider",
        "active_lifecycle_state",
        "rollback_lifecycle_state",
        "selection_sha256_before",
        "selection_sha256_during_rollback",
        "selection_sha256_restored",
        "rollback_smoke_path",
        "rollback_smoke_sha256",
        "restored_smoke_path",
        "restored_smoke_sha256",
        "rollback_smoke_passed",
        "restored_smoke_passed",
        "lifecycle_round_trip_passed",
        "frozen_artifacts_unchanged",
        "passed"
      ],
      "properties": {
        "role": {"type": "string"},
        "active_provider": {"type": "string"},
        "rollback_provider": {"type": "string"},
        "active_lifecycle_state": {"enum": ["benchmarked", "promoted"]},
        "rollback_lifecycle_state": {"enum": ["benchmarked", "promoted"]},
        "selection_sha256_before": {"$ref": "#/$defs/sha256"},
        "selection_sha256_during_rollback": {"$ref": "#/$defs/sha256"},
        "selection_sha256_restored": {"$ref": "#/$defs/sha256"},
        "rollback_smoke_path": {"type": "string", "minLength": 1},
        "rollback_smoke_sha256": {"$ref": "#/$defs/sha256"},
        "restored_smoke_path": {"type": "string", "minLength": 1},
        "restored_smoke_sha256": {"$ref": "#/$defs/sha256"},
        "rollback_smoke_passed": {"const": true},
        "restored_smoke_passed": {"const": true},
        "lifecycle_round_trip_passed": {"const": true},
        "frozen_artifacts_unchanged": {"const": true},
        "passed": {"const": true}
      }
    }
  }
}

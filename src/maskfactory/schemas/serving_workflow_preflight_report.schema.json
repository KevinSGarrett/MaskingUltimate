{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/serving_workflow_preflight_report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "checked_at",
    "ready",
    "policy_sha256",
    "input_sha256",
    "control_plane",
    "coverage",
    "findings",
    "authority",
    "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "checked_at": {"type": "string", "format": "date-time"},
    "ready": {"type": "boolean"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "input_sha256": {"$ref": "#/$defs/sha256"},
    "control_plane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registry_sha256", "pipeline_sha256", "external_registry_sha256"],
      "properties": {
        "registry_sha256": {"$ref": "#/$defs/nullable_sha256"},
        "pipeline_sha256": {"$ref": "#/$defs/nullable_sha256"},
        "external_registry_sha256": {"$ref": "#/$defs/nullable_sha256"}
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_scopes", "case_ids", "rollback_roles"],
      "properties": {
        "source_scopes": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {"enum": ["single_person", "multi_person"]}
        },
        "case_ids": {
          "const": [
            "mode_b_predict_single",
            "mode_b_predict_multi",
            "mode_b_refine_single",
            "mode_b_refine_multi",
            "mode_a_package_single",
            "mode_a_package_multi"
          ]
        },
        "rollback_roles": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "enum": [
              "champion_bodypart",
              "champion_hand",
              "champion_clothing",
              "interactive_segmenter"
            ]
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "subject", "detail"],
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "subject": {"type": "string", "minLength": 1},
          "detail": {"type": "string", "minLength": 1}
        }
      }
    },
    "authority": {
      "const": "execution_preflight_only_no_serving_mutation_mask_truth_gold_promotion_or_completion_authority"
    },
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "nullable_sha256": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/sha256"}
      ]
    }
  }
}

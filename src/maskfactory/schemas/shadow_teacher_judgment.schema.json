{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/shadow_teacher_judgment.schema.json",
  "title": "MaskFactory shadow teacher judgment",
  "description": "Closed shadow-only teacher judgment. Never grants gold, blocker clearance, quick-pass, or authoritative mask write authority. STATIC / offline fixtures only unless separately authorized for live dispatch.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "authority",
    "provider",
    "model",
    "verdict",
    "confidence",
    "defects",
    "observations",
    "evidence",
    "correction",
    "may_approve_gold",
    "may_clear_blocks",
    "may_write_authoritative_masks",
    "may_create_quick_pass",
    "paid_cloud_calls_executed"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "authority": { "const": "shadow_advisory_human_approval_required" },
    "provider": { "enum": ["gemini", "openai", "anthropic"] },
    "model": { "type": "string", "minLength": 1 },
    "verdict": { "enum": ["pass", "fail", "uncertain"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "defects": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "observations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "full_context",
        "source_crop",
        "mask",
        "overlay",
        "contour",
        "neighbor_overlap"
      ],
      "properties": {
        "full_context": { "type": "string", "minLength": 1 },
        "source_crop": { "type": "string", "minLength": 1 },
        "mask": { "type": "string", "minLength": 1 },
        "overlay": { "type": "string", "minLength": 1 },
        "contour": { "type": "string", "minLength": 1 },
        "neighbor_overlap": { "type": "string", "minLength": 1 }
      }
    },
    "evidence": { "type": "string", "minLength": 1 },
    "correction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "polygon",
        "positive_points",
        "negative_points",
        "rationale"
      ],
      "properties": {
        "tool": { "enum": ["none", "polygon", "points", "human_review"] },
        "polygon": {
          "type": "array",
          "maxItems": 256,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "integer", "minimum": 0, "maximum": 1000 }
          }
        },
        "positive_points": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "integer", "minimum": 0, "maximum": 1000 }
          }
        },
        "negative_points": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "integer", "minimum": 0, "maximum": 1000 }
          }
        },
        "rationale": { "type": "string" }
      }
    },
    "may_approve_gold": { "const": false },
    "may_clear_blocks": { "const": false },
    "may_write_authoritative_masks": { "const": false },
    "may_create_quick_pass": { "const": false },
    "paid_cloud_calls_executed": { "const": false }
  }
}

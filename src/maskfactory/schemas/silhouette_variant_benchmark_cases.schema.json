{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/silhouette_variant_benchmark_cases.schema.json",
  "title": "Silhouette-variant benchmark observations",
  "type": "object", "additionalProperties": false,
  "required": [
    "schema_version", "benchmark_id", "results_opened_at", "policy_sha256", "truth_tier",
    "truth_partition", "truth_manifest_sha256", "pipeline_fingerprint_sha256",
    "hardware_fingerprint_sha256", "providers", "fallback_drills", "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "benchmark_id": {"type": "string", "minLength": 1},
    "results_opened_at": {"type": "string", "format": "date-time"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "truth_tier": {"const": "human_anchor_gold"},
    "truth_partition": {"const": "holdout"},
    "truth_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "pipeline_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
    "hardware_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
    "providers": {
      "type": "object", "additionalProperties": false,
      "required": ["birefnet_general", "vitmatte_small", "birefnet_dynamic", "birefnet_hr", "birefnet_hr_matting"],
      "properties": {
        "birefnet_general": {"$ref": "#/$defs/providerEvidence"},
        "vitmatte_small": {"$ref": "#/$defs/providerEvidence"},
        "birefnet_dynamic": {"$ref": "#/$defs/providerEvidence"},
        "birefnet_hr": {"$ref": "#/$defs/providerEvidence"},
        "birefnet_hr_matting": {"$ref": "#/$defs/providerEvidence"}
      }
    },
    "fallback_drills": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"$ref": "#/$defs/fallback"}},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "role": {"enum": ["silhouette", "hair_edge", "matting"]},
    "context": {"enum": ["hair_boundaries", "multi_person_overlap", "occlusion_contact", "small_parts", "truncation"]},
    "observation": {
      "type": "object", "additionalProperties": false,
      "required": [
        "role", "context", "label", "case_count", "total_pixels",
        "predicted_foreground_pixels", "truth_foreground_pixels", "intersection_pixels",
        "truth_background_pixels", "false_positive_background_pixels",
        "boundary_true_positive", "boundary_false_positive", "boundary_false_negative",
        "correction_pixels", "alpha_reference_pixels", "alpha_absolute_error_sum",
        "alpha_squared_error_sum"
      ],
      "properties": {
        "role": {"$ref": "#/$defs/role"},
        "context": {"$ref": "#/$defs/context"},
        "label": {"type": "string", "minLength": 1},
        "case_count": {"type": "integer", "minimum": 1},
        "total_pixels": {"type": "integer", "minimum": 1},
        "predicted_foreground_pixels": {"type": "integer", "minimum": 0},
        "truth_foreground_pixels": {"type": "integer", "minimum": 0},
        "intersection_pixels": {"type": "integer", "minimum": 0},
        "truth_background_pixels": {"type": "integer", "minimum": 0},
        "false_positive_background_pixels": {"type": "integer", "minimum": 0},
        "boundary_true_positive": {"type": "integer", "minimum": 0},
        "boundary_false_positive": {"type": "integer", "minimum": 0},
        "boundary_false_negative": {"type": "integer", "minimum": 0},
        "correction_pixels": {"type": "integer", "minimum": 0},
        "alpha_reference_pixels": {"type": "integer", "minimum": 0},
        "alpha_absolute_error_sum": {"type": "number", "minimum": 0},
        "alpha_squared_error_sum": {"type": "number", "minimum": 0}
      }
    },
    "runtime": {
      "type": "object", "additionalProperties": false,
      "required": ["cold_latency_ms", "warm_latency_ms", "peak_vram_bytes", "oom_count", "crash_count", "repeat_count", "deterministic_output_sha256"],
      "properties": {
        "cold_latency_ms": {"type": "number", "minimum": 0},
        "warm_latency_ms": {"type": "number", "minimum": 0},
        "peak_vram_bytes": {"type": "integer", "minimum": 0},
        "oom_count": {"type": "integer", "minimum": 0},
        "crash_count": {"type": "integer", "minimum": 0},
        "repeat_count": {"type": "integer", "minimum": 1},
        "deterministic_output_sha256": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/sha256"}}
      }
    },
    "providerEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_hashes", "runtime_fingerprint", "governed_resolution", "observations", "runtime_metrics"],
      "properties": {
        "artifact_hashes": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/sha256"}},
        "runtime_fingerprint": {"type": "string", "minLength": 1},
        "governed_resolution": {"oneOf": [{"type": "integer", "minimum": 1}, {"type": "string", "minLength": 1}]},
        "observations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/observation"}},
        "runtime_metrics": {"$ref": "#/$defs/runtime"}
      }
    },
    "fallback": {
      "type": "object", "additionalProperties": false,
      "required": ["role", "challenger", "injected_failure", "expected_provider", "observed_provider", "output_sha256", "active_provider_after", "rollback_provider_after"],
      "properties": {
        "role": {"$ref": "#/$defs/role"},
        "challenger": {"type": "string", "minLength": 1},
        "injected_failure": {"type": "string", "minLength": 1},
        "expected_provider": {"type": "string", "minLength": 1},
        "observed_provider": {"type": "string", "minLength": 1},
        "output_sha256": {"$ref": "#/$defs/sha256"},
        "active_provider_after": {"type": "string", "minLength": 1},
        "rollback_provider_after": {"type": "string", "minLength": 1}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/silhouette_variant_benchmark_report.schema.json",
  "title": "Recomputed silhouette-variant benchmark report",
  "type": "object", "additionalProperties": false,
  "required": [
    "schema_version", "benchmark_id", "evaluated_at", "policy_sha256", "source_cases_sha256",
    "truth_manifest_sha256", "pipeline_fingerprint_sha256", "hardware_fingerprint_sha256",
    "providers", "comparisons", "fallback_drills", "findings", "result", "authority", "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "benchmark_id": {"type": "string", "minLength": 1},
    "evaluated_at": {"type": "string", "format": "date-time"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "source_cases_sha256": {"$ref": "#/$defs/sha256"},
    "truth_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "pipeline_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
    "hardware_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
    "providers": {"type": "array", "minItems": 5, "maxItems": 5, "items": {"type": "object"}},
    "comparisons": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"$ref": "#/$defs/comparison"}},
    "fallback_drills": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"type": "object"}},
    "findings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "result": {"enum": ["pass", "fail"]},
    "authority": {"const": "benchmark_evidence_only_no_gold_or_production_authority"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "comparison": {
      "type": "object", "additionalProperties": false,
      "required": [
        "role", "baseline", "challenger", "boundary_f_2px_delta", "foreground_iou_delta",
        "foreground_leakage_rate_delta", "alpha_mse_delta", "correction_pixels_per_100k_delta",
        "findings", "result"
      ],
      "properties": {
        "role": {"enum": ["silhouette", "hair_edge", "matting"]},
        "baseline": {"type": "string", "minLength": 1},
        "challenger": {"type": "string", "minLength": 1},
        "boundary_f_2px_delta": {"type": "number", "minimum": -1, "maximum": 1},
        "foreground_iou_delta": {"type": "number", "minimum": -1, "maximum": 1},
        "foreground_leakage_rate_delta": {"type": "number", "minimum": -1, "maximum": 1},
        "alpha_mse_delta": {"type": ["number", "null"]},
        "correction_pixels_per_100k_delta": {"type": "number"},
        "findings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "result": {"enum": ["pass", "fail"]}
      }
    }
  }
}

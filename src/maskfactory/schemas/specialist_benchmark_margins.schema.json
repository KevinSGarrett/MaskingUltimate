{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/specialist_benchmark_margins.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "frozen_at",
    "authority",
    "results_state",
    "delta_convention",
    "source_hashes",
    "roles",
    "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "manifest_id": {"const": "specialist_noninferiority_v1"},
    "frozen_at": {"type": "string", "format": "date-time"},
    "authority": {"const": "predeclared_thresholds_only_no_result_or_promotion_authority"},
    "results_state": {"const": "sealed_before_results"},
    "delta_convention": {"const": "positive_is_challenger_improvement"},
    "source_hashes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"$ref": "#/$defs/sha256"}
    },
    "roles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"$ref": "#/$defs/role"}
    },
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "nameArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "marginMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}
    },
    "primaryObjective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric", "minimum_improvement"],
      "properties": {
        "metric": {"type": "string", "minLength": 1},
        "minimum_improvement": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_provider_role",
        "primary_objective",
        "hard_labels",
        "high_risk_contexts",
        "label_margins",
        "context_margins",
        "zero_regression_metrics"
      ],
      "properties": {
        "target_provider_role": {"type": "string", "minLength": 1},
        "primary_objective": {"$ref": "#/$defs/primaryObjective"},
        "hard_labels": {"$ref": "#/$defs/nameArray"},
        "high_risk_contexts": {"$ref": "#/$defs/nameArray"},
        "label_margins": {"$ref": "#/$defs/marginMap"},
        "context_margins": {"$ref": "#/$defs/marginMap"},
        "zero_regression_metrics": {"$ref": "#/$defs/nameArray"}
      }
    }
  }
}

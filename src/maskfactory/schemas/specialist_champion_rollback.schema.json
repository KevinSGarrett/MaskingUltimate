{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/specialist_champion_rollback.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "action",
    "transaction_kind",
    "transaction_id",
    "promotion_transaction_id",
    "recorded_at",
    "candidate_key",
    "incumbent_key",
    "champion_role",
    "registry_before_sha256",
    "registry_after_sha256",
    "serving_smoke",
    "sha256"
  ],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "action": {"const": "rollback"},
    "transaction_kind": {"const": "specialist_champion"},
    "transaction_id": {"$ref": "#/$defs/transaction_id"},
    "promotion_transaction_id": {"$ref": "#/$defs/transaction_id"},
    "recorded_at": {"type": "string", "format": "date-time"},
    "candidate_key": {"type": "string", "minLength": 1},
    "incumbent_key": {"type": "string", "minLength": 1},
    "champion_role": {"enum": ["champion_hand", "champion_clothing"]},
    "registry_before_sha256": {"$ref": "#/$defs/sha256"},
    "registry_after_sha256": {"$ref": "#/$defs/sha256"},
    "serving_smoke": {"$ref": "#/$defs/smoke"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "transaction_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
    "smoke": {
      "type": "object",
      "required": ["result", "role", "model_key"],
      "properties": {
        "result": {"const": "pass"},
        "role": {"enum": ["champion_hand", "champion_clothing"]},
        "model_key": {"type": "string", "minLength": 1}
      }
    }
  }
}

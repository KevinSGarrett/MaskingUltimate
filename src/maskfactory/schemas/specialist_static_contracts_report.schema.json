{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maskfactory.local/schemas/specialist_static_contracts_report.schema.json",
  "title": "MaskFactory specialist STATIC contracts report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "proof_tier",
    "authority",
    "checked_at",
    "specialist_labels",
    "seeded_lane_checks",
    "seeded_panel_checks",
    "seeded_routing_checks",
    "checks",
    "mf_p3_07_01_sop_cadence_complete",
    "mf_p3_07_02_100_certified_complete",
    "mf_p3_07_03_labor_metrics_complete",
    "mf_p3_07_04_second_look_complete",
    "mf_p3_exit_complete",
    "kevin_sop_cadence_required",
    "certified_package_count",
    "doctor_green_claimed",
    "gold_claimed",
    "visual_qa_pass_claimed",
    "main_complete_claimed",
    "production_evidence_pass_claimed",
    "honest_non_claims",
    "report_id",
    "seal_sha256",
    "sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "specialist_static_contracts_report"},
    "proof_tier": {"const": "STATIC_PASS"},
    "authority": {
      "const": "specialist_static_contracts_only_no_sop_cadence_100_certified_or_p3_exit_authority"
    },
    "checked_at": {"type": "string", "minLength": 1},
    "specialist_labels": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["left_hand_base", "left_breast", "hair", "left_foot_base"]
      }
    },
    "seeded_lane_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hand_gap_ownership_and_finger_merge_residual",
        "chest_visible_truth_and_boundary_band",
        "hair_shoulder_zorder_and_face_protect",
        "feet_shod_material_and_toes_not_visible"
      ],
      "properties": {
        "hand_gap_ownership_and_finger_merge_residual": {"const": true},
        "chest_visible_truth_and_boundary_band": {"const": true},
        "hair_shoulder_zorder_and_face_protect": {"const": true},
        "feet_shod_material_and_toes_not_visible": {"const": true}
      }
    },
    "seeded_panel_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mandatory_chest_panel_2560x512",
        "hairline_panel_2560x512"
      ],
      "properties": {
        "mandatory_chest_panel_2560x512": {"const": true},
        "hairline_panel_2560x512": {"const": true}
      }
    },
    "seeded_routing_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certificate_covered_serves_without_routine_review",
        "uncertified_routes_residual_only",
        "preselected_audit_destination",
        "review_sample_excludes_certificate_covered_routine"
      ],
      "properties": {
        "certificate_covered_serves_without_routine_review": {"const": true},
        "uncertified_routes_residual_only": {"const": true},
        "preselected_audit_destination": {"const": true},
        "review_sample_excludes_certificate_covered_routine": {"const": true}
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hand_chest_hair_feet_lane_contracts",
        "qc_panel_fixtures",
        "residual_and_preselected_audit_routing"
      ],
      "properties": {
        "hand_chest_hair_feet_lane_contracts": {"const": "pass"},
        "qc_panel_fixtures": {"const": "pass"},
        "residual_and_preselected_audit_routing": {"const": "pass"}
      }
    },
    "mf_p3_07_01_sop_cadence_complete": {"const": false},
    "mf_p3_07_02_100_certified_complete": {"const": false},
    "mf_p3_07_03_labor_metrics_complete": {"const": false},
    "mf_p3_07_04_second_look_complete": {"const": false},
    "mf_p3_exit_complete": {"const": false},
    "kevin_sop_cadence_required": {"const": true},
    "certified_package_count": {"const": 0},
    "doctor_green_claimed": {"const": false},
    "gold_claimed": {"const": false},
    "visual_qa_pass_claimed": {"const": false},
    "main_complete_claimed": {"const": false},
    "production_evidence_pass_claimed": {"const": false},
    "honest_non_claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "report_id": {"type": "string", "pattern": "^ssc_[a-f0-9]{24}$"},
    "seal_sha256": {"$ref": "#/$defs/sha256"},
    "sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}

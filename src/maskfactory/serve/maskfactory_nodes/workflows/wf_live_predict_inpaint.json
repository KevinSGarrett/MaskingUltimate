{
  "1": {
    "class_type": "LoadImage",
    "inputs": {"image": "never_seen_input.png"}
  },
  "2": {
    "class_type": "MFPredictMasks",
    "inputs": {
      "image": ["1", 0], "labels": "left_forearm", "dilate_px": 8, "feather_px": 4
    }
  },
  "3": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {"ckpt_name": "__SELECT_CHECKPOINT__.safetensors"}
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "high quality anatomically correct forearm", "clip": ["3", 1]}
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "distorted arm, clothing changes", "clip": ["3", 1]}
  },
  "6": {
    "class_type": "VAEEncodeForInpaint",
    "inputs": {"pixels": ["1", 0], "vae": ["3", 2], "mask": ["2", 0], "grow_mask_by": 0}
  },
  "7": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["3", 0], "positive": ["4", 0], "negative": ["5", 0],

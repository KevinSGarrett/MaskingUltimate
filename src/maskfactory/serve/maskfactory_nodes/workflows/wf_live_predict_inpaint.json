      "steps": 20, "cfg": 7.0, "sampler_name": "euler", "scheduler": "normal", "denoise": 0.4
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["7", 0], "vae": ["3", 2]}
  },
  "9": {
    "class_type": "ImageCompositeMasked",
    "inputs": {
      "destination": ["1", 0], "source": ["8", 0], "x": 0, "y": 0,
      "resize_source": false, "mask": ["2", 0]
    }
  },
  "10": {
    "class_type": "SaveImage",
    "inputs": {"filename_prefix": "MaskFactory_live_left_forearm", "images": ["9", 0]}
  }
}
